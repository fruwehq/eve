#!/usr/bin/env bash
set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/status <instance>}"
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
OS_FAMILY=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')

printf '%-15s %s\n' "Profile:" "$PROFILE"
printf '%-15s %s\n' "Engine:" "$ENGINE"
printf '%-15s %s\n' "Provider:" "$PROVIDER"
printf '%-15s %s\n' "OS:" "$OS_FAMILY"

VM_STATUS="unknown"
TM_READ_FLAGS=(
  --disable-safeguards=git-untracked
  --disable-safeguards=git-uncommitted
  --disable-safeguards=git-out-of-sync
  --disable-safeguards=outdated-code
)

resolved_value() {
  printf "%s\n" "$RESOLVED_ENV" | awk -F= -v key="$1" '$1 == key { print substr($0, index($0, "=") + 1) }'
}

normalize_path() {
  local value="$1"
  # shellcheck disable=SC2088,SC2016
  case "$value" in
    '$(HOME)'|'$(HOME)/'*) printf '%s' "$HOME${value#\$\(HOME\)}" ;;
    '$HOME'|'$HOME/'*) printf '%s' "$HOME${value#\$HOME}" ;;
    '~'|'~/'*) printf '%s' "$HOME${value#\~}" ;;
    *) printf '%s' "$value" ;;
  esac
}

truenas_control_reachable() {
  local host port
  host="${TRUENAS_HOST:-$(resolved_value TRUENAS_HOST)}"
  port="${TRUENAS_SSH_PORT:-$(resolved_value TRUENAS_SSH_PORT)}"
  port="${port:-22}"

  if [ -z "$host" ]; then
    printf '%-15s %s\n' "Control:" "unreachable (missing TRUENAS_HOST)"
    return 1
  fi

  if command -v nc >/dev/null 2>&1; then
    if nc -z -w 2 "$host" "$port" >/dev/null 2>&1; then
      printf '%-15s %s\n' "Control:" "reachable (TrueNAS SSH $host:$port)"
      return 0
    fi
    printf '%-15s %s\n' "Control:" "unreachable (TrueNAS SSH $host:$port)"
    return 1
  fi

  printf '%-15s %s\n' "Control:" "unknown (nc not found; TrueNAS SSH $host:$port)"
  return 0
}

truenas_live_vm_state() {
  local vm_id="$1" host port user ssh_key output
  [ -n "$vm_id" ] || return 1
  host="${TRUENAS_HOST:-$(resolved_value TRUENAS_HOST)}"
  port="${TRUENAS_SSH_PORT:-$(resolved_value TRUENAS_SSH_PORT)}"
  port="${port:-22}"
  user="${TRUENAS_SSH_USER:-$(resolved_value TRUENAS_SSH_USER)}"
  [ -n "$host" ] && [ -n "$user" ] || return 1

  SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=5)
  if [ -n "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}" ]; then
    ssh_key="$(normalize_path "$TRUENAS_SSH_PRIVATE_KEY_FILE")"
    SSH_OPTS+=(-i "$ssh_key")
  fi
  [ -n "$port" ] && [ "$port" != "22" ] && SSH_OPTS+=(-p "$port")

  # shellcheck disable=SC2029
  output=$(ssh "${SSH_OPTS[@]}" "$user@$host" "sudo midclt call vm.query '[[\"id\",\"=\",$vm_id]]'" 2>/dev/null) || return 1
  printf '%s\n' "$output" | jq -r '.[0].status.state // .[0].state // empty' 2>/dev/null
}

tf_attr() {
  local json="$1" address="$2" attr="$3"
  printf '%s' "$json" | jq -r --arg addr "$address" --arg attr "$attr" \
    '[((.values // {} | .root_module // {} | .resources // [])
       | map(select(.address == $addr))
       | map(.values[$attr])[]?),
      ((.resources // [])
       | map(select((.type + "." + .name) == $addr))
       | map(.instances[]?.attributes[$attr])[]?)]
     | map(select(. != null and . != ""))
     | first // ""' 2>/dev/null
}

terraform_state_json() {
  local tags="$1" candidate
  local state_json="" state_path="" workspace="${TF_WORKSPACE:-default}"

  state_json=$(terramate run "${TM_READ_FLAGS[@]}" --quiet --tags="$tags-services" -- terraform show -json 2>/dev/null) || true
  if [ -n "$state_json" ] && printf '%s\n' "$state_json" | jq -e . >/dev/null 2>&1; then
    printf '%s\n' "$state_json"
    return 0
  fi

  if [ -n "${EVE_TF_STATE_BASE:-}" ]; then
    while IFS= read -r candidate; do
      state_path="${EVE_TF_STATE_BASE}/${candidate}/workspaces/${workspace}/terraform.tfstate"
      if [ -f "$state_path" ]; then
        cat "$state_path"
        return 0
      fi

      state_path="${EVE_TF_STATE_BASE}/${candidate}/default.tfstate"
      if [ -f "$state_path" ]; then
        cat "$state_path"
        return 0
      fi
    done <<EOF
$(terraform_state_stack_candidates)
EOF
  fi
}

terraform_state_stack_candidates() {
  case "$PROVIDER" in
    truenas)
      printf '%s\n' "plugins/providers/truenas/stacks/truenas/20-services" "stacks/truenas/20-services"
      ;;
    *)
      printf '%s\n' "plugins/providers/${PROVIDER}/stacks/20-services" "stacks/${PROVIDER}/20-services"
      ;;
  esac
}

case "$ENGINE" in
  metal)
    case "$PROVIDER" in
      raspberry-pi)
        IP=$(./scripts/instance-ip "$PROFILE" 2>/dev/null || true)
        if [ -n "$IP" ]; then
          printf '%-15s %s\n' "IP:" "$IP"
        fi
        if ./scripts/instance-ssh "$PROFILE" -- exit 0 >/dev/null 2>&1; then
          VM_STATUS="running"
        else
          VM_STATUS="unreachable"
        fi
        ;;
      *)
        VM_STATUS="unsupported provider ($PROVIDER)"
        ;;
    esac
    ;;
  vagrant)
    GENERATED_DIR="$(eve_instance_workdir "$PROFILE")"
    if [ ! -d "$GENERATED_DIR" ]; then
      VM_STATUS="not created"
    else
      case "$PROVIDER" in
        local-qemu)
          VAGRANT_STATE=$(cd "$GENERATED_DIR" && vagrant status --machine-readable 2>/dev/null | awk -F, '$3=="state"{print $4}')
          case "$VAGRANT_STATE" in
            running) VM_STATUS="running" ;;
            stopped|poweroff) VM_STATUS="stopped" ;;
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$VAGRANT_STATE" ;;
          esac
          ;;
        *)
          VM_STATUS="unsupported provider ($PROVIDER)"
          ;;
      esac
    fi
    ;;
  terraform)
    eval "$(./scripts/tf-env "$PROFILE")"
    TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
    STATE_JSON=$(terraform_state_json "$TAGS")

    if [ -z "$STATE_JSON" ]; then
      VM_STATUS="not created"
    else
      case "$PROVIDER" in
        aws)
          RAW=$(tf_attr "$STATE_JSON" "aws_instance.main" "instance_state")
          case "$RAW" in
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        gcp)
          RAW=$(tf_attr "$STATE_JSON" "google_compute_instance.main" "current_status")
          case "$RAW" in
            RUNNING) VM_STATUS="running" ;;
            TERMINATED) VM_STATUS="stopped" ;;
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        vultr)
          RAW=$(tf_attr "$STATE_JSON" "vultr_instance.default" "power_status")
          case "$RAW" in
            running) VM_STATUS="running" ;;
            stopped) VM_STATUS="stopped" ;;
            "")
              RAW2=$(tf_attr "$STATE_JSON" "vultr_instance.default" "status")
              case "$RAW2" in
                active) VM_STATUS="running" ;;
                "") VM_STATUS="not created" ;;
                *) VM_STATUS="$RAW2" ;;
              esac
              ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        truenas)
          RAW=$(tf_attr "$STATE_JSON" "truenas_vm.this" "state")
          case "$RAW" in
            [Rr][Uu][Nn][Nn][Ii][Nn][Gg]) VM_STATUS="running" ;;
            [Ss][Tt][Oo][Pp][Pp][Ee][Dd]) VM_STATUS="stopped" ;;
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        *)
          VM_STATUS="unsupported provider ($PROVIDER)"
          ;;
      esac

      if [ "$PROVIDER" = "truenas" ] && [ "$VM_STATUS" != "not created" ] && [ "$VM_STATUS" != "unsupported provider ($PROVIDER)" ]; then
        if truenas_control_reachable; then
          VM_ID=$(tf_attr "$STATE_JSON" "truenas_vm.this" "id")
          LIVE_STATE=$(truenas_live_vm_state "$VM_ID" || true)
          case "$LIVE_STATE" in
            [Rr][Uu][Nn][Nn][Ii][Nn][Gg]) VM_STATUS="running" ;;
            [Ss][Tt][Oo][Pp][Pp][Ee][Dd]) VM_STATUS="stopped" ;;
            "") ;;
            *) VM_STATUS="$LIVE_STATE" ;;
          esac
        else
          VM_STATUS="unreachable"
        fi
      fi

      if [ "$VM_STATUS" = "running" ]; then
        IP=$(./scripts/instance-ip "$PROFILE" 2>/dev/null || true)
        if [ -n "$IP" ]; then
          printf '%-15s %s\n' "IP:" "$IP"
        fi
      fi
    fi
    ;;
  *)
    VM_STATUS="unsupported engine ($ENGINE)"
    ;;
esac

printf '%-15s %s\n' "Status:" "$VM_STATUS"
