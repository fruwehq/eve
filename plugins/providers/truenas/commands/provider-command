#!/usr/bin/env ruby

require "json"

provider_dir = File.expand_path("..", __dir__)
provider_id = File.basename(provider_dir)
root = File.expand_path("../../..", provider_dir)
command = ARGV.shift
extra_args = ARGV

unless command
  warn "Usage: #{File.basename($PROGRAM_NAME)} <command> [args...]"
  exit 2
end

json_source = ENV["EGAME_RESOLVED_JSON"]
resolved = if json_source
             JSON.parse(json_source)
           else
             JSON.parse($stdin.read)
           end

actual_provider = resolved.fetch("machine").fetch("provider")
instance_name = resolved.fetch("instance").fetch("name")
engine = resolved.fetch("engine")

if actual_provider != provider_id
  warn "provider-command: manifest provider #{provider_id} does not match resolved provider #{actual_provider}"
  exit 1
end

if ENV["EGAME_PLUGIN_DRY_RUN"] == "1" || command == "resolve"
  puts JSON.generate({
    "kind" => "provider",
    "provider" => provider_id,
    "command" => command,
    "instance" => instance_name,
    "profile" => instance_name,
    "engine" => engine,
    "dry_run" => ENV["EGAME_PLUGIN_DRY_RUN"] == "1"
  })
  exit 0
end

def run_script(root, script, *args)
  exec File.join(root, "scripts", script), *args
end

case command
when "init"
  if engine == "metal"
    warn "[init] instance=#{instance_name} uses metal hardware; no Terraform backend to initialize."
    exit 0
  end
  run_script(root, "tf-init", instance_name)
when "plan"
  case engine
  when "vagrant"
    run_script(root, "vagrant-up", "--plan", instance_name)
  when "metal"
    warn "[plan] instance=#{instance_name} uses metal hardware; provisioning will run over SSH."
    run_script(root, "profile-resolve", "--profile", instance_name, "--emit", "env")
  else
    run_script(root, "tf-plan", instance_name)
  end
when "up"
  case engine
  when "vagrant"
    run_script(root, "vagrant-up", instance_name)
  when "metal"
    warn "[up] instance=#{instance_name} uses metal hardware; nothing to create."
    exit 0
  else
    run_script(root, "tf-apply", instance_name)
  end
when "down"
  case engine
  when "vagrant"
    run_script(root, "vagrant-destroy", instance_name)
  when "metal"
    warn "[down] instance=#{instance_name} uses metal hardware; nothing to destroy."
    exit 0
  else
    run_script(root, "tf-destroy", instance_name)
  end
when "start", "stop", "status"
  run_script(root, command, instance_name)
when "ip"
  run_script(root, "instance-ip", instance_name)
when "ssh"
  run_script(root, "instance-ssh", instance_name, *extra_args)
else
  warn "provider-command: unsupported command: #{command}"
  exit 2
end
