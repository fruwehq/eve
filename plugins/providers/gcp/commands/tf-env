#!/usr/bin/env ruby
# frozen_string_literal: true

require "open3"

$LOAD_PATH.unshift(File.expand_path("../../_terraform-common/lib", __dir__))
require "tf_env"

env = EgameProviderTfEnv.env

project_id = ENV["GOOGLE_CLOUD_PROJECT"] || ENV["GOOGLE_PROJECT"] || ""
if project_id.empty? && system("command -v gcloud >/dev/null 2>&1")
  out, _err, status = Open3.capture3("gcloud", "config", "get-value", "project")
  project_id = out.strip if status.success?
end
if project_id.empty?
  warn "tf-env: missing GOOGLE_CLOUD_PROJECT or GOOGLE_PROJECT for gcp provider"
  exit 2
end

EgameProviderTfEnv.print_kv("TF_VAR_disk_gb", env["VM_DISK_GB"].to_s)
EgameProviderTfEnv.print_kv("TF_VAR_disk_type", env["VM_DISK_TYPE"].to_s)
EgameProviderTfEnv.print_kv("TF_VAR_image_family", env["GCP_IMAGE_FAMILY"].to_s)
EgameProviderTfEnv.print_kv("TF_VAR_image_project", env["GCP_IMAGE_PROJECT"].to_s)
EgameProviderTfEnv.print_kv("TF_VAR_machine_type", env["VM_MACHINE_TYPE"].to_s)
EgameProviderTfEnv.print_kv("TF_VAR_project_id", project_id)
EgameProviderTfEnv.print_kv("TF_VAR_region", env["LOCATION_REGION"].to_s)

my_ip = ENV["MY_IP"].to_s
if my_ip.empty?
  warn "tf-env: missing MY_IP for gcp provider"
  exit 2
end
EgameProviderTfEnv.print_kv("TF_VAR_ssh_allowed_cidr", "#{my_ip}/32")
EgameProviderTfEnv.print_kv("TF_VAR_zone", env["LOCATION_ZONE"].to_s)
