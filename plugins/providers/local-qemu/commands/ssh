#!/usr/bin/env bash
# SSH into a local QEMU instance via vagrant ssh.
#
# Usage:
#   commands/ssh <instance>                         # interactive shell
#   commands/ssh <instance> -- <cmd> [args...]      # remote command
#   commands/ssh <instance> --scp <local> <remote>  # scp helper

set -euo pipefail

if [ -n "${EVE_INSTANCE_NAME:-}" ]; then
  PROFILE="$EVE_INSTANCE_NAME"
else
  PROFILE="${1:?Usage: commands/ssh <instance> [-- <cmd>] [--scp <local> <remote>]}"
  shift || true
fi
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=scripts/lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh

WORKDIR="$(eve_instance_workdir "$PROFILE")"
if [ ! -f "$WORKDIR/Vagrantfile" ]; then
  echo "instance-ssh: no Vagrantfile for $PROFILE at $WORKDIR" >&2
  echo "instance-ssh: run: make up INSTANCE=$PROFILE" >&2
  exit 1
fi
cd "$WORKDIR"

if [ "${1:-}" = "--scp" ]; then
  shift
  LOCAL_PATH="${1:?--scp requires <local> <remote>}"
  REMOTE_PATH="${2:?--scp requires <local> <remote>}"
  if [ -d "$LOCAL_PATH" ]; then
    DIR_NAME=$(basename "$LOCAL_PATH")
    tar --no-xattrs -C "$(dirname "$LOCAL_PATH")" -cf - --exclude='._*' "$DIR_NAME" | vagrant ssh -c "mkdir -p '$REMOTE_PATH' && cd '$REMOTE_PATH' && tar -xf -"
  else
    BASENAME=$(basename "$LOCAL_PATH")
    vagrant ssh -c "cat > '$REMOTE_PATH/$BASENAME'" < "$LOCAL_PATH"
  fi
  exit $?
fi

if [ "${1:-}" = "--" ]; then
  shift
  exec vagrant ssh -c "$*"
fi

exec vagrant ssh
