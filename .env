# -----------------------------------------------------------------------------
# AWS
# -----------------------------------------------------------------------------

# AWS CLI config file used by Terraform/Terramate when ENV=aws.
# Example: AWS_CONFIG_FILE=$(HOME)/.aws/config
# AWS_CONFIG_FILE=$(HOME)/.aws/config

# AWS CLI profile name used by Terraform/Terramate when ENV=aws.
# Example values: default, personal, ephemeral-gaming
# AWS_PROFILE=default

# AWS region for AWS provider resources.
# Example values: ap-northeast-1, us-east-1, eu-central-1
# AWS_REGION=ap-northeast-1

# AWS CLI credentials file used by Terraform/Terramate when ENV=aws.
# Example: AWS_SHARED_CREDENTIALS_FILE=$(HOME)/.aws/credentials
# AWS_SHARED_CREDENTIALS_FILE=$(HOME)/.aws/credentials


# -----------------------------------------------------------------------------
# GCP
# -----------------------------------------------------------------------------

# GCP project used by the Terraform Google provider. If unset, the scripts fall
# back to `gcloud config get-value project`.
# Example values: my-gcp-project, ephemeral-vm-dev
# GOOGLE_CLOUD_PROJECT=ephemeral-vm-dev

# Optional service-account JSON file for Terraform Application Default
# Credentials. Leave unset when using user ADC from `gcloud auth
# application-default login`.
# Example: GOOGLE_APPLICATION_CREDENTIALS=$(HOME)/.config/gcloud/terraform.json
# GOOGLE_APPLICATION_CREDENTIALS=$(HOME)/.config/gcloud/terraform.json

# Optional short-lived OAuth token for the Terraform Google provider. This is
# useful when user `gcloud auth print-access-token` has Compute permissions but
# Application Default Credentials do not.
# Example: GOOGLE_OAUTH_ACCESS_TOKEN=$(gcloud auth print-access-token)
# GOOGLE_OAUTH_ACCESS_TOKEN=ya29...


# -----------------------------------------------------------------------------
# Display And Moonlight
# -----------------------------------------------------------------------------

# Target FPS passed to Moonlight stream requests. Leave unset to use Moonlight's
# configured/default FPS.
# Example values: 30, 60, 120
# EPHEMERAL_DISPLAY_FPS=30

# Target display resolution for Linux VNC, Xpra desktop, Raspberry Pi dummy
# display, Moonlight stream requests, and Windows VDD custom modes.
# Example values: 1280x720, 1920x1080, 2560x1440, 5120x1440
# EPHEMERAL_DISPLAY_RESOLUTION=1920x1080

# Moonlight stream bitrate in Kbps. Leave unset to use Moonlight's configured
# bitrate.
# Example values: 3000, 10000, 20000, 50000
# EPHEMERAL_MOONLIGHT_BITRATE_KBPS=3000

# Moonlight display mode. Borderless is recommended on macOS because it works
# better with Spaces, window switching, screenshot tools, and overlays.
# Valid values: fullscreen, borderless, windowed.
# EPHEMERAL_MOONLIGHT_DISPLAY_MODE=borderless

# Moonlight video codec preference. Leave unset or use auto for Moonlight's
# automatic choice. Valid values: auto, H.264, HEVC, AV1.
# Example: EPHEMERAL_MOONLIGHT_VIDEO_CODEC=H.264
# EPHEMERAL_MOONLIGHT_VIDEO_CODEC=H.264

# Moonlight decoder preference. Use software to bypass macOS VideoToolbox or
# other hardware decoder issues. Valid values: auto, hardware, software.
# Example: EPHEMERAL_MOONLIGHT_VIDEO_DECODER=software
# EPHEMERAL_MOONLIGHT_VIDEO_DECODER=software


# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------

# Your client/public IP for providers that need to restrict inbound access.
# Example values: 1.2.3.4, 203.0.113.10
# MY_IP=1.2.3.4

# SSH public key injected into provisioned Linux/Windows instances.
# Example: SSH_PUBLIC_KEY_FILE=$(HOME)/.ssh/id_rsa.pub
# SSH_PUBLIC_KEY_FILE=$(HOME)/.ssh/id_rsa.pub

# Timezone applied during Linux provisioning.
# Example values: Asia/Tokyo, UTC, Europe/Berlin, America/New_York
# TIMEZONE=Asia/Tokyo

# Default Linux VM username for generated cloud-init/provider configs.
# Example values: terraform, ubuntu, chris
# VM_USER_NAME=terraform

# Optional password for the human VM user created during Linux provisioning.
# Leave unset to create the account with a locked password; automation still
# uses the provider's SSH/provisioning user.
# Example: VM_USER_PASSWORD=correct-horse-battery-staple
# VM_USER_PASSWORD=


# -----------------------------------------------------------------------------
# Raspberry Pi
# -----------------------------------------------------------------------------

# Raspberry Pi HDMI connector name used when a real HDMI mode is configured.
# Example values: HDMI-A-1, HDMI-A-2
# RASPBERRY_PI_HDMI_CONNECTOR=HDMI-A-1

# Raspberry Pi HDMI mode override. Normally leave unset and let
# EPHEMERAL_DISPLAY_RESOLUTION drive the dummy display.
# Example values: 1024x768@60D, 1920x1080@60D, 5120x1440@60D
# RASPBERRY_PI_HDMI_MODE=1024x768@60D

# Raspberry Pi host name used for IP discovery when RASPBERRY_PI_IP is unset.
# Example values: raspberrypi.local, rapi.local
# RASPBERRY_PI_HOST=raspberrypi.local

# Raspberry Pi fixed IP override. Leave unset to resolve from
# RASPBERRY_PI_HOST/profile discovery.
# Example values: 192.168.0.217, 192.168.0.218
# RASPBERRY_PI_IP=

# Raspberry Pi user's login password. Used to bootstrap passwordless sudo for
# provisioning when required.
# Example: RASPBERRY_PI_USER_PASSWORD=correct-horse-battery-staple
# RASPBERRY_PI_USER_PASSWORD=


# -----------------------------------------------------------------------------
# RustDesk
# -----------------------------------------------------------------------------

# RustDesk server public key, usually the id_ed25519.pub value from hbbs.
# Example: RUSTDESK_KEY=abcdefghijklmnopqrstuvwxyz1234567890=
# RUSTDESK_KEY=

# Permanent unattended-access password configured on the provisioned host.
# Example: RUSTDESK_PASSWORD=changeme
# RUSTDESK_PASSWORD=changeme

# RustDesk rendezvous/server hostname. Use host only; provisioning appends the
# required port where needed.
# Example values: rs-ny.rustdesk.com, rustdesk.example.com
# RUSTDESK_SERVER=rs-ny.rustdesk.com


# -----------------------------------------------------------------------------
# Sunshine
# -----------------------------------------------------------------------------

# Sunshine web UI and API password used for pairing and remote control.
# Example: EPHEMERAL_SUNSHINE_PASSWORD=correct-horse-battery-staple
# EPHEMERAL_SUNSHINE_PASSWORD=xxx

# Sunshine maximum encoder bitrate in Kbps for the host config.
# Example values: 3000, 10000, 20000, 50000
# SUNSHINE_MAX_BITRATE_KBPS=3000

# Sunshine release version installed during provisioning.
# Example values: 2025.924.154138, 2025.628.4510
# SUNSHINE_VERSION=2025.924.154138


# -----------------------------------------------------------------------------
# TrueNAS
# -----------------------------------------------------------------------------

# TrueNAS API key used by provider status checks and API-backed automation.
# Example: TRUENAS_API_KEY=tn_api_key_here
# TRUENAS_API_KEY=

# TrueNAS API username associated with TRUENAS_API_KEY.
# Example values: root, admin
# TRUENAS_API_USER=root

# TrueNAS host used for SSH/API access. Prefer one canonical name across LAN and
# VPN when possible.
# Example values: truenas.home.arpa, 192.168.0.52
# TRUENAS_HOST=truenas.home.arpa

# Expected TrueNAS SSH host key fingerprint for verification.
# Example: TRUENAS_SSH_HOST_KEY_FINGERPRINT=SHA256:abcdef...
# TRUENAS_SSH_HOST_KEY_FINGERPRINT=SHA256:...

# TrueNAS SSH port.
# Example values: 22, 2222
# TRUENAS_SSH_PORT=22

# Private key used for SSH to TrueNAS.
# Example: TRUENAS_SSH_PRIVATE_KEY_FILE=$(HOME)/.ssh/truenas_ed25519
# TRUENAS_SSH_PRIVATE_KEY_FILE=$(HOME)/.ssh/truenas_ed25519

# TrueNAS SSH username.
# Example values: terraform, root, admin
# TRUENAS_SSH_USER=terraform

# Base directory for VM files on the TrueNAS host. Must exist as a ZFS dataset
# before make up.
# Example: TRUENAS_VM_BASE_DIR=/mnt/pool1/egame
# TRUENAS_VM_BASE_DIR=/mnt/pool1/egame

# ZFS pool for VM zvols.
# Example values: pool1, tank
# TRUENAS_VM_POOL=pool1

# ZFS dataset path prefix for VM zvols below TRUENAS_VM_POOL.
# Example values: egame, vms/egame
# TRUENAS_VM_ZVOL_PREFIX=egame


# -----------------------------------------------------------------------------
# Vagrant
# -----------------------------------------------------------------------------

# Set to 1 to open the hypervisor console window for local VirtualBox/VMware
# profiles. Default is headless.
# Example values: 0, 1
# VAGRANT_SHOW_CONSOLE=0


# -----------------------------------------------------------------------------
# Vultr
# -----------------------------------------------------------------------------

# Vultr API key used by Terraform/Terramate when ENV=vultr.
# Example: VULTR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VULTR_API_KEY=xxx


# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------

# Windows Administrator password override. If unset, password lookup comes from
# the provider output where available.
# Example: EPHEMERAL_WINDOWS_PASSWORD=correct-horse-battery-staple
# EPHEMERAL_WINDOWS_PASSWORD=xxx
