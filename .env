# AWS
# AWS_CONFIG_FILE=$(HOME)/.aws/config
# AWS_PROFILE=default
# AWS_REGION=ap-northeast-1
# AWS_SHARED_CREDENTIALS_FILE=$(HOME)/.aws/credentials

# Ephemeral Windows
# EPHEMERAL_SUNSHINE_PASSWORD=xxx
# EPHEMERAL_WINDOWS_PASSWORD=xxx

# Global settings
# MY_IP=1.2.3.4
# SSH_PUBLIC_KEY_FILE=$(HOME)/.ssh/id_rsa.pub
# TIMEZONE=Asia/Tokyo

# RustDesk
# RUSTDESK_KEY=                          # server's public key (id_ed25519.pub from hbbs)
# RUSTDESK_PASSWORD=changeme             # permanent password for the VM
# RUSTDESK_SERVER=rs-ny.rustdesk.com     # host only, no port (provisioning appends :21116)

# TrueNAS
# Prefer one canonical name across LAN + VPN when possible:
# TRUENAS_HOST=truenas.home.arpa
# Fallback if DNS is unavailable:
# TRUENAS_HOST=192.168.0.52
# TRUENAS_SSH_PORT=22
# TRUENAS_SSH_USER=terraform
#
# Provider auth
# TRUENAS_SSH_PRIVATE_KEY_FILE=$(HOME)/.ssh/truenas_ed25519
# TRUENAS_SSH_HOST_KEY_FINGERPRINT=SHA256:...
#
# API key (used by providers.status and cloud-init ISO upload)
# TRUENAS_API_KEY=
# TRUENAS_API_USER=root
#
# VM defaults (override in .env.local if your setup differs)
# ZFS pool used for VM zvols and ISO storage
TRUENAS_VM_ISO_DIR=/mnt/main/iso

# Vultr
# VULTR_API_KEY=xxx
