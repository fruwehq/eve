{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ephemeral.dev/schemas/config.schema.json",
  "title": "Eve Configuration",
  "description": "Schema for config/defaults.yaml and .eve/config.yaml. Only TRUE-core sections are defined here; provider and package config fields, defaults, and validation come from each plugin's manifest config_schema. All fields are optional; null/empty values signal 'use a lower-precedence layer'.",

  "type": "object",
  "additionalProperties": false,

  "properties": {
    "display": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fps":        { "$ref": "#/$defs/nullable_positive_integer" },
        "resolution": { "$ref": "#/$defs/nullable_resolution" }
      }
    },

    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "my_ip":               { "$ref": "#/$defs/nullable_cidr" },
        "provision_user":      { "$ref": "#/$defs/nullable_string" },
        "ssh_public_key_file": { "$ref": "#/$defs/path" },
        "timezone":            { "$ref": "#/$defs/nullable_string" },
        "vm_user_name":        { "$ref": "#/$defs/nullable_string" }
      }
    },

    "human_user": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "password": { "$ref": "#/$defs/nullable_string" }
      }
    },

    "moonlight": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bitrate_kbps":  { "$ref": "#/$defs/nullable_bitrate_kbps" },
        "display_mode":  { "$ref": "#/$defs/nullable_moonlight_display_mode" },
        "video_codec":   { "$ref": "#/$defs/nullable_moonlight_video_codec" },
        "video_decoder": { "$ref": "#/$defs/nullable_moonlight_video_decoder" }
      }
    },

    "vagrant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "show_console": { "$ref": "#/$defs/nullable_boolean" }
      }
    },

    "windows": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "password": { "$ref": "#/$defs/nullable_string" }
      }
    }
  },

  "$defs": {
    "nullable_string": {
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },

    "nullable_boolean": {
      "anyOf": [{ "type": "boolean" }, { "type": "null" }]
    },

    "nullable_positive_integer": {
      "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
    },

    "nullable_bitrate_kbps": {
      "description": "Bitrate in kilobits per second.",
      "anyOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }]
    },

    "nullable_cidr": {
      "description": "IP address or CIDR notation for access rules.",
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },

    "path": {
      "description": "Filesystem path. May contain ~, $HOME, or $(HOME) for expansion at runtime.",
      "anyOf": [{ "type": "string" }, { "type": "null" }]
    },

    "nullable_resolution": {
      "description": "Display resolution in WxH format (e.g. 1920x1080).",
      "anyOf": [{ "type": "string", "pattern": "^[0-9]+x[0-9]+$" }, { "type": "null" }]
    },

    "nullable_moonlight_display_mode": {
      "description": "Moonlight stream display mode.",
      "anyOf": [{ "type": "string", "enum": ["fullscreen", "borderless", "windowed"] }, { "type": "null" }]
    },

    "nullable_moonlight_video_codec": {
      "description": "Moonlight video codec preference.",
      "anyOf": [{ "type": "string", "enum": ["auto", "H.264", "HEVC", "AV1"] }, { "type": "null" }]
    },

    "nullable_moonlight_video_decoder": {
      "description": "Moonlight video decoder preference.",
      "anyOf": [{ "type": "string", "enum": ["auto", "hardware", "software"] }, { "type": "null" }]
    }
  }
}
