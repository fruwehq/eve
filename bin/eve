#!/usr/bin/env sh
# eve launcher (env-bootstrap shim). Lives in bin/, not scripts/: it runs BEFORE
# the poetry environment exists (it is what invokes poetry), so it cannot itself
# be a poetry-run Python entrypoint. See bin/README.md.
#
# Opens the gcloud-style `eve <group> <verb>` CLI tree (scripts/eve-cli). With no
# args it prints help; `eve tui` opens the Textual TUI.
#
# Startup: prefer the in-project venv's python directly — `poetry run` adds ~0.6s
# of resolution overhead per invocation. Fall back to `poetry run` when the venv
# isn't materialized (e.g. a non-in-project virtualenvs config).
set -eu

script_dir="$(CDPATH=; cd -- "$(dirname -- "$0")" && pwd)"
cd "$script_dir/.."
venv_bin="$script_dir/../.venv/bin"
if [ -x "$venv_bin/python" ]; then
  # Put the venv on PATH so child scripts' `#!/usr/bin/env python3` shebang
  # resolves to the venv python (what `poetry run` does, without its overhead).
  PATH="$venv_bin:$PATH"
  export PATH
  exec "$venv_bin/python" ./scripts/eve-cli "$@"
fi
exec poetry run python ./scripts/eve-cli "$@"
