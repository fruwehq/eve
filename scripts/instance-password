#!/usr/bin/env python3
"""Resolve the Administrator/Windows password for a profile's instance.

Usage: scripts/instance-password <instance>

Honors EPHEMERAL_WINDOWS_PASSWORD as an override (skip terraform lookup).
Dispatches by provider — currently supports: vultr.
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import apply_tf_env, repo_root, resolve_env  # noqa: E402

_TM_OUTPUT_FLAGS = [
    "--disable-safeguards=git-untracked",
    "--disable-safeguards=git-uncommitted",
    "--disable-safeguards=git-out-of-sync",
    "--disable-safeguards=outdated-code",
]


def usage() -> None:
    print("Usage: scripts/instance-password <instance>", file=sys.stderr)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        usage()
        return 2
    root = repo_root()

    override = os.environ.get("EPHEMERAL_WINDOWS_PASSWORD", "")
    if override:
        sys.stdout.write(override + "\n")
        return 0

    resolved = resolve_env(root, profile)
    provider = resolved.get("PROVIDER", "")
    os_family = resolved.get("OS_FAMILY", "")
    tags = resolved.get("STACK_TAGS", "")

    if os_family != "windows":
        print(
            f"[instance-password] {profile} is not a Windows profile (os_family={os_family})",
            file=sys.stderr,
        )
        return 2

    if provider == "vultr":
        apply_tf_env(root, profile)
        output_cmd = [
            "terramate", "run", *_TM_OUTPUT_FLAGS, "--quiet",
            f"--tags={tags}-services", "--",
            "terraform", "output", "-raw", "vultr_instance_default_password",
        ]
        # First attempt: stdout flows through, stderr discarded. On failure,
        # run tf-init (stdout suppressed) then retry with stderr visible.
        first = subprocess.run(output_cmd, cwd=root, stderr=subprocess.DEVNULL, check=False)
        if first.returncode == 0:
            return 0
        init = subprocess.run(
            [str(root / "scripts/tf-init"), profile],
            cwd=root, stdout=subprocess.DEVNULL, check=False,
        )
        if init.returncode != 0:
            return init.returncode
        return subprocess.run(output_cmd, cwd=root, check=False).returncode

    print(f"[instance-password] not implemented for provider={provider}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
