#!/usr/bin/env bash
# Resolve the Administrator/Windows password for a profile's instance.
# Usage: scripts/instance-password <profile>
#
# Honors EPHEMERAL_WINDOWS_PASSWORD as an override (skip terraform lookup).
# Dispatches by provider — currently supports: vultr.

set -euo pipefail

PROFILE="${1:?Usage: scripts/instance-password <profile>}"
cd "$(git rev-parse --show-toplevel)"

if [ -n "${EPHEMERAL_WINDOWS_PASSWORD:-}" ]; then
  printf '%s\n' "$EPHEMERAL_WINDOWS_PASSWORD"
  exit 0
fi

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
OS_FAMILY=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')
TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')

if [ "$OS_FAMILY" != "windows" ]; then
  echo "[instance-password] $PROFILE is not a Windows profile (os_family=$OS_FAMILY)" >&2
  exit 2
fi

case "$PROVIDER" in
  vultr)
    eval "$(./scripts/tf-env "$PROFILE")"
    terramate run --quiet --tags="$TAGS-services" -- terraform output -raw vultr_instance_default_password
    ;;
  *)
    echo "[instance-password] not implemented for provider=$PROVIDER" >&2
    exit 2
    ;;
esac
