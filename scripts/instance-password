#!/usr/bin/env python3
"""Resolve the Administrator/Windows password for a profile's instance.

Usage: scripts/instance-password <instance>

Honors EPHEMERAL_WINDOWS_PASSWORD as an override (skip provider dispatch).
Dispatches to the instance's provider ``password`` command generically.
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import repo_root, resolve_env  # noqa: E402


def usage() -> None:
    print("Usage: scripts/instance-password <instance>", file=sys.stderr)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        usage()
        return 2
    root = repo_root()

    override = os.environ.get("EPHEMERAL_WINDOWS_PASSWORD", "")
    if override:
        sys.stdout.write(override + "\n")
        return 0

    resolved = resolve_env(root, profile)
    os_family = resolved.get("OS_FAMILY", "")

    if os_family != "windows":
        print(
            f"[instance-password] {profile} is not a Windows profile (os_family={os_family})",
            file=sys.stderr,
        )
        return 2

    # Dispatch to the provider's password command generically.
    return subprocess.run(
        [str(root / "scripts/provider-dispatch"),
         "--instance", profile, "--command", "password"],
        cwd=root, check=False,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
