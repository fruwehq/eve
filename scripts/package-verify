#!/usr/bin/env python3
"""Live package smoke verification for one concrete instance.

Usage: scripts/package-verify --instance <name> [--package <id>]

Generic dispatcher (v4.4 §15): for each selected installed package that declares
a ``verify`` action, run it via scripts/package-action (the package's verify
command does the live probes and prints ok/fail lines, exiting non-zero on
failure). Packages without a verify action get a generic installed-status check.
Core names no package.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

_USAGE = (
    "Usage: scripts/package-verify --instance <name> [--package <id>]\n\n"
    "Verifies selected package plugins with lightweight live probes."
)


def main(argv: list[str]) -> int:
    instance = ""
    package_filter = ""

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance = args.pop(0)
        elif arg == "--package" and args:
            package_filter = args.pop(0)
        elif arg in {"-h", "--help"}:
            print(_USAGE, file=sys.stderr)
            return 0
        else:
            print(_USAGE, file=sys.stderr)
            return 2

    if not instance:
        print(_USAGE, file=sys.stderr)
        return 2

    overlay_path_result = subprocess.run(
        [str(ROOT / "scripts/instance-paths"), "--instance", instance, "--emit", "json"],
        capture_output=True, text=True, check=True,
    )
    overlay_path = json.loads(overlay_path_result.stdout).get("INSTANCE_OVERLAY_PATH", "")
    if overlay_path:
        Path(overlay_path).parent.mkdir(parents=True, exist_ok=True)
        overlay_result = subprocess.run(
            [str(ROOT / "scripts/instance-profile-overlay"), "--instance", instance, "--output", overlay_path],
            stdout=subprocess.DEVNULL,
        )
        if overlay_result.returncode != 0:
            return overlay_result.returncode
        os.environ["EVE_CATALOG_LOCAL"] = overlay_path
    os.environ["EVE_INSTANCE_NAME"] = instance

    resolved_result = subprocess.run(
        [str(ROOT / "scripts/instance-resolve"), "--instance", instance, "--emit", "json"],
        capture_output=True, text=True, check=True,
    )
    os_family = json.loads(resolved_result.stdout).get("os", {}).get("family", "")

    list_result = subprocess.run(
        [str(ROOT / "scripts/package-list"), "--instance", instance, "--json"],
        capture_output=True, text=True, check=True,
    )
    all_packages = json.loads(list_result.stdout).get("packages", [])

    if package_filter:
        packages = [p for p in all_packages if p.get("id") == package_filter]
        if not packages:
            print(f"package.verify: unknown package for {instance}: {package_filter}", file=sys.stderr)
            return 2
    else:
        packages = [p for p in all_packages if p.get("selected") and p.get("supported")]

    if not packages:
        print(f"No selected supported packages to verify for {instance}.")
        return 0

    def status_for_package(pkg_id: str) -> str:
        result = subprocess.run(
            [str(ROOT / "scripts/package-dispatch"), "--instance", instance,
             "--package", pkg_id, "--command", "status"],
            capture_output=True, text=True, check=False,
        )
        output = result.stdout + result.stderr
        if result.returncode != 0:
            print(output, file=sys.stderr)
            return "failed"
        json_text = ""
        capturing = False
        for line in output.split("\n"):
            if not capturing and line.startswith("{"):
                capturing = True
                json_text = line
            elif capturing:
                json_text += "\n" + line
        try:
            return str(json.loads(json_text).get("status", "unknown")) or "unknown"
        except (json.JSONDecodeError, ValueError):
            return "unknown"

    print(f"Verifying packages for {instance} ({os_family})")
    failures = 0
    for pkg in packages:
        pkg_id = str(pkg.get("id", ""))
        actions = pkg.get("actions") or []
        has_verify = any(a.get("id") == "verify" for a in actions)
        if has_verify:
            result = subprocess.run(
                [str(ROOT / "scripts/package-action"), "--instance", instance,
                 "--package", pkg_id, "--action", "verify"],
                check=False,
            )
            if result.returncode != 0:
                failures += 1
            continue
        # Generic fallback: installed-status check only.
        status = status_for_package(pkg_id)
        if status == "installed":
            print(f"ok   {pkg_id:<14} {status}")
        else:
            print(f"fail {pkg_id:<14} status is {status}")
            failures += 1

    if failures > 0:
        print(f"package.verify failed with {failures} failure(s).")
        return 1
    print("package.verify passed.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
