#!/usr/bin/env python3
"""List concrete local VM instances from the instance registry."""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir  # noqa: E402


def absolute(path: str) -> Path:
    return Path(os.path.abspath(os.path.expanduser(path)))


def load_any(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    loaded = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    if not isinstance(loaded, dict):
        raise ValueError(f"{path}: expected a mapping")
    return loaded


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/instance-list",
        usage="scripts/instance-list [--json] [--registry <path>]",
        add_help=True,
    )
    arg_parser.add_argument("--json", action="store_true")
    arg_parser.add_argument("--registry")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    registry_path = absolute(args.registry) if args.registry else Workdir.instance_registry_path()
    try:
        registry = load_any(registry_path)
    except Exception as error:
        print(f"instance-list: {error}", file=sys.stderr)
        return 1
    raw_instances = registry.get("instances", [])
    instances = raw_instances if isinstance(raw_instances, list) else []

    if args.json:
        print(json.dumps({"instances": instances}, indent=2))
        return 0

    if not instances:
        print(
            "No instances found. Create one with: "
            "eve instance create --instance <name> --machine <machine> --os <os> --location <location>"
        )
        return 0

    print(f"{'INSTANCE':<28} {'MACHINE':<32} {'OS':<24} {'LOCATION':<24}")
    print(f"{'--------':<28} {'-------':<32} {'--':<24} {'--------':<24}")
    for instance in instances:
        if not isinstance(instance, dict):
            continue
        print(
            f"{instance.get('name', '')!s:<28} "
            f"{instance.get('machine') or '-'!s:<32} "
            f"{instance.get('os') or '-'!s:<24} "
            f"{instance.get('location') or '-'!s:<24}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
