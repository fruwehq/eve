#!/usr/bin/env bash
# Top-level test orchestrator. Runs all project checks.
# Usage: scripts/test              # run all
#        scripts/test catalog      # run only one suite
#        UPDATE_GOLDEN=1 scripts/test instances # refresh instance goldens

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

FAIL=0
if [ "$#" -eq 0 ]; then
  SUITES=(catalog config-save core-boundary instances lifecycle plugins plugins-sync provision-runner schemas secrets state-concurrency terraform tf-isolation tui python shellcheck lint)
else
  SUITES=("$@")
fi

run() {
  local name="$1"; shift
  printf '\n== %s ==\n' "$name"
  if "$@"; then
    printf '[OK]   %s\n' "$name"
  else
    printf '[FAIL] %s\n' "$name"
    FAIL=$((FAIL + 1))
  fi
}

for suite in "${SUITES[@]}"; do
  case "$suite" in
    catalog)   run "catalog"   ./scripts/test-catalog   ;;
    config-save) run "config-save" ./scripts/test-config-save ;;
    core-boundary) run "core-boundary" ./scripts/test-core-boundary ;;
    instances)  run "instances"  ./scripts/test-instances  ;;
    lifecycle)  run "lifecycle"  ./scripts/test-lifecycle  ;;
    plugins)    run "plugins"    ./scripts/test-plugins    ;;
    plugins-sync) run "plugins-sync" ./scripts/test-plugins-sync ;;
    provision-runner) run "provision-runner" ./scripts/test-provision-runner ;;
    python) run "python" ./scripts/test-python ;;
    schemas) run "schemas" ./scripts/test-schemas ;;
    secrets) run "secrets" ./scripts/test-secrets ;;
    shellcheck) run "shellcheck" ./scripts/test-shellcheck ;;
    state-concurrency) run "state-concurrency" ./scripts/test-state-concurrency ;;
    terraform)  run "terraform"  ./scripts/test-terraform  ;;
    tf-isolation) run "tf-isolation" ./scripts/test-tf-isolation ;;
    tui) run "tui" ./scripts/test-tui ;;
    lint) run "lint" ./scripts/test-lint ;;
    *) echo "unknown suite: $suite" >&2; exit 2 ;;
  esac
done

if [ "$FAIL" -ne 0 ]; then
  printf '\n%d suite(s) failed.\n' "$FAIL" >&2
  exit 1
fi
printf '\nAll tests passed.\n'
