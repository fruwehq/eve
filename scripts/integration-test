#!/usr/bin/env python3
"""Manual/AI-assisted live integration runner for concrete v3 instances."""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]


def now_iso() -> str:
    return datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/integration-test",
        description="Build dry-run or live integration test plans for concrete instances.",
    )
    arg_parser.add_argument("--instance", action="append", default=[])
    arg_parser.add_argument("--registry")
    arg_parser.add_argument("--live", action="store_true")
    arg_parser.add_argument("--json", action="store_true")
    arg_parser.add_argument("--report")
    arg_parser.add_argument("--no-cleanup", action="store_true")
    arg_parser.add_argument("--delete-instances", action="store_true")
    arg_parser.add_argument("--all-packages", action="store_true")
    return arg_parser


def run_capture(env: dict[str, str], *cmd: str) -> dict[str, Any]:
    result = subprocess.run(cmd, cwd=ROOT, env=env, text=True, capture_output=True, check=False)
    return {
        "command": " ".join(cmd),
        "status": "passed" if result.returncode == 0 else "failed",
        "exit_code": result.returncode,
        "output": (result.stdout + result.stderr).strip(),
    }


def run_stream(env: dict[str, str], *cmd: str) -> dict[str, Any]:
    process = subprocess.Popen(cmd, cwd=ROOT, env=env, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    output = ""
    assert process.stdout is not None
    for line in process.stdout:
        output += line
        print(line, end="")
        sys.stdout.flush()
    exit_code = process.wait()
    return {
        "command": " ".join(cmd),
        "status": "passed" if exit_code == 0 else "failed",
        "exit_code": exit_code,
        "output": output.strip(),
    }


def validate_step_result(result: dict[str, Any]) -> None:
    name = str(result["name"])
    if not name.startswith("package.status.") or result["status"] != "passed":
        return
    try:
        payload = json.loads(str(result["output"]))
        package_status = payload["status"]
        result["package_status"] = package_status
    except (json.JSONDecodeError, KeyError) as error:
        result["status"] = "failed"
        result["failure_reason"] = f"invalid package status JSON: {error}"
        return
    if package_status != "installed":
        result["status"] = "failed"
        result["failure_reason"] = f"expected package status installed, got {package_status}"


def run_json(env: dict[str, str], *cmd: str) -> dict[str, Any]:
    result = run_capture(env, *cmd)
    if result["status"] != "passed":
        raise RuntimeError(str(result["output"]))
    parsed = json.loads(str(result["output"]))
    if not isinstance(parsed, dict):
        raise RuntimeError(f"{cmd[0]} did not emit a JSON object")
    return parsed


def selected_instances(args: argparse.Namespace) -> list[str]:
    instances = list(args.instance)
    if not instances and os.environ.get("EVE_INTEGRATION_INSTANCES"):
        instances = [part.strip() for part in os.environ["EVE_INTEGRATION_INSTANCES"].split(",") if part.strip()]
    return instances


def build_plans(
    instances: list[str],
    registry_path: str | None,
    env: dict[str, str],
    all_packages: bool,
) -> list[dict[str, Any]]:
    plans = []
    for instance in instances:
        resolved_cmd = [str(ROOT / "scripts/instance-resolve"), "--instance", instance, "--emit", "json"]
        if registry_path:
            resolved_cmd += ["--registry", registry_path]
        resolved = run_json(env, *resolved_cmd)
        packages = resolved["bundle_packages"]
        os_family = resolved["os"]["family"]

        package_list_cmd = [str(ROOT / "scripts/package-list"), "--instance", instance, "--json"]
        if registry_path:
            package_list_cmd += ["--registry", registry_path]
        package_doc = run_json(env, *package_list_cmd)
        package_smoke_packages = (
            [
                package["id"]
                for package in package_doc["packages"]
                if package.get("supported") and package.get("installable")
            ]
            if all_packages
            else []
        )
        status_packages = sorted(set(packages + package_smoke_packages))
        plans.append(
            {
                "instance": instance,
                "os_family": os_family,
                "provider": resolved["machine"]["provider"],
                "machine": resolved["composition"]["machine"],
                "os": resolved["os"]["id"],
                "selected_packages": packages,
                "package_smoke": "all-supported" if all_packages else "selected-only",
                "package_smoke_packages": package_smoke_packages,
                "commands": [
                    f"eve instance validate --instance {instance}",
                    f"eve instance up --instance {instance}",
                    f"eve instance ssh-wait --instance {instance}",
                    f"eve instance provision --instance {instance}",
                    f"eve instance status --instance {instance} --json",
                    *[
                        f"eve package install --instance {instance} --package {package}"
                        for package in package_smoke_packages
                    ],
                    *[f"eve package status --instance {instance} --package {package}" for package in status_packages],
                ],
                "manual_checks": [
                    "Confirm SSH command execution works.",
                    f"Review eve instance status --instance {instance} for provider/provision/package state.",
                    "Package status confirms the package probe reports installed; GUI/remote-access packages "
                    "still need their package action or manual connection smoke.",
                    "Confirm Sunshine/RustDesk access and a smooth 3D app or game launch."
                    if os_family == "windows"
                    else "Confirm AI/dev package commands run inside the safer Linux environment.",
                    "Destroy or stop the instance when testing is complete if it is billable.",
                ],
            }
        )
    return plans


def print_dry_run(plans: list[dict[str, Any]], emit_json: bool) -> None:
    if emit_json:
        print(json.dumps({"live": False, "plans": plans}, indent=2))
        return
    for plan in plans:
        print(f"Instance: {plan['instance']} ({plan['os_family']}, {plan['provider']})")
        print("Commands:")
        for command in plan["commands"]:
            print(f"  {command}")
        print("Manual checks:")
        for check in plan["manual_checks"]:
            print(f"  - {check}")
        print()


def live_commands(plan: dict[str, Any]) -> list[list[str]]:
    instance = plan["instance"]
    inst_run = str(ROOT / "scripts/instance-run")
    dispatch = str(ROOT / "scripts/package-dispatch")
    commands = [
        ["validate", str(ROOT / "scripts/instance-resolve"), "--instance", instance, "--validate"],
        ["up", inst_run, "up", instance],
        ["ssh.wait", inst_run, "ssh.wait", instance],
        ["provision", str(ROOT / "scripts/instance-provision"), "--instance", instance],
        ["status", str(ROOT / "scripts/instance-status"), "--instance", instance, "--json"],
    ]
    for package in plan["package_smoke_packages"]:
        commands.append(
            ["package.install." + package, dispatch, "--instance", instance,
             "--package", package, "--command", "install"]
        )
    for package in sorted(set(plan["selected_packages"] + plan["package_smoke_packages"])):
        commands.append(
            ["package.status." + package, dispatch, "--instance", instance,
             "--package", package, "--command", "status"]
        )
    return commands


def run_live(
    plans: list[dict[str, Any]],
    env: dict[str, str],
    cleanup: bool,
    delete_instances: bool,
    report_path: str | None,
) -> int:
    report: dict[str, Any] = {"started_at": now_iso(), "live": True, "instances": []}
    for plan in plans:
        instance = plan["instance"]
        entry = {key: value for key, value in plan.items() if key != "commands"}
        entry["steps"] = []
        entry["cleanup"] = []

        for name, *cmd in live_commands(plan):
            print()
            print(f"== {instance}: {name} ==")
            print(f"$ {' '.join(cmd)}")
            result = run_stream(env, *cmd)
            result["name"] = name
            validate_step_result(result)
            entry["steps"].append(result)
            if result["status"] != "passed":
                break

        if cleanup:
            cleanup_commands = [
                ["cleanup.down", str(ROOT / "scripts/instance-run"), "down", instance]
            ]
            if delete_instances:
                cleanup_commands.append(
                    ["cleanup.delete", str(ROOT / "scripts/instance-delete"), "--instance", instance, "--purge"]
                )
            for name, *cmd in cleanup_commands:
                print()
                print(f"== {instance}: {name} ==")
                print(f"$ {' '.join(cmd)}")
                result = run_stream(env, *cmd)
                result["name"] = name
                entry["cleanup"].append(result)

        steps_passed = all(step["status"] == "passed" for step in entry["steps"])
        cleanup_passed = all(step["status"] == "passed" for step in entry["cleanup"])
        entry["status"] = "passed" if steps_passed and cleanup_passed else "failed"
        report["instances"].append(entry)

    report["finished_at"] = now_iso()
    output_path = (
        Path(report_path)
        if report_path
        else ROOT / "tmp" / f"integration-report-{datetime.now(UTC).strftime('%Y%m%dT%H%M%SZ')}.json"
    )
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(json.dumps(report, indent=2) + "\n", encoding="utf-8")
    print(output_path)
    return 0 if all(entry["status"] == "passed" for entry in report["instances"]) else 1


def main() -> int:
    args = parser().parse_args()
    instances = selected_instances(args)
    if not instances:
        parser().print_usage(sys.stderr)
        return 2
    if args.live and os.environ.get("YES") != "1":
        print("integration-test: live mode can create billable or local VMs; rerun with YES=1", file=sys.stderr)
        return 2

    registry_path = (
        str(Path(args.registry).expanduser().resolve())
        if args.registry
        else os.environ.get("EVE_INSTANCE_REGISTRY")
    )
    env = os.environ.copy()
    if registry_path:
        env["EVE_INSTANCE_REGISTRY"] = registry_path
    cleanup = os.environ.get("EVE_INTEGRATION_CLEANUP", "1") != "0" and not args.no_cleanup
    delete_instances = os.environ.get("EVE_INTEGRATION_DELETE_INSTANCES") == "1" or args.delete_instances
    all_packages = os.environ.get("EVE_INTEGRATION_ALL_PACKAGES") == "1" or args.all_packages

    plans = build_plans(instances, registry_path, env, all_packages)
    if not args.live:
        print_dry_run(plans, args.json)
        return 0
    return run_live(plans, env, cleanup, delete_instances, args.report)


if __name__ == "__main__":
    raise SystemExit(main())
