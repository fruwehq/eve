#!/usr/bin/env bash
set -euo pipefail

PROFILE="${1:?Usage: scripts/profile-stop <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')

tf_attr() {
  local json="$1" address="$2" attr="$3"
  printf '%s' "$json" | jq -r --arg addr "$address" --arg attr "$attr" \
    '(.values // {} | .root_module // {} | .resources // [])
     | map(select(.address == $addr))
     | map(.values[$attr])
     | first // ""' 2>/dev/null
}

case "$ENGINE" in
  vagrant)
    exec ./scripts/vagrant-stop "$PROFILE"
    ;;
  terraform)
    TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')

    STATE_JSON=$(terramate run --quiet --tags="$TAGS-services" -- terraform show -json 2>/dev/null) || true
    if [ -z "$STATE_JSON" ]; then
      echo "[profile-stop] No instance in state." >&2
      exit 1
    fi

    case "$PROVIDER" in
      aws)
        RAW=$(tf_attr "$STATE_JSON" "aws_instance.main" "instance_state")
        if [ "$RAW" = "stopped" ]; then
          echo "[profile-stop] Already stopped"
          exit 0
        fi
        INSTANCE_ID=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw instance_id)
        REGION=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^LOCATION_REGION=/{print $2}')
        echo "[profile-stop] Stopping AWS instance $INSTANCE_ID in $REGION"
        aws ec2 stop-instances --instance-ids "$INSTANCE_ID" --region "$REGION" --output table
        ;;
      vultr)
        RAW=$(tf_attr "$STATE_JSON" "vultr_instance.default" "power_status")
        if [ "$RAW" = "stopped" ]; then
          echo "[profile-stop] Already stopped"
          exit 0
        fi
        INSTANCE_ID=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw instance_id)
        echo "[profile-stop] Halting Vultr instance $INSTANCE_ID"
        HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" -X POST \
          -H "Authorization: Bearer ${VULTR_API_KEY}" \
          "https://api.vultr.com/v2/instances/$INSTANCE_ID/halt")
        if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
          echo "[profile-stop] Instance halt initiated (HTTP $HTTP_CODE)"
        else
          echo "[profile-stop] Failed to halt instance (HTTP $HTTP_CODE)" >&2
          exit 1
        fi
        ;;
      truenas)
        RAW=$(tf_attr "$STATE_JSON" "truenas_vm.this" "state")
        if [ "${RAW^^}" = "STOPPED" ]; then
          echo "[profile-stop] Already stopped"
          exit 0
        fi
        VM_ID=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw truenas_vm_id)
        echo "[profile-stop] Stopping TrueNAS VM $VM_ID"
        HTTP_CODE=$(curl -ksS -o /dev/null -w "%{http_code}" -X POST \
          -H "Authorization: Bearer ${TRUENAS_API_KEY}" \
          "https://${TRUENAS_HOST}/api/v2.0/vm/id/$VM_ID/stop")
        if [ "$HTTP_CODE" -ge 200 ] && [ "$HTTP_CODE" -lt 300 ]; then
          echo "[profile-stop] VM stop initiated (HTTP $HTTP_CODE)"
        else
          echo "[profile-stop] Failed to stop VM (HTTP $HTTP_CODE)" >&2
          exit 1
        fi
        ;;
      *)
        echo "[profile-stop] Unsupported provider: $PROVIDER" >&2
        exit 1
        ;;
    esac

    terramate run --quiet --tags="$TAGS-services" -- terraform refresh 2>/dev/null || true
    ;;
  *)
    echo "[profile-stop] Unsupported engine: $ENGINE" >&2
    exit 1
    ;;
esac
