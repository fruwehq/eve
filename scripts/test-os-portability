#!/usr/bin/env ruby
# frozen_string_literal: true

require "fileutils"
require "open3"
require "shellwords"
require "tmpdir"

ROOT = File.expand_path("..", __dir__)
RESOLVER_HELPER = File.join(ROOT, "plugins", "providers", "raspberry-pi", "lib", "host-resolver.sh")

$failures = 0

def pass(message)
  puts "  [OK] #{message}"
end

def fail(message)
  warn "  [FAIL] #{message}"
  $failures += 1
end

def write_executable(path, body)
  File.write(path, body)
  FileUtils.chmod("+x", path)
end

def resolver_case(name, os_name:, expected_ip:, commands:)
  Dir.mktmpdir("eve-os-portability.") do |dir|
    bin = File.join(dir, "bin")
    FileUtils.mkdir_p(bin)
    write_executable(File.join(bin, "uname"), "#!/usr/bin/env sh\nprintf '%s\\n' #{os_name.shellescape}\n")
    commands.each do |command_name, body|
      write_executable(File.join(bin, command_name), body)
    end

    env = { "PATH" => "#{bin}:#{ENV.fetch("PATH")}" }
    script = ". #{RESOLVER_HELPER.shellescape}; resolve_host_ip #{name.shellescape}"
    stdout, stderr, status = Open3.capture3(env, "bash", "-c", script)
    if status.success? && stdout.strip == expected_ip
      pass "resolve_host_ip #{os_name} branch"
    else
      fail "resolve_host_ip #{os_name} branch expected #{expected_ip.inspect}, got stdout=#{stdout.inspect} stderr=#{stderr.inspect} status=#{status.exitstatus}"
    end
  end
end

resolver_case(
  "raspberrypi.local",
  os_name: "Linux",
  expected_ip: "192.0.2.10",
  commands: {
    "getent" => "#!/usr/bin/env sh\nprintf '192.0.2.10 STREAM raspberrypi.local\\n'\n",
    "dscacheutil" => "#!/usr/bin/env sh\necho 'dscacheutil should not run on Linux' >&2\nexit 99\n"
  }
)

resolver_case(
  "raspberrypi.local",
  os_name: "Darwin",
  expected_ip: "192.0.2.20",
  commands: {
    "dscacheutil" => "#!/usr/bin/env sh\nprintf 'name: raspberrypi.local\\nip_address: 192.0.2.20\\n'\n",
    "getent" => "#!/usr/bin/env sh\necho 'getent should not run on Darwin' >&2\nexit 99\n"
  }
)

Dir.mktmpdir("eve-os-portability.") do |dir|
  bin = File.join(dir, "bin")
  FileUtils.mkdir_p(bin)
  write_executable(File.join(bin, "uname"), "#!/usr/bin/env sh\nprintf '%s\\n' FreeBSD\n")
  env = { "PATH" => "#{bin}:#{ENV.fetch("PATH")}" }
  script = ". #{RESOLVER_HELPER.shellescape}; resolve_host_ip raspberrypi.local"
  _stdout, stderr, status = Open3.capture3(env, "bash", "-c", script)
  if !status.success? && stderr.include?("unsupported host OS: FreeBSD")
    pass "resolve_host_ip rejects unsupported host OS"
  else
    fail "resolve_host_ip unsupported OS expected clear failure, got stderr=#{stderr.inspect} status=#{status.exitstatus}"
  end
end

exit($failures.zero? ? 0 : 1)
