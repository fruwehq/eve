#!/usr/bin/env sh
set -eu

CATALOG_PATH="config/catalog.yaml"
LOCAL_CATALOG_PATH="${EVE_CATALOG_LOCAL:-config/catalog.local.yaml}"
PROFILE=""
VALIDATE=0
EMIT=""
OUTPUT=""

usage() {
  cat <<'EOF'
Usage:
  scripts/profile-resolve --profile <name> [--validate] [--emit env|json|vagrant] [--output <path>] [--local-catalog <path>]

Notes:
  - Base catalog: config/catalog.yaml
  - Optional local overlay: config/catalog.local.yaml (if present)
  - EVE_CATALOG_LOCAL can point at a generated overlay for INSTANCE workflows.

Examples:
  scripts/profile-resolve --profile aws-ubuntu-dev-headless --validate
  scripts/profile-resolve --profile aws-ubuntu-dev-headless --emit env
  scripts/profile-resolve --profile local-vbox-ubuntu-dev --emit vagrant --output ./.generated/Vagrantfile
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --profile)
      PROFILE="${2:-}"
      shift 2
      ;;
    --validate)
      VALIDATE=1
      shift
      ;;
    --emit)
      EMIT="${2:-}"
      shift 2
      ;;
    --output)
      OUTPUT="${2:-}"
      shift 2
      ;;
    --local-catalog)
      LOCAL_CATALOG_PATH="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [ -z "$PROFILE" ]; then
  echo "--profile is required" >&2
  usage >&2
  exit 2
fi

# SDK fast-path: if a caller (provider-dispatch, package-dispatch) has already
# resolved+validated the instance and exported EVE_RESOLVED_JSON, reuse it
# instead of re-loading the catalog. The instance-resolve output is a strict
# superset of this script's RESOLVED_JSON shape (same .profile/.machine/.os/
# .init/.location/.bundle_packages/.engine/.stack_tags keys), so the
# downstream jq emitters work unchanged. This keeps the SDK-validated
# contract flowing through into bash dispatchers under
# plugins/providers/_common.
if [ -n "${EVE_RESOLVED_JSON:-}" ]; then
  RESOLVED_JSON_INPUT="$EVE_RESOLVED_JSON"
else
  RESOLVED_JSON_INPUT=""
fi

if [ -z "$RESOLVED_JSON_INPUT" ] && [ ! -f "$CATALOG_PATH" ]; then
  echo "Catalog not found: $CATALOG_PATH" >&2
  exit 1
fi

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to parse YAML catalogs (missing python3)" >&2
  exit 1
fi

if [ -n "$RESOLVED_JSON_INPUT" ]; then
  CATALOG_JSON=""
else
  CATALOG_JSON="$(python3 - "$CATALOG_PATH" "$LOCAL_CATALOG_PATH" <<'PY'
import json
import sys
from pathlib import Path

import yaml


def load_any(raw_path):
    path = Path(raw_path)
    if not path.exists():
        return {}
    if path.suffix.lower() in {".yaml", ".yml"}:
        return yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    if path.suffix.lower() == ".json":
        return json.loads(path.read_text(encoding="utf-8"))
    raise SystemExit(f"Unsupported catalog format: {path} (expected .yaml/.yml/.json)")


def deep_merge(base, override):
    if base is None:
        return override
    if override is None:
        return base
    if isinstance(base, dict) and isinstance(override, dict):
        merged = dict(base)
        for key, value in override.items():
            merged[key] = deep_merge(merged.get(key), value)
        return merged
    return override


def merge_by_key(base_items, override_items, key):
    merged = [dict(item) if isinstance(item, dict) else item for item in (base_items or [])]
    for entry in override_items or []:
        if not isinstance(entry, dict):
            continue
        index = next((i for i, item in enumerate(merged) if isinstance(item, dict) and item.get(key) == entry.get(key)), None)
        if index is None:
            merged.append(entry)
        else:
            merged[index] = deep_merge(merged[index], entry)
    return merged


base = load_any(sys.argv[1])
override = load_any(sys.argv[2])
catalog = deep_merge(base, override)
for section, key in {
    "machines": "name",
    "oses": "id",
    "inits": "id",
    "packages": "id",
    "bundles": "id",
    "locations": "name",
    "profiles": "name",
}.items():
    catalog[section] = merge_by_key(base.get(section), override.get(section), key)
print(json.dumps(catalog))
PY
)"
fi

# shellcheck disable=SC2016
# $-prefixed names below are jq variables, not shell expansions.
jq_get='def by_name($arr; $key; $val): ($arr // [] | map(select(.[$key] == $val)) | .[0]);

. as $root |
by_name($root.profiles; "name"; $profile) as $profile_override |
($profile_override) as $p |
if $p == null then
  error("Profile not found: \($profile)")
else
  by_name($root.machines; "name"; $p.machine) as $m |
  if $m == null then error("Machine not found: \($p.machine)") else . end |
  by_name($root.oses; "id"; $p.os) as $o |
  if $o == null then error("OS not found: \($p.os)") else . end |
  by_name($root.inits; "id"; $p.init) as $i |
  if $i == null then error("Init not found: \($p.init)") else . end |
  by_name($root.locations; "name"; $p.location) as $l |
  if $l == null then error("Location not found: \($p.location)") else . end |

  ($p.bundles // []) as $bundle_ids |
  ($root.bundles // []) as $all_bundles |
  ($bundle_ids | map(by_name($all_bundles; "id"; .))) as $bundle_objs |
  if ($bundle_objs | any(. == null)) then
    error("One or more bundles not found in profile: \($p.name)")
  else . end |

  (($p.packages // []) | unique) as $direct_packages |
  ($bundle_objs | map(.includes // []) | flatten | . + $direct_packages | unique) as $bundle_packages |
  ($root.packages // [] | map(.id)) as $package_catalog |
  if ($bundle_packages | all(. as $pkg | $package_catalog | index($pkg) != null) | not) then
    error("Profile references unknown package id")
  else . end |

  if (($i.os_family // "") != "" and ($i.os_family != ($o.family // ""))) then
    error("Init/OS mismatch: init \($i.id) expects \($i.os_family), got OS family \($o.family)")
  else . end |

  if ((($i.providers // []) | length) > 0 and (($i.providers // []) | index($m.provider // "") == null)) then
    error("Init/provider mismatch: init \($i.id) expects provider \($i.providers | join(", ")), got machine provider \($m.provider)")
  elif (($i.provider // "") != "" and ($i.provider != ($m.provider // ""))) then
    error("Init/provider mismatch: init \($i.id) expects provider \($i.provider), got machine provider \($m.provider)")
  else . end |

  # Package dependency validation lives in scripts/instance-resolve via
  # the depends_on manifest field. profile-resolve only enforces
  # catalog/profile integrity here; dependency checks would duplicate
  # logic and require keeping a hardcoded list of dep edges in this jq
  # filter.

  if ($l[($m.provider // "")] == null) then
    error("Location \($l.name) has no mapping for provider \($m.provider)")
  else . end |

  {
    profile: $p,
    machine: $m,
    os: $o,
    init: $i,
    location: $l,
    bundle_packages: $bundle_packages,
    engine: (
      if ($m.kind // "") == "metal" then "metal"
      elif (($m.provider // "") | startswith("local-")) then "vagrant"
      else "terraform"
      end
    ),
    stack_tags: ($m.provider // "")
  }
end'

if [ -n "$RESOLVED_JSON_INPUT" ]; then
  # SDK fast-path: caller supplied a validated resolved-instance JSON
  # (output of scripts/instance-resolve, schema:
  # core/schema/resolved-instance.schema.json). That shape carries the
  # catalog-resolved data under .machine/.os/.init/.location plus an
  # .instance block with the instance name. profile-resolve's downstream
  # jq emitters expect a .profile.name field (legacy profile shape), so
  # map .instance.name -> .profile.name without touching other keys.
  RESOLVED_JSON="$(printf '%s' "$RESOLVED_JSON_INPUT" | jq -c '
    if (.profile // null) == null then
      .profile = ((.instance // {}) + { name: ((.instance // {}).name // "") })
    else . end
  ')"
else
  RESOLVED_JSON="$(printf '%s' "$CATALOG_JSON" | jq -ce --arg profile "$PROFILE" "$jq_get")"
fi

if [ "$VALIDATE" -eq 1 ]; then
  echo "Profile validated: $PROFILE"
fi

if [ -z "$EMIT" ]; then
  exit 0
fi

emit_env() {
  echo "$RESOLVED_JSON" | jq -r '
    def env_or($name; $fallback): ((env[$name] | select(. != "")) // $fallback);
    def provision_user($locp):
      if (.os.family == "windows") then "Administrator"
      elif (.machine.provider == "truenas") then env_or("EVE_PROVISION_USER"; $locp.provision_user // "")
      else env_or("VM_USER_NAME"; "")
      end;
    def human_user($locp):
      (env_or("VM_USER_NAME"; "")) as $human |
      if $human != "" then $human else provision_user($locp) end;
    (.machine.provider) as $provider |
    (.location[$provider] // {}) as $locp |
    "ACCESS_BOOTSTRAP_USER=" + provision_user($locp),
    "ACCESS_HUMAN_USER=" + human_user($locp),
    "ACCESS_PROVISION_USER=" + provision_user($locp),
    "PROFILE_NAME=" + .profile.name,
    "ENGINE=" + .engine,
    "PROVIDER=" + $provider,
    "STACK_TAGS=" + .stack_tags,
    "LOCATION_NAME=" + .location.name,
    "OS_ID=" + .os.id,
    "OS_FAMILY=" + .os.family,
    "INIT_ID=" + .init.id,
    "BUNDLE_PACKAGES=" + (.bundle_packages | join(",")),
    "VM_MEMORY_MB=" + ((.machine.defaults.memory_mb // 0) | tostring),
    "VM_CPU_CORES=" + ((.machine.defaults.cpu_cores // .machine.defaults.cpus // 0) | tostring),
    "VM_CPU_MODE=" + (.machine.defaults.cpu_mode // ""),
    "VM_VCPUS=" + ((.machine.defaults.vcpus // 1) | tostring),
    "VM_AUTOSTART=" + ((.machine.defaults.autostart // true) | tostring),
    "VM_STATE=" + (.machine.defaults.state // "STOPPED"),
    "VM_NIC_ATTACH=" + (.machine.defaults.network // $locp.bridge // "br0"),
    "VM_DISK_GB=" + ((.machine.defaults.disk_gb // 30) | tostring),
    "VM_POOL=" + (.machine.defaults.pool // $locp.pool // "main"),
    "VM_PLAN=" + (.machine.defaults.plan // ""),
    "VM_MACHINE_TYPE=" + (.machine.defaults.machine_type // ""),
    "VM_DISK_TYPE=" + (.machine.defaults.disk_type // ""),
    "VM_INSTANCE_TYPE=" + (.machine.defaults.instance_type // ""),
    "VM_ROOT_VOLUME_TYPE=" + (.machine.defaults.root_volume_type // ""),
    "GCP_IMAGE_FAMILY=" + (.os.gcp_image_family // ""),
    "GCP_IMAGE_PROJECT=" + (.os.gcp_image_project // ""),
    "VULTR_OS_ID=" + ((.os.vultr_os_id // 0) | tostring),
    "LOCATION_REGION=" + ($locp.region // ""),
    "LOCATION_AVAILABILITY_ZONE=" + ($locp.availability_zone // ""),
    "LOCATION_ZONE=" + ($locp.zone // ""),
    "SSH_USER=" + provision_user($locp),
    "CLOUD_IMAGE_URL=" + (.os.cloud_image_url // ""),
    "HUMAN_USER_NAME=" + human_user($locp),
    "PROVISION_USER_NAME=" + provision_user($locp),
    "RASPBERRY_PI_HOST=" + (
      if (.machine.provider == "raspberry-pi" and (($locp.host // "") != "")) then $locp.host
      else env_or("RASPBERRY_PI_HOST"; $locp.host // "")
      end
    ),
    "RASPBERRY_PI_IP=" + (
      if (.machine.provider == "raspberry-pi" and (($locp.ip // "") != "")) then $locp.ip
      else env_or("RASPBERRY_PI_IP"; $locp.ip // "")
      end
    ),
    "TRUENAS_HOST=" + env_or("TRUENAS_HOST"; $locp.host // ""),
    "TRUENAS_SSH_PORT=" + env_or("TRUENAS_SSH_PORT"; (($locp.ssh_port // 22) | tostring)),
    "TRUENAS_SSH_USER=" + env_or("TRUENAS_SSH_USER"; $locp.ssh_user // ""),
    "VM_USER_NAME=" + env_or("VM_USER_NAME"; "")
  '
}

emit_json() {
  echo "$RESOLVED_JSON"
}

emit_vagrant() {
  family=$(echo "$RESOLVED_JSON" | jq -r '.os.family')
  if [ "$family" != "ubuntu" ]; then
    echo "profile-resolve: --emit vagrant only supports os.family=ubuntu (got: $family)" >&2
    exit 2
  fi
  echo "$RESOLVED_JSON" | jq -r '
    . as $r |
    (if $r.machine.provider == "local-qemu" then "qemu"
     else error("Vagrant emit only supports local-qemu, got " + $r.machine.provider)
     end) as $provider |
    ($r.os.vagrant_box // "cloud-image/ubuntu-26.04") as $box |
    ($r.os.arch // "amd64") as $arch |
    (if ($r.os.arch // "amd64") == "arm64" then "aarch64" else "x86_64" end) as $qemu_arch |
    $r.profile.name as $name |
    (($r.machine.defaults.cpus // 2) | tostring) as $cpus |
    (($r.machine.defaults.memory_mb // 4096)) as $memory_mb |
    ($memory_mb | tostring) as $memory |
    (((($memory_mb / 1024) | floor) | tostring) + "G") as $qemu_memory |
    (((($r.machine.defaults.disk_gb // 30) | tostring) + "G")) as $qemu_disk |
    ($r.bundle_packages | join(" ")) as $pkg_list |

    { docker: ($r.bundle_packages | index("docker") != null), dev: ($r.bundle_packages | index("dev-toolchain") != null) } as $flags |

    # Port forwards: vagrant defaults to NAT and only forwards SSH, so each
    # remote-access port has to be enumerated here or remote-* helpers on the
    # host (which always hit 127.0.0.1 for vagrant) cannot reach the VM.
    (
      (if ($r.bundle_packages | index("sunshine")) != null then
        "  # Sunshine / Moonlight\n" +
        "  config.vm.network \"forwarded_port\", guest: 47984, host: 47984, auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 47989, host: 47989, auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 47990, host: 47990, auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 48010, host: 48010, auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 47998, host: 47998, protocol: \"udp\", auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 47999, host: 47999, protocol: \"udp\", auto_correct: true\n" +
        "  config.vm.network \"forwarded_port\", guest: 48000, host: 48000, protocol: \"udp\", auto_correct: true\n"
      else "" end) +
      (if ($r.bundle_packages | index("vnc")) != null then
        "  # VNC\n" +
        "  config.vm.network \"forwarded_port\", guest: 5901, host: 5901, auto_correct: true\n"
      else "" end) +
      (if ($r.bundle_packages | index("xpra")) != null then
        "  # Xpra\n" +
        "  config.vm.network \"forwarded_port\", guest: 14500, host: 14500, auto_correct: true\n"
      else "" end) +
      (if ($r.bundle_packages | index("rdp")) != null then
        "  # RDP\n" +
        "  config.vm.network \"forwarded_port\", guest: 3389, host: 3389, auto_correct: true\n"
      else "" end) +
      (if ($r.bundle_packages | index("thinlinc")) != null then
        "  # ThinLinc Web Access\n" +
        "  config.vm.network \"forwarded_port\", guest: 300, host: 300, auto_correct: true\n"
      else "" end)
    ) as $port_forwards |

    # Build bundle-aware install lines (each line must be indented by 4 spaces)
    (if $flags.docker then
      "    # Install Docker\n" +
      "    sudo install -m 0755 -d /etc/apt/keyrings\n" +
      "    curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --batch --yes --dearmor -o /etc/apt/keyrings/docker.gpg\n" +
      "    echo \"deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo $VERSION_CODENAME) stable\" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null\n" +
      "    sudo apt-get update -y\n" +
      "    sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin\n" +
      "    sudo usermod -aG docker vagrant\n"
    else "" end) as $docker_setup |

    (if $flags.dev then
      "    sudo apt-get install -y build-essential pkg-config libssl-dev\n"
    else "" end) as $dev_setup |

    "Vagrant.configure(\"2\") do |config|\n" +
    "  config.vm.box = \"" + $box + "\"\n" +
    "  config.vm.box_architecture = \"" + $arch + "\"\n" +
    "  config.vm.hostname = \"" + $name + "\"\n" +
    "\n" +
    (if $provider == "qemu" then
      "  config.vm.provider \"qemu\" do |qe|\n" +
      "    qe.arch = \"" + $qemu_arch + "\"\n" +
      "    qe.smp = \"" + $cpus + "\"\n" +
      "    qe.memory = \"" + $qemu_memory + "\"\n" +
      "    qe.disk_resize = \"" + $qemu_disk + "\"\n" +
      "  end\n"
    else
      "  config.vm.provider \"" + $provider + "\" do |v|\n" +
      "    v.cpus = " + $cpus + "\n" +
      "    v.memory = " + $memory + "\n" +
      "    # Set VAGRANT_SHOW_CONSOLE=1 to open the hypervisor console window.\n" +
      "    v.gui = ENV[\"VAGRANT_SHOW_CONSOLE\"] == \"1\"\n" +
      "  end\n"
    end) +
    "\n" +
    $port_forwards +
    (if $port_forwards != "" then "\n" else "" end) +
    "  config.vm.provision \"shell\", inline: <<-SHELL\n" +
    "    set -e\n" +
    "    export DEBIAN_FRONTEND=noninteractive\n" +
    "    echo \"Bootstrapping profile: " + $name + "\"\n" +
    "    echo \"Packages: " + $pkg_list + "\"\n" +
    "    sudo apt-get update -y\n" +
    "    sudo apt-get install -y curl git jq\n" +
    $docker_setup +
    $dev_setup +
    "  SHELL\n" +
    "end\n"
  '
}

PROVIDER_FROM_RESOLVE="$(echo "$RESOLVED_JSON" | jq -r '.machine.provider // empty' 2>/dev/null || true)"
if [ -n "$PROVIDER_FROM_RESOLVE" ]; then
  SECRETS_EXPORT="$(python3 - "$PROVIDER_FROM_RESOLVE" <<'PY'
import os
import shlex
import sys
from pathlib import Path

sys.path.insert(0, str(Path.cwd()))
from eve_sdk.secrets import Secrets

for key, value in Secrets.read(sys.argv[1]).items():
    if value is None or key in os.environ:
        continue
    print(f"export {key}={shlex.quote(str(value))}")
PY
)"
  if [ -n "$SECRETS_EXPORT" ]; then
    eval "$SECRETS_EXPORT"
  fi
fi

case "$EMIT" in
  env)
    OUT="$(emit_env)"
    ;;
  json)
    OUT="$(emit_json)"
    ;;
  vagrant)
    OUT="$(emit_vagrant)"
    ;;
  *)
    echo "Unsupported --emit format: $EMIT" >&2
    exit 2
    ;;
esac

if [ -n "$OUTPUT" ]; then
  mkdir -p "$(dirname "$OUTPUT")"
  printf '%s\n' "$OUT" > "$OUTPUT"
else
  printf '%s\n' "$OUT"
fi
