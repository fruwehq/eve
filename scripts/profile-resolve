#!/usr/bin/env python3
"""Resolve a profile against the catalog and emit env/JSON/Vagrant output.

Usage: scripts/profile-resolve --profile <name> [--validate]
       [--emit env|json|vagrant] [--output <path>] [--local-catalog <path>]
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.profile_resolve import (  # noqa: E402
    PROFILE_NOT_FOUND_EXIT,
    ProfileResolveError,
    adopt_resolved_instance,
    apply_provider_secrets,
    emit_env,
    emit_json,
    emit_vagrant,
    load_catalog_with_profiles,
    resolve_profile,
)

_USAGE_USAGE_LINE = (
    "  scripts/profile-resolve --profile <name> [--validate] "
    "[--emit env|json|vagrant] [--output <path>] [--local-catalog <path>]"
)
USAGE = (
    "Usage:\n"
    f"{_USAGE_USAGE_LINE}\n"
    "\n"
    "Notes:\n"
    "  - Base catalog: config/catalog.yaml\n"
    "  - Optional local overlay: config/catalog.local.yaml (if present)\n"
    "  - EVE_CATALOG_LOCAL can point at a generated overlay for INSTANCE workflows.\n"
    "\n"
    "Examples:\n"
    "  scripts/profile-resolve --profile aws-ubuntu-dev-headless --validate\n"
    "  scripts/profile-resolve --profile aws-ubuntu-dev-headless --emit env\n"
    "  scripts/profile-resolve --profile local-vbox-ubuntu-dev --emit vagrant"
    " --output ./.generated/Vagrantfile\n"
)


def main(argv: list[str]) -> int:
    profile = ""
    validate = False
    emit = ""
    output = ""

    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--profile":
            profile = argv[i + 1] if i + 1 < len(argv) else ""
            i += 2
        elif arg == "--validate":
            validate = True
            i += 1
        elif arg == "--emit":
            emit = argv[i + 1] if i + 1 < len(argv) else ""
            i += 2
        elif arg == "--output":
            output = argv[i + 1] if i + 1 < len(argv) else ""
            i += 2
        elif arg == "--local-catalog":
            os.environ["EVE_CATALOG_LOCAL"] = argv[i + 1] if i + 1 < len(argv) else ""
            i += 2
        elif arg in ("-h", "--help"):
            print(USAGE)
            return 0
        else:
            print(f"Unknown argument: {arg}", file=sys.stderr)
            print(USAGE, file=sys.stderr)
            return 2

    if not profile:
        print("--profile is required", file=sys.stderr)
        print(USAGE, file=sys.stderr)
        return 2

    resolved_json_input = os.environ.get("EVE_RESOLVED_JSON") or ""

    if not resolved_json_input:
        catalog_path = ROOT / "config/catalog.yaml"
        if not catalog_path.exists():
            print(f"Catalog not found: {catalog_path}", file=sys.stderr)
            return 1

    try:
        if resolved_json_input:
            resolved = adopt_resolved_instance(resolved_json_input)
        else:
            catalog = load_catalog_with_profiles()
            resolved = resolve_profile(catalog, profile)
    except ProfileResolveError as error:
        print(str(error), file=sys.stderr)
        return PROFILE_NOT_FOUND_EXIT

    if validate:
        print(f"Profile validated: {profile}")

    if not emit:
        return 0

    apply_provider_secrets(resolved)

    if emit == "env":
        out = emit_env(resolved)
    elif emit == "json":
        out = emit_json(resolved)
    elif emit == "vagrant":
        try:
            out = emit_vagrant(resolved)
        except SystemExit as exit_exc:
            if exit_exc.code == 2:
                os_family = resolved.get("os", {}).get("family", "")
                print(
                    f"profile-resolve: --emit vagrant only supports os.family=ubuntu (got: {os_family})",
                    file=sys.stderr,
                )
                return 2
            raise
        except ProfileResolveError as error:
            print(str(error), file=sys.stderr)
            return PROFILE_NOT_FOUND_EXIT
    else:
        print(f"Unsupported --emit format: {emit}", file=sys.stderr)
        return 2

    normalized = out.rstrip("\n") + "\n"
    if output:
        Path(output).parent.mkdir(parents=True, exist_ok=True)
        Path(output).write_text(normalized, encoding="utf-8")
    else:
        sys.stdout.write(normalized)

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
