#!/usr/bin/env python3
"""Read or update local v3 instance state."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.schema import SchemaValidationError  # noqa: E402
from eve_sdk.state import State, StateError  # noqa: E402


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/instance-state",
        usage=(
            "scripts/instance-state --instance <name> --get\n"
            "      scripts/instance-state --instance <name> --recover-running\n"
            "      scripts/instance-state --instance <name> --observed-json <json>\n"
            "      scripts/instance-state --instance <name> --operation <name> --status <status> "
            "[--desired-state <state>] [--provider-state <state>] [--provision-state <state>] "
            "[--package <id> --package-state <state>] [--error <message>]"
        ),
        add_help=True,
    )
    arg_parser.add_argument("--instance", required=True)
    arg_parser.add_argument("--get", action="store_true")
    arg_parser.add_argument("--recover-running", action="store_true")
    arg_parser.add_argument("--operation")
    arg_parser.add_argument("--status")
    arg_parser.add_argument("--desired-state")
    arg_parser.add_argument("--provider-state")
    arg_parser.add_argument("--provision-state")
    arg_parser.add_argument("--package")
    arg_parser.add_argument("--package-state")
    arg_parser.add_argument("--observed-json")
    arg_parser.add_argument("--error")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    try:
        if args.get:
            state = State.read(args.instance)
        elif args.observed_json:
            observed = json.loads(args.observed_json)
            if not isinstance(observed, dict):
                raise ValueError("observed_json must be an object")
            state = State.update_observed(args.instance, observed)
        elif args.recover_running:
            state = State.recover_running(args.instance)
        else:
            if not args.operation or not args.status:
                parser().print_usage(sys.stderr)
                return 2
            if (args.package is None) != (args.package_state is None):
                raise ValueError("package and package_state must be provided together")
            state = State.record_operation(
                args.instance,
                args.operation,
                args.status,
                error=args.error,
                desired_state=args.desired_state,
                provider_state=args.provider_state,
                provision_state=args.provision_state,
                package=args.package,
                package_state=args.package_state,
            )
        print(json.dumps(state, indent=2))
        return 0
    except (StateError, SchemaValidationError, json.JSONDecodeError, ValueError) as error:
        print(f"instance-state: {error}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
