#!/usr/bin/env ruby
# Read or update local v3 instance state.
# All reads and writes go through core/sdk/state.rb (sole state owner).

require "json"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-state --instance <name> --get
      scripts/instance-state --instance <name> --recover-running
      scripts/instance-state --instance <name> --observed-json <json>
      scripts/instance-state --instance <name> --operation <name> --status <status> [--desired-state <state>] [--provider-state <state>] [--provision-state <state>] [--package <id> --package-state <state>] [--error <message>]
  USAGE
end

instance = nil
get = false
recover_running = false
operation = nil
status = nil
desired_state = nil
provider_state = nil
provision_state = nil
package = nil
package_state = nil
observed_json = nil
error = nil

args = ARGV.dup
until args.empty?
  case args.shift
  when "--instance"
    instance = args.shift
  when "--get"
    get = true
  when "--recover-running"
    recover_running = true
  when "--operation"
    operation = args.shift
  when "--status"
    status = args.shift
  when "--desired-state"
    desired_state = args.shift
  when "--provider-state"
    provider_state = args.shift
  when "--provision-state"
    provision_state = args.shift
  when "--package"
    package = args.shift
  when "--package-state"
    package_state = args.shift
  when "--observed-json"
    observed_json = args.shift
  when "--error"
    error = args.shift
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless instance
  usage
  exit 2
end

begin
  if get
    puts JSON.pretty_generate(Eve::SDK::State.read(instance))
    exit 0
  end

  if observed_json
    observed = JSON.parse(observed_json)
    raise "observed_json must be an object" unless observed.is_a?(Hash)

    state = Eve::SDK::State.update_observed(instance, observed)
    puts JSON.pretty_generate(state)
    exit 0
  end

  if recover_running
    state = Eve::SDK::State.recover_running(instance)
    puts JSON.pretty_generate(state)
    exit 0
  end

  unless operation && status
    usage
    exit 2
  end

  raise "package and package_state must be provided together" if package.nil? != package_state.nil?

  state = Eve::SDK::State.record_operation(
    instance, operation, status,
    error: error,
    desired_state: desired_state,
    provider_state: provider_state,
    provision_state: provision_state,
    package: package,
    package_state: package_state
  )
  puts JSON.pretty_generate(state)
rescue Eve::SDK::StateError, Eve::SDK::SchemaValidationError, JSON::ParserError, ArgumentError => e
  warn "instance-state: #{e.message}"
  exit 2
end
