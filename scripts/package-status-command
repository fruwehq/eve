#!/usr/bin/env bash
# Run a remote package status probe and emit the package status JSON contract.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

PACKAGE="${1:?Usage: scripts/package-status-command <package> <remote-command>}"
REMOTE_COMMAND="${2:?Usage: scripts/package-status-command <package> <remote-command>}"
PROFILE="${EVE_INSTANCE_NAME:?EVE_INSTANCE_NAME is required}"
OS_FAMILY="${EVE_PACKAGE_OS_FAMILY:-ubuntu}"
SSH_HELPER="${EVE_PACKAGE_STATUS_SSH:-./scripts/instance-ssh}"

if RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env 2>/dev/null); then
  SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^SSH_USER=/{print $2}')
  VM_USER_NAME=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^VM_USER_NAME=/{print $2}')
else
  SSH_USER=""
  VM_USER_NAME=""
fi
HUMAN_USER="${VM_USER_NAME:-$SSH_USER}"
HUMAN_USER="${HUMAN_USER:-$(id -un)}"
case "$HUMAN_USER" in
  *[!a-zA-Z0-9._-]*)
    echo "package-status-command: unsupported VM user name: $HUMAN_USER" >&2
    exit 2
    ;;
esac

REMOTE_COMMAND_WITH_CONTEXT=$(cat <<EOF
set -eu
EVE_HUMAN_USER="$HUMAN_USER"
EVE_HUMAN_HOME=\$(getent passwd "\$EVE_HUMAN_USER" | cut -d: -f6)
EVE_HUMAN_UID=\$(id -u "\$EVE_HUMAN_USER")
export EVE_HUMAN_USER EVE_HUMAN_HOME EVE_HUMAN_UID
export HOME="\$EVE_HUMAN_HOME"
export PATH="\$EVE_HUMAN_HOME/.local/bin:\$EVE_HUMAN_HOME/.cargo/bin:\$PATH"
eve_human_run() {
  sudo -H -u "\$EVE_HUMAN_USER" env \
    HOME="\$EVE_HUMAN_HOME" \
    USER="\$EVE_HUMAN_USER" \
    LOGNAME="\$EVE_HUMAN_USER" \
    PATH="\$EVE_HUMAN_HOME/.local/bin:\$EVE_HUMAN_HOME/.cargo/bin:\$PATH" \
    XDG_RUNTIME_DIR="/run/user/\$EVE_HUMAN_UID" \
    "\$@"
}
$REMOTE_COMMAND
EOF
)

set +e
output="$("$SSH_HELPER" "$PROFILE" -- "$REMOTE_COMMAND_WITH_CONTEXT" 2>&1)"
exit_status=$?
set -e

clean_details() {
  printf '%s\n' "$1" |
    tr -d '\r' |
    awk '
      /^#< CLIXML/ { next }
      /^<Objs / { next }
      /^<Obj / { next }
      /^<\/Objs>/ { next }
      /_x000D__/ { next }
      { print }
    '
}

details="$(clean_details "$output")"

if [ "$exit_status" -eq 0 ]; then
  status="$(printf '%s\n' "$details" | awk '/^(installed|missing|unknown)$/ { print; exit }')"
  status="${status:-unknown}"
  case "$status" in
    installed|missing|unknown) ;;
    *) status="unknown" ;;
  esac
else
  status="failed"
fi

jq -n \
  --arg kind "package-status" \
  --arg package "$PACKAGE" \
  --arg command "status" \
  --arg instance "$PROFILE" \
  --arg os_family "$OS_FAMILY" \
  --arg status "$status" \
  --arg details "$details" \
  '{kind: $kind, package: $package, command: $command, instance: $instance, os_family: $os_family, status: $status, details: $details}'
