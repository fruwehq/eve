#!/usr/bin/env python3
"""Run a remote package status probe and emit the package status JSON contract.

Usage: scripts/package-status-command <package> <remote-command>

Wraps the remote command in the human-user bash context (with ``.cargo/bin`` in
PATH, matching the original), runs it via ``EVE_PACKAGE_STATUS_SSH``, and emits
the package-status JSON. ``EVE_PACKAGE_OS_FAMILY`` selects the reported family
(default ``ubuntu``).
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.package_dispatch import (  # noqa: E402
    build_linux_human_context,
    emit_json,
    first_status,
    resolve_human_user,
    run_status_probe,
)

_USAGE = "Usage: scripts/package-status-command <package> <remote-command>"
_VALID = {"installed", "missing", "unknown"}


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(_USAGE, file=sys.stderr)
        return 1
    package = argv[0]
    remote_command = argv[1]
    profile = os.environ.get("EVE_INSTANCE_NAME", "")
    if not profile:
        print("EVE_INSTANCE_NAME is required", file=sys.stderr)
        return 1
    os_family = os.environ.get("EVE_PACKAGE_OS_FAMILY", "ubuntu")
    ssh_helper = os.environ.get("EVE_PACKAGE_STATUS_SSH", str(ROOT / "scripts/instance-ssh"))

    human_user = resolve_human_user(ROOT, profile, "package-status-command")
    remote_command_with_context = build_linux_human_context(
        human_user, remote_command, include_cargo=True,
    )

    exit_status, details = run_status_probe(ssh_helper, profile, remote_command_with_context)

    if exit_status == 0:
        status = first_status(details, _VALID) or "unknown"
        if status not in _VALID:
            status = "unknown"
    else:
        status = "failed"

    emit_json({
        "kind": "package-status",
        "package": package,
        "command": "status",
        "instance": profile,
        "os_family": os_family,
        "status": status,
        "details": details,
    })
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
