#!/usr/bin/env python3
"""Upload Linux provisioning scripts and run the step subset for one package.

Usage:
  scripts/package-provision --instance <name> --package <id> [--dry-run]
  scripts/package-provision --profile <name> --package <id> [--dry-run]

Topologically expands the install chain for the requested package (via
``depends_on`` in plugin manifests), uploads the staging tree, and runs the
selected steps on the remote host.
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.config import ConfigEnv  # noqa: E402
from eve_sdk.resolve import instance_package_config  # noqa: E402
from eve_sdk.package_dispatch import emit_json  # noqa: E402
from eve_sdk.tf_dispatch import repo_root, resolve_env  # noqa: E402

_USAGE = (
    "Usage:\n"
    "  scripts/package-provision --instance <name> --package <id> [--dry-run]\n"
    "  scripts/package-provision --profile <name> --package <id> [--dry-run]  "
    "# compatibility alias"
)


class ChainError(Exception):
    """Raised when the dependency chain cannot be resolved."""


def _plugin_list_json() -> list[dict[str, object]]:
    result = subprocess.run(
        [str(ROOT / "scripts/plugin-list"), "--kind", "package", "--json"],
        capture_output=True, text=True, check=True,
    )
    doc = json.loads(result.stdout)
    plugins = doc["plugins"] if isinstance(doc, dict) else doc
    return [p for p in plugins if isinstance(p, dict)]


def _resolve_install_chain(plugins: list[dict[str, object]], root_id: str) -> list[dict[str, object]]:
    """Topologically expand ``depends_on`` with stable first-occurrence dedup."""
    by_id: dict[str, dict[str, object]] = {str(p["id"]): p for p in plugins}

    def visit(plugin_id: str, stack: list[str]) -> list[dict[str, object]]:
        if plugin_id not in by_id:
            raise ChainError(f"package-provision: unknown package id: {plugin_id}")
        if plugin_id in stack:
            cycle = " -> ".join([*stack, plugin_id])
            raise ChainError(f"package-provision: dependency cycle: {cycle}")
        plugin = by_id[plugin_id]
        deps = plugin.get("depends_on") or []
        if not isinstance(deps, list):
            deps = []
        result: list[dict[str, object]] = []
        for dep in deps:
            result.extend(visit(str(dep), [*stack, plugin_id]))
        result.append(plugin)
        return result

    ordered = visit(root_id, [])
    seen: set[str] = set()
    chain: list[dict[str, object]] = []
    for p in ordered:
        pid = str(p["id"])
        if pid not in seen:
            seen.add(pid)
            chain.append(p)
    return chain


def _ssh_retry(label: str, cmd: list[str]) -> int:
    return subprocess.run([str(ROOT / "scripts/ssh-retry"), label, *cmd]).returncode


def _env_line(key: str, value: str) -> str:
    return f'export {key}="{value}"'


def main(argv: list[str]) -> int:
    instance_name = ""
    package = ""
    dry_run = False

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg in {"--instance", "--profile"} and args:
            instance_name = args.pop(0)
        elif arg == "--package" and args:
            package = args.pop(0)
        elif arg == "--dry-run":
            dry_run = True
        elif arg in {"-h", "--help"}:
            print(_USAGE, file=sys.stderr)
            return 0
        else:
            print(_USAGE, file=sys.stderr)
            return 2

    if not instance_name or not package:
        print(_USAGE, file=sys.stderr)
        return 2

    root = repo_root()

    tmp_overlay: str | None = None
    try:
        if os.environ.get("EVE_INSTANCE_REGISTRY"):
            fd, tmp_overlay = tempfile.mkstemp(
                prefix="eve-package-provision-overlay.", suffix=".yaml",
                dir=os.environ.get("TMPDIR", "/tmp"),
            )
            os.close(fd)
            result = subprocess.run(
                [str(ROOT / "scripts/instance-profile-overlay"),
                 "--registry", os.environ["EVE_INSTANCE_REGISTRY"],
                 "--instance", instance_name, "--output", tmp_overlay],
                stdout=subprocess.DEVNULL,
            )
            if result.returncode != 0:
                return result.returncode
            os.environ["EVE_CATALOG_LOCAL"] = tmp_overlay

        resolved = resolve_env(root, instance_name)
    except SystemExit:
        raise
    finally:
        if tmp_overlay and os.path.exists(tmp_overlay):
            os.unlink(tmp_overlay)

    os_family = resolved.get("OS_FAMILY", "")
    os_id = resolved.get("OS_ID", "")
    profile_name = resolved.get("PROFILE_NAME", "")
    provider = resolved.get("PROVIDER", "")
    bundle_packages = resolved.get("BUNDLE_PACKAGES", "")
    os_provision_dir = root / "oses" / os_id / "provision"

    if os_family != "ubuntu":
        print(
            f"package-provision: granular package install is only implemented for "
            f"ubuntu, got {os_family}",
            file=sys.stderr,
        )
        return 2
    if not os_provision_dir.is_dir():
        print(
            f"package-provision: OS provisioning directory not found: {os_provision_dir}",
            file=sys.stderr,
        )
        return 2
    os_provision_dir = os_provision_dir.resolve()

    try:
        plugins = _plugin_list_json()
        chain = _resolve_install_chain(plugins, package)
    except ChainError as error:
        print(str(error), file=sys.stderr)
        return 2

    if not chain:
        print(f"package-provision: no install chain for {package}", file=sys.stderr)
        return 2

    steps: list[str] = []
    step_roots: list[str] = []
    package_markers: list[str] = []
    for plugin in chain:
        plugin_id = str(plugin["id"])
        install = plugin.get("install", {})
        install_ubuntu = install.get("ubuntu") if isinstance(install, dict) else None
        if install_ubuntu is None:
            print(
                f"package-provision: no ubuntu install step mapping for package: {plugin_id}",
                file=sys.stderr,
            )
            return 2
        plugin_path = plugin.get("path") or ""
        plugin_root = str(Path(str(plugin_path)).parent)

        for step in install_ubuntu.get("steps", []):
            step = str(step)
            if step not in steps:
                steps.append(step)
                step_roots.append(plugin_root)

        markers = install_ubuntu.get("package_markers") or [plugin_id]
        for marker in markers:
            marker = str(marker)
            if marker not in package_markers:
                package_markers.append(marker)

    if not steps:
        print(
            f"package-provision: ubuntu install steps for {package} are empty in plugin manifest",
            file=sys.stderr,
        )
        return 2

    if dry_run:
        emit_json({
            "kind": "package-provision",
            "instance": instance_name,
            "profile": instance_name,
            "package": package,
            "os_family": os_family,
            "steps": steps,
            "package_markers": package_markers,
            "dry_run": True,
        })
        return 0

    ssh = str(ROOT / "scripts/instance-ssh")
    wait_status = subprocess.run([str(ROOT / "scripts/ssh-wait"), instance_name]).returncode
    if wait_status != 0:
        return wait_status

    def sudo_ok() -> bool:
        return subprocess.run(
            [ssh, instance_name, "--", "sudo -n true"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        ).returncode == 0

    if not sudo_ok():
        # Provider-declared bootstrap password (manifest bootstrap.sudo_password_env),
        # read generically — core names no provider.
        bootstrap_password = ConfigEnv.bootstrap_sudo_password(provider)
        if bootstrap_password:
            print("[package-provision] configuring passwordless sudo via the provider's bootstrap password")
            sudo_setup = (
                'tmp=$(mktemp); printf "%s ALL=(ALL) NOPASSWD:ALL\\n" "$USER" > "$tmp"; '
                'chmod 0440 "$tmp"; sudo -S -p "" install -o root -g root -m 0440 '
                '"$tmp" /etc/sudoers.d/90-eve-provision; rm -f "$tmp"; '
                "sudo -n visudo -cf /etc/sudoers.d/90-eve-provision"
            )
            subprocess.run([ssh, instance_name, "--", sudo_setup],
                           input=bootstrap_password + "\n", text=True)

    if not sudo_ok():
        print(
            "[package-provision] Linux package install requires passwordless sudo for the SSH user.",
            file=sys.stderr,
        )
        return 1

    stage = Path(tempfile.mkdtemp())
    try:
        shutil.copytree(os_provision_dir / "scripts", stage / "scripts")
        (stage / "state").mkdir(parents=True, exist_ok=True)

        for step, plugin_root in zip(steps, step_roots, strict=False):
            target = stage / "scripts" / "steps" / Path(step).name
            os_source = os_provision_dir / "scripts" / "steps" / step
            plugin_source = Path(plugin_root) / step
            if os_source.is_file():
                source = os_source
            elif plugin_source.is_file():
                source = plugin_source
            else:
                print(f"package-provision: install step not found: {step}", file=sys.stderr)
                return 2
            shutil.copy2(source, target)

        (stage / "state" / "bundle_packages").write_text(
            "".join(m + "\n" for m in package_markers)
        )
        (stage / "state" / "selected_packages").write_text(
            bundle_packages.replace(",", "\n") + "\n"
        )

        host_tz = os.environ.get("TIMEZONE", "")
        if not host_tz:
            tz_result = subprocess.run(
                [str(ROOT / "scripts/host-timezone")],
                capture_output=True, text=True, check=False,
            )
            host_tz = tz_result.stdout.strip() if tz_result.returncode == 0 else ""

        # Stage package type:path config files (local installers/bundles) onto
        # the remote and rewrite each env var to its remote path — generic, so
        # core names no package. (local_path, remote_rel_dir); uploaded below.
        stage_files: list[tuple[str, str]] = []
        for stage_var in ConfigEnv.package_stage_env_names():
            local_path = os.environ.get(stage_var, "")
            if not local_path:
                continue
            if not Path(local_path).exists():
                print(f"package-provision: {stage_var} does not exist: {local_path}", file=sys.stderr)
                return 2
            remote_rel = f"provision/downloads/{stage_var.lower()}"
            os.environ[stage_var] = f"$HOME/{remote_rel}/{Path(local_path).name}"
            stage_files.append((local_path, remote_rel))

        # Core (non-plugin) provision env; plugin env appended generically below
        # so core names no provider or package (v4.4 §15.5).
        env_lines = [
            _env_line("ACCESS_BOOTSTRAP_USER", resolved.get("ACCESS_BOOTSTRAP_USER", "")),
            _env_line("ACCESS_HUMAN_USER", resolved.get("ACCESS_HUMAN_USER", "")),
            _env_line("ACCESS_PROVISION_USER", resolved.get("ACCESS_PROVISION_USER", "")),
            _env_line("OS_FAMILY", os_family),
            _env_line("PROFILE_NAME", profile_name),
            _env_line("HUMAN_USER_NAME", resolved.get("HUMAN_USER_NAME", "")),
            _env_line("PROVISION_USER_NAME", resolved.get("PROVISION_USER_NAME", "")),
            _env_line("VM_USER_NAME", resolved.get("VM_USER_NAME", "")),
            _env_line("VM_USER_PASSWORD", os.environ.get("VM_USER_PASSWORD", "")),
            _env_line("EPHEMERAL_DISPLAY_RESOLUTION", os.environ.get("EPHEMERAL_DISPLAY_RESOLUTION", "")),
            _env_line("EPHEMERAL_DISPLAY_FPS", os.environ.get("EPHEMERAL_DISPLAY_FPS", "")),
            _env_line("PROVIDER", provider),
            _env_line("TIMEZONE", host_tz),
            _env_line("VIRTUAL_MONITOR_WIDTH", os.environ.get("VIRTUAL_MONITOR_WIDTH", "1920")),
            _env_line("VIRTUAL_MONITOR_HEIGHT", os.environ.get("VIRTUAL_MONITOR_HEIGHT", "1080")),
        ]
        # Per-instance package option overrides (§16): instance scope wins over
        # the user-scope config-env in os.environ before the generic plugin loop
        # reads it. Field→env_var mapping comes from each package manifest.
        os.environ.update(ConfigEnv.instance_package_env(instance_package_config(instance_name)))
        env_lines += [
            _env_line(_name, os.environ.get(_name, ""))
            for _name in ConfigEnv.plugin_provision_env_names()
        ]
        (stage / "state" / "env").write_text("\n".join(env_lines) + "\n")

        print(f"[package-provision] uploading {os_provision_dir} scripts for package={package}")
        uploads: list[tuple[str, list[str]]] = [(
            "prepare linux package provision directory",
            [ssh, instance_name, "--",
             "rm -rf ~/provision/scripts && mkdir -p ~/provision/state ~/provision/logs ~/provision/downloads"],
        )]
        for local_path, remote_rel in stage_files:
            uploads.append((
                f"prepare {remote_rel}",
                [ssh, instance_name, "--",
                 f"rm -rf ~/{remote_rel} && mkdir -p ~/{remote_rel}"],
            ))
            uploads.append((
                f"upload {Path(local_path).name}",
                [ssh, instance_name, "--scp", local_path, remote_rel],
            ))
        uploads.extend([
            ("upload linux package scripts",
             [ssh, instance_name, "--scp", str(stage / "scripts"), "provision/"]),
            ("upload linux package bundle list",
             [ssh, instance_name, "--scp", str(stage / "state" / "bundle_packages"), "provision/state/"]),
            ("upload linux selected package list",
             [ssh, instance_name, "--scp", str(stage / "state" / "selected_packages"), "provision/state/"]),
            ("upload linux package environment",
             [ssh, instance_name, "--scp", str(stage / "state" / "env"), "provision/state/"]),
        ])
        for label, cmd in uploads:
            status = _ssh_retry(label, cmd)
            if status != 0:
                return status

        remote_steps = "".join(f" ~/provision/scripts/steps/{Path(s).name}" for s in steps)
        print(f"[package-provision] running package={package} steps:{remote_steps}")
        remote_cmd = (
            'set -e; export PROVISION_ROOT="$HOME/provision"; '
            '. "$HOME/provision/state/env"; '
            "chmod +x ~/provision/scripts/steps/*.sh ~/provision/scripts/lib/*.sh; "
            f"for step in{remote_steps}; do "
            'echo "[package-provision] running $(basename "$step")"; '
            '/usr/bin/env bash "$step"; done'
        )
        return subprocess.run([ssh, instance_name, "--", remote_cmd]).returncode
    finally:
        shutil.rmtree(stage, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
