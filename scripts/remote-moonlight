#!/usr/bin/env bash
# Start a Moonlight stream to the instance.
set -euo pipefail

PROFILE="${1:?Usage: scripts/remote-moonlight <profile>}"
cd "$(git rev-parse --show-toplevel)"

PKGS=$(./scripts/profile-resolve --profile "$PROFILE" --emit env | awk -F= '/^BUNDLE_PACKAGES/{print $2}')
echo "$PKGS" | tr ',' '\n' | grep -qx sunshine || { echo "sunshine not in bundle — skipping"; exit 0; }

IP=$(./scripts/instance-ip "$PROFILE")

EXTRA_ARGS=()
if [ -n "${EPHEMERAL_DISPLAY_RESOLUTION:-}" ]; then
  EXTRA_ARGS+=(--resolution "$EPHEMERAL_DISPLAY_RESOLUTION")
fi

exec /Applications/Moonlight.app/Contents/MacOS/Moonlight stream --game-optimization "${EXTRA_ARGS[@]}" "$IP" "Desktop"
