#!/usr/bin/env python3
"""Start a Moonlight stream to the instance.

Usage: scripts/remote-moonlight <instance>
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    exec_replace,
    has_package,
    instance_ip,
    moonlight_stream_command,
    repo_root,
    resolve_env,
)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/remote-moonlight <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    resolved = resolve_env(root, profile)
    if not has_package(resolved, "sunshine"):
        print("sunshine not in bundle — skipping")
        return 0
    ip = instance_ip(root, profile)
    exec_replace(moonlight_stream_command(ip))
    return 0  # unreachable


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
