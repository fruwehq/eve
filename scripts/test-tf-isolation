#!/usr/bin/env bash
# Verify per-instance Terraform state isolation:
#   - tf-env emits TF_WORKSPACE and per-instance Terraform roots only when
#     EGAME_INSTANCE_NAME is set.
#   - tf-init schedules per-instance backend config plus a
#     `workspace select -or-create <instance>` step in instance mode and skips
#     it in PROFILE= mode.
#   - Two different instance names produce two different workspace names and
#     backend paths.
# Uses tf-init's EGAME_TF_PRINT=1 mode so no real terraform/terramate runs.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# tf-env requires SSH_PUBLIC_KEY_FILE to exist for terraform-engine profiles.
TMPKEY=$(mktemp)
printf 'ssh-rsa AAAAB3NzaC1yc2EAAAA_test_only test@test\n' > "$TMPKEY"
TMPWORK=$(mktemp -d)
TMPSTATE=$(mktemp -d)
TMPCATALOG_DIR=$(mktemp -d "${TMPDIR:-/tmp}/egame-tf-profile.XXXXXX")
TMPCATALOG="$TMPCATALOG_DIR/catalog.local.yaml"
trap 'rm -f "$TMPKEY"; rm -rf "$TMPWORK" "$TMPSTATE" "$TMPCATALOG_DIR"' EXIT
cat >"$TMPCATALOG" <<'YAML'
profiles:
  - name: aws-ubuntu-dev-headless
    machine: aws-cheap-x86
    os: ubuntu-26.04-amd64
    init: ssh-ubuntu-cloud-init
    bundles: [dev-ai]
    location: tokyo
YAML
export SSH_PUBLIC_KEY_FILE="$TMPKEY"
export EGAME_CATALOG_LOCAL="$TMPCATALOG"
export EGAME_INSTANCE_REGISTRY="tests/fixtures/instances.yaml"
export EGAME_INSTANCE_WORKDIR="$TMPWORK/work"
export EGAME_STATE_DIR="$TMPSTATE/state"

PROFILE="aws-ubuntu-dev-headless"
FAIL=0

# 1. tf-env without instance: no TF_WORKSPACE export.
env_profile_only=$(unset EGAME_INSTANCE_NAME; ./scripts/tf-env "$PROFILE")
if printf '%s\n' "$env_profile_only" | grep -q 'TF_WORKSPACE'; then
  printf '  [FAIL] tf-env emitted TF_WORKSPACE in PROFILE= mode\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] tf-env omits TF_WORKSPACE without EGAME_INSTANCE_NAME\n'
fi

# 2. tf-env with instance: emits TF_WORKSPACE.
env_instance=$(EGAME_INSTANCE_NAME=aws-gpu-a ./scripts/tf-env "$PROFILE")
if printf '%s\n' "$env_instance" | grep -qE "^export TF_WORKSPACE='aws-gpu-a';\$" &&
  printf '%s\n' "$env_instance" | grep -qE "^export EGAME_TF_DATA_BASE='$TMPWORK/work/aws-gpu-a/tf/data';\$" &&
  printf '%s\n' "$env_instance" | grep -qE "^export EGAME_TF_STATE_BASE='$TMPWORK/work/aws-gpu-a/tf/state';\$"; then
  printf '  [OK] tf-env emits isolated Terraform env for EGAME_INSTANCE_NAME=aws-gpu-a\n'
else
  printf '  [FAIL] tf-env did not emit expected isolated Terraform exports\n' >&2
  printf '%s\n' "$env_instance" >&2
  FAIL=$((FAIL + 1))
fi

# 3. tf-init in print mode without instance: no workspace step.
init_profile=$(EGAME_TF_PRINT=1 ./scripts/tf-init "$PROFILE" 2>&1)
if printf '%s\n' "$init_profile" | grep -q 'terraform init -reconfigure' &&
  ! printf '%s\n' "$init_profile" | grep -q 'terraform workspace'; then
  printf '  [OK] tf-init skips workspace step in PROFILE= mode\n'
else
  printf '  [FAIL] tf-init PROFILE= output unexpected\n' >&2
  printf '%s\n' "$init_profile" >&2
  FAIL=$((FAIL + 1))
fi

# 4. tf-init in print mode with instance: includes workspace step naming the instance.
init_a=$(EGAME_TF_PRINT=1 EGAME_INSTANCE_NAME=aws-gpu-a ./scripts/tf-init "$PROFILE" 2>&1)
if printf '%s\n' "$init_a" | grep -q 'terraform init -reconfigure' &&
  printf '%s\n' "$init_a" | grep -q "backend-config=path=$TMPWORK/work/aws-gpu-a/tf/state" &&
  printf '%s\n' "$init_a" | grep -q "backend-config=workspace_dir=$TMPWORK/work/aws-gpu-a/tf/state" &&
  printf '%s\n' "$init_a" | grep -q "terraform workspace select -or-create aws-gpu-a"; then
  printf '  [OK] tf-init schedules isolated backend and workspace for instance aws-gpu-a\n'
else
  printf '  [FAIL] tf-init instance-mode output missing isolated backend/workspace setup\n' >&2
  printf '%s\n' "$init_a" >&2
  FAIL=$((FAIL + 1))
fi

# 5. Two different instances → two different workspace names and backend roots.
init_b=$(EGAME_TF_PRINT=1 EGAME_INSTANCE_NAME=truenas-all-a ./scripts/tf-init "$PROFILE" 2>&1)
if printf '%s\n' "$init_b" | grep -q "terraform workspace select -or-create truenas-all-a" &&
  printf '%s\n' "$init_b" | grep -q "backend-config=path=$TMPWORK/work/truenas-all-a/tf/state" &&
  ! printf '%s\n' "$init_b" | grep -q "backend-config=path=$TMPWORK/work/aws-gpu-a/tf/state" &&
  ! printf '%s\n' "$init_b" | grep -q "terraform workspace select -or-create aws-gpu-a"; then
  printf '  [OK] distinct instance names produce distinct Terraform roots\n'
else
  printf '  [FAIL] second instance did not produce distinct Terraform roots\n' >&2
  printf '%s\n' "$init_b" >&2
  FAIL=$((FAIL + 1))
fi

[ "$FAIL" -eq 0 ]
