#!/usr/bin/env python3
# ruff: noqa: E501
"""Verify per-instance Terraform state isolation.

Uses tf-init's EVE_TF_PRINT=1 mode so no real terraform/terramate runs.
"""

from __future__ import annotations

import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    tmpkey = tempfile.NamedTemporaryFile(mode="w", suffix="_key", delete=False)  # noqa: SIM115
    tmpkey.write("ssh-rsa AAAAB3NzaC1yc2EAAAA_test_only test@test\n")
    tmpkey.close()

    tmpwork = tempfile.mkdtemp()
    tmpstate = tempfile.mkdtemp()
    tmpcatalog_dir = tempfile.mkdtemp(prefix="eve-tf-profile.")
    tmpcatalog = Path(tmpcatalog_dir) / "catalog.local.yaml"
    tmpcatalog.write_text(
        "profiles:\n"
        "  - name: aws-ubuntu-dev-headless\n"
        "    machine: aws-cheap-x86\n"
        "    os: ubuntu-26.04-amd64\n"
        "    init: ssh-ubuntu-cloud-init\n"
        "    bundles: [dev-ai]\n"
        "    location: tokyo\n",
        encoding="utf-8",
    )

    import shutil
    try:
        env = {
            **os.environ,
            "SSH_PUBLIC_KEY_FILE": tmpkey.name,
            "EVE_CATALOG_LOCAL": str(tmpcatalog),
            "EVE_INSTANCE_REGISTRY": "tests/fixtures/instances.yaml",
            "EVE_INSTANCE_WORKDIR": f"{tmpwork}/work",
            "EVE_STATE_DIR": f"{tmpstate}/state",
            "VM_USER_NAME": "eve-test",
        }
        profile = "aws-ubuntu-dev-headless"
        fail = 0

        def _run_with_files(cmd, e):
            """Run a subprocess, capturing output via temp files (avoids pipe-deadlock
            when grandchild processes inherit stdout/stderr FDs)."""
            with tempfile.NamedTemporaryFile(mode="w+") as outf, tempfile.NamedTemporaryFile(mode="w+") as errf:
                subprocess.run(
                    cmd, cwd=str(ROOT), env=e,
                    stdout=outf, stderr=errf, stdin=subprocess.DEVNULL,
                    start_new_session=True, check=False,
                )
                outf.seek(0)
                errf.seek(0)
                return outf.read() + errf.read()

        def run_tf_env(extra_env=None, profile_arg=None):
            e = {**env, **(extra_env or {})}
            if not (extra_env and "EVE_INSTANCE_NAME" in extra_env):
                e.pop("EVE_INSTANCE_NAME", None)
            return _run_with_files(
                [sys.executable, str(ROOT / "scripts/tf-env"), profile_arg or profile], e,
            )

        def run_tf_init(extra_env=None):
            e = {**env, "EVE_TF_PRINT": "1", **(extra_env or {})}
            if not (extra_env and "EVE_INSTANCE_NAME" in extra_env):
                e.pop("EVE_INSTANCE_NAME", None)
            return _run_with_files(
                [sys.executable, str(ROOT / "scripts/tf-init"), profile], e,
            )

        # 1. tf-env without instance: no TF_WORKSPACE export.
        out = run_tf_env()
        if "TF_WORKSPACE" in out:
            print("  [FAIL] tf-env emitted TF_WORKSPACE in PROFILE= mode", file=sys.stderr)
            fail += 1
        else:
            print("  [OK] tf-env omits TF_WORKSPACE without EVE_INSTANCE_NAME")

        # 2. tf-env with instance: emits TF_WORKSPACE.
        out = run_tf_env({"EVE_INSTANCE_NAME": "aws-gpu-a"})
        if (re.search(r"^export TF_WORKSPACE='aws-gpu-a';$", out, re.M) and
            f"export EVE_TF_DATA_BASE='{tmpwork}/work/aws-gpu-a/tf/data';" in out and
            f"export EVE_TF_STATE_BASE='{tmpwork}/work/aws-gpu-a/tf/state';" in out):
            print("  [OK] tf-env emits isolated Terraform env for EVE_INSTANCE_NAME=aws-gpu-a")
        else:
            print("  [FAIL] tf-env did not emit expected isolated Terraform exports", file=sys.stderr)
            print(out, file=sys.stderr)
            fail += 1

        # 3. tf-init in print mode without instance: no workspace step.
        out = run_tf_init()
        if "terraform init -reconfigure" in out and "terraform workspace" not in out:
            print("  [OK] tf-init skips workspace step in PROFILE= mode")
        else:
            print("  [FAIL] tf-init PROFILE= output unexpected", file=sys.stderr)
            print(out, file=sys.stderr)
            fail += 1

        # 4. tf-init with instance: includes workspace step.
        out = run_tf_init({"EVE_INSTANCE_NAME": "aws-gpu-a"})
        if ("terraform init -reconfigure" in out and
            f"backend-config=path={tmpwork}/work/aws-gpu-a/tf/state" in out and
            f"backend-config=workspace_dir={tmpwork}/work/aws-gpu-a/tf/state" in out and
            "terraform workspace select -or-create aws-gpu-a" in out):
            print("  [OK] tf-init schedules isolated backend and workspace for instance aws-gpu-a")
        else:
            print("  [FAIL] tf-init instance-mode output missing isolated backend/workspace setup", file=sys.stderr)
            print(out, file=sys.stderr)
            fail += 1

        # 5. Two different instances → different workspace names.
        out_b = run_tf_init({"EVE_INSTANCE_NAME": "truenas-all-a"})
        if ("terraform workspace select -or-create truenas-all-a" in out_b and
            f"backend-config=path={tmpwork}/work/truenas-all-a/tf/state" in out_b and
            f"backend-config=path={tmpwork}/work/aws-gpu-a/tf/state" not in out_b and
            "terraform workspace select -or-create aws-gpu-a" not in out_b):
            print("  [OK] distinct instance names produce distinct Terraform roots")
        else:
            print("  [FAIL] second instance did not produce distinct Terraform roots", file=sys.stderr)
            print(out_b, file=sys.stderr)
            fail += 1

        # 6. Path normalization.
        norm_expected = f"{os.environ['HOME']}/foo"
        for norm_val in ["~/foo", "$HOME/foo", "$(HOME)/foo"]:
            e = {**env, "SSH_PUBLIC_KEY_FILE": norm_val, "EVE_RUNTIME_ENV_LOADED": "1"}
            e.pop("EVE_INSTANCE_NAME", None)
            norm_out = _run_with_files(
                [sys.executable, str(ROOT / "scripts/tf-env"), profile], e,
            )
            m = re.search(r"^export TF_VAR_ssh_public_key_file='(.*)';$", norm_out, re.M)
            norm_actual = m.group(1) if m else ""
            if norm_actual == norm_expected:
                print(f"  [OK] tf-env normalizes SSH_PUBLIC_KEY_FILE={norm_val} to {norm_expected}")
            else:
                print(f"  [FAIL] tf-env SSH_PUBLIC_KEY_FILE={norm_val}: expected {norm_expected}, got {norm_actual}", file=sys.stderr)
                fail += 1

        # 7. tf-env preserves child exit status.
        e = {**env, "EVE_RUNTIME_ENV_LOADED": "1"}
        e.pop("EVE_INSTANCE_NAME", None)
        bad_rc = subprocess.run(
            [sys.executable, str(ROOT / "scripts/tf-env"), "definitely-not-a-profile"],
            cwd=str(ROOT), env=e, stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True, check=False,
        ).returncode
        if bad_rc == 5:
            print("  [OK] tf-env preserves profile-resolve exit status 5")
        else:
            print(f"  [FAIL] tf-env exit status: expected 5, got {bad_rc}", file=sys.stderr)
            fail += 1

        return 1 if fail else 0
    finally:
        Path(tmpkey.name).unlink(missing_ok=True)
        shutil.rmtree(tmpwork, ignore_errors=True)
        shutil.rmtree(tmpstate, ignore_errors=True)
        shutil.rmtree(tmpcatalog_dir, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
