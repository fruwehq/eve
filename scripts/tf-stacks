#!/usr/bin/env python3
"""Terraform/Terramate stack helpers for the core ``stacks/`` tree.

Usage:
  scripts/tf-stacks generate     # terramate generate
  scripts/tf-stacks fmt          # terramate fmt (format in place)
  scripts/tf-stacks init         # generate, then terraform init across stacks
  scripts/tf-stacks clean        # remove generated terraform files and cache

TM_PARALLEL controls init parallelism (default 8).
"""

from __future__ import annotations

import os
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def _run(cmd: list[str]) -> int:
    return subprocess.run(cmd, cwd=ROOT, check=False).returncode


def _clean() -> int:
    stacks = ROOT / "stacks"
    if stacks.is_dir():
        for path in stacks.rglob(".terraform"):
            if path.is_dir():
                shutil.rmtree(path, ignore_errors=True)
        for pattern in (".terraform.lock.hcl", "z_*.tf"):
            for path in stacks.rglob(pattern):
                if path.is_file():
                    path.unlink()
    for sub in ("data", "plugins", "state"):
        cache = ROOT / ".terraform-cache-dir" / sub
        if cache.is_dir():
            for child in cache.iterdir():
                if child.is_dir():
                    shutil.rmtree(child, ignore_errors=True)
                else:
                    child.unlink()
    return 0


def main(argv: list[str]) -> int:
    command = argv[0] if argv else ""
    parallel = os.environ.get("TM_PARALLEL", "8")
    if command == "generate":
        return _run(["terramate", "generate"])
    if command in ("fmt", "lint"):
        return _run(["terramate", "fmt"])
    if command == "init":
        return _run(["terramate", "generate"]) or _run(
            ["terramate", "run", "--parallel", parallel, "--continue-on-error", "--", "terraform", "init", "-upgrade"]
        )
    if command == "clean":
        return _clean()
    print("Usage: scripts/tf-stacks generate|fmt|init|clean", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
