#!/usr/bin/env python3
"""Package command dispatcher (install / status / down / reinstall).

Thin cold wrapper around ``eve_sdk.package_dispatch.dispatch_package`` — the
same in-process orchestration the warm Engine uses. This script parses fresh
per invocation (``plugins=None, catalog=None``); the Engine passes its memoized
sets so a multi-op session parses catalog/plugins exactly once.
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.package_dispatch import dispatch_package  # noqa: E402


def usage() -> None:
    print(
        "Usage:\n"
        "  scripts/package-dispatch --instance <name> --package <id> "
        "--command install|status|down|reinstall [--registry <path>] [--dry-run] [--yes]",
        file=sys.stderr,
    )


def parse_args(argv: list[str]) -> tuple[str, str, str, str | None, bool, bool]:
    instance_name: str | None = None
    package_id: str | None = None
    command: str | None = None
    registry_path = __import__("os").environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else None
    dry_run = False
    yes = False

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--package" and args:
            package_id = args.pop(0)
        elif arg == "--command" and args:
            command = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg == "--dry-run":
            dry_run = True
        elif arg == "--yes":
            yes = True
        elif arg in {"-h", "--help"}:
            usage()
            raise SystemExit(0)
        else:
            usage()
            raise SystemExit(2)

    if not instance_name or not package_id or not command:
        usage()
        raise SystemExit(2)
    if command not in {"install", "status", "down", "reinstall"}:
        print(f"package-dispatch: unsupported command: {command}", file=sys.stderr)
        raise SystemExit(2)
    return instance_name, package_id, command, registry_path, dry_run, yes


def main(argv: list[str]) -> int:
    instance_name, package_id, command, registry_path, dry_run, yes = parse_args(argv)
    return dispatch_package(
        instance_name,
        package_id,
        command,
        registry_path=registry_path,
        dry_run=dry_run,
        yes=yes,
    )


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
