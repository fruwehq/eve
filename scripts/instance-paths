#!/usr/bin/env ruby
# Resolve instance-scoped filesystem paths (workdir, state, tf subdir).
#
# This is the single source of truth for where per-instance artifacts live.
# It does not create any directories — that is the consumer's responsibility.
# It honors the same env overrides the rest of the v3 scripts already use:
#   EVE_INSTANCE_WORKDIR — base dir for generated per-instance workdirs
#   EVE_STATE_DIR        — base dir for instance state JSON files
#   EVE_INSTANCE_REGISTRY — alternative registry path

require "json"
require "yaml"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"
DEFAULT_REGISTRY_PATH = Eve::SDK::Workdir.instance_registry_path

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-paths --instance <name> [--emit env|json] [--registry <path>]
  USAGE
end

def load_registry(path)
  return {} unless File.exist?(path)

  YAML.safe_load(File.read(path), permitted_classes: [], aliases: true) || {}
end

def absolute(path)
  File.expand_path(path, Dir.pwd)
end

def emit_env(paths)
  paths.each { |key, value| puts "#{key}=#{value}" }
end

instance_name = nil
emit = "env"
registry_path = ENV["EVE_INSTANCE_REGISTRY"] && !ENV["EVE_INSTANCE_REGISTRY"].empty? \
                ? absolute(ENV["EVE_INSTANCE_REGISTRY"]) \
                : DEFAULT_REGISTRY_PATH

args = ARGV.dup
until args.empty?
  case args.shift
  when "--instance"
    instance_name = args.shift
  when "--emit"
    emit = args.shift
  when "--registry"
    registry_path = absolute(args.shift)
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless instance_name && !instance_name.empty?
  usage
  exit 2
end

if instance_name !~ /\A[A-Za-z0-9][A-Za-z0-9._-]*\z/
  warn "instance-paths: invalid instance name: #{instance_name.inspect}"
  exit 1
end

registry = load_registry(registry_path)
instance = (registry["instances"] || []).find { |entry| entry.is_a?(Hash) && entry["name"] == instance_name }
unless instance
  warn "instance-paths: instance not found: #{instance_name} (registry: #{registry_path})"
  exit 1
end

paths = Eve::SDK::Workdir.all_paths(instance_name)

case emit
when "env"
  emit_env(paths)
when "json"
  puts JSON.pretty_generate(paths)
else
  warn "instance-paths: unsupported --emit format: #{emit}"
  exit 2
end
