#!/usr/bin/env python3
"""Resolve instance-scoped filesystem paths."""

from __future__ import annotations

import argparse
import json
import os
import re
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir


def absolute(path: str) -> Path:
    return Path(os.path.abspath(os.path.expanduser(path)))


def load_registry(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    loaded = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    if not isinstance(loaded, dict):
        raise ValueError(f"{path}: expected a mapping")
    return loaded


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/instance-paths",
        usage="scripts/instance-paths --instance <name> [--emit env|json] [--registry <path>]",
        add_help=True,
    )
    arg_parser.add_argument("--instance", required=True)
    arg_parser.add_argument("--emit", choices=["env", "json"], default="env")
    arg_parser.add_argument("--registry")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    instance_name = args.instance
    if not re.match(r"^[A-Za-z0-9][A-Za-z0-9._-]*$", instance_name):
        print(f"instance-paths: invalid instance name: {instance_name!r}", file=sys.stderr)
        return 1

    registry_path = absolute(args.registry) if args.registry else Workdir.instance_registry_path()
    try:
        registry = load_registry(registry_path)
    except Exception as error:
        print(f"instance-paths: {error}", file=sys.stderr)
        return 1

    instances = registry.get("instances", [])
    instance = next(
        (entry for entry in instances if isinstance(entry, dict) and entry.get("name") == instance_name),
        None,
    )
    if instance is None:
        print(f"instance-paths: instance not found: {instance_name} (registry: {registry_path})", file=sys.stderr)
        return 1

    paths = Workdir.all_paths(instance_name)
    if args.emit == "json":
        print(json.dumps(paths, indent=2))
    else:
        for key, value in paths.items():
            print(f"{key}={value}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
