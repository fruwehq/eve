#!/usr/bin/env ruby
# tf-env: emit TF_VAR_* exports for a profile, gated by provider.
# Usage: scripts/tf-env <profile>
#
# Emits shell-compatible "export KEY='value';" lines suitable for eval.
# Preserves the same CLI, env output format, behavior, and exit codes as the
# original sh implementation.

require "open3"

ROOT = File.expand_path("..", __dir__)

def usage
  warn "usage: scripts/tf-env <profile>"
  exit 2
end

profile = ARGV[0]
usage if profile.nil? || profile.empty?

Dir.chdir(ROOT)

def run_cmd(*args)
  out, status = Open3.capture2(*args)
  return out.strip if status.success?
  warn "tf-env: command failed: #{args.join(' ')}"
  exit status.exitstatus || 1
end

if ENV["EGAME_RUNTIME_ENV_LOADED"] != "1"
  loader = File.join(ROOT, "scripts/lib/load-runtime-env.sh")
  out, err, status = Open3.capture3(
    "sh",
    "-eu",
    "-c",
    '. "$1" && env -0',
    "tf-env-loader",
    loader,
  )
  unless status.success?
    warn "tf-env: runtime env loader failed:"
    warn err unless err.strip.empty?
    exit status.exitstatus || 1
  end
  out.split("\0").each do |entry|
    idx = entry.index("=")
    next unless idx
    key = entry[0...idx]
    val = entry[(idx + 1)..]
    ENV[key] = val
  end
end

resolved_env_raw = run_cmd("./scripts/profile-resolve", "--profile", profile, "--emit", "env")

env = {}
resolved_env_raw.each_line do |line|
  line.chomp!
  idx = line.index("=")
  next unless idx
  key = line[0...idx]
  val = line[(idx + 1)..]
  env[key] = val
end

provider = env["PROVIDER"]
os_family = env["OS_FAMILY"]
ssh_user = env["SSH_USER"]
vm_user_name = env["VM_USER_NAME"]

if os_family != "windows" && (ssh_user.nil? || ssh_user.empty?)
  warn "tf-env: missing VM_USER_NAME for #{profile} (#{os_family})"
  exit 2
end
vm_user_name = ssh_user if vm_user_name.nil? || vm_user_name.empty?

def quote(value)
  "'" + value.gsub("'", "'\\''") + "'"
end

def print_kv(key, value)
  puts "export #{key}=#{quote(value)};"
end

def normalize_path(value)
  return value if value.nil? || value.empty?
  home = ENV["HOME"].to_s
  case value
  when "~"
    home
  when /\A~\// then home + value[1..]
  when "$HOME"
    home
  when /\A\$HOME\// then home + value[5..]
  when "$(HOME)"
    home
  when /\A\$\(HOME\)\// then home + value[7..]
  else value
  end
end

instance_name = ENV["EGAME_INSTANCE_NAME"]
unless instance_name.nil? || instance_name.empty?
  ip_args = ["./scripts/instance-paths", "--instance", instance_name, "--emit", "env"]
  registry = ENV["EGAME_INSTANCE_REGISTRY"]
  ip_args += ["--registry", registry] if registry && !registry.empty?
  instance_paths_raw = run_cmd(*ip_args)

  paths = {}
  instance_paths_raw.each_line do |line|
    line.chomp!
    idx = line.index("=")
    next unless idx
    key = line[0...idx]
    val = line[(idx + 1)..]
    paths[key] = val
  end

  print_kv("TF_WORKSPACE", instance_name)
  print_kv("EGAME_TF_DATA_BASE", paths["INSTANCE_TF_DATA_BASE"].to_s)
  print_kv("EGAME_TF_STATE_BASE", paths["INSTANCE_TF_STATE_BASE"].to_s)
end

print_kv("TF_VAR_bundle_packages", env["BUNDLE_PACKAGES"].to_s)
print_kv("TF_VAR_location_name", env["LOCATION_NAME"].to_s)
print_kv("TF_VAR_os_family", os_family.to_s)
print_kv("TF_VAR_os_id", env["OS_ID"].to_s)
print_kv("TF_VAR_profile_name", profile)
print_kv("TF_VAR_ssh_public_key_file", normalize_path(ENV["SSH_PUBLIC_KEY_FILE"].to_s))
print_kv("TF_VAR_vm_user_name", vm_user_name.to_s)

case provider
when "aws"
  print_kv("TF_VAR_availability_zone", env["LOCATION_AVAILABILITY_ZONE"].to_s)
  print_kv("TF_VAR_disk_gb", env["VM_DISK_GB"].to_s)
  print_kv("TF_VAR_instance_type", env["VM_INSTANCE_TYPE"].to_s)
  print_kv("TF_VAR_region", env["LOCATION_REGION"].to_s)
  print_kv("TF_VAR_root_volume_type", env["VM_ROOT_VOLUME_TYPE"].to_s)
when "gcp"
  project_id = ENV["GOOGLE_CLOUD_PROJECT"] || ENV["GOOGLE_PROJECT"] || ""
  if project_id.empty? && system("command -v gcloud >/dev/null 2>&1")
    out, status = Open3.capture2("gcloud config get-value project 2>/dev/null")
    project_id = out.strip if status.success?
  end
  if project_id.nil? || project_id.empty?
    warn "tf-env: missing GOOGLE_CLOUD_PROJECT or GOOGLE_PROJECT for gcp provider"
    exit 2
  end
  print_kv("TF_VAR_disk_gb", env["VM_DISK_GB"].to_s)
  print_kv("TF_VAR_disk_type", env["VM_DISK_TYPE"].to_s)
  print_kv("TF_VAR_image_family", env["GCP_IMAGE_FAMILY"].to_s)
  print_kv("TF_VAR_image_project", env["GCP_IMAGE_PROJECT"].to_s)
  print_kv("TF_VAR_machine_type", env["VM_MACHINE_TYPE"].to_s)
  print_kv("TF_VAR_project_id", project_id)
  print_kv("TF_VAR_region", env["LOCATION_REGION"].to_s)
  my_ip = ENV["MY_IP"].to_s
  if my_ip.empty?
    warn "tf-env: missing MY_IP for gcp provider"
    exit 2
  end
  print_kv("TF_VAR_ssh_allowed_cidr", "#{my_ip}/32")
  print_kv("TF_VAR_zone", env["LOCATION_ZONE"].to_s)
when "vultr"
  print_kv("TF_VAR_plan", env["VM_PLAN"].to_s)
  print_kv("TF_VAR_region", env["LOCATION_REGION"].to_s)
  print_kv("TF_VAR_vultr_os_id", env["VULTR_OS_ID"].to_s)
when "truenas"
  truenas_ssh_user_val = ENV["TRUENAS_SSH_USER"]
  if truenas_ssh_user_val.nil? || truenas_ssh_user_val.empty?
    warn "Error: required environment variable(s) not set:\n  - TRUENAS_SSH_USER\n\nSet them in .env.local (or your shell environment) and retry."
    exit 1
  end
  print_kv("TF_VAR_cloud_image_url", env["CLOUD_IMAGE_URL"].to_s)
  print_kv("TF_VAR_provision_user_name", ssh_user.to_s)
  print_kv("TF_VAR_truenas_host", env["TRUENAS_HOST"].to_s)
  print_kv("TF_VAR_truenas_ssh_host_key_fingerprint", ENV["TRUENAS_SSH_HOST_KEY_FINGERPRINT"].to_s)
  print_kv("TF_VAR_truenas_ssh_port", env["TRUENAS_SSH_PORT"].to_s)
  print_kv("TF_VAR_truenas_ssh_private_key_file", normalize_path(ENV["TRUENAS_SSH_PRIVATE_KEY_FILE"].to_s))
  print_kv("TF_VAR_truenas_ssh_user", env["TRUENAS_SSH_USER"].to_s)
  print_kv("TF_VAR_vm_autostart", env["VM_AUTOSTART"].to_s)
  print_kv("TF_VAR_vm_base_dir", ENV["TRUENAS_VM_BASE_DIR"].to_s)
  print_kv("TF_VAR_vm_cpu_cores", env["VM_CPU_CORES"].to_s)
  print_kv("TF_VAR_vm_cpu_mode", env["VM_CPU_MODE"].to_s)
  print_kv("TF_VAR_vm_disk_gb", env["VM_DISK_GB"].to_s)
  print_kv("TF_VAR_vm_memory_mb", env["VM_MEMORY_MB"].to_s)
  print_kv("TF_VAR_vm_nic_attach", env["VM_NIC_ATTACH"].to_s)
  print_kv("TF_VAR_vm_pool", ENV["TRUENAS_VM_POOL"].to_s)
  print_kv("TF_VAR_vm_state", env["VM_STATE"].to_s)
  print_kv("TF_VAR_vm_vcpus", env["VM_VCPUS"].to_s)
  print_kv("TF_VAR_vm_zvol_prefix", ENV["TRUENAS_VM_ZVOL_PREFIX"].to_s)
end
