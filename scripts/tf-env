#!/usr/bin/env ruby
# tf-env: emit TF_VAR_* exports for a profile, gated by provider.
# Usage: scripts/tf-env <instance>
#
# Emits shell-compatible "export KEY='value';" lines suitable for eval.
# Preserves the same CLI, env output format, behavior, and exit codes as the
# original sh implementation.

require "open3"
require "json"

ROOT = File.expand_path("..", __dir__)

def usage
  warn "usage: scripts/tf-env <instance>"
  exit 2
end

profile = ARGV[0]
usage if profile.nil? || profile.empty?

Dir.chdir(ROOT)

def run_cmd(*args)
  out, status = Open3.capture2(*args)
  return out.strip if status.success?
  warn "tf-env: command failed: #{args.join(' ')}"
  exit status.exitstatus || 1
end

def run_json(*args)
  out, status = Open3.capture2e(*args)
  raise out unless status.success?

  JSON.parse(out)
end

def command_vector(plugin, spec)
  exec_path = spec.fetch("exec")
  unless exec_path.start_with?("/")
    plugin_exec = File.join(File.dirname(plugin.fetch("path")), exec_path)
    root_exec = File.join(ROOT, exec_path)
    exec_path = File.exist?(plugin_exec) ? plugin_exec : root_exec
  end
  unless File.file?(exec_path) && File.executable?(exec_path)
    warn "tf-env: provider plugin #{plugin.fetch("id")} command is not executable: #{spec.fetch("exec")}"
    exit 1
  end
  [exec_path, *(spec["args"] || [])]
end

def provider_plugin_for(provider)
  plugin_doc = run_json(File.join(ROOT, "scripts/plugin-list"), "--kind", "provider", "--json")
  plugin_doc.fetch("plugins").find { |entry| entry["id"] == provider }
end

if ENV["EVE_RUNTIME_ENV_LOADED"] != "1"
  loader = File.join(ROOT, "scripts/lib/load-runtime-env.sh")
  out, err, status = Open3.capture3(
    "sh",
    "-eu",
    "-c",
    '. "$1" && env -0',
    "tf-env-loader",
    loader,
  )
  unless status.success?
    warn "tf-env: runtime env loader failed:"
    warn err unless err.strip.empty?
    exit status.exitstatus || 1
  end
  out.split("\0").each do |entry|
    idx = entry.index("=")
    next unless idx
    key = entry[0...idx]
    val = entry[(idx + 1)..]
    ENV[key] = val
  end
end

resolved_env_raw = run_cmd("./scripts/profile-resolve", "--profile", profile, "--emit", "env")

env = {}
resolved_env_raw.each_line do |line|
  line.chomp!
  idx = line.index("=")
  next unless idx
  key = line[0...idx]
  val = line[(idx + 1)..]
  env[key] = val
end

provider = env["PROVIDER"]
os_family = env["OS_FAMILY"]
ssh_user = env["SSH_USER"]
vm_user_name = env["VM_USER_NAME"]
vm_user_name = ssh_user if vm_user_name.nil? || vm_user_name.empty?

def quote(value)
  "'" + value.gsub("'", "'\\''") + "'"
end

def print_kv(key, value)
  puts "export #{key}=#{quote(value)};"
end

def print_provider_tf_env(provider, env)
  plugin = provider_plugin_for(provider)
  unless plugin
    warn "tf-env: provider plugin not found: #{provider}"
    exit 1
  end

  spec = plugin.fetch("commands")["tf-env"]
  unless spec
    warn "tf-env: provider plugin #{provider} has no tf-env command"
    exit 1
  end

  out, err, status = Open3.capture3({ "EVE_TF_ENV_JSON" => JSON.generate(env) }, *command_vector(plugin, spec), chdir: ROOT)
  print out
  return if status.success?

  warn err unless err.strip.empty?
  exit status.exitstatus || 1
end

def normalize_path(value)
  return value if value.nil? || value.empty?
  home = ENV["HOME"].to_s
  case value
  when "~"
    home
  when /\A~\// then home + value[1..]
  when "$HOME"
    home
  when /\A\$HOME\// then home + value[5..]
  when "$(HOME)"
    home
  when /\A\$\(HOME\)\// then home + value[7..]
  else value
  end
end

instance_name = ENV["EVE_INSTANCE_NAME"]
unless instance_name.nil? || instance_name.empty?
  ip_args = ["./scripts/instance-paths", "--instance", instance_name, "--emit", "env"]
  registry = ENV["EVE_INSTANCE_REGISTRY"]
  ip_args += ["--registry", registry] if registry && !registry.empty?
  instance_paths_raw = run_cmd(*ip_args)

  paths = {}
  instance_paths_raw.each_line do |line|
    line.chomp!
    idx = line.index("=")
    next unless idx
    key = line[0...idx]
    val = line[(idx + 1)..]
    paths[key] = val
  end

  print_kv("TF_WORKSPACE", instance_name)
  print_kv("EVE_TF_DATA_BASE", paths["INSTANCE_TF_DATA_BASE"].to_s)
  print_kv("EVE_TF_STATE_BASE", paths["INSTANCE_TF_STATE_BASE"].to_s)
end

print_kv("TF_VAR_bundle_packages", env["BUNDLE_PACKAGES"].to_s)
print_kv("TF_VAR_location_name", env["LOCATION_NAME"].to_s)
print_kv("TF_VAR_os_family", os_family.to_s)
print_kv("TF_VAR_os_id", env["OS_ID"].to_s)
print_kv("TF_VAR_profile_name", profile)
print_kv("TF_VAR_ssh_public_key_file", normalize_path(ENV["SSH_PUBLIC_KEY_FILE"].to_s))
print_kv("TF_VAR_vm_user_name", vm_user_name.to_s)
print_provider_tf_env(provider, env)
