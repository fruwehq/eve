#!/usr/bin/env sh
set -eu

PROFILE="${1:-}"

if [ -z "$PROFILE" ]; then
  echo "usage: scripts/tf-env <profile>" >&2
  exit 2
fi

RESOLVED_ENV="$(./scripts/profile-resolve --profile "$PROFILE" --emit env)"

getv() {
  printf '%s\n' "$RESOLVED_ENV" | awk -F= -v key="$1" '$1 == key { print substr($0, index($0, "=") + 1) }'
}

normalize_path() {
  value="$1"
  # shellcheck disable=SC2088,SC2016
  # The patterns below are deliberately unexpanded string literals we match against.
  case "$value" in
    '~'|'~/'*)
      printf '%s\n' "$HOME${value#\~}"
      ;;
    '$HOME'|'$HOME/'*)
      printf '%s\n' "$HOME${value#\$HOME}"
      ;;
    '$(HOME)'|'$(HOME)/'*)
      printf '%s\n' "$HOME${value#\$\(HOME\)}"
      ;;
    *)
      printf '%s\n' "$value"
      ;;
  esac
}

quote() {
  printf "%s" "$1" | sed "s/'/'\\''/g; 1s/^/'/; \$s/\$/'/"
}

print_kv() {
  key="$1"
  value="$2"
  printf 'export %s=%s;\n' "$key" "$(quote "$value")"
}

PROVIDER="$(getv PROVIDER)"
OS_FAMILY="$(getv OS_FAMILY)"
SSH_USER="$(getv SSH_USER)"
VM_USER_NAME_VALUE="$(getv VM_USER_NAME)"

if [ "$OS_FAMILY" != "windows" ] && [ -z "$SSH_USER" ]; then
  echo "tf-env: missing VM_USER_NAME for $PROFILE ($OS_FAMILY)" >&2
  exit 2
fi
if [ -z "$VM_USER_NAME_VALUE" ]; then
  VM_USER_NAME_VALUE="$SSH_USER"
fi

# Per-instance state isolation: when EGAME_INSTANCE_NAME is set the caller is
# in v3 INSTANCE= mode. Route Terraform to a dedicated workspace plus
# per-instance data/backend roots so two instances on the same provider do not
# clobber each other's state. PROFILE= callers leave EGAME_INSTANCE_NAME unset
# and continue to use the default compatibility paths.
if [ -n "${EGAME_INSTANCE_NAME:-}" ]; then
  if [ -n "${EGAME_INSTANCE_REGISTRY:-}" ]; then
    INSTANCE_PATHS="$(./scripts/instance-paths --instance "$EGAME_INSTANCE_NAME" --emit env --registry "$EGAME_INSTANCE_REGISTRY")"
  else
    INSTANCE_PATHS="$(./scripts/instance-paths --instance "$EGAME_INSTANCE_NAME" --emit env)"
  fi
  getp() {
    printf '%s\n' "$INSTANCE_PATHS" | awk -F= -v key="$1" '$1 == key { print substr($0, index($0, "=") + 1) }'
  }

  print_kv TF_WORKSPACE "$EGAME_INSTANCE_NAME"
  print_kv EGAME_TF_DATA_BASE "$(getp INSTANCE_TF_DATA_BASE)"
  print_kv EGAME_TF_STATE_BASE "$(getp INSTANCE_TF_STATE_BASE)"
fi

# Common — shared by every terraform-based provider
print_kv TF_VAR_bundle_packages "$(getv BUNDLE_PACKAGES)"
print_kv TF_VAR_location_name "$(getv LOCATION_NAME)"
print_kv TF_VAR_os_family "$OS_FAMILY"
print_kv TF_VAR_os_id "$(getv OS_ID)"
print_kv TF_VAR_profile_name "$PROFILE"
print_kv TF_VAR_ssh_public_key_file "$(normalize_path "${SSH_PUBLIC_KEY_FILE:-}")"
print_kv TF_VAR_vm_user_name "$VM_USER_NAME_VALUE"

case "$PROVIDER" in
  aws)
    print_kv TF_VAR_availability_zone "$(getv LOCATION_AVAILABILITY_ZONE)"
    print_kv TF_VAR_disk_gb "$(getv VM_DISK_GB)"
    print_kv TF_VAR_instance_type "$(getv VM_INSTANCE_TYPE)"
    print_kv TF_VAR_region "$(getv LOCATION_REGION)"
    print_kv TF_VAR_root_volume_type "$(getv VM_ROOT_VOLUME_TYPE)"
    ;;
  gcp)
    PROJECT_ID="${GOOGLE_CLOUD_PROJECT:-${GOOGLE_PROJECT:-}}"
    if [ -z "$PROJECT_ID" ] && command -v gcloud >/dev/null 2>&1; then
      PROJECT_ID="$(gcloud config get-value project 2>/dev/null || true)"
    fi
    if [ -z "$PROJECT_ID" ]; then
      echo "tf-env: missing GOOGLE_CLOUD_PROJECT or GOOGLE_PROJECT for gcp provider" >&2
      exit 2
    fi
    print_kv TF_VAR_disk_gb "$(getv VM_DISK_GB)"
    print_kv TF_VAR_disk_type "$(getv VM_DISK_TYPE)"
    print_kv TF_VAR_image_family "$(getv GCP_IMAGE_FAMILY)"
    print_kv TF_VAR_image_project "$(getv GCP_IMAGE_PROJECT)"
    print_kv TF_VAR_machine_type "$(getv VM_MACHINE_TYPE)"
    print_kv TF_VAR_project_id "$PROJECT_ID"
    print_kv TF_VAR_region "$(getv LOCATION_REGION)"
    print_kv TF_VAR_ssh_allowed_cidr "${MY_IP}/32"
    print_kv TF_VAR_zone "$(getv LOCATION_ZONE)"
    ;;
  vultr)
    print_kv TF_VAR_plan "$(getv VM_PLAN)"
    print_kv TF_VAR_region "$(getv LOCATION_REGION)"
    print_kv TF_VAR_vultr_os_id "$(getv VULTR_OS_ID)"
    ;;
  truenas)
    ./scripts/env-require TRUENAS_SSH_USER
    print_kv TF_VAR_cloud_image_url "$(getv CLOUD_IMAGE_URL)"
    print_kv TF_VAR_provision_user_name "$SSH_USER"
    print_kv TF_VAR_truenas_host "$(getv TRUENAS_HOST)"
    print_kv TF_VAR_truenas_ssh_host_key_fingerprint "${TRUENAS_SSH_HOST_KEY_FINGERPRINT:-}"
    print_kv TF_VAR_truenas_ssh_port "$(getv TRUENAS_SSH_PORT)"
    print_kv TF_VAR_truenas_ssh_private_key_file \
      "$(normalize_path "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}")"
    print_kv TF_VAR_truenas_ssh_user "$(getv TRUENAS_SSH_USER)"
    print_kv TF_VAR_vm_autostart "$(getv VM_AUTOSTART)"
    print_kv TF_VAR_vm_base_dir "${TRUENAS_VM_BASE_DIR:-}"
    print_kv TF_VAR_vm_cpu_cores "$(getv VM_CPU_CORES)"
    print_kv TF_VAR_vm_cpu_mode "$(getv VM_CPU_MODE)"
    print_kv TF_VAR_vm_disk_gb "$(getv VM_DISK_GB)"
    print_kv TF_VAR_vm_memory_mb "$(getv VM_MEMORY_MB)"
    print_kv TF_VAR_vm_nic_attach "$(getv VM_NIC_ATTACH)"
    print_kv TF_VAR_vm_pool "${TRUENAS_VM_POOL:-}"
    print_kv TF_VAR_vm_state "$(getv VM_STATE)"
    print_kv TF_VAR_vm_vcpus "$(getv VM_VCPUS)"
    print_kv TF_VAR_vm_zvol_prefix "${TRUENAS_VM_ZVOL_PREFIX:-}"
    ;;
esac
