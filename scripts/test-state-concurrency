#!/usr/bin/env ruby
# frozen_string_literal: true

# Concurrency regression test: 20 parallel writers against a single state file.
# Asserts the final state file is valid JSON and passes schema validation.
# State writes go through core/sdk/state.rb (sole state owner).

require "json"
require "tempfile"
require "fileutils"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"

WRITER_COUNT = 20
INSTANCE_NAME = "concurrency-test"

failures = 0

def pass(msg)
  puts "[OK]   #{msg}"
end

def fail_test(msg)
  puts "[FAIL] #{msg}"
  1
end

puts "\n== state-concurrency: #{WRITER_COUNT} parallel writers =="

begin
  tmpdir = Dir.mktmpdir("eve-state-test-")
  state_dir = File.join(tmpdir, "instances")
  FileUtils.mkdir_p(state_dir)

  ENV["EVE_STATE_DIR"] = tmpdir

  Eve::SDK::State.write(INSTANCE_NAME, Eve::SDK::State.default_state(INSTANCE_NAME, Time.now.utc.iso8601))

  children = WRITER_COUNT.times.map do |i|
    fork do
      begin
        Eve::SDK::State.record_operation(
          INSTANCE_NAME,
          "provider.status",
          i.even? ? "succeeded" : "failed",
          error: i.odd? ? "writer #{i} error" : nil,
          provider_state: i.even? ? "running" : "error"
        )
        exit 0
      rescue StandardError => e
        warn "writer #{i}: #{e.message}"
        exit 1
      end
    end
  end

  pids = children.map { |pid| Process.waitpid2(pid) }
  writer_failures = pids.count { |_pid, status| !status.success? }
  if writer_failures.positive?
    failures += fail_test "#{writer_failures}/#{WRITER_COUNT} writers failed"
  else
    pass "all #{WRITER_COUNT} writers completed"
  end

  path = Eve::SDK::Workdir.state_path(INSTANCE_NAME)
  raw = File.read(path)
  state = JSON.parse(raw)
  pass "final state is valid JSON"

  Eve::SDK::State.validate_state!(state)
  pass "final state passes schema validation"

  history = state.fetch("operation_history", [])
  if history.length == WRITER_COUNT
    pass "all #{WRITER_COUNT} operations recorded in history"
  else
    failures += fail_test "expected #{WRITER_COUNT} history entries, got #{history.length}"
  end

  expected_statuses = %w[succeeded failed]
  invalid = history.reject { |e| expected_statuses.include?(e["status"]) }
  if invalid.empty?
    pass "all history entries have valid status"
  else
    failures += fail_test "invalid history statuses: #{invalid.map { |e| e["status"] }.inspect}"
  end

  puts "\n  state dir: #{tmpdir}"
  puts "  state file: #{path}"
  puts "  history entries: #{history.length}"
ensure
  FileUtils.rm_rf(tmpdir) if tmpdir
  ENV.delete("EVE_STATE_DIR")
end

# ---------- Read validation ----------
puts "\n== state-validation: read rejects invalid on-disk state =="

begin
  tmpdir2 = Dir.mktmpdir("eve-state-read-test-")
  state_dir2 = File.join(tmpdir2, "instances")
  FileUtils.mkdir_p(state_dir2)
  ENV["EVE_STATE_DIR"] = tmpdir2

  valid = Eve::SDK::State.default_state("read-test", Time.now.utc.iso8601)
  valid["provider_state"] = "running"
  Eve::SDK::State.write("read-test", valid)
  read_back = Eve::SDK::State.read("read-test")
  if read_back["provider_state"] == "running"
    pass "valid state reads back correctly"
  else
    failures += fail_test "valid state read mismatch"
  end

  invalid_path = File.join(state_dir2, "corrupt.json")
  bad_state = valid.dup
  bad_state["provider_state"] = "not-a-real-state"
  File.write(invalid_path, JSON.pretty_generate(bad_state) + "\n")
  begin
    Eve::SDK::State.read("corrupt")
    failures += fail_test "read accepted schema-invalid on-disk state"
  rescue Eve::SDK::SchemaValidationError
    pass "read rejects schema-invalid on-disk state"
  end

  missing_path = File.join(state_dir2, "absent.json")
  default_read = Eve::SDK::State.read("absent")
  if default_read["instance"] == "absent" && default_read["provider_state"] == "unknown"
    pass "read returns defaults for nonexistent state file"
  else
    failures += fail_test "read default state shape mismatch"
  end
rescue StandardError => e
  failures += fail_test "read validation suite error: #{e.message}"
ensure
  FileUtils.rm_rf(tmpdir2) if tmpdir2
  ENV.delete("EVE_STATE_DIR")
end

# ---------- Write validation inside lock ----------
puts "\n== state-validation: write rejects invalid state before disk =="

begin
  tmpdir3 = Dir.mktmpdir("eve-state-write-test-")
  ENV["EVE_STATE_DIR"] = tmpdir3
  FileUtils.mkdir_p(File.join(tmpdir3, "instances"))

  valid = Eve::SDK::State.default_state("write-test", Time.now.utc.iso8601)
  valid["provider_state"] = "running"
  Eve::SDK::State.write("write-test", valid)
  pass "write accepts valid state"

  bad = valid.dup
  bad["provider_state"] = "not-a-real-state"
  begin
    Eve::SDK::State.write("write-test", bad)
    failures += fail_test "write accepted schema-invalid state"
  rescue Eve::SDK::SchemaValidationError
    pass "write rejects schema-invalid state"
  end

  path3 = Eve::SDK::Workdir.state_path("write-test")
  disk = JSON.parse(File.read(path3))
  if disk["provider_state"] == "running"
    pass "invalid state was not written to disk"
  else
    failures += fail_test "disk state was overwritten with invalid data"
  end
rescue StandardError => e
  failures += fail_test "write validation suite error: #{e.message}"
ensure
  FileUtils.rm_rf(tmpdir3) if tmpdir3
  ENV.delete("EVE_STATE_DIR")
end

if failures.positive?
  $stderr.puts "\n#{failures} check(s) failed."
  exit 1
end
puts "\nAll state checks passed."
