#!/usr/bin/env bash
set -euo pipefail

# Run terraform plan for a profile's stacks.
# Usage: scripts/tf-plan <profile>

PROFILE="${1:?Usage: scripts/tf-plan <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" != "terraform" ]; then
  echo "[tf-plan] not supported for engine=$ENGINE"
  exit 1
fi

TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
echo "[tf-plan] profile=$PROFILE tags=$TAGS"
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
if [ "$PROVIDER" = "gcp" ]; then
  PROJECT="${GOOGLE_CLOUD_PROJECT:-${GOOGLE_PROJECT:-}}"
  if [ -z "$PROJECT" ] && command -v gcloud >/dev/null 2>&1; then
    PROJECT="$(gcloud config get-value project 2>/dev/null || true)"
  fi
  REGION=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^LOCATION_REGION=/{print $2}')
  ZONE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^LOCATION_ZONE=/{print $2}')
  echo "[tf-plan] gcp project=$PROJECT region=$REGION zone=$ZONE"
fi

terramate generate

eval "$(./scripts/tf-env "$PROFILE")"

FAIL=0

echo "  === Shared infrastructure ==="
if ! terramate run --tags="$TAGS-shared" -- terraform plan; then
  echo "  [FAIL] Shared plan failed." >&2
  FAIL=1
fi

echo "  === Services ==="
if ! terramate run --tags="$TAGS-services" -- terraform plan; then
  echo "  [FAIL] Services plan failed. Apply shared first: make apply PROFILE=$PROFILE" >&2
  FAIL=1
fi

if [ "$FAIL" -ne 0 ]; then
  exit 1
fi
