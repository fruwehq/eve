#!/usr/bin/env python3
"""Run terraform plan for a profile's stacks.

Usage: scripts/tf-plan <instance>
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import apply_tf_env, prepare_provider_stacks, repo_root, resolve_env  # noqa: E402


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/tf-plan <instance>", file=sys.stderr)
        return 2
    root = repo_root()

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    if engine != "terraform":
        print(f"[tf-plan] not supported for engine={engine}")
        return 1

    tags = resolved.get("STACK_TAGS", "")
    print(f"[tf-plan] profile={profile} tags={tags}")

    prepare_provider_stacks(root, resolved.get("PROVIDER", ""))
    rc = subprocess.run(["terramate", "generate"], cwd=root).returncode
    if rc != 0:
        return rc

    apply_tf_env(root, profile)

    fail = 0

    print("  === Shared infrastructure ===")
    rc = subprocess.run(
        ["terramate", "run", f"--tags={tags}-shared", "--", "terraform", "plan"], cwd=root,
    ).returncode
    if rc != 0:
        print("  [FAIL] Shared plan failed.", file=sys.stderr)
        fail = 1

    print("  === Services ===")
    rc = subprocess.run(
        ["terramate", "run", f"--tags={tags}-services", "--", "terraform", "plan"], cwd=root,
    ).returncode
    if rc != 0:
        print(
            f"  [FAIL] Services plan failed. Apply shared first: eve instance up --instance {profile}",
            file=sys.stderr,
        )
        fail = 1

    return 1 if fail else 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
