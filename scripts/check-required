#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir  # noqa: E402


def command_available(command: str) -> bool:
    return subprocess.run(["sh", "-c", f"command -v {command} >/dev/null 2>&1"], check=False).returncode == 0


def host_os() -> str:
    try:
        result = subprocess.run(["uname", "-s"], text=True, capture_output=True, check=False)
    except FileNotFoundError:
        return "unknown"
    return result.stdout.strip() if result.returncode == 0 and result.stdout.strip() else "unknown"


def load_yaml(path: Path) -> dict[str, Any]:
    loaded = yaml.safe_load(path.read_text(encoding="utf-8")) if path.exists() else {}
    return loaded if isinstance(loaded, dict) else {}


def portability_warnings() -> list[dict[str, str]]:
    warnings: list[dict[str, str]] = []
    match host_os():
        case "Linux":
            if not command_available("getent"):
                warnings.append(
                    {
                        "id": "linux-getent-missing",
                        "scope": "os-portability",
                        "description": "Raspberry Pi hostname resolution on Linux requires getent.",
                    }
                )
            if not command_available("xfreerdp"):
                warnings.append(
                    {
                        "id": "linux-xfreerdp-missing",
                        "scope": "os-portability",
                        "description": "Opening RDP sessions on Linux requires xfreerdp.",
                    }
                )
        case "Darwin":
            if not command_available("dscacheutil"):
                warnings.append(
                    {
                        "id": "darwin-dscacheutil-missing",
                        "scope": "os-portability",
                        "description": "Raspberry Pi hostname resolution on macOS requires dscacheutil.",
                    }
                )
            if not command_available("pbcopy"):
                warnings.append(
                    {
                        "id": "darwin-pbcopy-missing",
                        "scope": "os-portability",
                        "description": "Opening RDP sessions on macOS copies passwords with pbcopy.",
                    }
                )
        case _:
            warnings.append(
                {
                    "id": "unsupported-host-os",
                    "scope": "os-portability",
                    "description": "This host OS is not supported by the v3.3 portability contract.",
                }
            )
    return warnings


def build_report() -> dict[str, Any]:
    defaults = load_yaml(ROOT / "config/defaults.yaml")
    config = load_yaml(Workdir.config_path())
    missing: list[dict[str, str]] = []

    for section_id in sorted(defaults.keys()):
        section_defaults = defaults.get(section_id)
        if not isinstance(section_defaults, dict):
            continue
        section_config = config.get(section_id)
        if not isinstance(section_config, dict):
            section_config = {}
        for field, value in section_defaults.items():
            if not str(value).startswith("REQUIRED_"):
                continue
            if not str(section_config.get(field, "")).strip():
                missing.append(
                    {
                        "provider": section_id,
                        "scope": "config",
                        "field": str(field),
                        "description": f"Global required setting: {section_id}.{field}",
                    }
                )

    return {"missing": missing, "warnings": portability_warnings(), "ok": not missing}


def main(argv: list[str]) -> int:
    fmt = "json" if "--json" in argv else "missing"
    report = build_report()
    if fmt == "json":
        print(json.dumps(report, indent=2))
    else:
        for entry in report["missing"]:
            print(f"{entry['provider']}.{entry['scope']}.{entry['field']}")
    return 0 if report["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
