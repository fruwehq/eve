#!/usr/bin/env ruby
# frozen_string_literal: true

# Check which required fields are missing. Outputs JSON.
# Exit 0 if all required fields populated, 1 if missing.
# --json: full report. --missing: just missing field names.

require "json"
require "open3"
require "yaml"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"

format = ARGV.include?("--json") ? "json" : "missing"

manifest_dir = File.join(ROOT, "plugins", "providers")
defaults_path = File.join(ROOT, "config", "defaults.yaml")
config_path = Eve::SDK::Workdir.config_path

defaults = YAML.safe_load(File.read(defaults_path), aliases: false) || {}
config = YAML.safe_load(File.read(config_path), aliases: false) if File.exist?(config_path)
config ||= {}

missing = []
warnings = []

def command_available?(command)
  system("command -v #{command} >/dev/null 2>&1")
end

def host_os
  stdout, status = Open3.capture2("uname", "-s")
  return stdout.strip if status.success? && !stdout.strip.empty?

  "unknown"
rescue Errno::ENOENT
  "unknown"
end

case host_os
when "Linux"
  warnings << {
    "id" => "linux-getent-missing",
    "scope" => "os-portability",
    "description" => "Raspberry Pi hostname resolution on Linux requires getent."
  } unless command_available?("getent")
  warnings << {
    "id" => "linux-xfreerdp-missing",
    "scope" => "os-portability",
    "description" => "Opening RDP sessions on Linux requires xfreerdp."
  } unless command_available?("xfreerdp")
when "Darwin"
  warnings << {
    "id" => "darwin-dscacheutil-missing",
    "scope" => "os-portability",
    "description" => "Raspberry Pi hostname resolution on macOS requires dscacheutil."
  } unless command_available?("dscacheutil")
  warnings << {
    "id" => "darwin-pbcopy-missing",
    "scope" => "os-portability",
    "description" => "Opening RDP sessions on macOS copies passwords with pbcopy."
  } unless command_available?("pbcopy")
else
  warnings << {
    "id" => "unsupported-host-os",
    "scope" => "os-portability",
    "description" => "This host OS is not supported by the v3.3 portability contract."
  }
end

Dir.glob(File.join(manifest_dir, "*", "eve-plugin.yaml")).sort.each do |path|
  data = YAML.safe_load(File.read(path), aliases: false)
  next unless data.is_a?(Hash) && data["kind"] == "provider"

  provider_id = data["id"]
  schema = data["config_schema"] || {}

  schema["config"]&.each do |field, spec|
    next unless spec["required"]
    config_val = config.dig(provider_id.tr("-", "_"), field)
    default_val = defaults.dig(provider_id.tr("-", "_"), field)
    env_name = spec["env"] # not standard; skip env check for now
    has_value = !config_val.to_s.strip.empty? || !default_val.to_s.strip.empty?
    missing << { "provider" => provider_id, "scope" => "config", "field" => field, "description" => spec["description"] } unless has_value
  end

  schema["secrets"]&.each do |field, spec|
    next unless spec["required"]
    keys = begin
             Eve::SDK::Secrets.keys_set(provider_id)
           rescue Eve::SDK::Secrets::SecretsError
             []
           end
    missing << { "provider" => provider_id, "scope" => "secrets", "field" => field, "description" => spec["description"] } unless keys.include?(field)
  end
end

case format
when "json"
  puts JSON.pretty_generate("missing" => missing, "warnings" => warnings, "ok" => missing.empty?)
when "missing"
  missing.each { |m| puts "#{m['provider']}.#{m['scope']}.#{m['field']}" }
end

exit(missing.empty? ? 0 : 1)
