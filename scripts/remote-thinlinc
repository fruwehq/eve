#!/usr/bin/env python3
"""Open the ThinLinc Web Access page for an instance.

Usage: scripts/remote-thinlinc <instance>
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    exec_replace,
    has_command,
    instance_ip,
    repo_root,
    thinlinc_url,
    url_open_command,
)


def main(argv: list[str]) -> int:
    instance = argv[0] if argv else ""
    if not instance:
        print("Usage: scripts/remote-thinlinc <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    ip = instance_ip(root, instance)
    if not ip:
        print(f"remote-thinlinc: could not resolve IP for {instance}", file=sys.stderr)
        return 1
    url = thinlinc_url(ip)
    opener = "open" if has_command("open") else "xdg-open"
    exec_replace(url_open_command(opener, url))
    return 0  # unreachable


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
