#!/usr/bin/env ruby
# frozen_string_literal: true

require "json"
require "tempfile"
require "fileutils"
require "yaml"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"

WRITER_COUNT = 20

failures = 0

def pass(msg)
  puts "[OK]   #{msg}"
end

def fail_test(msg)
  puts "[FAIL] #{msg}"
  1
end

begin
  tmpdir = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir

  puts "\n== secrets-concurrency: #{WRITER_COUNT} parallel writers =="

  pids = []
  WRITER_COUNT.times do |i|
    pid = fork do
      Eve::SDK::Secrets.update("test-provider", "key_#{i}" => "value_#{i}")
    end
    pids << pid
  end

  all_ok = true
  pids.each do |pid|
    _pid, status = Process.waitpid2(pid)
    all_ok = false unless status.success?
  end

  if all_ok
    pass "all #{WRITER_COUNT} writers completed"
  else
    failures += fail_test "not all writers completed successfully"
  end

  path = Eve::SDK::Secrets.path_for("test-provider")
  if File.exist?(path)
    pass "secrets file exists"
  else
    failures += fail_test "secrets file missing after concurrent writes"
  end

  raw = File.read(path)
  parsed = YAML.safe_load(raw)
  if parsed.is_a?(Hash) && parsed.key?("test-provider")
    pass "final secrets file is valid YAML with correct top-level key"
  else
    failures += fail_test "final secrets file has wrong structure"
    parsed = {}
  end

  secrets = parsed["test-provider"] || {}
  if secrets.size >= WRITER_COUNT
    pass "all #{WRITER_COUNT} secret entries recorded"
  else
    failures += fail_test "expected >= #{WRITER_COUNT} entries, got #{secrets.size}"
  end

  FileUtils.rm_rf(tmpdir)
  tmpdir = nil

  puts "\n== secrets: read returns empty for missing provider =="

  tmpdir2 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir2

  result = Eve::SDK::Secrets.read("nonexistent")
  if result == {}
    pass "read returns {} for missing file"
  else
    failures += fail_test "expected {}, got #{result.inspect}"
  end

  FileUtils.rm_rf(tmpdir2)
  tmpdir2 = nil

  puts "\n== secrets: write and read round-trip =="

  tmpdir3 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir3

  Eve::SDK::Secrets.write("aws", "access_key_id" => "AKIA_TEST", "secret_access_key" => "secret123")
  read_back = Eve::SDK::Secrets.read("aws")
  if read_back["access_key_id"] == "AKIA_TEST" && read_back["secret_access_key"] == "secret123"
    pass "write/read round-trip preserves values"
  else
    failures += fail_test "round-trip mismatch: #{read_back.inspect}"
  end

  FileUtils.rm_rf(tmpdir3)
  tmpdir3 = nil

  puts "\n== secrets: get returns single value =="

  tmpdir4 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir4

  Eve::SDK::Secrets.write("aws", "access_key_id" => "AKIA_TEST")
  val = Eve::SDK::Secrets.get("aws", "access_key_id")
  if val == "AKIA_TEST"
    pass "get returns correct value"
  else
    failures += fail_test "get returned #{val.inspect}, expected 'AKIA_TEST'"
  end

  missing = Eve::SDK::Secrets.get("aws", "nonexistent")
  if missing.nil?
    pass "get returns nil for missing key"
  else
    failures += fail_test "get returned #{missing.inspect} for missing key"
  end

  FileUtils.rm_rf(tmpdir4)
  tmpdir4 = nil

  puts "\n== secrets: update merges partial =="

  tmpdir5 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir5

  Eve::SDK::Secrets.write("aws", "access_key_id" => "AKIA_OLD", "region" => "us-east-1")
  Eve::SDK::Secrets.update("aws", "access_key_id" => "AKIA_NEW")
  updated = Eve::SDK::Secrets.read("aws")
  if updated["access_key_id"] == "AKIA_NEW" && updated["region"] == "us-east-1"
    pass "update merges partial, preserves existing keys"
  else
    failures += fail_test "update result: #{updated.inspect}"
  end

  FileUtils.rm_rf(tmpdir5)
  tmpdir5 = nil

  puts "\n== secrets: update with nil deletes key =="

  tmpdir6 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir6

  Eve::SDK::Secrets.write("aws", "a" => "1", "b" => "2")
  Eve::SDK::Secrets.update("aws", "a" => nil)
  after_delete = Eve::SDK::Secrets.read("aws")
  if !after_delete.key?("a") && after_delete["b"] == "2"
    pass "update with nil value deletes key"
  else
    failures += fail_test "after nil update: #{after_delete.inspect}"
  end

  FileUtils.rm_rf(tmpdir6)
  tmpdir6 = nil

  puts "\n== secrets: delete removes specific keys =="

  tmpdir7 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir7

  Eve::SDK::Secrets.write("aws", "a" => "1", "b" => "2", "c" => "3")
  Eve::SDK::Secrets.delete("aws", keys: ["a", "c"])
  after_del = Eve::SDK::Secrets.read("aws")
  if after_del == { "b" => "2" }
    pass "delete removes specified keys"
  else
    failures += fail_test "after delete keys: #{after_del.inspect}"
  end

  FileUtils.rm_rf(tmpdir7)
  tmpdir7 = nil

  puts "\n== secrets: delete :all removes file =="

  tmpdir8 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir8

  Eve::SDK::Secrets.write("vultr", "api_key" => "secret")
  Eve::SDK::Secrets.delete("vultr")
  if !File.exist?(Eve::SDK::Secrets.path_for("vultr"))
    pass "delete :all removes file"
  else
    failures += fail_test "file still exists after delete :all"
  end

  FileUtils.rm_rf(tmpdir8)
  tmpdir8 = nil

  puts "\n== secrets: modify yields writable hash =="

  tmpdir9 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir9

  Eve::SDK::Secrets.write("gcp", "project" => "old-project")
  Eve::SDK::Secrets.modify("gcp") do |secrets|
    secrets["project"] = "new-project"
    secrets["region"] = "us-central1"
    secrets
  end
  modified = Eve::SDK::Secrets.read("gcp")
  if modified["project"] == "new-project" && modified["region"] == "us-central1"
    pass "modify updates and persists changes"
  else
    failures += fail_test "modify result: #{modified.inspect}"
  end

  FileUtils.rm_rf(tmpdir9)
  tmpdir9 = nil

  puts "\n== secrets: file mode is 0600 =="

  tmpdir10 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir10

  Eve::SDK::Secrets.write("truenas", "api_key" => "secret")
  mode = File.stat(Eve::SDK::Secrets.path_for("truenas")).mode & 0o777
  if mode == 0o600
    pass "secrets file mode is 0600"
  else
    failures += fail_test "expected mode 0600, got #{format('%04o', mode)}"
  end

  FileUtils.rm_rf(tmpdir10)
  tmpdir10 = nil

  puts "\n== secrets: rejects non-string values =="

  tmpdir11 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir11

  begin
    Eve::SDK::Secrets.write("bad", "key" => 123)
    failures += fail_test "write should reject integer value"
  rescue Eve::SDK::Secrets::SecretsError
    pass "write rejects non-string values"
  end

  FileUtils.rm_rf(tmpdir11)
  tmpdir11 = nil

  puts "\n== secrets: rejects malformed YAML =="

  tmpdir12 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir12

  bad_path = Eve::SDK::Secrets.path_for("broken")
  FileUtils.mkdir_p(File.dirname(bad_path))
  File.write(bad_path, "broken: [invalid yaml\n")
  begin
    Eve::SDK::Secrets.read("broken")
    failures += fail_test "read should reject malformed YAML"
  rescue Eve::SDK::Secrets::SecretsError
    pass "read rejects malformed YAML"
  end

  FileUtils.rm_rf(tmpdir12)
  tmpdir12 = nil

  puts "\n== secrets: rejects wrong top-level key =="

  tmpdir13 = Dir.mktmpdir("eve-secrets-test-")
  ENV["EVE_SECRETS_DIR"] = tmpdir13

  wrong_path = Eve::SDK::Secrets.path_for("aws")
  FileUtils.mkdir_p(File.dirname(wrong_path))
  File.write(wrong_path, YAML.dump("gcp" => { "key" => "val" }))
  begin
    Eve::SDK::Secrets.read("aws")
    failures += fail_test "read should reject wrong top-level key"
  rescue Eve::SDK::Secrets::SecretsError
    pass "read rejects wrong top-level key"
  end

  FileUtils.rm_rf(tmpdir13)
  tmpdir13 = nil

  puts "\n== secrets: malformed secrets surface as nonzero exit =="

  secrets_dir_malformed = Dir.mktmpdir("eve-secrets-test-")
  mal_path = File.join(secrets_dir_malformed, "vultr.yaml")
  File.write(mal_path, "vultr: [invalid yaml\n")

  pid = Process.spawn(
    { "EVE_SECRETS_DIR" => secrets_dir_malformed },
    "ruby -I#{File.join(ROOT, "core")} -rsdk -e \"Eve::SDK::Secrets.read(ARGV[0])\" vultr",
    out: File::NULL, err: File::NULL
  )
  _w, status = Process.waitpid2(pid)
  if !status.success?
    pass "malformed secrets file causes nonzero exit"
  else
    failures += fail_test "malformed secrets should cause nonzero exit"
  end

  FileUtils.rm_rf(secrets_dir_malformed)

  puts "\n== secrets: wrong top-level key surfaces as nonzero exit =="

  secrets_dir_wrong = Dir.mktmpdir("eve-secrets-test-")
  wrong_path = File.join(secrets_dir_wrong, "vultr.yaml")
  File.write(wrong_path, YAML.dump("gcp" => { "key" => "val" }))

  pid2 = Process.spawn(
    { "EVE_SECRETS_DIR" => secrets_dir_wrong },
    "ruby -I#{File.join(ROOT, "core")} -rsdk -e \"Eve::SDK::Secrets.read(ARGV[0])\" vultr",
    out: File::NULL, err: File::NULL
  )
  _w2, status2 = Process.waitpid2(pid2)
  if !status2.success?
    pass "wrong top-level key causes nonzero exit"
  else
    failures += fail_test "wrong top-level key should cause nonzero exit"
  end

  FileUtils.rm_rf(secrets_dir_wrong)

ensure
  FileUtils.rm_rf(tmpdir) if tmpdir
  ENV.delete("EVE_SECRETS_DIR")
end

if failures.positive?
  $stderr.puts "\n#{failures} check(s) failed."
  exit 1
end
puts "\nAll secrets checks passed."
