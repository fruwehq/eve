#!/usr/bin/env sh
set -eu

# Interactive profile selector.
# Reads available profiles and prompts the user to pick one.
# Outputs the selected profile name to stdout.
# Usage: scripts/profile-menu
#   Set SKIP_MENU=1 to auto-select the default (for non-interactive use).

DEFAULT_PROFILE="local-vmware-ubuntu-dev-gui"

PROFILES=$(scripts/profiles-list)

if [ -n "${SKIP_MENU:-}" ]; then
  echo "$DEFAULT_PROFILE"
  exit 0
fi

# If not a terminal, output the default
if [ ! -t 0 ] || [ ! -t 1 ]; then
  echo "$DEFAULT_PROFILE"
  exit 0
fi

echo ""
echo "  Available profiles:"
echo "  -------------------"
echo ""

i=1
for name in $PROFILES; do
  printf "  %2d) %s\n" "$i" "$name"
  i=$((i + 1))
done

echo ""
printf "  Select profile [1-%d] (default: %s): " "$((i - 1))" "$DEFAULT_PROFILE"

read -r selection 2>/dev/null || true

# Handle empty input (use default)
if [ -z "$selection" ]; then
  echo "$DEFAULT_PROFILE"
  exit 0
fi

# Handle numeric selection
case "$selection" in
  *[!0-9]*)
    # Non-numeric — treat as profile name
    if echo "$PROFILES" | grep -qx "$selection"; then
      echo "$selection"
      exit 0
    fi
    echo "Error: unknown profile '$selection'" >&2
    exit 1
    ;;
esac

# Numeric selection
count=0
for name in $PROFILES; do
  count=$((count + 1))
  if [ "$count" -eq "$selection" ]; then
    echo "$name"
    exit 0
  fi
done

echo "Error: selection $selection out of range (1-$count)" >&2
exit 1
