#!/usr/bin/env ruby
# frozen_string_literal: true

ROOT = File.expand_path("..", __dir__)
instance = ARGV.shift || ENV["INSTANCE"]

unless instance && !instance.empty?
  warn "Usage: scripts/instance-ssh <instance> [-- <cmd>] [--scp <local> <remote>]"
  exit 2
end

args = [File.join(ROOT, "scripts/provider-dispatch"), "--instance", instance, "--command", "ssh"]
args << "--"
args.concat(ARGV)
exec(*args)
