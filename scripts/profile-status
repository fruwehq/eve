#!/usr/bin/env bash
set -euo pipefail

PROFILE="${1:?Usage: scripts/profile-status <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
OS_FAMILY=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')

printf '%-15s %s\n' "Profile:" "$PROFILE"
printf '%-15s %s\n' "Engine:" "$ENGINE"
printf '%-15s %s\n' "Provider:" "$PROVIDER"
printf '%-15s %s\n' "OS:" "$OS_FAMILY"

VM_STATUS="unknown"

tf_attr() {
  local json="$1" address="$2" attr="$3"
  printf '%s' "$json" | jq -r --arg addr "$address" --arg attr "$attr" \
    '(.values // {} | .root_module // {} | .resources // [])
     | map(select(.address == $addr))
     | map(.values[$attr])
     | first // ""' 2>/dev/null
}

case "$ENGINE" in
  vagrant)
    GENERATED_DIR=".generated/$PROFILE"
    if [ ! -d "$GENERATED_DIR" ]; then
      VM_STATUS="not created"
    else
      case "$PROVIDER" in
        local-vmware)
          VMX=$(find "$GENERATED_DIR/.vagrant/machines/default" -name '*.vmx' 2>/dev/null | head -1)
          if [ -z "$VMX" ]; then
            VM_STATUS="not created"
          elif vmrun list | grep -q "$VMX"; then
            VM_STATUS="running"
          else
            VM_STATUS="stopped"
          fi
          ;;
        local-virtualbox)
          VM_NAME=$(cd "$GENERATED_DIR" && VBoxManage list vms 2>/dev/null | head -1 | awk -F'"' '{print $2}')
          if [ -z "$VM_NAME" ]; then
            VM_STATUS="not created"
          elif cd "$GENERATED_DIR" && VBoxManage list runningvms 2>/dev/null | grep -q "$VM_NAME"; then
            VM_STATUS="running"
          else
            VM_STATUS="stopped"
          fi
          ;;
        *)
          VM_STATUS="unsupported provider ($PROVIDER)"
          ;;
      esac
    fi
    ;;
  terraform)
    TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
    STATE_JSON=$(terramate run --quiet --tags="$TAGS-services" -- terraform show -json 2>/dev/null) || true

    if [ -z "$STATE_JSON" ]; then
      VM_STATUS="not created"
    else
      case "$PROVIDER" in
        aws)
          RAW=$(tf_attr "$STATE_JSON" "aws_instance.main" "instance_state")
          case "$RAW" in
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        vultr)
          RAW=$(tf_attr "$STATE_JSON" "vultr_instance.default" "power_status")
          case "$RAW" in
            running) VM_STATUS="running" ;;
            stopped) VM_STATUS="stopped" ;;
            "")
              RAW2=$(tf_attr "$STATE_JSON" "vultr_instance.default" "status")
              case "$RAW2" in
                active) VM_STATUS="running" ;;
                "") VM_STATUS="not created" ;;
                *) VM_STATUS="$RAW2" ;;
              esac
              ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        truenas)
          RAW=$(tf_attr "$STATE_JSON" "truenas_vm.this" "state")
          case "${RAW^^}" in
            RUNNING) VM_STATUS="running" ;;
            STOPPED) VM_STATUS="stopped" ;;
            "") VM_STATUS="not created" ;;
            *) VM_STATUS="$RAW" ;;
          esac
          ;;
        *)
          VM_STATUS="unsupported provider ($PROVIDER)"
          ;;
      esac

      if [ "$VM_STATUS" = "running" ]; then
        IP=$(./scripts/profile-ip "$PROFILE" 2>/dev/null || true)
        if [ -n "$IP" ]; then
          printf '%-15s %s\n' "IP:" "$IP"
        fi
      fi
    fi
    ;;
  *)
    VM_STATUS="unsupported engine ($ENGINE)"
    ;;
esac

printf '%-15s %s\n' "Status:" "$VM_STATUS"
