#!/usr/bin/env python3
"""Emit package status by checking common Windows install paths.

Usage: scripts/package-status-windows <package> <path> [path...]

Builds a PowerShell probe (Test-Path + optional Get-Process / Get-Service),
encodes it as a ``-EncodedCommand`` so SSH shell expansion cannot corrupt the
``$`` variables, runs it via ``EVE_PACKAGE_STATUS_SSH``, and emits the
package-status JSON contract.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.package_dispatch import (  # noqa: E402
    emit_json,
    encode_ps_command,
    first_status,
    quote_ps_single,
    run_status_probe,
)

_USAGE = "Usage: scripts/package-status-windows <package> <path> [path...]"

_PS_SCRIPT = (
    "$paths = @({paths}); "
    "$processName = {process}; "
    "$servicePattern = {service}; "
    "$installed = [bool]($paths | Where-Object {{ Test-Path $_ }}); "
    "$running = $false; "
    "if ($installed -and $processName) {{ "
    "$running = [bool](Get-Process -Name $processName -ErrorAction SilentlyContinue | Select-Object -First 1) }}; "
    "if ($installed -and -not $running -and $servicePattern) {{ "
    "$running = [bool](Get-Service -ErrorAction SilentlyContinue | "
    "Where-Object {{ ($_.Name -match $servicePattern -or $_.DisplayName -match $servicePattern) "
    "-and $_.Status -eq 'Running' }} | Select-Object -First 1) }}; "
    "if ($running) {{ 'running' }} elseif ($installed) {{ 'installed' }} else {{ 'missing' }}"
)

_VALID = {"running", "installed", "missing", "unknown"}


def main(argv: list[str]) -> int:
    if len(argv) < 1:
        print(_USAGE, file=sys.stderr)
        return 1
    package = argv[0]
    paths = argv[1:]
    if not paths:
        print("package-status-windows: at least one path is required", file=sys.stderr)
        return 2

    ps_paths = ",".join(quote_ps_single(p) for p in paths)
    process_name = os.environ.get("EVE_PACKAGE_STATUS_PROCESS", "")
    service_pattern = os.environ.get("EVE_PACKAGE_STATUS_SERVICE_PATTERN", "")
    ps_script = _PS_SCRIPT.format(
        paths=ps_paths,
        process=quote_ps_single(process_name),
        service=quote_ps_single(service_pattern),
    )
    encoded = encode_ps_command(ps_script)
    remote_command = f"powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand {encoded}"

    profile = os.environ.get("EVE_INSTANCE_NAME", "")
    if not profile:
        print("EVE_INSTANCE_NAME is required", file=sys.stderr)
        return 1
    ssh_helper = os.environ.get("EVE_PACKAGE_STATUS_SSH", str(ROOT / "scripts/instance-ssh"))

    exit_status, details = run_status_probe(ssh_helper, profile, remote_command)

    if exit_status == 0:
        status = first_status(details, _VALID) or "unknown"
        if status == "running":
            status = "installed"
        elif status not in {"installed", "missing", "unknown"}:
            status = "unknown"
    else:
        status = "failed"

    emit_json({
        "kind": "package-status",
        "package": package,
        "command": "status",
        "instance": profile,
        "os_family": "windows",
        "status": status,
        "details": details,
    })
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
