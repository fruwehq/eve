#!/usr/bin/env bash
set -euo pipefail

USAGE="Usage: scripts/remote-rustdesk <profile> [connect]

Prints the RustDesk connection details for a profile's instance.
With 'connect', configures the local RustDesk client and opens a connection.
"

PROFILE="${1:?$USAGE}"
ACTION="${2:-info}"
cd "$(git rev-parse --show-toplevel)"

SSH_CMD=(./scripts/instance-ssh "$PROFILE" --)

OS_FAMILY=$(./scripts/profile-resolve --profile "$PROFILE" --emit env | awk -F= '/^OS_FAMILY=/{print $2}')

case "$OS_FAMILY" in
  windows)
    # shellcheck disable=SC2016  # PowerShell $_ / $rd / $cfg are not bash expansions
    RD_LOCATE='$rd = @("C:\Program Files\RustDesk\rustdesk.exe","C:\Program Files (x86)\RustDesk\rustdesk.exe","C:\Program Files\RustDesk\RustDesk.exe","C:\Program Files (x86)\RustDesk\RustDesk.exe") | Where-Object { Test-Path $_ } | Select-Object -First 1'
    # shellcheck disable=SC2016
    CFG_LOCATE='$cfg = @("C:\Windows\ServiceProfiles\LocalService\AppData\Roaming\RustDesk\config\RustDesk2.toml","C:\Windows\System32\config\systemprofile\AppData\Roaming\RustDesk\config\RustDesk2.toml","$env:APPDATA\RustDesk\config\RustDesk2.toml") | Where-Object { Test-Path $_ } | Select-Object -First 1'
    # shellcheck disable=SC2016
    GET_ID_CMD="$RD_LOCATE; if (\$rd) { & \$rd --get-id } else { Write-Error 'rustdesk.exe not found on remote' }"
    # shellcheck disable=SC2016
    SERVER_CMD="$CFG_LOCATE; if (\$cfg) { Get-Content \$cfg | Select-String -Pattern '^(rendezvous_server|custom-rendezvous-server)' | Select-Object -Last 1 | ForEach-Object { (\$_ -split '=',2)[1].Trim().Trim(\"'\") } }"
    # shellcheck disable=SC2016
    KEY_CMD="$CFG_LOCATE; if (\$cfg) { Get-Content \$cfg | Select-String -Pattern '^key ' | Select-Object -First 1 | ForEach-Object { (\$_ -split '=',2)[1].Trim().Trim(\"'\") } }"
    ;;
  *)
    GET_ID_CMD='rustdesk --get-id 2>/dev/null'
    SERVER_CMD='sudo grep -E "^(rendezvous_server|custom-rendezvous-server)" /root/.config/rustdesk/RustDesk2.toml 2>/dev/null | tail -1 | sed "s/^[^=]*= .//;s/.$//"'
    KEY_CMD='sudo grep "^key " /root/.config/rustdesk/RustDesk2.toml 2>/dev/null | sed "s/^key = .//;s/.$//"'
    ;;
esac

ID=$("${SSH_CMD[@]}" "$GET_ID_CMD" | tr -d '[:space:]' || true)
if [ -z "$ID" ]; then
  echo "RustDesk ID not available — is the service running?" >&2
  exit 1
fi

SERVER=$("${SSH_CMD[@]}" "$SERVER_CMD" | tr -d '\r' || true)
KEY=$("${SSH_CMD[@]}" "$KEY_CMD" | tr -d '\r' || true)

case "$ACTION" in
  connect)
    RUSTDESK_CLI=""
    for candidate in \
      rustdesk \
      /Applications/RustDesk.app/Contents/MacOS/rustdesk \
      /usr/bin/rustdesk; do
      if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
        RUSTDESK_CLI="$candidate"
        break
      fi
    done
    if [ -z "$RUSTDESK_CLI" ]; then
      echo "RustDesk client not found locally" >&2
      exit 1
    fi

    PASSWORD_ARG=""
    if [ -n "${RUSTDESK_PASSWORD:-}" ]; then
      PASSWORD_ARG="--password"
    fi

    echo "Connecting to RustDesk ID $ID..."
    nohup "$RUSTDESK_CLI" --connect "$ID" ${PASSWORD_ARG:+"$PASSWORD_ARG" "$RUSTDESK_PASSWORD"} >/dev/null 2>&1 &
    ;;
  info|*)
    echo "RustDesk ID:  $ID"
    echo "Server:       ${SERVER:-(default)}"
    echo "Key:          ${KEY:-(not set)}"
    ;;
esac
