#!/usr/bin/env bash
set -euo pipefail

USAGE="Usage: scripts/remote-rustdesk <instance> [connect]

Prints the RustDesk connection details for a profile's instance.
With 'connect', configures the local RustDesk client and opens a connection.
"

PROFILE="${1:?$USAGE}"
ACTION="${2:-info}"
cd "$(git rev-parse --show-toplevel)"

SSH_CMD=(./scripts/instance-ssh "$PROFILE" --)

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
OS_FAMILY=$(printf '%s\n' "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')
VM_USER_NAME_RESOLVED=$(printf '%s\n' "$RESOLVED_ENV" | awk -F= '/^VM_USER_NAME=/{print $2}')

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

case "$OS_FAMILY" in
  windows)
    # shellcheck disable=SC2016
    RD_LOCATE='$rd = @("C:\Program Files\RustDesk\rustdesk.exe","C:\Program Files (x86)\RustDesk\rustdesk.exe","C:\Users\Administrator\AppData\Local\rustdesk\rustdesk.exe","C:\Windows\System32\config\systemprofile\AppData\Local\rustdesk\rustdesk.exe","$env:LOCALAPPDATA\rustdesk\rustdesk.exe") | Where-Object { Test-Path $_ } | Select-Object -First 1; if (-not $rd) { $proc = Get-Process rustdesk -ErrorAction SilentlyContinue | Select-Object -First 1; if ($proc -and $proc.Path) { $rd = $proc.Path } }'
    # shellcheck disable=SC2016
    CFG_LOCATE='$cfg = @("C:\Users\Administrator\AppData\Roaming\RustDesk\config\RustDesk2.toml","C:\Windows\System32\config\systemprofile\AppData\Roaming\RustDesk\config\RustDesk2.toml","$env:APPDATA\RustDesk\config\RustDesk2.toml") | Where-Object { Test-Path $_ } | Select-Object -First 1'
    # shellcheck disable=SC2016
    GET_ID_CMD="$RD_LOCATE; if (\$rd) { & \$rd --get-id } else { Write-Error 'rustdesk.exe not found on remote' }"
    # shellcheck disable=SC2016
    SERVER_CMD="$CFG_LOCATE; if (\$cfg) { Get-Content \$cfg | Select-String -Pattern '^(rendezvous_server|custom-rendezvous-server)' | Select-Object -Last 1 | ForEach-Object { (\$_ -split '=',2)[1].Trim().Trim(\"'\") } }"
    # shellcheck disable=SC2016
    KEY_CMD="$CFG_LOCATE; if (\$cfg) { Get-Content \$cfg | Select-String -Pattern '^key ' | Select-Object -First 1 | ForEach-Object { (\$_ -split '=',2)[1].Trim().Trim(\"'\") } }"
    # shellcheck disable=SC2016
    PREP_CMD="$RD_LOCATE; if (\$rd) { \$script = 'C:\Users\Administrator\provision\state\configure-rustdesk-user.ps1'; if (Test-Path \$script) { powershell.exe -NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File \$script | Out-Null }; \$proc = Get-Process rustdesk -ErrorAction SilentlyContinue | Select-Object -First 1; if (-not \$proc) { Start-Process -FilePath \$rd -WindowStyle Hidden; Start-Sleep -Seconds 5 } }"
    ;;
  *)
    # Start the admin service and nudge a user-session server if the desktop
    # has already logged in. If the user desktop is not up yet, --get-id below
    # still reports the admin-service ID rather than a misleading empty value.
    if [ -n "$VM_USER_NAME_RESOLVED" ]; then
      VM_USER_Q=$(shell_quote "$VM_USER_NAME_RESOLVED")
      PREP_CMD="sudo systemctl start rustdesk 2>/dev/null || true; rd_user=$VM_USER_Q; if id \"\$rd_user\" >/dev/null 2>&1; then uid=\$(id -u \"\$rd_user\"); home=\$(getent passwd \"\$rd_user\" | cut -d: -f6); runtime=\"/run/user/\$uid\"; if [ -d \"\$runtime\" ]; then sudo -H -u \"\$rd_user\" env HOME=\"\$home\" USER=\"\$rd_user\" LOGNAME=\"\$rd_user\" XDG_RUNTIME_DIR=\"\$runtime\" DISPLAY=\"\${DISPLAY:-:0}\" XAUTHORITY=\"\${XAUTHORITY:-\$home/.Xauthority}\" systemctl --user import-environment DISPLAY XAUTHORITY XDG_RUNTIME_DIR 2>/dev/null || true; sudo -H -u \"\$rd_user\" env HOME=\"\$home\" USER=\"\$rd_user\" LOGNAME=\"\$rd_user\" XDG_RUNTIME_DIR=\"\$runtime\" DISPLAY=\"\${DISPLAY:-:0}\" XAUTHORITY=\"\${XAUTHORITY:-\$home/.Xauthority}\" setsid rustdesk --server >/tmp/eve-rustdesk-user.log 2>&1 < /dev/null & fi; fi; sleep 2"
    else
      # shellcheck disable=SC2016
      PREP_CMD='sudo systemctl start rustdesk 2>/dev/null || true; uid=$(id -u); home=$(getent passwd "$USER" | cut -d: -f6); export XDG_RUNTIME_DIR="/run/user/$uid"; export DISPLAY="${DISPLAY:-:0}"; export XAUTHORITY="${XAUTHORITY:-$home/.Xauthority}"; if [ -d "$XDG_RUNTIME_DIR" ]; then systemctl --user import-environment DISPLAY XAUTHORITY XDG_RUNTIME_DIR 2>/dev/null || true; setsid rustdesk --server >/tmp/eve-rustdesk-user.log 2>&1 < /dev/null & fi; sleep 2'
    fi
    GET_ID_CMD='sudo rustdesk --get-id 2>/dev/null || rustdesk --get-id 2>/dev/null || true'
    SERVER_CMD='sudo grep -E "^(rendezvous_server|custom-rendezvous-server)" /root/.config/rustdesk/RustDesk2.toml 2>/dev/null | tail -1 | sed "s/^[^=]*= .//;s/.$//"'
    KEY_CMD='sudo grep "^key " /root/.config/rustdesk/RustDesk2.toml 2>/dev/null | sed "s/^key = .//;s/.$//"'
    ;;
esac

"${SSH_CMD[@]}" "$PREP_CMD" >/dev/null 2>&1 || true

ID=$("${SSH_CMD[@]}" "$GET_ID_CMD" | tr -d '[:space:]' || true)
if [ -z "$ID" ]; then
  echo "RustDesk ID not available — is the service running?" >&2
  exit 1
fi

SERVER=$("${SSH_CMD[@]}" "$SERVER_CMD" | tr -d '\r' || true)
KEY=$("${SSH_CMD[@]}" "$KEY_CMD" | tr -d '\r' || true)

case "$ACTION" in
  connect)
    RUSTDESK_CLI=""
    if [ "$(uname -s)" = "Darwin" ] && [ -x /Applications/RustDesk.app/Contents/MacOS/rustdesk ]; then
      RUSTDESK_CLI=/Applications/RustDesk.app/Contents/MacOS/rustdesk
    fi
    for candidate in rustdesk /usr/bin/rustdesk; do
      [ -z "$RUSTDESK_CLI" ] || break
      if command -v "$candidate" >/dev/null 2>&1 || [ -x "$candidate" ]; then
        RUSTDESK_CLI="$candidate"
        break
      fi
    done
    if [ -z "$RUSTDESK_CLI" ]; then
      echo "RustDesk client not found locally" >&2
      exit 1
    fi

    PASSWORD_ARG=""
    if [ -n "${RUSTDESK_PASSWORD:-}" ]; then
      PASSWORD_ARG="--password"
    fi

    echo "Connecting to RustDesk ID $ID..."
    nohup "$RUSTDESK_CLI" --connect "$ID" ${PASSWORD_ARG:+"$PASSWORD_ARG" "$RUSTDESK_PASSWORD"} >/dev/null 2>&1 &
    ;;
  info|*)
    echo "RustDesk ID:  $ID"
    echo "Server:       ${SERVER:-(default)}"
    echo "Key:          ${KEY:-(not set)}"
    ;;
esac
