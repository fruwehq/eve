#!/usr/bin/env ruby
# Delete a concrete local VM instance entry from the instance registry.
# Optionally removes the generated workdir and state files.

require "fileutils"
require "json"
require "open3"
require "tempfile"
require "yaml"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"
DEFAULT_REGISTRY_PATH = Eve::SDK::Workdir.instance_registry_path

def with_registry_lock(registry_path)
  FileUtils.mkdir_p(File.dirname(registry_path))
  File.open("#{registry_path}.lock", File::RDWR | File::CREAT, 0o600) do |lock|
    lock.flock(File::LOCK_EX)
    yield
  end
end

def write_registry!(registry_path, registry)
  Tempfile.create(["eve-registry-", ".yaml"], File.dirname(registry_path)) do |tmp|
    tmp.write(registry.to_yaml)
    tmp.close
    FileUtils.mv(tmp.path, registry_path)
  end
end

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-delete --instance <name> [options]

    Options:
      --registry <path>
      --purge   Remove generated workdir and state files
      --force   Delete the registry entry even when observed state suggests
                provider resources may still exist. Use only after confirming
                the cloud-side VM was already destroyed.
  USAGE
end

instance_name = nil
registry_path = ENV["EVE_INSTANCE_REGISTRY"] && !ENV["EVE_INSTANCE_REGISTRY"].empty? \
                ? File.expand_path(ENV["EVE_INSTANCE_REGISTRY"], Dir.pwd) \
                : DEFAULT_REGISTRY_PATH
purge = false
force = false

args = ARGV.dup
until args.empty?
  case args.shift
  when "--instance"
    instance_name = args.shift
  when "--registry"
    registry_path = File.expand_path(args.shift, Dir.pwd)
  when "--purge"
    purge = true
  when "--force"
    force = true
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless instance_name && !instance_name.empty?
  usage
  exit 2
end

if instance_name !~ /\A[A-Za-z0-9][A-Za-z0-9._-]*\z/
  warn "instance-delete: invalid instance name: #{instance_name.inspect}"
  exit 2
end

paths = nil

with_registry_lock(registry_path) do
  unless File.exist?(registry_path)
    warn "instance-delete: registry not found: #{registry_path}"
    exit 1
  end

  registry = YAML.safe_load(File.read(registry_path), permitted_classes: [], aliases: true) || {}
  registry["instances"] ||= []

  index = registry["instances"].index { |e| e.is_a?(Hash) && e["name"] == instance_name }
  unless index
    warn "instance-delete: instance not found: #{instance_name}"
    exit 1
  end

  # Refuse to drop a registry entry whose provider resources may still
  # exist. A user who runs `make instance.delete` without first running
  # `make down` can otherwise leak billable cloud VMs whose only handle
  # was the registry entry. Bypass with --force after manually
  # confirming the cloud side is gone.
  #
  # `absent` = provider resources confirmed destroyed.
  # `unknown` = no provider lifecycle has ever recorded state (fresh
  #             instance, or only package ops have run); safe to drop
  #             the entry.
  # Anything else (running/stopped/error/changing/...) means a
  # provider lifecycle has touched the cloud side and we cannot
  # confirm it's gone.
  unless force
    state_path = Eve::SDK::Workdir.state_path(instance_name)
    if File.exist?(state_path)
      state = Eve::SDK::State.read(instance_name)
      provider_state = state["provider_state"]
      safe_states = %w[absent unknown]
      if provider_state && !safe_states.include?(provider_state)
        warn <<~MSG
          instance-delete: refusing to delete #{instance_name}; provider_state=#{provider_state}.
          Provider resources may still exist (cloud VM, terraform state, etc.).

          Recommended:
            make down INSTANCE=#{instance_name}     # destroys provider resources
            make instance.delete INSTANCE=#{instance_name}#{purge ? " PURGE=1" : ""}

          Or bypass this check if you have already destroyed the cloud side:
            make instance.delete INSTANCE=#{instance_name}#{purge ? " PURGE=1" : ""} FORCE=1
        MSG
        exit 1
      end
    end
  end

  if purge
    out, status = Open3.capture2e(
      File.join(ROOT, "scripts/instance-paths"),
      "--registry", registry_path,
      "--instance", instance_name,
      "--emit", "json"
    )
    unless status.success?
      warn out
      exit 1
    end
    paths = JSON.parse(out)
  end

  registry["instances"].delete_at(index)

  if registry["instances"].empty?
    FileUtils.rm_f(registry_path)
  else
    write_registry!(registry_path, registry)
  end
end

puts "Deleted instance: #{instance_name}"
puts "Registry: #{registry_path}"

if purge
  workdir = paths.fetch("INSTANCE_WORKDIR")

  if File.exist?(workdir)
    FileUtils.rm_rf(workdir)
    puts "Removed workdir: #{workdir}"
  end

  Eve::SDK::State.delete!(instance_name)
  puts "Removed state: #{paths.fetch("INSTANCE_STATE_PATH")}"
end
