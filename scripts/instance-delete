#!/usr/bin/env python3
from __future__ import annotations

import fcntl
import os
import re
import shutil
import sys
import tempfile
from contextlib import contextmanager
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import run_json  # noqa: E402
from eve_sdk.resolve import default_registry_path  # noqa: E402
from eve_sdk.state import State  # noqa: E402
from eve_sdk.workdir import Workdir  # noqa: E402


@contextmanager
def registry_lock(registry_path: Path) -> Any:
    registry_path.parent.mkdir(parents=True, exist_ok=True)
    lock_path = Path(f"{registry_path}.lock")
    with lock_path.open("a+b") as lock:
        os.chmod(lock_path, 0o600)
        fcntl.flock(lock.fileno(), fcntl.LOCK_EX)
        try:
            yield
        finally:
            fcntl.flock(lock.fileno(), fcntl.LOCK_UN)


def load_registry(registry_path: Path) -> dict[str, Any]:
    loaded = yaml.safe_load(registry_path.read_text(encoding="utf-8")) or {}
    if not isinstance(loaded, dict):
        raise ValueError(f"{registry_path}: registry must be a mapping")
    loaded.setdefault("instances", [])
    return loaded


def write_registry(registry_path: Path, registry: dict[str, Any]) -> None:
    with tempfile.NamedTemporaryFile(
        "w",
        encoding="utf-8",
        dir=registry_path.parent,
        prefix="eve-registry-",
        suffix=".yaml",
        delete=False,
    ) as tmp:
        tmp.write(yaml.safe_dump(registry, sort_keys=False))
        tmp_name = tmp.name
    os.replace(tmp_name, registry_path)


def usage() -> None:
    print(
        """Usage:
  scripts/instance-delete --instance <name> [options]

Options:
  --registry <path>
  --purge   Remove generated workdir and state files
  --force   Delete the registry entry even when observed state suggests
            provider resources may still exist. Use only after confirming
            the cloud-side VM was already destroyed.""",
        file=sys.stderr,
    )


def main(argv: list[str]) -> int:
    instance_name: str | None = None
    registry_path = Path(os.environ.get("EVE_INSTANCE_REGISTRY") or default_registry_path()).resolve()
    purge = False
    force = False
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = Path(args.pop(0)).resolve()
        elif arg == "--purge":
            purge = True
        elif arg == "--force":
            force = True
        elif arg in {"-h", "--help"}:
            usage()
            return 0
        else:
            usage()
            return 2
    if not instance_name:
        usage()
        return 2
    if not re.match(r"^[A-Za-z0-9][A-Za-z0-9._-]*$", instance_name):
        print(f"instance-delete: invalid instance name: {instance_name!r}", file=sys.stderr)
        return 2

    paths: dict[str, str] | None = None
    try:
        with registry_lock(registry_path):
            if not registry_path.exists():
                print(f"instance-delete: registry not found: {registry_path}", file=sys.stderr)
                return 1
            registry = load_registry(registry_path)
            instances = registry["instances"]
            index = next(
                (
                    idx
                    for idx, entry in enumerate(instances)
                    if isinstance(entry, dict) and entry.get("name") == instance_name
                ),
                None,
            )
            if index is None:
                print(f"instance-delete: instance not found: {instance_name}", file=sys.stderr)
                return 1
            if not force:
                state_path = Workdir.state_path(instance_name)
                if state_path.exists():
                    state = State.read(instance_name)
                    provider_state = state.get("provider_state")
                    if provider_state and provider_state not in {"absent", "unknown"}:
                        observed = state.get("observed_state", {})
                        observed_status = observed.get("provider_status") if isinstance(observed, dict) else None
                        if observed_status != "absent":
                            suffix = " --purge" if purge else ""
                            print(
                                f"instance-delete: refusing to delete {instance_name}; "
                                f"provider_state={provider_state}.\n"
                                "Provider resources may still exist (cloud VM, terraform state, etc.).\n"
                                "\n"
                                "Recommended:\n"
                                f"  eve instance down --instance {instance_name}     # destroys provider resources\n"
                                f"  eve instance delete --instance {instance_name}{suffix}\n"
                                "\n"
                                "Or bypass this check if you have already destroyed the cloud side:\n"
                                f"  eve instance delete --instance {instance_name}{suffix} --force",
                                file=sys.stderr,
                            )
                            return 1
            if purge:
                paths = run_json(
                    str(ROOT / "scripts/instance-paths"),
                    "--registry",
                    str(registry_path),
                    "--instance",
                    instance_name,
                    "--emit",
                    "json",
                )
            instances.pop(index)
            if not instances:
                registry_path.unlink(missing_ok=True)
            else:
                write_registry(registry_path, registry)
        print(f"Deleted instance: {instance_name}")
        print(f"Registry: {registry_path}")
        if purge and paths:
            workdir = Path(paths["INSTANCE_WORKDIR"])
            if workdir.exists():
                shutil.rmtree(workdir)
                print(f"Removed workdir: {workdir}")
            State.delete(instance_name)
            print(f"Removed state: {paths['INSTANCE_STATE_PATH']}")
        return 0
    except Exception as error:
        print(f"instance-delete: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
