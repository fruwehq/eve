#!/usr/bin/env python3
"""Add/remove bundle selections on a concrete instance registry entry."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.registry_selection import (  # noqa: E402
    load_registry,
    mutate_selection,
    registry_lock,
    registry_path,
    validate_registry,
    write_registry,
)


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/bundle-selection",
        usage="scripts/bundle-selection --instance <name> --bundle <id> --add [--registry <path>]",
    )
    arg_parser.add_argument("--instance", required=True)
    arg_parser.add_argument("--bundle", required=True, dest="bundle_id")
    arg_parser.add_argument("--add", action="store_true")
    arg_parser.add_argument("--remove", action="store_true")
    arg_parser.add_argument("--registry")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    if args.add == args.remove:
        parser().print_usage(sys.stderr)
        return 2
    action = "add" if args.add else "remove"
    path = registry_path(args.registry)
    try:
        with registry_lock(path):
            registry = load_registry(path, "bundle-selection")
            mutate_selection(
                command_name="bundle-selection",
                instance_name=args.instance,
                item_id=args.bundle_id,
                action=action,
                field="bundles",
                registry=registry,
            )
            validate_registry(ROOT, registry, args.instance, "bundle-selection")
            write_registry(path, registry)
    except RuntimeError as error:
        print(error, file=sys.stderr)
        return 1

    print(f"{'Selected' if action == 'add' else 'Unselected'} bundle: {args.bundle_id}")
    print(f"Instance: {args.instance}")
    print(f"Registry: {path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
