#!/usr/bin/env python3
"""Open the VM's graphical console for a local profile.

Usage: scripts/remote-console <instance>

QEMU: not implemented; use VNC/RustDesk/Waypipe/Xpra inside the guest.
"""

from __future__ import annotations

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import repo_root, resolve_env  # noqa: E402


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/remote-console <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    provider = resolved.get("PROVIDER", "")
    if engine != "vagrant":
        print(
            f"remote.console is only supported for local (vagrant) profiles. "
            f"Provider: {provider}",
            file=sys.stderr,
        )
        return 1
    if provider == "local-qemu":
        print(
            "remote.console is not implemented for local-qemu. "
            "Use SSH or provision a remote GUI package.",
            file=sys.stderr,
        )
        return 2
    print(f"remote.console: unsupported local provider: {provider}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
