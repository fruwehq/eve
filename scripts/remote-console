#!/usr/bin/env bash
# Open the VM's graphical console for a local profile.
# Usage: scripts/remote-console <profile>
#
# QEMU: not implemented; use VNC/RustDesk/Waypipe/Xpra inside the guest.

set -euo pipefail

PROFILE="${1:?Usage: scripts/remote-console <profile>}"
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')

if [ "$ENGINE" != "vagrant" ]; then
  echo "remote.console is only supported for local (vagrant) profiles. Provider: $PROVIDER" >&2
  exit 1
fi

case "$PROVIDER" in
  local-qemu)
    echo "remote.console is not implemented for local-qemu. Use SSH or provision a remote GUI package." >&2
    exit 2
    ;;
  *)
    echo "remote.console: unsupported local provider: $PROVIDER" >&2
    exit 1
    ;;
esac
