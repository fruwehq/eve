#!/usr/bin/env python3
"""eve-local-install — thin on-instance runner.

Executes a flattened step bundle on the instance side. Designed for
Dockerfile ``RUN`` or direct SSH invocation. The host ships a
``steps.json`` bundle; this runner executes it and records observed state.

Usage:
  eve-local-install                    # run from ~/.eve/install/steps.json
  eve-local-install --bundle PATH      # run from a specific bundle
  eve-local-install --status           # show last observed state
  eve-local-install --dry-run          # print what would run without executing

The step bundle is a JSON object:
  {
    "instance": "dev-a",
    "os_family": "ubuntu",
    "steps": [
      {"name": "base.sh", "script": "#!/bin/sh\\necho base"},
      {"name": "docker.sh", "script": "#!/bin/sh\\napt-get install -y docker.io"}
    ],
    "config": {"VM_USER_NAME": "ubuntu", "TIMEZONE": "UTC"}
  }

Observed state is written to ``~/.eve/install/state.json`` — each step's
status (pending/running/succeeded/failed/skipped), timing, and exit code.
Re-runs only execute steps whose desired script changed since last run
(enables edit-config → rebuild without re-running everything).
"""
from __future__ import annotations

import hashlib
import json
import os
import subprocess
import sys
import tempfile
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

INSTALL_DIR = Path(os.environ.get("EVE_INSTALL_DIR", str(Path.home() / ".eve" / "install")))
STEPS_FILE = INSTALL_DIR / "steps.json"
STATE_FILE = INSTALL_DIR / "state.json"


def _now() -> str:
    return datetime.now(UTC).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def _load_bundle(path: Path | None) -> dict[str, Any]:
    bundle_path = path or STEPS_FILE
    if not bundle_path.exists():
        print(f"eve-local-install: no step bundle found at {bundle_path}", file=sys.stderr)
        print("Run 'eve install <instance>' on the host first to generate"
              " and ship the bundle.", file=sys.stderr)
        raise SystemExit(1)
    return json.loads(bundle_path.read_text(encoding="utf-8"))


def _load_state() -> dict[str, Any]:
    if STATE_FILE.exists():
        try:
            return json.loads(STATE_FILE.read_text(encoding="utf-8"))
        except Exception:
            pass
    return {"steps": {}}


def _save_state(state: dict[str, Any]) -> None:
    INSTALL_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(json.dumps(state, indent=2) + "\n", encoding="utf-8")


def _step_hash(script: str) -> str:
    return hashlib.sha256(script.encode()).hexdigest()[:16]


def _run_step(step: dict[str, Any], config: dict[str, str], os_family: str) -> dict[str, Any]:
    name = step.get("name", "unknown")
    script = step.get("script", "")
    suffix = ".ps1" if os_family == "windows" else ".sh"
    if os_family == "windows":
        interpreter = ["powershell", "-NoProfile", "-ExecutionPolicy", "Bypass", "-File"]
    else:
        interpreter = ["bash"]

    started = _now()
    with tempfile.NamedTemporaryFile(mode="w", suffix=suffix, delete=False, encoding="utf-8") as f:
        f.write(script)
        f.flush()
        step_path = f.name

    try:
        os.chmod(step_path, 0o755)
        env = {**os.environ, **config}
        result = subprocess.run([*interpreter, step_path], env=env, capture_output=True, text=True, check=False)
        ended = _now()
        status = "succeeded" if result.returncode == 0 else "failed"
        if result.stdout:
            print(result.stdout, end="")
        if result.stderr:
            print(result.stderr, end="", file=sys.stderr)
        return {
            "name": name,
            "status": status,
            "started_at": started,
            "ended_at": ended,
            "exit_code": result.returncode,
        }
    finally:
        Path(step_path).unlink(missing_ok=True)


def main(argv: list[str]) -> int:
    bundle_path: Path | None = None
    dry_run = False
    show_status = False
    force = False

    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--bundle" and i + 1 < len(argv):
            bundle_path = Path(argv[i + 1])
            i += 2
        elif arg == "--dry-run":
            dry_run = True
            i += 1
        elif arg == "--status":
            show_status = True
            i += 1
        elif arg == "--force":
            force = True
            i += 1
        elif arg in ("-h", "--help"):
            print(__doc__)
            return 0
        else:
            print(f"eve-local-install: unknown argument: {arg}", file=sys.stderr)
            return 2

    if show_status:
        state = _load_state()
        steps = state.get("steps", {})
        if not steps:
            print("No steps have been run yet.")
            return 0
        for name, info in steps.items():
            print(f"  {info.get('status', 'unknown'):10} {name}")
        return 0

    bundle = _load_bundle(bundle_path)
    os_family = bundle.get("os_family", "ubuntu")
    config = bundle.get("config", {})
    steps = bundle.get("steps", [])
    prev_state = _load_state()
    prev_steps = prev_state.get("steps", {})

    INSTALL_DIR.mkdir(parents=True, exist_ok=True)

    overall_status = "running"
    started_at = _now()
    results: dict[str, Any] = {}

    for step in steps:
        name = step.get("name", "unknown")
        script = step.get("script", "")
        desired_hash = _step_hash(script)

        if not force and name in prev_steps:
            prev = prev_steps[name]
            if prev.get("hash") == desired_hash and prev.get("status") == "succeeded":
                results[name] = prev
                print(f"  [SKIP] {name} (unchanged, already succeeded)")
                continue

        if dry_run:
            print(f"  [DRY] {name}")
            results[name] = {"name": name, "status": "pending", "hash": desired_hash}
            continue

        print(f"  [RUN] {name}")
        result = _run_step(step, config, os_family)
        result["hash"] = desired_hash
        results[name] = result
        if result["status"] == "failed":
            overall_status = "failed"
            break

    if overall_status != "failed":
        overall_status = "done"

    new_state = {
        "api_version": 1,
        "os_family": os_family,
        "started_at": started_at,
        "finished_at": _now(),
        "status": overall_status,
        "steps": results,
    }

    if not dry_run:
        _save_state(new_state)
        print(f"\nProvisioning {'complete' if overall_status == 'done' else 'failed'} ({len(results)} steps).")
    else:
        print(f"\nDry run: {len(results)} steps would execute.")

    return 0 if overall_status != "failed" else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
