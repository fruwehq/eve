#!/usr/bin/env python3
from __future__ import annotations

import os
import subprocess
import sys
from datetime import UTC, datetime, timedelta
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.state import State, StateError  # noqa: E402

DEFAULT_TTL_SECONDS = 30


def usage() -> None:
    print("Usage:\n  scripts/instance-observe --instance <name> [--ttl <seconds>]", file=sys.stderr)


def run_command(env: dict[str, str], *cmd: str) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        list(cmd),
        cwd=ROOT,
        env=os.environ | env,
        text=True,
        capture_output=True,
        check=False,
    )


def normalize_provider_status(value: str) -> str:
    normalized = value.strip().lower()
    if normalized in {"running", "stopped"}:
        return normalized
    if normalized in {"not created", "not-created", "absent"}:
        return "absent"
    if normalized in {"unreachable", "error", "failed"}:
        return "unreachable"
    return normalized if normalized else "unknown"


def parse_status_output(output: str) -> dict[str, object]:
    observed: dict[str, object] = {}
    for line in output.splitlines():
        parts = [part.strip() for part in line.split(":", 1)]
        if len(parts) != 2:
            continue
        key, value = parts
        if key == "Status":
            observed["provider_status"] = normalize_provider_status(value)
        elif key == "IP" and value:
            observed["ip"] = value
        elif key == "Control":
            observed["control_reachable"] = value.startswith("reachable")
            observed["control_summary"] = value
    return observed


def main(argv: list[str]) -> int:
    instance: str | None = None
    ttl = DEFAULT_TTL_SECONDS
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance = args.pop(0)
        elif arg == "--ttl" and args:
            ttl = int(args.pop(0))
        elif arg in {"-h", "--help"}:
            usage()
            return 0
        else:
            usage()
            return 2
    if not instance:
        usage()
        return 2
    try:
        now = datetime.now(UTC).replace(microsecond=0)
        observed: dict[str, object] = {
            "observed_at": now.isoformat().replace("+00:00", "Z"),
            "expires_at": (now + timedelta(seconds=ttl)).isoformat().replace("+00:00", "Z"),
        }
        env = {"EVE_DISABLE_STATE": "1"}
        status = run_command(
            env, str(ROOT / "scripts/provider-dispatch"), "--instance", instance, "--command", "status"
        )
        if status.returncode == 0:
            observed.update(parse_status_output(status.stdout))
            observed["provider_status_raw"] = status.stdout.strip()
            observed["refresh_error"] = None
            if observed.get("provider_status") == "running" and not observed.get("ip"):
                ip = run_command(env, str(ROOT / "scripts/instance-run"), "ip", instance)
                if ip.returncode == 0 and ip.stdout.strip():
                    observed["ip"] = ip.stdout.strip()
                else:
                    observed["refresh_error"] = ip.stderr.strip() or ip.stdout.strip()
        else:
            error = status.stderr.strip() or status.stdout.strip()
            observed["refresh_error"] = error
            if any(token in error.lower() for token in ["unreachable", "timed out", "timeout", "connect"]):
                observed["control_reachable"] = False
        observed.setdefault("provider_status", "unknown")
        state = State.update_observed(instance, observed)
        import json

        print(json.dumps(state, indent=2))
        return 0
    except (StateError, Exception) as error:
        print(f"instance-observe: {error}", file=sys.stderr)
        return 2 if isinstance(error, StateError) else 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
