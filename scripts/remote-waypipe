#!/usr/bin/env python3
"""Run a remote Wayland app through waypipe.

Usage: scripts/remote-waypipe <instance> [app [args...]]
"""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    exec_replace,
    has_command,
    instance_ip,
    instance_workdir,
    repo_root,
    resolve_env,
    resolve_private_key,
    vagrant_ssh_config,
    waypipe_ssh_command,
    waypipe_ssh_opts,
    waypipe_vagrant_command,
)


def main(argv: list[str]) -> int:
    if not argv:
        print("Usage: scripts/remote-waypipe <instance> [app [args...]]", file=sys.stderr)
        return 2
    profile = argv[0]
    app = argv[1:] or ["foot"]
    root = repo_root()

    if not has_command("waypipe"):
        print("remote-waypipe: local waypipe is not installed.", file=sys.stderr)
        print("  macOS: brew tap J-x-Z/tap && brew install cocoa-way waypipe-darwin", file=sys.stderr)
        return 2

    if not os.environ.get("WAYLAND_DISPLAY"):
        print("remote-waypipe: WAYLAND_DISPLAY is not set on the local machine.", file=sys.stderr)
        if os.environ.get("DISPLAY"):
            print(
                f"  DISPLAY={os.environ['DISPLAY']} is an X11/XQuartz display, "
                "not a Wayland socket.",
                file=sys.stderr,
            )
        print("  Start Cocoa-Way first: cocoa-way", file=sys.stderr)
        find_result = subprocess.run(
            ["find", "/var/folders", "/tmp", "-type", "d", "-name", "cocoa-way"],
            capture_output=True, text=True, check=False,
        )
        lines = find_result.stdout.splitlines()
        first = lines[0] if lines else ""
        print(f'  Then export XDG_RUNTIME_DIR="{first}"', file=sys.stderr)
        print("  And export WAYLAND_DISPLAY=wayland-1 before retrying.", file=sys.stderr)
        return 2

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    provider = resolved.get("PROVIDER", "")
    os_family = resolved.get("OS_FAMILY", "")

    if os_family != "ubuntu":
        print("remote-waypipe: waypipe is currently implemented for Ubuntu instances only.", file=sys.stderr)
        return 2

    if engine == "vagrant":
        subprocess.run(
            [str(root / "scripts/vagrant-up"), "--plan", profile],
            cwd=root, stdout=subprocess.DEVNULL, check=False,
        )
        workdir = instance_workdir(root, profile)
        tmp_config = tempfile.mktemp(prefix="eve-waypipe-ssh.", dir=os.environ.get("TMPDIR", "/tmp"))
        config = vagrant_ssh_config(workdir)
        Path(tmp_config).write_text(config)
        try:
            exec_replace(waypipe_vagrant_command(tmp_config, app))
        finally:
            Path(tmp_config).unlink(missing_ok=True)
        return 0  # unreachable

    ssh_user = resolved.get("SSH_USER", "")
    raspberry_pi_ip = resolved.get("RASPBERRY_PI_IP", "")
    if engine == "metal" and provider == "raspberry-pi" and raspberry_pi_ip:
        ip = raspberry_pi_ip
    else:
        ip = instance_ip(root, profile)
    if not ip:
        print(f"remote-waypipe: could not resolve IP for {profile}", file=sys.stderr)
        return 1

    priv_key = resolve_private_key()
    ssh_opts = waypipe_ssh_opts(priv_key)
    exec_replace(waypipe_ssh_command(ssh_opts, f"{ssh_user}@{ip}", app))
    return 0  # unreachable


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
