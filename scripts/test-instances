#!/usr/bin/env python3
# ruff: noqa: E501, E701
"""Validate fixture instances hermetically (synthetic mock plugins only)."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
os.environ["EVE_PLUGIN_ROOTS"] = str(ROOT / "tests/fixtures/hermetic")
os.environ["EVE_PLUGIN_ROOTS_EXCLUSIVE"] = "1"
os.environ.setdefault("EVE_HOME", tempfile.mkdtemp(prefix="eve-instances."))
sys.path.insert(0, str(ROOT))

FIXTURE = str(ROOT / "tests/fixtures/hermetic/instances.yaml")
GOLDEN_DIR = ROOT / "tests/golden/instances"
UPDATE = os.environ.get("UPDATE_GOLDEN", "0") == "1"
FAIL = 0

_UNSET = [
    "MOCK_REGION", "MOCK_API_KEY", "SSH_PUBLIC_KEY_FILE", "VM_USER_NAME",
    "EVE_CONFIG_PATH", "EVE_HOME",
]
for _v in _UNSET:
    os.environ.pop(_v, None)


def _run(*args, env=None, timeout=120):
    e = {**os.environ, **(env or {})}
    cmd = list(args)
    if cmd and not cmd[0].startswith(("/", "python", "rg")):
        cmd[0] = str(ROOT / cmd[0])
    return subprocess.run(cmd, cwd=str(ROOT), env=e, capture_output=True, text=True, check=False, timeout=timeout)


def _run_json(*args, env=None):
    r = _run(*args, env=env)
    if r.returncode != 0 or not r.stdout.strip():
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def _ok(label): print(f"  [OK] {label}")
def _fail(label, detail=""):
    global FAIL
    print(f"  [FAIL] {label}", file=sys.stderr)
    if detail: print(detail, file=sys.stderr)
    FAIL += 1
def _check(label, cond, detail=""):
    if cond: _ok(label)
    else: _fail(label, detail)


def _extract(env_text, key):
    for line in env_text.splitlines():
        if line.startswith(f"{key}="):
            return line[len(key) + 1:]
    return ""


def main():
    global FAIL

    # --- OS provisioning folders ---
    _check("root OS provisioning folders live under oses/",
          not any((ROOT / d).is_dir() for d in ["linux", "windows"]))

    # --- instance list + golden comparison ---
    ilist = _run_json("scripts/instance-list", "--registry", FIXTURE, "--json")
    instances = [i["name"] for i in (ilist or {}).get("instances", [])] if ilist else []
    _check("instance-list returns mock fixtures", len(instances) == 3 and "mock-dev-a" in instances)

    for inst in instances:
        vr = _run("scripts/instance-resolve", "--registry", FIXTURE, "--instance", inst, "--validate")
        if vr.returncode != 0:
            _fail(f"validate: {inst}", vr.stderr)
            continue
        env_out = _run("scripts/instance-resolve", "--registry", FIXTURE, "--instance", inst, "--emit", "env")
        actual = "\n".join(sorted(env_out.stdout.splitlines()))
        golden = GOLDEN_DIR / f"{inst}.env"
        if UPDATE:
            golden.write_text(actual + "\n", encoding="utf-8")
            print(f"  [UPDATE] {golden}")
            continue
        if not golden.exists():
            _fail(f"missing golden: {golden}")
            continue
        expected = golden.read_text(encoding="utf-8").rstrip("\n")
        _check(inst, actual == expected)

    # --- access defaults ---
    tj = _run_json("scripts/instance-resolve", "--registry", FIXTURE, "--instance", "mock-dev-a", "--emit", "json")
    _check("access defaults resolve from manifest",
          tj is not None and tj.get("access", {}).get("bootstrap_user") == "mock-user" and
          tj["access"]["provision_user"] == "mock-user" and tj["access"]["human_user"] == "mock-user")

    # --- structured config ---
    tmp_dir = tempfile.mkdtemp(prefix="eve-instance-overlay.")
    tmp_config = str(Path(tmp_dir) / "config.yaml")
    Path(tmp_config).write_text("display:\n  resolution: 5120x1440\nglobal:\n  vm_user_name: eve-user\n", encoding="utf-8")
    ce = _run("scripts/config-env", "--make", env={"EVE_CONFIG_PATH": tmp_config}).stdout
    _check("structured config emits non-secret environment overrides",
          "EPHEMERAL_DISPLAY_RESOLUTION=5120x1440" in ce and "VM_USER_NAME=eve-user" in ce)

    tmp_reg = tempfile.mktemp(prefix="eve-instance-test.")
    try:
        # --- create valid instance ---
        cr = _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "test-dev",
                  "--machine", "mock-small", "--os", "mockos-1.0-arm64", "--init", "ssh-mockos-cloud-init",
                  "--location", "mock-tokyo", "--bundles", "mock-dev", "--disk-gb", "30", "--memory-mb", "2048")
        dj = _run_json("scripts/instance-resolve", "--registry", tmp_reg, "--instance", "test-dev", "--emit", "json")
        _check("create valid instance", cr.returncode == 0 and dj is not None and
              "mock-app" in dj.get("bundle_packages", []))

        # --- create with inferred init ---
        cr2 = _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "direct-dev",
                   "--machine", "mock-small", "--os", "mockos-1.0-arm64", "--location", "mock-tokyo",
                   "--bundles", "mock-dev")
        dj2 = _run_json("scripts/instance-resolve", "--registry", tmp_reg, "--instance", "direct-dev", "--emit", "json")
        _check("create with inferred init", cr2.returncode == 0 and dj2 is not None and
              dj2.get("composition", {}).get("init") == "ssh-mockos-cloud-init")

        # --- reject invalid instance ---
        before = Path(tmp_reg).read_text(encoding="utf-8") if Path(tmp_reg).exists() else ""
        ir = _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "bad-a",
                  "--machine", "no-such-machine", "--os", "mockos-1.0-amd64", "--location", "mock-tokyo")
        after = Path(tmp_reg).read_text(encoding="utf-8") if Path(tmp_reg).exists() else ""
        _check("reject invalid instance without registry write", ir.returncode != 0 and before == after)

        # --- delete instance ---
        dr = _run("scripts/instance-delete", "--registry", tmp_reg, "--instance", "test-dev")
        vr = _run("scripts/instance-resolve", "--registry", tmp_reg, "--instance", "test-dev", "--emit", "json")
        _check("delete instance removes from registry", dr.returncode == 0 and vr.returncode != 0)

        # --- delete non-existent ---
        _check("delete non-existent instance fails",
              _run("scripts/instance-delete", "--registry", tmp_reg, "--instance", "test-dev").returncode != 0)

        # --- create resets stale state ---
        stale_state = f"{tmp_dir}/stale-state"
        _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "stale-dev",
             "--machine", "mock-small", "--os", "mockos-1.0-arm64", "--location", "mock-tokyo", "--bundles", "mock-dev",
             env={"EVE_STATE_DIR": stale_state})
        _run("scripts/instance-state", "--instance", "stale-dev", "--operation", "package.mock-app.status",
             "--status", "succeeded", "--package", "mock-app", "--package-state", "installed", env={"EVE_STATE_DIR": stale_state})
        _run("scripts/instance-delete", "--registry", tmp_reg, "--instance", "stale-dev", env={"EVE_STATE_DIR": stale_state})
        stale_exists = Path(stale_state).joinpath("instances/stale-dev.json").exists()
        _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "stale-dev",
             "--machine", "mock-small", "--os", "mockos-1.0-arm64", "--location", "mock-tokyo", "--bundles", "mock-dev",
             env={"EVE_STATE_DIR": stale_state})
        stale_gone = not Path(stale_state).joinpath("instances/stale-dev.json").exists()
        _check("create resets stale local instance state", stale_exists and stale_gone)

        # --- instance-delete safety ---
        safety_state = f"{tmp_dir}/safety-state"
        _run("scripts/instance-create", "--registry", tmp_reg, "--instance", "safety-dev",
             "--machine", "mock-small", "--os", "mockos-1.0-arm64", "--location", "mock-tokyo")
        _run("scripts/instance-state", "--instance", "safety-dev", "--operation", "provider.up",
             "--status", "succeeded", "--provider-state", "running", "--desired-state", "running", env={"EVE_STATE_DIR": safety_state})
        _check("instance-delete refuses when provider_state=running",
              _run("scripts/instance-delete", "--registry", tmp_reg, "--instance", "safety-dev",
                   env={"EVE_STATE_DIR": safety_state}).returncode != 0)
        _check("instance-delete --force bypasses safety check",
              _run("scripts/instance-delete", "--registry", tmp_reg, "--instance", "safety-dev", "--force",
                   env={"EVE_STATE_DIR": safety_state}).returncode == 0)

        # --- profile overlay ---
        overlay = f"{tmp_dir}/mock-dev-a.catalog.local.yaml"
        _run("scripts/instance-profile-overlay", "--registry", FIXTURE, "--instance", "mock-dev-a", "--output", overlay)
        _run("scripts/profile-resolve", "--profile", "mock-dev-a", "--validate", env={"EVE_CATALOG_LOCAL": overlay})
        _check("generated profile overlay validates", True)

        pe = _run("scripts/profile-resolve", "--profile", "mock-dev-a", "--emit", "env", env={"EVE_CATALOG_LOCAL": overlay}).stdout
        _check("profile overlay preserves instance overrides",
              "PROFILE_NAME=mock-dev-a" in pe and "VM_DISK_GB=30" in pe)

        # --- instance-paths distinct ---
        pa = _run("scripts/instance-paths", "--registry", FIXTURE, "--instance", "mock-dev-a", "--emit", "env",
                  env={"EVE_INSTANCE_WORKDIR": f"{tmp_dir}/paths", "EVE_STATE_DIR": f"{tmp_dir}/paths-state"}).stdout
        pb = _run("scripts/instance-paths", "--registry", FIXTURE, "--instance", "mock-gpu-a", "--emit", "env",
                  env={"EVE_INSTANCE_WORKDIR": f"{tmp_dir}/paths", "EVE_STATE_DIR": f"{tmp_dir}/paths-state"}).stdout
        _check("instance-paths resolves distinct workdir/state per instance",
              _extract(pa, "INSTANCE_WORKDIR") != _extract(pb, "INSTANCE_WORKDIR"))

        _check("instance-paths rejects unknown instance",
              _run("scripts/instance-paths", "--registry", FIXTURE, "--instance", "no-such", "--emit", "env").returncode != 0)
        _check("instance-paths rejects unsafe instance name",
              _run("scripts/instance-paths", "--registry", FIXTURE, "--instance", "../evil", "--emit", "env").returncode != 0)

        # --- instance state ---
        SE = {"EVE_STATE_DIR": f"{tmp_dir}/state"}
        empty = _run_json("scripts/instance-state", "--instance", "fresh-a", "--get", env=SE)
        _check("instance state get returns default state shape",
              empty is not None and empty.get("desired_state") == "unknown" and empty.get("package_state") == {})

        sj = _run_json("scripts/instance-state", "--instance", "mock-dev-a", "--operation", "package.down",
                       "--status", "succeeded", "--desired-state", "running", "--provider-state", "running",
                       "--package", "mock-app", "--package-state", "removed", env=SE)
        _check("instance state records package operation",
              sj is not None and sj["last_operation"]["name"] == "package.down" and sj["package_state"]["mock-app"]["status"] == "removed")

        # --- invalid state values ---
        _check("instance state rejects invalid provider_state",
              _run("scripts/instance-state", "--instance", "d", "--operation", "provider.status",
                   "--status", "succeeded", "--provider-state", "nonsense", env=SE).returncode != 0)

        # --- observed state ---
        os_j = _run_json("scripts/instance-state", "--instance", "observed-a",
                         "--observed-json", '{"provider_status":"running","ip":"10.0.0.10"}', env=SE)
        _check("instance state records observed facts without operations",
              os_j is not None and os_j["observed_state"]["ip"] == "10.0.0.10")

        # --- instance.status ---
        sj = _run_json("scripts/instance-status", "--instance", "mock-dev-a", "--json",
                       env={"EVE_INSTANCE_REGISTRY": FIXTURE, "EVE_INSTANCE_WORKDIR": f"{tmp_dir}/run", "EVE_STATE_DIR": f"{tmp_dir}/state"})
        _check("instance.status combines metadata, state, packages, and paths",
              sj is not None and sj.get("instance", {}).get("name") == "mock-dev-a" and
              sj.get("instance", {}).get("provider") == "mock-cloud")

        # --- ssh dry-run ---
        sd = _run_json("scripts/instance-ssh", "mock-dev-a", "--", "true",
                       env={"EVE_PROVIDER_DRY_RUN": "1", "EVE_INSTANCE_REGISTRY": FIXTURE})
        _check("instance-ssh dispatches through provider command",
              sd is not None and sd.get("provider") == "mock-cloud" and sd.get("command") == "ssh" and sd.get("dry_run") is True)

    finally:
        Path(tmp_reg).unlink(missing_ok=True)
        shutil.rmtree(tmp_dir, ignore_errors=True)

    return 1 if FAIL else 0


if __name__ == "__main__":
    raise SystemExit(main())
