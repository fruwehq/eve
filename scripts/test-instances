#!/usr/bin/env bash
# Validate fixture instances and compare emitted env to golden snapshots.
# Usage:        scripts/test-instances
# Refresh:      UPDATE_GOLDEN=1 scripts/test-instances

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

FIXTURE="tests/fixtures/instances.yaml"
GOLDEN_DIR="tests/golden/instances"
UPDATE="${UPDATE_GOLDEN:-0}"

mkdir -p "$GOLDEN_DIR"

# Keep output deterministic regardless of local host configuration.
unset TRUENAS_HOST TRUENAS_SSH_PORT TRUENAS_SSH_USER \
      TRUENAS_SSH_PRIVATE_KEY_FILE TRUENAS_SSH_HOST_KEY_FINGERPRINT \
      TRUENAS_API_KEY TRUENAS_API_USER SSH_PUBLIC_KEY_FILE \
      RASPBERRY_PI_HOST RASPBERRY_PI_IP VM_USER_NAME

FAIL=0
INSTANCES=$(./scripts/instance-list --registry "$FIXTURE" --json | jq -r '.instances[].name')

for instance in $INSTANCES; do
  if ! ./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --validate >/dev/null 2>&1; then
    printf '  [FAIL] validate: %s\n' "$instance" >&2
    ./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --validate >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  actual=$(./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --emit env | LC_ALL=C sort)
  golden="$GOLDEN_DIR/$instance.env"

  if [ "$UPDATE" = "1" ]; then
    printf '%s\n' "$actual" > "$golden"
    printf '  [UPDATE] %s\n' "$golden"
    continue
  fi

  if [ ! -f "$golden" ]; then
    printf '  [FAIL] missing golden: %s (run: UPDATE_GOLDEN=1 make test.instances)\n' "$golden" >&2
    FAIL=$((FAIL + 1))
    continue
  fi

  if ! diff -u "$golden" <(printf '%s\n' "$actual") >/dev/null; then
    printf '  [FAIL] golden mismatch: %s\n' "$instance" >&2
    diff -u "$golden" <(printf '%s\n' "$actual") >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  printf '  [OK] %s\n' "$instance"
done

tmp_registry="$(mktemp "${TMPDIR:-/tmp}/egame-instance-test.XXXXXX")"
tmp_external_registry="$(mktemp "${TMPDIR:-/tmp}/egame-instance-external.XXXXXX")"
invalid_output="$(mktemp "${TMPDIR:-/tmp}/egame-instance-test-output.XXXXXX")"
tmp_local_catalog="$(mktemp "${TMPDIR:-/tmp}/egame-instance-catalog.XXXXXX.yaml")"
tmp_overlay_dir="$(mktemp -d "${TMPDIR:-/tmp}/egame-instance-overlay.XXXXXX")"
trap 'rm -f "$tmp_registry" "$tmp_external_registry" "$invalid_output" "$tmp_local_catalog"; rm -rf "$tmp_overlay_dir"' EXIT
rm -f "$tmp_registry"

if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance test-dev \
  --recipe local-vmware-ubuntu-dev-gui \
  --packages steam \
  --disk-gb 90 \
  --memory-mb 8192 >/dev/null; then
  if ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --validate >/dev/null &&
    ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
      jq -e '.composition.packages == ["steam"] and (.bundle_packages | index("steam")) and .package_sources.steam == ["direct"]' >/dev/null; then
    printf '  [OK] create valid instance\n'
  else
    printf '  [FAIL] created instance did not validate\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] create valid instance\n' >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" make package.unselect INSTANCE=test-dev PACKAGE=steam >/dev/null &&
  ! ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '.bundle_packages | index("steam")' >/dev/null &&
  EGAME_INSTANCE_REGISTRY="$tmp_registry" make package.select INSTANCE=test-dev PACKAGE=steam >/dev/null &&
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '.composition.packages == ["steam"] and (.bundle_packages | index("steam")) and .package_sources.steam == ["direct"]' >/dev/null; then
  printf '  [OK] package selection updates direct instance packages\n'
else
  printf '  [FAIL] package selection updates direct instance packages\n' >&2
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json >&2 || true
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/direct" \
  make --no-print-directory env INSTANCE=test-dev |
  grep -q '^BUNDLE_PACKAGES=.*steam'; then
  printf '  [OK] profile overlay exposes direct instance packages\n'
else
  printf '  [FAIL] profile overlay exposes direct instance packages\n' >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
profiles:
  - name: local-vmware-ubuntu-dev-gui
    packages: [steam]
YAML
if EGAME_CATALOG_LOCAL="$tmp_local_catalog" ./scripts/instance-resolve --registry "$FIXTURE" --instance dev-a --emit json |
  jq -e '(.bundle_packages | index("steam")) and .package_sources.steam == ["direct"]' >/dev/null; then
  printf '  [OK] instance resolver honors EGAME_CATALOG_LOCAL\n'
else
  printf '  [FAIL] instance resolver honors EGAME_CATALOG_LOCAL\n' >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
machines:
  - name: acme-small
    provider: acme
    kind: vm
    defaults:
      disk_gb: 30
      memory_mb: 4096
profiles:
  - name: acme-test
    machine: acme-small
    os: ubuntu-26.04-amd64
    init: ssh-ubuntu-cloud-init
    bundles: [access-headless]
    location: tokyo
locations:
  - name: tokyo
    acme:
      region: test-region
YAML
cat >"$tmp_external_registry" <<'YAML'
version: 1
instances:
  - name: acme-a
    recipe: acme-test
YAML

if EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted provider without plugin\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'Provider plugin not found: acme' "$invalid_output"; then
  printf '  [OK] instance resolver rejects provider without plugin\n'
else
  printf '  [FAIL] instance resolver rejects provider without plugin\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_PLUGIN_ROOTS="tests/fixtures/plugins/providers/acme" EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --emit json |
  jq -e '.provider_plugin == "acme" and .machine.provider == "acme"' >/dev/null; then
  printf '  [OK] instance resolver accepts external provider plugin\n'
else
  printf '  [FAIL] instance resolver accepts external provider plugin\n' >&2
  EGAME_PLUGIN_ROOTS="tests/fixtures/plugins/providers/acme" EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
    ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --emit json >&2 || true
  FAIL=$((FAIL + 1))
fi

before_invalid="$(cat "$tmp_registry")"
if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance bad-a \
  --recipe no-such-recipe >"$invalid_output" 2>&1; then
  printf '  [FAIL] invalid instance create succeeded\n' >&2
  FAIL=$((FAIL + 1))
elif [ "$(cat "$tmp_registry")" = "$before_invalid" ]; then
  printf '  [OK] reject invalid instance without registry write\n'
else
  printf '  [FAIL] invalid instance create changed registry\n' >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-delete --registry "$tmp_registry" --instance test-dev >/dev/null; then
  if ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json >/dev/null 2>&1; then
    printf '  [FAIL] deleted instance still resolves\n' >&2
    FAIL=$((FAIL + 1))
  else
    printf '  [OK] delete instance removes from registry\n'
  fi
else
  printf '  [FAIL] delete instance\n' >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-delete --registry "$tmp_registry" --instance test-dev >/dev/null 2>&1; then
  printf '  [FAIL] delete non-existent instance succeeded\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] delete non-existent instance fails\n'
fi

purge_workdir="$tmp_overlay_dir/delete-work"
purge_state="$tmp_overlay_dir/delete-state"
if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance purge-dev \
  --recipe local-vmware-ubuntu-dev-gui >/dev/null; then
  mkdir -p "$purge_workdir/purge-dev" "$purge_state/instances"
  printf '{}\n' > "$purge_state/instances/purge-dev.json"
  if EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$purge_workdir" EGAME_STATE_DIR="$purge_state" \
    make package.select INSTANCE=purge-dev PACKAGE=steam >/dev/null &&
    EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$purge_workdir" EGAME_STATE_DIR="$purge_state" \
      make instance.delete INSTANCE=purge-dev PURGE=1 >/dev/null &&
    [ ! -e "$purge_workdir/purge-dev" ] &&
    [ ! -e "$purge_state/instances/purge-dev.json" ]; then
    printf '  [OK] delete purge honors env registry/workdir/state paths\n'
  else
    printf '  [FAIL] delete purge honors env registry/workdir/state paths\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] create purge test instance\n' >&2
  FAIL=$((FAIL + 1))
fi

overlay="$tmp_overlay_dir/dev-a.catalog.local.yaml"
if ./scripts/instance-profile-overlay --registry "$FIXTURE" --instance dev-a --output "$overlay"; then
  if EGAME_CATALOG_LOCAL="$overlay" ./scripts/profile-resolve --profile dev-a --validate >/dev/null; then
    printf '  [OK] generated profile overlay validates\n'
  else
    printf '  [FAIL] generated profile overlay did not validate\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] generate profile overlay\n' >&2
  FAIL=$((FAIL + 1))
fi

profile_env="$(EGAME_CATALOG_LOCAL="$overlay" ./scripts/profile-resolve --profile dev-a --emit env | LC_ALL=C sort)"
if printf '%s\n' "$profile_env" | grep -qx 'PROFILE_NAME=dev-a' &&
  printf '%s\n' "$profile_env" | grep -qx 'VM_DISK_GB=120' &&
  printf '%s\n' "$profile_env" | grep -qx 'VM_MEMORY_MB=12288' &&
  printf '%s\n' "$profile_env" | grep -qx 'STACK_TAGS=local-vmware'; then
  printf '  [OK] profile overlay preserves instance overrides\n'
else
  printf '  [FAIL] profile overlay env mismatch\n' >&2
  printf '%s\n' "$profile_env" >&2
  FAIL=$((FAIL + 1))
fi

bridge_env="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" make env INSTANCE=dev-a 2>/dev/null | LC_ALL=C sort)"
if printf '%s\n' "$bridge_env" | grep -qx 'PROFILE_NAME=dev-a' &&
  printf '%s\n' "$bridge_env" | grep -qx 'VM_DISK_GB=120' &&
  printf '%s\n' "$bridge_env" | grep -qx 'VM_MEMORY_MB=12288'; then
  printf '  [OK] make target routes INSTANCE through generated profile overlay\n'
else
  printf '  [FAIL] INSTANCE make bridge env mismatch\n' >&2
  printf '%s\n' "$bridge_env" >&2
  FAIL=$((FAIL + 1))
fi

extract() { printf '%s\n' "$1" | awk -F= -v key="$2" '$1 == key { print substr($0, index($0, "=") + 1) }'; }

paths_target="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" \
  make instance.paths INSTANCE=dev-a 2>/dev/null)"
paths_target_workdir="$(extract "$paths_target" INSTANCE_WORKDIR)"
paths_target_tf_state="$(extract "$paths_target" INSTANCE_TF_STATE_BASE)"
expected_paths_target_workdir="$(printf '%s' "$tmp_overlay_dir/run/dev-a" | tr -s /)"
expected_paths_target_tf_state="$(printf '%s' "$tmp_overlay_dir/run/dev-a/tf/state" | tr -s /)"
if [ "$paths_target_workdir" = "$expected_paths_target_workdir" ] &&
  [ "$paths_target_tf_state" = "$expected_paths_target_tf_state" ]; then
  printf '  [OK] make target exposes instance artifact paths\n'
else
  printf '  [FAIL] instance.paths make target output mismatch\n' >&2
  printf 'expected workdir:  %s\n' "$expected_paths_target_workdir" >&2
  printf 'actual workdir:    %s\n' "$paths_target_workdir" >&2
  printf 'expected tf state: %s\n' "$expected_paths_target_tf_state" >&2
  printf 'actual tf state:   %s\n' "$paths_target_tf_state" >&2
  printf '%s\n' "$paths_target" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" EGAME_STATE_DIR="$tmp_overlay_dir/state" \
  make status INSTANCE=aws-gpu-a >/dev/null 2>&1; then
  printf '  [OK] terraform-backed INSTANCE status uses isolated execution path\n'
else
  printf '  [FAIL] terraform-backed INSTANCE status should no longer be blocked\n' >&2
  EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" EGAME_STATE_DIR="$tmp_overlay_dir/state" \
    make status INSTANCE=aws-gpu-a >&2 || true
  FAIL=$((FAIL + 1))
fi

state_target="$(EGAME_STATE_DIR="$tmp_overlay_dir/state" make --no-print-directory instance.state INSTANCE=aws-gpu-a 2>/dev/null)"
if printf '%s\n' "$state_target" | jq -e '.last_operation.name == "provider.status"' >/dev/null; then
  printf '  [OK] make target exposes local instance state\n'
else
  printf '  [FAIL] instance.state make target output mismatch\n' >&2
  printf '%s\n' "$state_target" >&2
  FAIL=$((FAIL + 1))
fi

paths_workdir="$(printf '%s' "$tmp_overlay_dir/paths-work" | tr -s /)"
paths_state="$(printf '%s' "$tmp_overlay_dir/paths-state" | tr -s /)"
paths_a="$(EGAME_INSTANCE_WORKDIR="$paths_workdir" EGAME_STATE_DIR="$paths_state" \
  ./scripts/instance-paths --registry "$FIXTURE" --instance dev-a --emit env)"
paths_b="$(EGAME_INSTANCE_WORKDIR="$paths_workdir" EGAME_STATE_DIR="$paths_state" \
  ./scripts/instance-paths --registry "$FIXTURE" --instance aws-gpu-a --emit env)"

workdir_a="$(extract "$paths_a" INSTANCE_WORKDIR)"
workdir_b="$(extract "$paths_b" INSTANCE_WORKDIR)"
state_a="$(extract "$paths_a" INSTANCE_STATE_PATH)"
state_b="$(extract "$paths_b" INSTANCE_STATE_PATH)"
tf_a="$(extract "$paths_a" INSTANCE_TF_WORKDIR)"
tf_b="$(extract "$paths_b" INSTANCE_TF_WORKDIR)"
tf_state_a="$(extract "$paths_a" INSTANCE_TF_STATE_BASE)"
tf_state_b="$(extract "$paths_b" INSTANCE_TF_STATE_BASE)"
tf_data_a="$(extract "$paths_a" INSTANCE_TF_DATA_BASE)"
tf_data_b="$(extract "$paths_b" INSTANCE_TF_DATA_BASE)"

paths_failed=0
[ -n "$workdir_a" ] && [ -n "$workdir_b" ] || paths_failed=1
[ "$workdir_a" != "$workdir_b" ] || paths_failed=1
[ "$state_a" != "$state_b" ] || paths_failed=1
[ "$tf_a" != "$tf_b" ] || paths_failed=1
[ "$tf_state_a" != "$tf_state_b" ] || paths_failed=1
[ "$tf_data_a" != "$tf_data_b" ] || paths_failed=1
[ "$workdir_a" = "$paths_workdir/dev-a" ] || paths_failed=1
[ "$state_a" = "$paths_state/instances/dev-a.json" ] || paths_failed=1
[ "$tf_a" = "$paths_workdir/dev-a/tf" ] || paths_failed=1
[ "$tf_state_a" = "$paths_workdir/dev-a/tf/state" ] || paths_failed=1
[ "$tf_data_a" = "$paths_workdir/dev-a/tf/data" ] || paths_failed=1

if [ "$paths_failed" -eq 0 ]; then
  printf '  [OK] instance-paths resolves distinct workdir/state per instance\n'
else
  printf '  [FAIL] instance-paths produced overlapping or unexpected paths\n' >&2
  printf 'expected workdir_a: %s\n' "$paths_workdir/dev-a" >&2
  printf 'actual workdir_a:   %s\n' "$workdir_a" >&2
  printf 'expected state_a:   %s\n' "$paths_state/instances/dev-a.json" >&2
  printf 'actual state_a:     %s\n' "$state_a" >&2
  printf 'expected tf_a:      %s\n' "$paths_workdir/dev-a/tf" >&2
  printf 'actual tf_a:        %s\n' "$tf_a" >&2
  printf 'expected tf_state_a:%s\n' "$paths_workdir/dev-a/tf/state" >&2
  printf 'actual tf_state_a:  %s\n' "$tf_state_a" >&2
  printf 'expected tf_data_a: %s\n' "$paths_workdir/dev-a/tf/data" >&2
  printf 'actual tf_data_a:   %s\n' "$tf_data_a" >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-paths --registry "$FIXTURE" --instance no-such-instance --emit env >/dev/null 2>&1; then
  printf '  [FAIL] instance-paths accepted unknown instance\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] instance-paths rejects unknown instance\n'
fi

if ./scripts/instance-paths --registry "$FIXTURE" --instance '../evil' --emit env >/dev/null 2>&1; then
  printf '  [FAIL] instance-paths accepted unsafe instance name\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] instance-paths rejects unsafe instance name\n'
fi

[ "$FAIL" -eq 0 ]
