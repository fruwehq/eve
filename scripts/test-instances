    EGAME_WAIT_FOR_PROVISION_PROBE_SCRIPT="$status_malformed_probe" \
    EGAME_PROVISION_WAIT_POLL_INTERVAL=0 \
    ./scripts/wait-for-provision dev-a 5 2>&1
)" || true
if printf '%s\n' "$status_malformed_out" | grep -q 'malformed'; then
  printf '  [OK] wait-for-provision malformed status rejected\n'
else
  printf '  [FAIL] wait-for-provision malformed status not rejected\n' >&2
  printf '%s\n' "$status_malformed_out" >&2
  FAIL=$((FAIL + 1))
fi

