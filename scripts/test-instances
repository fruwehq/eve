tmp_bin="$(mktemp -d "${TMPDIR:-/tmp}/egame-integration-bin.XXXXXX")"
cat >"$tmp_bin/make" <<'SH'
#!/usr/bin/env bash
set -euo pipefail
target=""
package=""
for arg in "$@"; do
  case "$arg" in
    --no-print-directory) ;;
    PACKAGE=*) package="${arg#PACKAGE=}" ;;
    *) target="$arg"; break ;;
  esac
done
if [ "$target" = "package.status" ]; then
  printf '{"kind":"package-status","package":"%s","command":"status","instance":"dev-a","os_family":"ubuntu","status":"installed","details":"installed"}\n' "$package"
  exit 0
fi
printf 'stub live step: %s\n' "$target"
SH
chmod +x "$tmp_bin/make"
integration_report="$tmp_overlay_dir/integration-live-report.json"
integration_live_out="$(
  YES=1 PATH="$tmp_bin:$PATH" EGAME_INSTANCE_REGISTRY="$FIXTURE" \
    ./scripts/integration-test --live --instance dev-a --report "$integration_report"
)"
if printf '%s\n' "$integration_live_out" | grep -q '^== dev-a: validate ==$' &&
  printf '%s\n' "$integration_live_out" | grep -q '^stub live step: instance.validate$' &&
  printf '%s\n' "$integration_live_out" | grep -q '^== dev-a: cleanup.down ==$' &&
  [ -f "$integration_report" ] &&
  jq -e '.instances[0].status == "passed" and .instances[0].steps[0].output == "stub live step: instance.validate" and .instances[0].cleanup[0].name == "cleanup.down"' "$integration_report" >/dev/null; then
  printf '  [OK] integration-test live mode streams and records step output\n'
else
  printf '  [FAIL] integration-test live mode streams and records step output\n' >&2
  printf '%s\n' "$integration_live_out" >&2
  [ -f "$integration_report" ] && cat "$integration_report" >&2
  FAIL=$((FAIL + 1))
fi

wait_probe="$tmp_overlay_dir/wait-probe"
cat >"$wait_probe" <<'SH'
#!/usr/bin/env bash
set -euo pipefail
os_family="$1"
offset="$2"
[ "$os_family" = "ubuntu" ] || exit 2
if [ "$offset" = "status" ]; then
  printf 'STATUS_FILE\tABSENT\n'
  exit 0
fi
printf 'STATE\t'
if [ "$offset" -ge 2 ]; then
  printf 'DONE\n'
  printf 'LINES\t4\n'
else
  printf 'RUNNING\n'
  printf 'LINES\t2\n'
fi
printf 'LAST\t2026-05-09 10:00:00 Running step [0/1] base.sh\n'
printf '__EGAME_LOG_BEGIN__\n'
if [ "$offset" -eq 0 ]; then
  printf '2026-05-09 10:00:00 Running step [0/1] base.sh\n'
  printf '2026-05-09 10:00:01 apt is streaming\n'
else
  printf '2026-05-09 10:00:02 package output continues\n'
  printf '2026-05-09 10:00:03 Provisioning complete.\n'
fi
SH
chmod +x "$wait_probe"
wait_out="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" \
    EGAME_CATALOG_LOCAL="$overlay" \
    EGAME_WAIT_FOR_PROVISION_PROBE_SCRIPT="$wait_probe" \
    EGAME_PROVISION_WAIT_POLL_INTERVAL=0 \
    ./scripts/wait-for-provision dev-a 5
)"
if printf '%s\n' "$wait_out" | grep -q '^2026-05-09 10:00:01 apt is streaming$' &&
  printf '%s\n' "$wait_out" | grep -q '^2026-05-09 10:00:02 package output continues$' &&
  printf '%s\n' "$wait_out" | grep -q '^Provisioning complete for profile dev-a'; then
  printf '  [OK] wait-for-provision streams appended remote log lines\n'
else
  printf '  [FAIL] wait-for-provision did not stream appended log lines\n' >&2
  printf '%s\n' "$wait_out" >&2
  FAIL=$((FAIL + 1))
fi

