paths_target_tf_state="$(extract "$paths_target" INSTANCE_TF_STATE_BASE)"
expected_paths_target_workdir="$(printf '%s' "$tmp_overlay_dir/run/dev-a" | tr -s /)"
expected_paths_target_tf_state="$(printf '%s' "$tmp_overlay_dir/run/dev-a/tf/state" | tr -s /)"
if [ "$paths_target_workdir" = "$expected_paths_target_workdir" ] &&
  [ "$paths_target_tf_state" = "$expected_paths_target_tf_state" ]; then
  printf '  [OK] make target exposes instance artifact paths\n'
else
  printf '  [FAIL] instance.paths make target output mismatch\n' >&2
  printf 'expected workdir:  %s\n' "$expected_paths_target_workdir" >&2
  printf 'actual workdir:    %s\n' "$paths_target_workdir" >&2
  printf 'expected tf state: %s\n' "$expected_paths_target_tf_state" >&2
  printf 'actual tf state:   %s\n' "$paths_target_tf_state" >&2
  printf '%s\n' "$paths_target" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" EGAME_STATE_DIR="$tmp_overlay_dir/state" \
