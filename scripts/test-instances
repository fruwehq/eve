status_raw_json_running_probe="$tmp_overlay_dir/status-raw-json-running-probe"
status_raw_json_running_flag="$tmp_overlay_dir/raw-running-flag"
cat >"$status_raw_json_running_probe" <<SH
#!/usr/bin/env bash
set -euo pipefail
os_family="\$1"
offset="\$2"
[ "\$os_family" = "ubuntu" ] || exit 2
if [ "\$offset" = "status" ]; then
  if [ -f "$status_raw_json_running_flag" ]; then
    printf '{"api_version":1,"os_family":"ubuntu","started_at":"2026-01-15T10:30:00Z","finished_at":"2026-01-15T10:35:00Z","status":"done","steps":[{"step":"base.sh","phase":"succeeded","started_at":"2026-01-15T10:30:00Z","ended_at":"2026-01-15T10:31:00Z","exit_code":0}]}\n'
  else
    touch "$status_raw_json_running_flag"
    printf '{"api_version":1,"os_family":"ubuntu","started_at":"2026-01-15T10:30:00Z","finished_at":null,"status":"running","steps":[{"step":"base.sh","phase":"running","started_at":"2026-01-15T10:30:00Z","ended_at":null,"exit_code":null}]}\n'
  fi
  exit 0
fi
printf 'STATE\tRUNNING\nLINES\t0\nLAST\t\n__EGAME_LOG_BEGIN__\n'
SH
chmod +x "$status_raw_json_running_probe"
status_raw_json_running_out="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" \
    EGAME_CATALOG_LOCAL="$overlay" \
    EGAME_WAIT_FOR_PROVISION_PROBE_SCRIPT="$status_raw_json_running_probe" \
    EGAME_PROVISION_WAIT_POLL_INTERVAL=0 \
    ./scripts/wait-for-provision dev-a 5
)"
if printf '%s\n' "$status_raw_json_running_out" | grep -q 'Provisioning complete for profile dev-a'; then
  printf '  [OK] wait-for-provision raw JSON running then done (no STATUS_FILE header)\n'
else
  printf '  [FAIL] wait-for-provision raw JSON running then done (no STATUS_FILE header)\n' >&2
  printf '%s\n' "$status_raw_json_running_out" >&2
  FAIL=$((FAIL + 1))
fi

tmp_bin_missing="$(mktemp -d "${TMPDIR:-/tmp}/egame-integration-bin-missing.XXXXXX")"
cat >"$tmp_bin_missing/make" <<'SH'
#!/usr/bin/env bash
set -euo pipefail
target=""
package=""
for arg in "$@"; do
  case "$arg" in
    --no-print-directory) ;;
    PACKAGE=*) package="${arg#PACKAGE=}" ;;
    *) target="$arg"; break ;;
  esac
done
if [ "$target" = "package.status" ]; then
  printf '{"kind":"package-status","package":"%s","command":"status","instance":"dev-a","os_family":"ubuntu","status":"missing","details":"missing"}\n' "$package"
  exit 0
fi
printf 'stub live step: %s\n' "$target"
SH
chmod +x "$tmp_bin_missing/make"
integration_missing_report="$tmp_overlay_dir/integration-live-missing-report.json"
set +e
integration_missing_out="$(
  YES=1 PATH="$tmp_bin_missing:$PATH" EGAME_INSTANCE_REGISTRY="$FIXTURE" \
    ./scripts/integration-test --live --instance dev-a --report "$integration_missing_report" 2>&1
)"
integration_missing_status=$?
set -e
if [ "$integration_missing_status" -ne 0 ] &&
  [ -f "$integration_missing_report" ] &&
  jq -e '.instances[0].status == "failed" and .instances[0].cleanup[0].name == "cleanup.down" and (.instances[0].steps[] | select(.name | startswith("package.status.")) | .status == "failed" and .package_status == "missing" and (.failure_reason | test("expected package status installed")))' "$integration_missing_report" >/dev/null; then
  printf '  [OK] integration-test live mode fails on missing selected package\n'
else
  printf '  [FAIL] integration-test live mode missing package handling mismatch\n' >&2
  printf '%s\n' "$integration_missing_out" >&2
  [ -f "$integration_missing_report" ] && cat "$integration_missing_report" >&2
  FAIL=$((FAIL + 1))
fi

state_target="$(EGAME_STATE_DIR="$tmp_overlay_dir/state" make --no-print-directory instance.state INSTANCE=aws-gpu-a 2>/dev/null)"
if printf '%s\n' "$state_target" | jq -e '.instance == "aws-gpu-a" and .last_operation == null and .provider_state == "unknown" and (.observed_state | type == "object")' >/dev/null; then
  printf '  [OK] make target exposes local instance state\n'
else
  printf '  [FAIL] instance.state make target output mismatch\n' >&2
  printf '%s\n' "$state_target" >&2
  FAIL=$((FAIL + 1))
fi

observed_state="$(
  EGAME_STATE_DIR="$tmp_overlay_dir/state-observed" ./scripts/instance-state \
    --instance observed-a \
    --observed-json '{"provider_status":"running","ip":"10.0.0.10","observed_at":"2026-01-01T00:00:00Z"}'
)"
if printf '%s\n' "$observed_state" |
  jq -e '.observed_state.provider_status == "running" and .observed_state.ip == "10.0.0.10" and (.operation_history | length == 0) and .last_operation == null' >/dev/null; then
  printf '  [OK] instance state records observed facts without operations\n'
else
  printf '  [FAIL] instance state observed-state update mismatch\n' >&2
  printf '%s\n' "$observed_state" >&2
  FAIL=$((FAIL + 1))
fi

tmp_observe_bin="$tmp_overlay_dir/bin-observe"
