mkdir -p "$ssh_workdir/dev-a" "$ssh_workdir/bin"
ssh_workdir="$(cd "$ssh_workdir" && pwd -P)"
EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$ssh_workdir" \
  ./scripts/instance-profile-overlay --registry "$FIXTURE" --instance dev-a --output "$ssh_workdir/dev-a/catalog.local.yaml"
touch "$ssh_workdir/dev-a/Vagrantfile"
cat >"$ssh_workdir/bin/vagrant" <<'SH'
#!/usr/bin/env sh
pwd
SH
chmod +x "$ssh_workdir/bin/vagrant"
ssh_pwd="$(
  PATH="$ssh_workdir/bin:$PATH" \
    EGAME_CATALOG_LOCAL="$ssh_workdir/dev-a/catalog.local.yaml" \
    EGAME_INSTANCE_REGISTRY="$FIXTURE" \
    EGAME_INSTANCE_WORKDIR="$ssh_workdir" \
    ./scripts/instance-ssh dev-a -- 'true'
)"
if [ "$ssh_pwd" = "$ssh_workdir/dev-a" ]; then
  printf '  [OK] instance-ssh uses per-instance vagrant workdir\n'
else
  printf '  [FAIL] instance-ssh used wrong workdir\n' >&2
  printf 'expected: %s\nactual:   %s\n' "$ssh_workdir/dev-a" "$ssh_pwd" >&2
  FAIL=$((FAIL + 1))
fi

retry_dir="$(mktemp -d "${TMPDIR:-/tmp}/egame-ssh-retry.XXXXXX")"
cat >"$retry_dir/flaky" <<'SH'
#!/usr/bin/env sh
state="$1"
count="$(cat "$state" 2>/dev/null || printf 0)"
count=$((count + 1))
printf '%s\n' "$count" > "$state"
[ "$count" -ge 2 ]
SH
chmod +x "$retry_dir/flaky"
if EGAME_SSH_RETRY_ATTEMPTS=3 EGAME_SSH_RETRY_DELAY=0 ./scripts/ssh-retry "test retry" "$retry_dir/flaky" "$retry_dir/state"; then
  if [ "$(cat "$retry_dir/state")" = "2" ]; then
    printf '  [OK] ssh-retry retries transient command failures\n'
  else
    printf '  [FAIL] ssh-retry used unexpected attempt count\n' >&2
    cat "$retry_dir/state" >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] ssh-retry did not recover transient failure\n' >&2
  FAIL=$((FAIL + 1))
fi

[ "$FAIL" -eq 0 ]
