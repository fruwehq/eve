#!/usr/bin/env sh
shift
target="$1"
case "$target" in
  provider.status)
    printf 'Profile:        dev-a\n'
    printf 'Engine:         terraform\n'
    printf 'Provider:       aws\n'
    printf 'OS:             ubuntu\n'
    printf 'Control:        reachable (stub)\n'
    printf 'Status:         running\n'
    ;;
  ip)
    printf '10.0.0.42\n'
    ;;
  *)
    printf 'unexpected target: %s\n' "$target" >&2
    exit 2
    ;;
esac
SH
chmod +x "$tmp_observe_bin/make"
observed_refresh="$(
  PATH="$tmp_observe_bin:$PATH" EGAME_STATE_DIR="$tmp_overlay_dir/state-observe-refresh" \
    ./scripts/instance-observe --instance dev-a
)"
if printf '%s\n' "$observed_refresh" |
  jq -e '.observed_state.provider_status == "running" and .observed_state.ip == "10.0.0.42" and .observed_state.control_reachable == true and .observed_state.refresh_error == null and (.operation_history | length == 0)' >/dev/null; then
  printf '  [OK] instance.observe refreshes observed state without lifecycle history\n'
else
  printf '  [FAIL] instance.observe output mismatch\n' >&2
  printf '%s\n' "$observed_refresh" >&2
  FAIL=$((FAIL + 1))
fi

tmp_upload_dir="$tmp_overlay_dir/upload"
mkdir -p "$tmp_upload_dir/direct-a"
printf 'hello\n' >"$tmp_upload_dir/direct-a/file.txt"
upload_reject_out="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/upload-work" EGAME_UPLOAD_DIR="$tmp_upload_dir" \
    ./scripts/instance-run upload dev-a ../bad 2>&1 || true
)"
upload_missing_out="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/upload-work" EGAME_UPLOAD_DIR="$tmp_upload_dir" \
    ./scripts/instance-run upload dev-a missing-a 2>&1 || true
)"
if printf '%s\n' "$upload_reject_out" | grep -q 'invalid upload name' &&
  printf '%s\n' "$upload_missing_out" | grep -q 'not a direct folder under upload'; then
  printf '  [OK] upload selection rejects unsafe or missing folders\n'
else
  printf '  [FAIL] upload selection validation mismatch\n' >&2
  printf '%s\n%s\n' "$upload_reject_out" "$upload_missing_out" >&2
  FAIL=$((FAIL + 1))
fi

status_target="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" EGAME_STATE_DIR="$tmp_overlay_dir/state" \
    make --no-print-directory instance.status INSTANCE=aws-gpu-a EMIT=json 2>/dev/null
)"
if printf '%s\n' "$status_target" |
  jq -e '.instance.name == "aws-gpu-a" and .instance.provider == "aws" and .instance.engine == "terraform" and .state.last_operation == null and .state.effective_provider_state == "unknown" and (.observed_state | type == "object") and .packages.summary.unknown >= 1 and (.packages.selected[] | select(.id == "docker" and .state.status == "unknown")) and (.paths.INSTANCE_TF_STATE_BASE | test("aws-gpu-a/tf/state$"))' >/dev/null; then
  printf '  [OK] instance.status combines metadata, state, packages, and paths\n'
else
  printf '  [FAIL] instance.status combined output mismatch\n' >&2
  printf '%s\n' "$status_target" >&2
  FAIL=$((FAIL + 1))
fi

status_text="$(
  EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" EGAME_STATE_DIR="$tmp_overlay_dir/state" \
    make --no-print-directory instance.status INSTANCE=aws-gpu-a 2>/dev/null
)"
if printf '%s\n' "$status_text" | grep -q '^Selected package states:' &&
  printf '%s\n' "$status_text" | grep -q '^PACKAGE[[:space:]]\+STATE[[:space:]]\+SUPPORTED[[:space:]]\+SELECTED_BY'; then
  printf '  [OK] instance.status text shows selected package states\n'
else
  printf '  [FAIL] instance.status text output mismatch\n' >&2
  printf '%s\n' "$status_text" >&2
  FAIL=$((FAIL + 1))
fi

paths_workdir="$(printf '%s' "$tmp_overlay_dir/paths-work" | tr -s /)"
paths_state="$(printf '%s' "$tmp_overlay_dir/paths-state" | tr -s /)"
paths_a="$(EGAME_INSTANCE_WORKDIR="$paths_workdir" EGAME_STATE_DIR="$paths_state" \
  ./scripts/instance-paths --registry "$FIXTURE" --instance dev-a --emit env)"
paths_b="$(EGAME_INSTANCE_WORKDIR="$paths_workdir" EGAME_STATE_DIR="$paths_state" \
  ./scripts/instance-paths --registry "$FIXTURE" --instance aws-gpu-a --emit env)"

workdir_a="$(extract "$paths_a" INSTANCE_WORKDIR)"
workdir_b="$(extract "$paths_b" INSTANCE_WORKDIR)"
state_a="$(extract "$paths_a" INSTANCE_STATE_PATH)"
state_b="$(extract "$paths_b" INSTANCE_STATE_PATH)"
tf_a="$(extract "$paths_a" INSTANCE_TF_WORKDIR)"
tf_b="$(extract "$paths_b" INSTANCE_TF_WORKDIR)"
tf_state_a="$(extract "$paths_a" INSTANCE_TF_STATE_BASE)"
tf_state_b="$(extract "$paths_b" INSTANCE_TF_STATE_BASE)"
tf_data_a="$(extract "$paths_a" INSTANCE_TF_DATA_BASE)"
tf_data_b="$(extract "$paths_b" INSTANCE_TF_DATA_BASE)"

paths_failed=0
[ -n "$workdir_a" ] && [ -n "$workdir_b" ] || paths_failed=1
[ "$workdir_a" != "$workdir_b" ] || paths_failed=1
[ "$state_a" != "$state_b" ] || paths_failed=1
[ "$tf_a" != "$tf_b" ] || paths_failed=1
[ "$tf_state_a" != "$tf_state_b" ] || paths_failed=1
[ "$tf_data_a" != "$tf_data_b" ] || paths_failed=1
[ "$workdir_a" = "$paths_workdir/dev-a" ] || paths_failed=1
[ "$state_a" = "$paths_state/instances/dev-a.json" ] || paths_failed=1
[ "$tf_a" = "$paths_workdir/dev-a/tf" ] || paths_failed=1
[ "$tf_state_a" = "$paths_workdir/dev-a/tf/state" ] || paths_failed=1
[ "$tf_data_a" = "$paths_workdir/dev-a/tf/data" ] || paths_failed=1

if [ "$paths_failed" -eq 0 ]; then
  printf '  [OK] instance-paths resolves distinct workdir/state per instance\n'
else
  printf '  [FAIL] instance-paths produced overlapping or unexpected paths\n' >&2
  printf 'expected workdir_a: %s\n' "$paths_workdir/dev-a" >&2
  printf 'actual workdir_a:   %s\n' "$workdir_a" >&2
  printf 'expected state_a:   %s\n' "$paths_state/instances/dev-a.json" >&2
  printf 'actual state_a:     %s\n' "$state_a" >&2
  printf 'expected tf_a:      %s\n' "$paths_workdir/dev-a/tf" >&2
  printf 'actual tf_a:        %s\n' "$tf_a" >&2
  printf 'expected tf_state_a:%s\n' "$paths_workdir/dev-a/tf/state" >&2
  printf 'actual tf_state_a:  %s\n' "$tf_state_a" >&2
  printf 'expected tf_data_a: %s\n' "$paths_workdir/dev-a/tf/data" >&2
  printf 'actual tf_data_a:   %s\n' "$tf_data_a" >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-paths --registry "$FIXTURE" --instance no-such-instance --emit env >/dev/null 2>&1; then
  printf '  [FAIL] instance-paths accepted unknown instance\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] instance-paths rejects unknown instance\n'
fi

if ./scripts/instance-paths --registry "$FIXTURE" --instance '../evil' --emit env >/dev/null 2>&1; then
  printf '  [FAIL] instance-paths accepted unsafe instance name\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] instance-paths rejects unsafe instance name\n'
fi

