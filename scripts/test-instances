provider_bridge_failed=0
for provider_target in up down stop ip ssh; do
  provider_bridge_out="$(
    EGAME_PROVIDER_DRY_RUN=1 EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/provider-bridge" \
      make --no-print-directory "$provider_target" INSTANCE=dev-a 2>/dev/null
  )"
  if ! printf '%s\n' "$provider_bridge_out" |
    jq -e --arg command "$provider_target" '.provider == "local-qemu" and .command == $command and .dry_run == true' >/dev/null; then
    printf '  [FAIL] make %s INSTANCE did not route through provider dry-run\n' "$provider_target" >&2
    printf '%s\n' "$provider_bridge_out" >&2
    provider_bridge_failed=$((provider_bridge_failed + 1))
  fi
done
provider_bridge_start="$(
  EGAME_PROVIDER_DRY_RUN=1 EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/provider-bridge" \
    make --no-print-directory start INSTANCE=dev-a 2>/dev/null
)"
if ! printf '%s\n' "$provider_bridge_start" |
  jq -e '.provider == "local-qemu" and .command == "start" and .dry_run == true' >/dev/null; then
  printf '  [FAIL] make start INSTANCE did not route through provider dry-run\n' >&2
  printf '%s\n' "$provider_bridge_start" >&2
  provider_bridge_failed=$((provider_bridge_failed + 1))
fi
if [ "$provider_bridge_failed" -eq 0 ]; then
  printf '  [OK] make lifecycle targets route INSTANCE through provider plugins\n'
else
  FAIL=$((FAIL + 1))
fi

