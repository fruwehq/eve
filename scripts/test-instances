#!/usr/bin/env bash
# Validate fixture instances and compare emitted env to golden snapshots.
# Usage:        scripts/test-instances
# Refresh:      UPDATE_GOLDEN=1 scripts/test-instances

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

FIXTURE="tests/fixtures/instances.yaml"
GOLDEN_DIR="tests/golden/instances"
UPDATE="${UPDATE_GOLDEN:-0}"

mkdir -p "$GOLDEN_DIR"

# Keep output deterministic regardless of local host configuration.
unset TRUENAS_HOST TRUENAS_SSH_PORT TRUENAS_SSH_USER \
      TRUENAS_SSH_PRIVATE_KEY_FILE TRUENAS_SSH_HOST_KEY_FINGERPRINT \
      TRUENAS_API_KEY TRUENAS_API_USER SSH_PUBLIC_KEY_FILE \
      AWS_CONFIG_FILE AWS_PROFILE AWS_REGION AWS_SHARED_CREDENTIALS_FILE \
      EPHEMERAL_DISPLAY_FPS EPHEMERAL_DISPLAY_RESOLUTION \
      EPHEMERAL_MOONLIGHT_BITRATE_KBPS EPHEMERAL_MOONLIGHT_VIDEO_CODEC \
      EPHEMERAL_MOONLIGHT_VIDEO_DECODER GOOGLE_APPLICATION_CREDENTIALS \
      GOOGLE_CLOUD_PROJECT GOOGLE_PROJECT MY_IP RASPBERRY_PI_HDMI_CONNECTOR \
      RASPBERRY_PI_HDMI_MODE RASPBERRY_PI_HOST RASPBERRY_PI_IP \
      RUSTDESK_SERVER SUNSHINE_MAX_BITRATE_KBPS SUNSHINE_VERSION \
      TIMEZONE VAGRANT_SHOW_CONSOLE VM_USER_NAME EGAME_CONFIG_PATH

FAIL=0
INSTANCES=$(./scripts/instance-list --registry "$FIXTURE" --json | jq -r '.instances[].name')

if [ -d linux ] || [ -d windows ] || [ -d ubuntu26 ] || [ -d windows-server-2025 ]; then
  printf '  [FAIL] root OS provisioning folders must live under oses/<catalog-os-id>/\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] root OS provisioning folders live under oses/\n'
fi

missing_os_dirs=0
for os_id in $(yq -r '.oses[].id' config/catalog.yaml 2>/dev/null || ruby -ryaml -e 'YAML.load_file("config/catalog.yaml").fetch("oses").each { |os| puts os.fetch("id") }'); do
  if [ ! -d "oses/$os_id/provision" ]; then
    printf '  [FAIL] missing OS provisioning folder: oses/%s/provision\n' "$os_id" >&2
    missing_os_dirs=$((missing_os_dirs + 1))
  elif [ -L "oses/$os_id/provision" ]; then
    target=$(cd "oses/$os_id/provision" && pwd -P)
    case "$target" in
      "$PWD"/oses/*/provision) ;;
      *)
        printf '  [FAIL] OS provisioning symlink escapes oses/: oses/%s/provision -> %s\n' "$os_id" "$target" >&2
        missing_os_dirs=$((missing_os_dirs + 1))
        ;;
    esac
  fi
done
if [ "$missing_os_dirs" -eq 0 ]; then
  printf '  [OK] OS provisioning folders match catalog OS IDs\n'
else
  FAIL=$((FAIL + missing_os_dirs))
fi

for instance in $INSTANCES; do
  if ! ./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --validate >/dev/null 2>&1; then
    printf '  [FAIL] validate: %s\n' "$instance" >&2
    ./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --validate >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  actual=$(./scripts/instance-resolve --registry "$FIXTURE" --instance "$instance" --emit env | LC_ALL=C sort)
  golden="$GOLDEN_DIR/$instance.env"

  if [ "$UPDATE" = "1" ]; then
    printf '%s\n' "$actual" > "$golden"
    printf '  [UPDATE] %s\n' "$golden"
    continue
  fi

  if [ ! -f "$golden" ]; then
    printf '  [FAIL] missing golden: %s (run: UPDATE_GOLDEN=1 make test.instances)\n' "$golden" >&2
    FAIL=$((FAIL + 1))
    continue
  fi

  if ! diff -u "$golden" <(printf '%s\n' "$actual") >/dev/null; then
    printf '  [FAIL] golden mismatch: %s\n' "$instance" >&2
    diff -u "$golden" <(printf '%s\n' "$actual") >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  printf '  [OK] %s\n' "$instance"
done

truenas_access_json="$(./scripts/instance-resolve --registry "$FIXTURE" --instance truenas-all-a --emit json)"
if printf '%s\n' "$truenas_access_json" |
  jq -e '.access.bootstrap_user == "egame-provision" and .access.provision_user == "egame-provision" and .access.human_user == "egame-provision"' >/dev/null; then
  printf '  [OK] TrueNAS access defaults resolve from catalog\n'
else
  printf '  [FAIL] TrueNAS access defaults did not resolve from catalog\n' >&2
  printf '%s\n' "$truenas_access_json" >&2
  FAIL=$((FAIL + 1))
fi

truenas_human_access_json="$(VM_USER_NAME=chris ./scripts/instance-resolve --registry "$FIXTURE" --instance truenas-all-a --emit json)"
if printf '%s\n' "$truenas_human_access_json" |
  jq -e '.access.bootstrap_user == "egame-provision" and .access.provision_user == "egame-provision" and .access.human_user == "chris"' >/dev/null; then
  printf '  [OK] TrueNAS human user can differ from provision user\n'
else
  printf '  [FAIL] TrueNAS human user override mismatch\n' >&2
  printf '%s\n' "$truenas_human_access_json" >&2
  FAIL=$((FAIL + 1))
fi

tmp_registry="$(mktemp "${TMPDIR:-/tmp}/egame-instance-test.XXXXXX")"
tmp_concurrent_registry="$(mktemp "${TMPDIR:-/tmp}/egame-instance-concurrent.XXXXXX")"
tmp_external_registry="$(mktemp "${TMPDIR:-/tmp}/egame-instance-external.XXXXXX")"
invalid_output="$(mktemp "${TMPDIR:-/tmp}/egame-instance-test-output.XXXXXX")"
tmp_overlay_dir="$(mktemp -d "${TMPDIR:-/tmp}/egame-instance-overlay.XXXXXX")"
tmp_local_catalog="$tmp_overlay_dir/catalog.local.yaml"
trap 'rm -f "$tmp_registry" "$tmp_registry.lock" "$tmp_concurrent_registry" "$tmp_concurrent_registry.lock" "$tmp_external_registry" "$invalid_output"; rm -rf "$tmp_overlay_dir"' EXIT
rm -f "$tmp_registry" "$tmp_concurrent_registry"

tmp_config="$tmp_overlay_dir/config.yaml"
cat >"$tmp_config" <<'YAML'
display:
  resolution: 5120x1440
global:
  vm_user_name: egame-user
moonlight:
  display_mode: borderless
  video_codec: HEVC
YAML

config_env="$(EGAME_CONFIG_PATH="$tmp_config" ./scripts/config-env --make | LC_ALL=C sort)"
if printf '%s\n' "$config_env" | grep -qx 'EPHEMERAL_DISPLAY_RESOLUTION=5120x1440' &&
  printf '%s\n' "$config_env" | grep -qx 'EPHEMERAL_MOONLIGHT_DISPLAY_MODE=borderless' &&
  printf '%s\n' "$config_env" | grep -qx 'EPHEMERAL_MOONLIGHT_VIDEO_CODEC=HEVC' &&
  printf '%s\n' "$config_env" | grep -qx 'VM_USER_NAME=egame-user'; then
  printf '  [OK] structured config emits non-secret environment overrides\n'
else
  printf '  [FAIL] structured config emits non-secret environment overrides\n' >&2
  printf '%s\n' "$config_env" >&2
  FAIL=$((FAIL + 1))
fi

tmp_env_local="$tmp_overlay_dir/env.local"
tmp_migrated_config="$tmp_overlay_dir/migrated-config.yaml"
cat >"$tmp_env_local" <<'ENV'
EPHEMERAL_DISPLAY_RESOLUTION=2560x1440
TRUENAS_API_KEY=secret-value
RUSTDESK_SERVER=rustdesk.example.com
ENV
if EGAME_ENV_LOCAL="$tmp_env_local" EGAME_CONFIG_PATH="$tmp_migrated_config" ./scripts/config-migrate --apply >/dev/null &&
  ruby -ryaml -e 'config = YAML.safe_load(File.read(ARGV[0])); exit(config.dig("display", "resolution") == "2560x1440" && config.dig("rustdesk", "server") == "rustdesk.example.com" ? 0 : 1)' "$tmp_migrated_config" &&
  grep -qx '# migrated to .egame/config.yaml: EPHEMERAL_DISPLAY_RESOLUTION=2560x1440' "$tmp_env_local" &&
  grep -qx 'TRUENAS_API_KEY=secret-value' "$tmp_env_local"; then
  printf '  [OK] config migration moves non-secret values and keeps secrets in env\n'
else
  printf '  [FAIL] config migration moves non-secret values and keeps secrets in env\n' >&2
  [ -f "$tmp_env_local" ] && sed 's/=.*/=<redacted>/' "$tmp_env_local" >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance test-dev \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --init ssh-ubuntu-cloud-init \
  --location tokyo \
  --bundles desktop-streaming,dev-ai \
  --packages macos-desktop-theme \
  --disk-gb 64 \
  --memory-mb 4096 >/dev/null; then
  if ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --validate >/dev/null &&
    ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
      jq -e '.composition.packages == ["macos-desktop-theme"] and (.bundle_packages | index("macos-desktop-theme")) and .package_sources["macos-desktop-theme"] == ["direct"]' >/dev/null; then
    printf '  [OK] create valid instance\n'
  else
    printf '  [FAIL] created instance did not validate\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] create valid instance\n' >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance direct-dev \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --location tokyo \
  --bundles dev-ai \
  --packages gnome-desktop \
  --disk-gb 32 >/dev/null; then
  if ./scripts/instance-resolve --registry "$tmp_registry" --instance direct-dev --validate >/dev/null &&
    ./scripts/instance-resolve --registry "$tmp_registry" --instance direct-dev --emit json |
      jq -e '
        .composition.machine == "local-qemu-medium" and
        .composition.os == "ubuntu-26.04-arm64" and
        .composition.init == "ssh-ubuntu-cloud-init" and
        (.bundle_packages | index("gnome-desktop")) and
        .package_sources["gnome-desktop"] == ["direct"]
      ' >/dev/null; then
    printf '  [OK] create direct composition instance with inferred init\n'
  else
    printf '  [FAIL] direct composition instance did not validate\n' >&2
    ./scripts/instance-resolve --registry "$tmp_registry" --instance direct-dev --emit json >&2 || true
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] create direct composition instance\n' >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" make --no-print-directory instance.validate INSTANCE=test-dev >/dev/null &&
  EGAME_INSTANCE_REGISTRY="$tmp_registry" make --no-print-directory instance.list |
    grep -q '^test-dev'; then
  printf '  [OK] make instance targets honor EGAME_INSTANCE_REGISTRY\n'
else
  printf '  [FAIL] make instance targets honor EGAME_INSTANCE_REGISTRY\n' >&2
  EGAME_INSTANCE_REGISTRY="$tmp_registry" make --no-print-directory instance.validate INSTANCE=test-dev >&2 || true
  FAIL=$((FAIL + 1))
fi

./scripts/instance-create \
  --registry "$tmp_concurrent_registry" \
  --instance concurrent-a \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --location tokyo >/dev/null &
create_a_pid=$!
./scripts/instance-create \
  --registry "$tmp_concurrent_registry" \
  --instance concurrent-b \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --location tokyo >/dev/null &
create_b_pid=$!
if wait "$create_a_pid" && wait "$create_b_pid" &&
  ./scripts/instance-list --registry "$tmp_concurrent_registry" --json |
    jq -e '.instances | length == 2 and any(.[]; .name == "concurrent-a") and any(.[]; .name == "concurrent-b")' >/dev/null; then
  printf '  [OK] concurrent instance creates preserve registry\n'
else
  printf '  [FAIL] concurrent instance creates preserve registry\n' >&2
  cat "$tmp_concurrent_registry" >&2 || true
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" make package.unselect INSTANCE=test-dev PACKAGE=macos-desktop-theme >/dev/null &&
  ! ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '.bundle_packages | index("macos-desktop-theme")' >/dev/null &&
  EGAME_INSTANCE_REGISTRY="$tmp_registry" make package.select INSTANCE=test-dev PACKAGE=macos-desktop-theme >/dev/null &&
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '.composition.packages == ["macos-desktop-theme"] and (.bundle_packages | index("macos-desktop-theme")) and .package_sources["macos-desktop-theme"] == ["direct"]' >/dev/null; then
  printf '  [OK] package selection updates direct instance packages\n'
else
  printf '  [FAIL] package selection updates direct instance packages\n' >&2
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json >&2 || true
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" make bundle.unselect INSTANCE=test-dev BUNDLE=dev-ai >/dev/null &&
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '(.composition.bundles == ["desktop-streaming"]) and (.bundle_packages | index("docker") | not)' >/dev/null &&
  EGAME_INSTANCE_REGISTRY="$tmp_registry" make bundle.select INSTANCE=test-dev BUNDLE=desktop-gnome >/dev/null &&
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json |
    jq -e '(.composition.bundles | index("desktop-gnome")) and (.bundle_packages | index("gnome-desktop")) and .package_sources["gnome-desktop"] == ["bundle:desktop-gnome"]' >/dev/null; then
  printf '  [OK] bundle selection updates instance bundles\n'
else
  printf '  [FAIL] bundle selection updates instance bundles\n' >&2
  ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json >&2 || true
  FAIL=$((FAIL + 1))
fi

registry_before_invalid_bundle="$(cat "$tmp_registry")"
if EGAME_INSTANCE_REGISTRY="$tmp_registry" make bundle.select INSTANCE=test-dev BUNDLE=does-not-exist >/dev/null 2>&1; then
  printf '  [FAIL] invalid bundle selection should fail\n' >&2
  FAIL=$((FAIL + 1))
elif [ "$registry_before_invalid_bundle" = "$(cat "$tmp_registry")" ]; then
  printf '  [OK] invalid bundle selection leaves registry unchanged\n'
else
  printf '  [FAIL] invalid bundle selection mutated registry\n' >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/direct" \
  make --no-print-directory env INSTANCE=test-dev |
  grep -q '^BUNDLE_PACKAGES=.*waypipe'; then
  printf '  [OK] profile overlay exposes direct instance packages\n'
else
  printf '  [FAIL] profile overlay exposes direct instance packages\n' >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
bundles:
  - id: desktop-streaming
    includes: [rustdesk, vnc, waypipe]
YAML
if EGAME_CATALOG_LOCAL="$tmp_local_catalog" ./scripts/instance-resolve --registry "$FIXTURE" --instance dev-a --emit json |
  jq -e '(.bundle_packages | index("waypipe")) and .package_sources.waypipe == ["bundle:desktop-streaming"]' >/dev/null; then
  printf '  [OK] instance resolver honors EGAME_CATALOG_LOCAL\n'
else
  printf '  [FAIL] instance resolver honors EGAME_CATALOG_LOCAL\n' >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
bundles:
  - id: desktop-streaming
    includes: [xpra]
YAML
if EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$FIXTURE" --instance truenas-all-a --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted unsupported ubuntu package version\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'Package plugin xpra does not support ubuntu version 26.04' "$invalid_output"; then
  printf '  [OK] instance resolver enforces package ubuntu version support\n'
else
  printf '  [FAIL] instance resolver package ubuntu version support mismatch\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
bundles:
  - id: desktop-streaming
    includes: [steam]
YAML
if EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$FIXTURE" --instance qemu-a --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted unsupported package architecture\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'Package plugin steam does not support architecture arm64' "$invalid_output"; then
  printf '  [OK] instance resolver enforces package architecture support\n'
else
  printf '  [FAIL] instance resolver package architecture support mismatch\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
oses:
  - id: ubuntu-no-vagrant
    family: ubuntu
    version: "26.04"
    arch: arm64
YAML
cat >"$tmp_external_registry" <<'YAML'
version: 1
instances:
  - name: qemu-invalid-os
    machine: local-qemu-medium
    os: ubuntu-no-vagrant
    init: ssh-ubuntu-cloud-init
    location: tokyo
    bundles: []
    packages: []
YAML
if EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance qemu-invalid-os --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted provider-invalid OS metadata\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'OS/provider mismatch: OS ubuntu-no-vagrant has no Vagrant box' "$invalid_output"; then
  printf '  [OK] instance resolver runs provider OS metadata validation hook\n'
else
  printf '  [FAIL] instance resolver provider OS validation hook mismatch\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
machines:
  - name: acme-small
    provider: acme
    kind: vm
    defaults:
      disk_gb: 30
      memory_mb: 4096
locations:
  - name: tokyo
    acme:
      region: test-region
inits:
  - id: ssh-ubuntu-cloud-init
    providers: [acme]
YAML
cat >"$tmp_external_registry" <<'YAML'
version: 1
instances:
  - name: acme-a
    machine: acme-small
    os: ubuntu-26.04-amd64
    init: ssh-ubuntu-cloud-init
    packages: [docker]
    location: tokyo
YAML

if EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted provider without plugin\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'Provider plugin not found: acme' "$invalid_output"; then
  printf '  [OK] instance resolver rejects provider without plugin\n'
else
  printf '  [FAIL] instance resolver rejects provider without plugin\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_PLUGIN_ROOTS="tests/fixtures/plugins/providers/acme" EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --emit json |
  jq -e '.provider_plugin == "acme" and .machine.provider == "acme"' >/dev/null; then
  printf '  [OK] instance resolver accepts external provider plugin\n'
else
  printf '  [FAIL] instance resolver accepts external provider plugin\n' >&2
  EGAME_PLUGIN_ROOTS="tests/fixtures/plugins/providers/acme" EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
    ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --emit json >&2 || true
  FAIL=$((FAIL + 1))
fi

cat >"$tmp_local_catalog" <<'YAML'
machines:
  - name: acme-small
    provider: acme
    kind: metal
    defaults:
      disk_gb: 30
      memory_mb: 4096
locations:
  - name: tokyo
    acme:
      region: test-region
inits:
  - id: ssh-ubuntu-cloud-init
    providers: [acme]
YAML
if EGAME_PLUGIN_ROOTS="tests/fixtures/plugins/providers/acme" EGAME_CATALOG_LOCAL="$tmp_local_catalog" \
  ./scripts/instance-resolve --registry "$tmp_external_registry" --instance acme-a --validate 2>"$invalid_output"; then
  printf '  [FAIL] instance resolver accepted unsupported provider plugin metadata\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'Provider plugin acme does not support engine metal' "$invalid_output"; then
  printf '  [OK] instance resolver enforces provider plugin supports\n'
else
  printf '  [FAIL] instance resolver enforces provider plugin supports\n' >&2
  cat "$invalid_output" >&2
  FAIL=$((FAIL + 1))
fi

before_invalid="$(cat "$tmp_registry")"
if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance bad-a \
  --machine no-such-machine \
  --os ubuntu-26.04-amd64 \
  --location tokyo >"$invalid_output" 2>&1; then
  printf '  [FAIL] invalid instance create succeeded\n' >&2
  FAIL=$((FAIL + 1))
elif [ "$(cat "$tmp_registry")" = "$before_invalid" ]; then
  printf '  [OK] reject invalid instance without registry write\n'
else
  printf '  [FAIL] invalid instance create changed registry\n' >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-delete --registry "$tmp_registry" --instance test-dev >/dev/null; then
  if ./scripts/instance-resolve --registry "$tmp_registry" --instance test-dev --emit json >/dev/null 2>&1; then
    printf '  [FAIL] deleted instance still resolves\n' >&2
    FAIL=$((FAIL + 1))
  else
    printf '  [OK] delete instance removes from registry\n'
  fi
else
  printf '  [FAIL] delete instance\n' >&2
  FAIL=$((FAIL + 1))
fi

if ./scripts/instance-delete --registry "$tmp_registry" --instance test-dev >/dev/null 2>&1; then
  printf '  [FAIL] delete non-existent instance succeeded\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] delete non-existent instance fails\n'
fi

stale_state_dir="$tmp_overlay_dir/stale-state"
if EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance stale-dev \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --location tokyo \
  --bundles desktop-streaming >/dev/null &&
  EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-state \
    --instance stale-dev \
    --operation package.rustdesk.status \
    --status succeeded \
    --package rustdesk \
    --package-state installed >/dev/null &&
  EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-delete --registry "$tmp_registry" --instance stale-dev >/dev/null &&
  [ -e "$stale_state_dir/instances/stale-dev.json" ] &&
  EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-create \
    --registry "$tmp_registry" \
    --instance stale-dev \
    --machine local-qemu-medium \
    --os ubuntu-26.04-arm64 \
    --location tokyo \
    --bundles desktop-streaming >/dev/null &&
  [ ! -e "$stale_state_dir/instances/stale-dev.json" ] &&
  EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-status --registry "$tmp_registry" --instance stale-dev --json |
    jq -e '.packages.summary.installed == 0 and .packages.summary.unknown > 0' >/dev/null; then
  printf '  [OK] create resets stale local instance state\n'
else
  printf '  [FAIL] create resets stale local instance state\n' >&2
  EGAME_STATE_DIR="$stale_state_dir" ./scripts/instance-status --registry "$tmp_registry" --instance stale-dev --json >&2 || true
  FAIL=$((FAIL + 1))
fi

purge_workdir="$tmp_overlay_dir/delete-work"
purge_state="$tmp_overlay_dir/delete-state"
if ./scripts/instance-create \
  --registry "$tmp_registry" \
  --instance purge-dev \
  --machine local-qemu-medium \
  --os ubuntu-26.04-arm64 \
  --location tokyo >/dev/null; then
  mkdir -p "$purge_workdir/purge-dev" "$purge_state/instances"
  printf '{}\n' > "$purge_state/instances/purge-dev.json"
  if EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$purge_workdir" EGAME_STATE_DIR="$purge_state" \
    make package.select INSTANCE=purge-dev PACKAGE=waypipe >/dev/null &&
    EGAME_INSTANCE_REGISTRY="$tmp_registry" EGAME_INSTANCE_WORKDIR="$purge_workdir" EGAME_STATE_DIR="$purge_state" \
      make instance.delete INSTANCE=purge-dev PURGE=1 >/dev/null &&
    [ ! -e "$purge_workdir/purge-dev" ] &&
    [ ! -e "$purge_state/instances/purge-dev.json" ]; then
    printf '  [OK] delete purge honors env registry/workdir/state paths\n'
  else
    printf '  [FAIL] delete purge honors env registry/workdir/state paths\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] create purge test instance\n' >&2
  FAIL=$((FAIL + 1))
fi

overlay="$tmp_overlay_dir/dev-a.catalog.local.yaml"
if ./scripts/instance-profile-overlay --registry "$FIXTURE" --instance dev-a --output "$overlay"; then
  if EGAME_CATALOG_LOCAL="$overlay" ./scripts/profile-resolve --profile dev-a --validate >/dev/null; then
    printf '  [OK] generated profile overlay validates\n'
  else
    printf '  [FAIL] generated profile overlay did not validate\n' >&2
    FAIL=$((FAIL + 1))
  fi
else
  printf '  [FAIL] generate profile overlay\n' >&2
  FAIL=$((FAIL + 1))
fi

overlay_before="$tmp_overlay_dir/dev-a.catalog.local.yaml.before"
cp "$overlay" "$overlay_before"
if ./scripts/instance-profile-overlay --registry "$FIXTURE" --instance dev-a --output "$overlay" &&
  cmp -s "$overlay_before" "$overlay"; then
  printf '  [OK] unchanged profile overlay is not rewritten\n'
else
  printf '  [FAIL] unchanged profile overlay rewrite check\n' >&2
  FAIL=$((FAIL + 1))
fi

profile_env="$(EGAME_CATALOG_LOCAL="$overlay" ./scripts/profile-resolve --profile dev-a --emit env | LC_ALL=C sort)"
if printf '%s\n' "$profile_env" | grep -qx 'PROFILE_NAME=dev-a' &&
  printf '%s\n' "$profile_env" | grep -qx 'VM_DISK_GB=64' &&
  printf '%s\n' "$profile_env" | grep -qx 'VM_MEMORY_MB=4096' &&
  printf '%s\n' "$profile_env" | grep -qx 'STACK_TAGS=local-qemu'; then
  printf '  [OK] profile overlay preserves instance overrides\n'
else
  printf '  [FAIL] profile overlay env mismatch\n' >&2
  printf '%s\n' "$profile_env" >&2
  FAIL=$((FAIL + 1))
fi

bridge_env="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" make env INSTANCE=dev-a 2>/dev/null | LC_ALL=C sort)"
if printf '%s\n' "$bridge_env" | grep -qx 'PROFILE_NAME=dev-a' &&
  printf '%s\n' "$bridge_env" | grep -qx 'VM_DISK_GB=64' &&
  printf '%s\n' "$bridge_env" | grep -qx 'VM_MEMORY_MB=4096'; then
  printf '  [OK] make target routes INSTANCE through generated profile overlay\n'
else
  printf '  [FAIL] INSTANCE make bridge env mismatch\n' >&2
  printf '%s\n' "$bridge_env" >&2
  FAIL=$((FAIL + 1))
fi

extract() { printf '%s\n' "$1" | awk -F= -v key="$2" '$1 == key { print substr($0, index($0, "=") + 1) }'; }

rpi_a_env="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" ./scripts/instance-resolve --instance rpi-all-a --emit env)"
rpi_b_env="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" ./scripts/instance-resolve --instance rpi-all-b --emit env)"
rpi_a_ip="$(extract "$rpi_a_env" RASPBERRY_PI_IP)"
rpi_b_ip="$(extract "$rpi_b_env" RASPBERRY_PI_IP)"
if [ "$rpi_a_ip" = "192.0.2.10" ] && [ "$rpi_b_ip" = "192.0.2.11" ]; then
  printf '  [OK] Raspberry Pi instances keep separate provider IPs\n'
else
  printf '  [FAIL] Raspberry Pi provider IP resolution mismatch\n' >&2
  printf 'rpi-all-a IP: %s\n' "$rpi_a_ip" >&2
  printf 'rpi-all-b IP: %s\n' "$rpi_b_ip" >&2
  FAIL=$((FAIL + 1))
fi

rpi_overlay="$tmp_overlay_dir/rpi-all-a/catalog.local.yaml"
EGAME_INSTANCE_REGISTRY="$FIXTURE" ./scripts/instance-profile-overlay --instance rpi-all-a --output "$rpi_overlay"
rpi_overlay_env="$(EGAME_CATALOG_LOCAL="$rpi_overlay" ./scripts/profile-resolve --profile rpi-all-a --emit env)"
if [ "$(extract "$rpi_overlay_env" RASPBERRY_PI_IP)" = "192.0.2.10" ] &&
  [ "$(extract "$rpi_overlay_env" RASPBERRY_PI_HOST)" = "192.0.2.10" ]; then
  printf '  [OK] generated profile overlay preserves Raspberry Pi address\n'
else
  printf '  [FAIL] Raspberry Pi overlay address mismatch\n' >&2
  printf '%s\n' "$rpi_overlay_env" >&2
  FAIL=$((FAIL + 1))
fi

paths_target="$(EGAME_INSTANCE_REGISTRY="$FIXTURE" EGAME_INSTANCE_WORKDIR="$tmp_overlay_dir/run" \
  make instance.paths INSTANCE=dev-a 2>/dev/null)"
