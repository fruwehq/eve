#!/usr/bin/env sh
# env-require: error if any of the listed environment variables is unset or empty.
# Usage: scripts/env-require VAR1 [VAR2 ...]
#
# Used to enforce that variables documented in config/defaults.yaml (and
# meant to be supplied via config-save or the shell) are actually populated
# before a code path that depends on them runs. Variables for unrelated
# providers are not checked — only call this with the vars the current operation actually needs.
set -eu

if [ "$#" -eq 0 ]; then
  echo "usage: scripts/env-require VAR1 [VAR2 ...]" >&2
  exit 2
fi

missing=""
for var in "$@"; do
  eval "value=\${$var:-}"
  if [ -z "$value" ]; then
    missing="$missing $var"
  fi
done

if [ -n "$missing" ]; then
  echo "Error: required environment variable(s) not set:" >&2
  for var in $missing; do
    echo "  - $var" >&2
  done
  echo "" >&2
  echo "Set them via config-save or your shell environment and retry." >&2
  exit 1
fi
