#!/usr/bin/env bash
# Wait until SSH on the profile's instance accepts connections.
# Usage: scripts/profile-ssh-wait <profile> [max-attempts]

set -euo pipefail

PROFILE="${1:?Usage: scripts/profile-ssh-wait <profile> [max-attempts]}"
MAX=${2:-60}
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

i=1
while [ "$i" -le "$MAX" ]; do
  if [ "$ENGINE" = "vagrant" ]; then
    if (cd ".generated/$PROFILE" && vagrant ssh -c "exit 0" >/dev/null 2>&1); then
      echo "SSH ready for profile $PROFILE"
      exit 0
    fi
  else
    if ./scripts/profile-ssh "$PROFILE" -- exit 0 >/dev/null 2>&1; then
      echo "SSH ready for profile $PROFILE"
      exit 0
    fi
  fi
  echo "waiting for SSH ($i/$MAX)..."
  sleep 5
  i=$((i + 1))
done

echo "SSH did not become ready in time for profile $PROFILE" >&2
exit 1
