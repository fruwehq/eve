#!/usr/bin/env ruby
# Create a concrete local VM instance entry in the instance registry.

require "fileutils"
require "tempfile"
require "time"
require "yaml"

ROOT = File.expand_path("..", __dir__)
DEFAULT_REGISTRY_PATH = File.join(ROOT, ".egame/instances.yaml")

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-create --name <name> --recipe <recipe> [options]

    Options:
      --registry <path>
      --machine <machine>
      --os <os-id>
      --init <init-id>
      --location <location>
      --bundles <bundle-a,bundle-b>
      --packages <package-a,package-b>
      --disk-gb <gb>
      --memory-mb <mb>
      --cpu-cores <n>
      --vcpus <n>
      --instance-type <aws-type>
      --root-volume-type <aws-volume-type>
      --plan <vultr-plan>
  USAGE
end

name = nil
recipe = nil
registry_path = DEFAULT_REGISTRY_PATH
fields = {}
overrides = {}

args = ARGV.dup
until args.empty?
  case args.shift
  when "--name"
    name = args.shift
  when "--recipe"
    recipe = args.shift
  when "--registry"
    registry_path = File.expand_path(args.shift, Dir.pwd)
  when "--machine"
    fields["machine"] = args.shift
  when "--os"
    fields["os"] = args.shift
  when "--init"
    fields["init"] = args.shift
  when "--location"
    fields["location"] = args.shift
  when "--bundles"
    fields["bundles"] = args.shift.to_s.split(",").map(&:strip).reject(&:empty?)
  when "--packages"
    fields["packages"] = args.shift.to_s.split(",").map(&:strip).reject(&:empty?)
  when "--disk-gb"
    overrides["disk_gb"] = Integer(args.shift)
  when "--memory-mb"
    overrides["memory_mb"] = Integer(args.shift)
  when "--cpu-cores"
    overrides["cpu_cores"] = Integer(args.shift)
  when "--vcpus"
    overrides["vcpus"] = Integer(args.shift)
  when "--instance-type"
    overrides["instance_type"] = args.shift
  when "--root-volume-type"
    overrides["root_volume_type"] = args.shift
  when "--plan"
    overrides["plan"] = args.shift
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless name && recipe
  usage
  exit 2
end

unless name.match?(/\A[a-z][a-z0-9-]*\z/)
  warn "instance-create: name must match [a-z][a-z0-9-]*"
  exit 2
end

registry = if File.exist?(registry_path)
             YAML.safe_load(File.read(registry_path), permitted_classes: [], aliases: true) || {}
           else
             { "version" => 1, "instances" => [] }
           end
registry["version"] ||= 1
registry["instances"] ||= []

if registry["instances"].any? { |instance| instance["name"] == name }
  warn "instance-create: instance already exists: #{name}"
  exit 1
end

now = Time.now.utc.iso8601
entry = {
  "name" => name,
  "recipe" => recipe,
  "created_at" => now,
  "updated_at" => now
}.merge(fields)
entry["overrides"] = overrides unless overrides.empty?

registry["instances"] << entry

Tempfile.create(["egame-instance-", ".yaml"]) do |tmp|
  tmp.write(registry.to_yaml)
  tmp.close

  ok = system(
    File.join(ROOT, "scripts/instance-resolve"),
    "--registry", tmp.path,
    "--instance", name,
    "--validate",
    out: File::NULL
  )
  unless ok
    warn "instance-create: resolved instance did not validate; registry was not changed"
    exit 1
  end
end

FileUtils.mkdir_p(File.dirname(registry_path))
File.write(registry_path, registry.to_yaml)

puts "Created instance: #{name}"
puts "Registry: #{registry_path}"
