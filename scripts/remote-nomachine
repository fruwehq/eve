#!/usr/bin/env python3
"""Print NoMachine connection details for an instance, or open the client.

Usage:
  scripts/remote-nomachine <instance> [connect]

With 'connect', opens the local NoMachine client (nxplayer) against the
instance when one is installed; otherwise prints the connection details.
"""

from __future__ import annotations

import os
import platform
import shutil
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import DispatchError  # noqa: E402

# NoMachine's NX protocol listens on TCP 4000 by default and authenticates
# against the host's system account (the instance user's password).
NX_PORT = 4000


def resolve_ip(instance: str) -> str:
    result = subprocess.run(
        [str(ROOT / "scripts/instance-ip"), instance],
        cwd=ROOT,
        text=True,
        capture_output=True,
        check=False,
    )
    ip = result.stdout.strip()
    if result.returncode != 0 or not ip:
        details = f"{result.stdout.strip()}{result.stderr.strip()}"
        raise DispatchError(f"could not resolve IP for {instance}: {details}".rstrip(": "))
    return ip


def resolve_user(instance: str) -> str:
    result = subprocess.run(
        [str(ROOT / "scripts/profile-resolve"), "--profile", instance, "--emit", "env"],
        cwd=ROOT,
        text=True,
        capture_output=True,
        check=False,
    )
    for line in result.stdout.splitlines():
        if line.startswith("VM_USER_NAME="):
            return line.split("=", 1)[1].strip()
    return ""


def find_client() -> str | None:
    if platform.system() == "Darwin":
        mac_client = "/Applications/NoMachine.app/Contents/MacOS/nxplayer"
        if os.access(mac_client, os.X_OK):
            return mac_client
    for candidate in ("nxplayer", "/usr/NX/bin/nxplayer"):
        found = shutil.which(candidate)
        if found:
            return found
        if os.access(candidate, os.X_OK):
            return candidate
    return None


def print_info(ip: str, user: str) -> None:
    print(f"Host:  {ip}")
    print(f"Port:  {NX_PORT} (NX)")
    print(f"User:  {user}")


def main(argv: list[str]) -> int:
    if not argv:
        print(__doc__, file=sys.stderr)
        return 2
    instance = argv[0]
    action = argv[1] if len(argv) > 1 else "info"
    try:
        ip = resolve_ip(instance)
        user = resolve_user(instance) or "the instance user"
        if action == "connect":
            client = find_client()
            if not client:
                print("NoMachine client (nxplayer) not found locally", file=sys.stderr)
                print_info(ip, user)
                return 1
            print(f"Opening NoMachine to {ip}:{NX_PORT}...")
            subprocess.Popen(
                [client, f"nx://{ip}:{NX_PORT}"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                start_new_session=True,
            )
        else:
            print_info(ip, user)
            print("Auth:  the instance user's system password")
        return 0
    except DispatchError as error:
        print(f"remote-nomachine: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
