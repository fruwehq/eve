#!/usr/bin/env python3
"""Converge provisioning for a concrete v3 instance through the generated
profile overlay, while recording v3 provision state.

Usage: scripts/instance-provision --instance <name> [--registry <path>] [--force] [--dry-run]
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.instance_dispatch import instance_paths_env  # noqa: E402
from eve_sdk.package_dispatch import emit_json  # noqa: E402
from eve_sdk.tf_dispatch import repo_root  # noqa: E402

_USAGE = (
    "Usage: scripts/instance-provision --instance <name> "
    "[--registry <path>] [--force] [--dry-run]"
)


def main(argv: list[str]) -> int:
    instance_name = ""
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY", "")
    force = False
    dry_run = os.environ.get("EVE_PROVISION_DRY_RUN", "0") == "1"

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = args.pop(0)
        elif arg == "--force":
            force = True
        elif arg == "--dry-run":
            dry_run = True
        elif arg in {"-h", "--help"}:
            print(_USAGE, file=sys.stderr)
            return 0
        else:
            print(_USAGE, file=sys.stderr)
            return 2

    if not instance_name:
        print(_USAGE, file=sys.stderr)
        return 2

    root = repo_root()

    paths = instance_paths_env(root, instance_name, registry_path or None)
    overlay = paths.get("INSTANCE_OVERLAY_PATH", "")

    overlay_cmd = [
        str(root / "scripts/instance-profile-overlay"),
        "--instance", instance_name, "--output", overlay,
    ]
    if registry_path:
        overlay_cmd += ["--registry", registry_path]
    rc = subprocess.run(overlay_cmd, cwd=root, check=False).returncode
    if rc != 0:
        return rc

    os.environ["EVE_CATALOG_LOCAL"] = overlay
    os.environ["EVE_INSTANCE_NAME"] = instance_name
    if registry_path:
        os.environ["EVE_INSTANCE_REGISTRY"] = registry_path

    state_disabled = os.environ.get("EVE_DISABLE_STATE", "0") == "1" or dry_run

    def record_state(status: str, provision_state: str, error: str = "") -> None:
        if state_disabled:
            return
        cmd = [
            str(root / "scripts/instance-state"),
            "--instance", instance_name,
            "--operation", "provision",
            "--status", status,
            "--provision-state", provision_state,
        ]
        if error:
            cmd += ["--error", error]
        # set -e: a failing instance-state call is fatal with its exit status.
        state_rc = subprocess.run(
            cmd, cwd=root, stdout=subprocess.DEVNULL, check=False,
        ).returncode
        if state_rc != 0:
            raise SystemExit(state_rc)

    def mark_selected_packages_installed() -> None:
        if state_disabled:
            return
        # stdout captured (replaces the `package-list | jq` pipeline); stderr of
        # package-list passes through. Under pipefail a failure is fatal.
        result = subprocess.run(
            [str(root / "scripts/package-list"), "--instance", instance_name, "--json"],
            cwd=root, text=True, stdout=subprocess.PIPE, check=False,
        )
        if result.returncode != 0:
            raise SystemExit(result.returncode)
        doc = json.loads(result.stdout)
        packages = doc.get("packages", []) if isinstance(doc, dict) else []
        for package in packages:
            if not isinstance(package, dict):
                continue
            if package.get("selected") is True and package.get("installable") is True:
                package_id = str(package.get("id"))
                state_rc = subprocess.run(
                    [
                        str(root / "scripts/instance-state"),
                        "--instance", instance_name,
                        "--operation", "package.install",
                        "--status", "succeeded",
                        "--package", package_id,
                        "--package-state", "installed",
                    ],
                    cwd=root, stdout=subprocess.DEVNULL, check=False,
                ).returncode
                if state_rc != 0:
                    raise SystemExit(state_rc)

    if dry_run:
        emit_json({
            "instance": instance_name,
            "command": "provision",
            "overlay": overlay,
            "force": force,
            "dry_run": True,
        })
        return 0

    record_state("running", "provisioning")

    if force:
        clear_rc = subprocess.run(
            [str(root / "scripts/instance-run"), "provision.clear-state", instance_name],
            cwd=root, check=False,
        ).returncode
        if clear_rc != 0:
            record_state("failed", "error", "provision.clear-state failed")
            return 1

    provision_script = os.environ.get("EVE_PROVISION_SCRIPT", str(root / "scripts/provision"))
    resolve_cmd = [
        str(root / "scripts/instance-resolve"),
        "--instance", instance_name, "--emit", "json",
    ]
    if registry_path:
        resolve_cmd += ["--registry", registry_path]
    # stdout captured into EVE_RESOLVED_JSON (command-substitution strips
    # trailing newlines); stderr passes through; failure is fatal (set -e).
    resolved = subprocess.run(
        resolve_cmd, cwd=root, text=True, stdout=subprocess.PIPE, check=False,
    )
    if resolved.returncode != 0:
        return resolved.returncode
    os.environ["EVE_RESOLVED_JSON"] = resolved.stdout.rstrip("\n")

    exit_code = subprocess.run(
        [provision_script, instance_name], cwd=root, check=False,
    ).returncode
    if exit_code != 0:
        record_state("failed", "error", f"exit {exit_code}")
        return exit_code

    mark_selected_packages_installed()
    record_state("succeeded", "provisioned")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
