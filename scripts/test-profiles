#!/usr/bin/env bash
# Validate every profile in the catalog, and compare its emitted env to a
# committed golden snapshot under tests/golden/.
# Usage:        scripts/test-profiles
# Refresh:      UPDATE_GOLDEN=1 scripts/test-profiles

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

GOLDEN_DIR="tests/golden"
UPDATE="${UPDATE_GOLDEN:-0}"

mkdir -p "$GOLDEN_DIR"

# Unset env-dependent vars so profile-resolve output is deterministic.
unset RASPBERRY_PI_HOST SSH_PUBLIC_KEY_FILE \
      TRUENAS_API_KEY TRUENAS_API_USER TRUENAS_HOST TRUENAS_SSH_HOST_KEY_FINGERPRINT \
      TRUENAS_SSH_PORT TRUENAS_SSH_PRIVATE_KEY_FILE TRUENAS_SSH_USER \
      VM_USER_NAME

FAIL=0
PROFILES=$(./scripts/profiles-list)

for profile in $PROFILES; do
  if ! ./scripts/profile-resolve --profile "$profile" --validate >/dev/null 2>&1; then
    printf '  [FAIL] validate: %s\n' "$profile" >&2
    ./scripts/profile-resolve --profile "$profile" --validate >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  # Sort emitted env so goldens stay stable regardless of profile-resolve's
  # internal emission order, and are easier to scan by eye.
  actual=$(./scripts/profile-resolve --profile "$profile" --emit env | LC_ALL=C sort)
  golden="$GOLDEN_DIR/$profile.env"

  if [ "$UPDATE" = "1" ]; then
    printf '%s\n' "$actual" > "$golden"
    printf '  [UPDATE] %s\n' "$golden"
    continue
  fi

  if [ ! -f "$golden" ]; then
    printf '  [FAIL] missing golden: %s (run: UPDATE_GOLDEN=1 make test)\n' "$golden" >&2
    FAIL=$((FAIL + 1))
    continue
  fi

  if ! diff -u "$golden" <(printf '%s\n' "$actual") >/dev/null; then
    printf '  [FAIL] golden mismatch: %s\n' "$profile" >&2
    diff -u "$golden" <(printf '%s\n' "$actual") >&2 || true
    FAIL=$((FAIL + 1))
    continue
  fi

  printf '  [OK] %s\n' "$profile"
done

qemu_vagrant="$(./scripts/profile-resolve --profile local-qemu-ubuntu-dev-gui --emit vagrant)"
if ! printf '%s\n' "$qemu_vagrant" | grep -q 'qe.disk_resize = "64G"'; then
  printf '  [FAIL] local-qemu Vagrantfile emits disk resize\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] local-qemu Vagrantfile emits disk resize\n'
fi

[ "$FAIL" -eq 0 ]
