#!/usr/bin/env bash
set -euo pipefail

# Resolve PROFILE interactively if not set, then exec the requested make target.
# Usage: scripts/profile-run <make-target> [PROFILE]
#
# This is called from the Makefile when PROFILE is empty.
# It prompts the user to pick a profile, then re-executes make with PROFILE=<choice>.

TARGET="${1:?Usage: scripts/profile-run <make-target> [PROFILE]}"
PROFILE="${2:-}"

if [ -z "$PROFILE" ] && [ -n "${INSTANCE:-}" ]; then
  exec ./scripts/instance-run "$TARGET" "$INSTANCE"
fi

if [ -z "$PROFILE" ]; then
  if [ ! -t 0 ] || [ ! -t 1 ]; then
    echo "Error: PROFILE is required in non-interactive mode." >&2
    echo "       Or pass INSTANCE=<name> to run through the v3 instance bridge." >&2
    echo "Usage: make $TARGET PROFILE=<name>" >&2
    echo "" >&2
    echo "Available profiles:" >&2
    scripts/profiles-list >&2
    exit 1
  fi

  PROFILES=$(scripts/profiles-list)
  TOTAL=$(echo "$PROFILES" | wc -l | tr -d ' ')

  echo ""
  echo "  No PROFILE specified. Pick one:"
  echo ""

  i=1
  while IFS= read -r p; do
    printf "  %2d) %s\n" "$i" "$p"
    i=$((i + 1))
  done <<< "$PROFILES"

  echo ""
  printf "  Select [1-%s] (or type a name): " "$TOTAL"
  read -r selection

  # Check if it's a number
  if echo "$selection" | grep -qE '^[0-9]+$'; then
    count=0
    while IFS= read -r p; do
      count=$((count + 1))
      if [ "$count" -eq "$selection" ]; then
        PROFILE="$p"
        break
      fi
    done <<< "$PROFILES"
    if [ -z "$PROFILE" ]; then
      echo "Error: selection $selection out of range (1-$TOTAL)" >&2
      exit 1
    fi
  else
    # Treat as profile name
    if ! echo "$PROFILES" | grep -qx "$selection"; then
      echo "Error: unknown profile '$selection'" >&2
      exit 1
    fi
    PROFILE="$selection"
  fi

  echo ""
  echo "  Selected: $PROFILE"
  echo ""
fi

exec make "$TARGET" "PROFILE=$PROFILE"
