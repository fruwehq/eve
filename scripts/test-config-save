#!/usr/bin/env python3
from __future__ import annotations

import subprocess
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

result = subprocess.run(
    [
        "poetry",
        "run",
        "pytest",
        "tests/python/commands/test_config_state_commands.py",
        "tests/python/sdk/test_config.py",
    ],
    cwd=ROOT,
    check=False,
)
raise SystemExit(result.returncode)
