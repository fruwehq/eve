        BINDINGS: ClassVar[list[Binding | tuple[str, str] | tuple[str, str, str]]] = [
            Binding("/", "focus_filter", "Filter", show=True),
            Binding("?", "help", "Help", show=True),
            Binding("h", "toggle_hidden", "Hidden"),
            Binding("r", "refresh", "Refresh"),
            Binding("u", "provider('up')", "Up"),
            Binding("t", "provider('stop')", "Stop"),
            Binding("p", "provision", "Provision"),
            Binding("x", "down_instance", "Down"),
            Binding("d", "delete_instance", "Delete Local"),
            Binding("c", "cancel_command", "Cancel", priority=True),
            Binding("ctrl+c", "cancel_command", "Cancel", priority=True),
            Binding("escape", "cancel_command", "Cancel", priority=True),
            Binding("l", "focus_log", "Log", priority=True),
            Binding("y", "copy_log", "Copy Log", priority=True),
            Binding("q", "quit", "Quit"),
