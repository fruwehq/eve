#!/usr/bin/env python3
"""Optional Textual TUI for v3 instance management."""

from __future__ import annotations

import argparse
import asyncio
import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any, ClassVar, cast

ROOT = Path(__file__).resolve().parents[1]


def usage() -> str:
    return """Usage: scripts/egame-tui [--check]

Open an optional Textual interface for v3 concrete instances.

Options:
  --check   Validate that the script is syntactically importable without
            requiring Textual to be installed.
"""


def run_command(args: list[str], *, env: dict[str, str] | None = None) -> tuple[int, str, str]:
    proc = subprocess.run(
        args,
        cwd=ROOT,
        env={**os.environ, **(env or {})},
        text=True,
        capture_output=True,
        check=False,
    )
    return proc.returncode, proc.stdout, proc.stderr


def load_json(args: list[str]) -> dict[str, Any]:
    code, out, err = run_command(args)
    if code != 0:
        raise RuntimeError(err.strip() or out.strip() or f"{args[0]} exited {code}")
    parsed = json.loads(out)
    if not isinstance(parsed, dict):
        raise RuntimeError(f"{args[0]} did not return a JSON object")
    return cast(dict[str, Any], parsed)


def instance_rows() -> list[dict[str, Any]]:
    doc = load_json([str(ROOT / "scripts/instance-list"), "--json"])
    return list(doc.get("instances", []))


def instance_status(instance: str) -> dict[str, Any]:
    return load_json([str(ROOT / "scripts/instance-status"), "--instance", instance, "--json"])


def dispatch_provider(instance: str, command: str) -> tuple[int, str, str]:
    return run_command(
        [
            str(ROOT / "scripts/provider-dispatch"),
            "--instance",
            instance,
            "--command",
            command,
        ]
    )


def dispatch_package(instance: str, package: str, command: str) -> tuple[int, str, str]:
    return run_command(
        [
            str(ROOT / "scripts/package-dispatch"),
            "--instance",
            instance,
            "--package",
            package,
            "--command",
            command,
        ]
    )


def provision_instance(instance: str, *, force: bool = False) -> tuple[int, str, str]:
    args = [str(ROOT / "scripts/instance-provision"), "--instance", instance]
    if force:
        args.append("--force")
    return run_command(args)


def update_package_selection(instance: str, package: str, *, selected: bool) -> tuple[int, str, str]:
    return run_command(
        [
            str(ROOT / "scripts/package-selection"),
            "--instance",
            instance,
            "--package",
            package,
            "--add" if selected else "--remove",
        ]
    )


def render_instance_details(status: dict[str, Any] | None) -> str:
    if not status:
        return "Select an instance to inspect state."

    instance = status.get("instance", {})
    state = status.get("state", {})
    summary = status.get("packages", {}).get("summary", {})
    last_operation = state.get("last_operation") or {}
    return "\n".join(
        [
            f"[b]{instance.get('name', '-')}[/b]",
            f"Provider: {instance.get('provider', '-')} ({instance.get('provider_plugin', '-')})",
            f"Engine: {instance.get('engine', '-')}",
            f"OS: {instance.get('os', '-')} ({instance.get('os_family', '-')})",
            f"Location: {instance.get('location') or '-'}",
            "",
            f"Desired: {state.get('desired_state', 'unknown')}",
            f"Provider: {state.get('provider_state', 'unknown')}",
            f"Provision: {state.get('provision_state', 'unknown')}",
            f"Packages: installed={summary.get('installed', 0)} missing={summary.get('missing', 0)} "
            f"unknown={summary.get('unknown', 0)} failed={summary.get('failed', 0)}",
            "",
            f"Last: {last_operation.get('name', 'none')} {last_operation.get('status', '')}".strip(),
            f"Error: {state.get('last_error') or 'none'}",
        ]
    )


def run_tui() -> int:
    try:
        from textual.app import App, ComposeResult
        from textual.binding import Binding
        from textual.containers import Container, Horizontal, Vertical
        from textual.widgets import Button, DataTable, Footer, Header, RichLog, Static
    except ModuleNotFoundError:
        print(
            "Textual is required for the TUI.\n"
            "Install it with: python3 -m pip install textual\n"
            "The non-TUI v3 commands still work through make targets.",
            file=sys.stderr,
        )
        return 2

    class EGameTui(App[None]):
        """Instance manager built on the existing v3 command surface."""

        CSS = """
        Screen {
            background: #0b1020;
            color: #e7edf7;
        }

        #root {
            height: 1fr;
            padding: 1;
            layout: vertical;
        }

        #main {
            height: 3fr;
        }

        #left {
            width: 42;
            min-width: 36;
            margin-right: 1;
        }

        #right {
            width: 1fr;
        }

        .panel {
            border: round #3b82f6;
            background: #111827;
            padding: 1;
        }

        .panel-title {
            color: #93c5fd;
            text-style: bold;
            margin-bottom: 1;
        }

        #details {
            height: auto;
            margin-bottom: 1;
        }

        #actions {
            height: auto;
            margin-bottom: 1;
        }

        #packages {
            height: 1fr;
        }

        Button {
            min-width: 13;
            margin-right: 1;
            margin-bottom: 1;
        }

        #logs {
            height: 11;
            margin-top: 1;
            border: round #475569;
            background: #030712;
            padding: 1;
        }
        """

        BINDINGS: ClassVar[list[Binding | tuple[str, str] | tuple[str, str, str]]] = [
            ("r", "refresh", "Refresh"),
            ("s", "provider_action('status')", "Provider status"),
            ("p", "provision", "Provision"),
            ("q", "quit", "Quit"),
        ]

        def __init__(self) -> None:
            super().__init__()
            self.instances: list[dict[str, Any]] = []
            self.current_instance: str | None = None
            self.current_package: str | None = None
            self.current_status: dict[str, Any] | None = None

        def compose(self) -> ComposeResult:
            yield Header(show_clock=True)
            with Container(id="root"):
                with Horizontal(id="main"):
                    with Vertical(id="left", classes="panel"):
                        yield Static("Instances", classes="panel-title")
                        yield DataTable(id="instances")
                    with Vertical(id="right", classes="panel"):
                        yield Static("Instance", classes="panel-title")
                        yield Static("Select an instance to inspect state.", id="details")
                        with Horizontal(id="actions"):
                            yield Button("Refresh", id="refresh", variant="primary")
                            yield Button("Status", id="provider-status")
                            yield Button("Plan", id="provider-plan")
                            yield Button("Start", id="provider-start", variant="success")
                            yield Button("Stop", id="provider-stop", variant="warning")
                            yield Button("Provision", id="instance-provision", variant="primary")
                            yield Button("Force Prov", id="instance-force-provision", variant="warning")
                            yield Button("New Cmd", id="instance-new-command")
                            yield Button("Delete Cmd", id="instance-delete-command", variant="error")
                        yield Static("Packages", classes="panel-title")
                        yield DataTable(id="packages")
                        with Horizontal(id="package-actions"):
                            yield Button("Pkg Status", id="package-status")
                            yield Button("Select", id="package-select")
                            yield Button("Unselect", id="package-unselect")
                            yield Button("Install", id="package-install", variant="success")
                            yield Button("Down Cmd", id="package-down-command", variant="warning")
                            yield Button("SSH Cmd", id="ssh-command")
                yield RichLog(id="logs", markup=True, wrap=True)
            yield Footer()

        async def on_mount(self) -> None:
            instances = self.query_one("#instances", DataTable)
            instances.cursor_type = "row"
            instances.add_columns("Instance", "Recipe", "Machine", "OS")

            packages = self.query_one("#packages", DataTable)
            packages.cursor_type = "row"
            packages.add_columns("Package", "Selected", "State", "Supported", "Display")

            await self.refresh_instances()
            self.update_action_state()

        def write_log(self, message: str) -> None:
            self.query_one("#logs", RichLog).write(message)

        async def refresh_instances(self) -> None:
            self.write_log("[b blue]Refreshing instances[/b blue]")
            try:
                rows = await asyncio.to_thread(instance_rows)
            except Exception as exc:
                self.write_log(f"[red]instance-list failed:[/red] {exc}")
                return

            self.instances = rows
            table = self.query_one("#instances", DataTable)
            table.clear()
            for row in rows:
                name = str(row.get("name", ""))
                if not name:
                    continue
                table.add_row(
                    name,
                    str(row.get("recipe") or "-"),
                    str(row.get("machine") or "-"),
                    str(row.get("os") or "-"),
                    key=name,
                )

            if rows:
                self.current_instance = str(rows[0].get("name"))
                await self.refresh_current_status()
            else:
                self.current_instance = None
                self.current_status = None
                self.query_one("#details", Static).update("No instances found. Create one with make instance.create.")
                self.query_one("#packages", DataTable).clear()
            self.update_action_state()

        async def refresh_current_status(self) -> None:
            if not self.current_instance:
                return

            self.write_log(f"[b blue]Loading {self.current_instance}[/b blue]")
            try:
                status = await asyncio.to_thread(instance_status, self.current_instance)
            except Exception as exc:
                self.write_log(f"[red]instance-status failed:[/red] {exc}")
                return

            self.current_status = status
            self.query_one("#details", Static).update(render_instance_details(status))
            self.render_packages(status)
            self.update_action_state()

        def render_packages(self, status: dict[str, Any]) -> None:
            packages = status.get("packages", {}).get("all", [])
            table = self.query_one("#packages", DataTable)
            table.clear()
            self.current_package = None
            for package in packages:
                package_id = str(package.get("id", ""))
                if not package_id:
                    continue
                if self.current_package is None and package.get("selected"):
                    self.current_package = package_id
                state = package.get("state", {}) or {}
                table.add_row(
                    package_id,
                    "yes" if package.get("selected") else "no",
                    str(state.get("status") or "unknown"),
                    "yes" if package.get("supported") else "no",
                    str(package.get("display_name") or package_id),
                    key=package_id,
                )
            self.update_action_state()

        async def on_data_table_row_selected(self, event: DataTable.RowSelected) -> None:
            table_id = event.data_table.id
            row_key = str(event.row_key.value)
            if table_id == "instances":
                self.current_instance = row_key
                await self.refresh_current_status()
            elif table_id == "packages":
                self.current_package = row_key
                self.write_log(f"Selected package [b]{row_key}[/b]")
                self.update_action_state()

        async def on_button_pressed(self, event: Button.Pressed) -> None:
            button_id = event.button.id
            if button_id == "refresh":
                await self.action_refresh()
            elif button_id and button_id.startswith("provider-"):
                await self.action_provider_action(button_id.replace("provider-", "", 1))
            elif button_id == "package-status":
                await self.package_action("status")
            elif button_id == "package-select":
                await self.package_selection(True)
            elif button_id == "package-unselect":
                await self.package_selection(False)
            elif button_id == "package-install":
                await self.package_action("install")
            elif button_id == "package-down-command":
                self.show_package_down_command()
            elif button_id == "instance-provision":
                await self.action_provision(force=False)
            elif button_id == "instance-force-provision":
                await self.action_provision(force=True)
            elif button_id == "instance-new-command":
                self.show_new_instance_command()
            elif button_id == "instance-delete-command":
                self.show_delete_instance_command()
            elif button_id == "ssh-command":
                self.show_ssh_command()

        async def action_refresh(self) -> None:
            await self.refresh_instances()

        async def action_provision(self, *, force: bool) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            label = "instance.provision --force" if force else "instance.provision"
            self.write_log(f"[b blue]{label} {self.current_instance}[/b blue]")
            code, out, err = await asyncio.to_thread(provision_instance, self.current_instance, force=force)
            self.write_command_result(code, out, err)
            await self.refresh_current_status()

        async def action_provider_action(self, command: str) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            self.write_log(f"[b blue]provider.{command} {self.current_instance}[/b blue]")
            code, out, err = await asyncio.to_thread(dispatch_provider, self.current_instance, command)
            self.write_command_result(code, out, err)
            await self.refresh_current_status()

        async def package_selection(self, selected: bool) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            if not self.current_package:
                self.write_log("[yellow]Select a package first.[/yellow]")
                return
            verb = "select" if selected else "unselect"
            self.write_log(f"[b blue]package.{verb} {self.current_package} on {self.current_instance}[/b blue]")
            code, out, err = await asyncio.to_thread(
                update_package_selection,
                self.current_instance,
                self.current_package,
                selected=selected,
            )
            self.write_command_result(code, out, err)
            await self.refresh_current_status()

        async def package_action(self, command: str) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            if not self.current_package:
                self.write_log("[yellow]Select a package first.[/yellow]")
                return
            self.write_log(f"[b blue]package.{command} {self.current_package} on {self.current_instance}[/b blue]")
            code, out, err = await asyncio.to_thread(
                dispatch_package,
                self.current_instance,
                self.current_package,
                command,
            )
            self.write_command_result(code, out, err)
            await self.refresh_current_status()

        def write_command_result(self, code: int, out: str, err: str) -> None:
            if out.strip():
                self.write_log(out.rstrip())
            if err.strip():
                self.write_log(f"[red]{err.rstrip()}[/red]")
            if code == 0:
                self.write_log("[green]Command succeeded.[/green]")
            else:
                self.write_log(f"[red]Command failed with exit {code}.[/red]")

        def show_ssh_command(self) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            self.write_log(f"[b]SSH:[/b] make ssh INSTANCE={self.current_instance}")

        def show_new_instance_command(self) -> None:
            self.write_log(
                "[b]Create:[/b] make instance.create INSTANCE=<name> RECIPE=<recipe> "
                "[MACHINE=<id>] [OS=<id>] [PACKAGES=a,b]"
            )

        def show_delete_instance_command(self) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            self.write_log(f"[b red]Delete:[/b red] make instance.delete INSTANCE={self.current_instance} PURGE=1")

        def show_package_down_command(self) -> None:
            if not self.current_instance:
                self.write_log("[yellow]Select an instance first.[/yellow]")
                return
            if not self.current_package:
                self.write_log("[yellow]Select a package first.[/yellow]")
                return
            self.write_log(
                f"[b yellow]Package down:[/b yellow] make package.down "
                f"INSTANCE={self.current_instance} PACKAGE={self.current_package} YES=1"
            )

        def package_entry(self) -> dict[str, Any] | None:
            if not self.current_status or not self.current_package:
                return None
            packages = self.current_status.get("packages", {}).get("all", [])
            for package in packages:
                if isinstance(package, dict) and package.get("id") == self.current_package:
                    return package
            return None

        def set_button(self, button_id: str, *, disabled: bool) -> None:
            self.query_one(f"#{button_id}", Button).disabled = disabled

        def update_action_state(self) -> None:
            has_instance = self.current_instance is not None
            state = self.current_status.get("state", {}) if self.current_status else {}
            provider_state = str(state.get("provider_state", "unknown"))
            provision_state = str(state.get("provision_state", "unknown"))
            provider_busy = provider_state == "changing"
            provider_absent = provider_state == "absent"

            self.set_button("provider-status", disabled=not has_instance)
            self.set_button("provider-plan", disabled=not has_instance or provider_busy)
            self.set_button("provider-start", disabled=not has_instance or provider_busy or provider_state == "running")
            self.set_button(
                "provider-stop",
                disabled=not has_instance or provider_busy or provider_state in {"unknown", "stopped", "absent"},
            )
            self.set_button("instance-provision", disabled=not has_instance or provider_busy or provider_absent)
            self.set_button(
                "instance-force-provision",
                disabled=not has_instance or provider_busy or provider_absent or provision_state == "provisioning",
            )
            self.set_button("instance-delete-command", disabled=not has_instance)
            self.set_button("ssh-command", disabled=not has_instance)

            package = self.package_entry()
            has_package = package is not None
            supported = bool(package.get("supported")) if package else False
            selected = bool(package.get("selected")) if package else False
            selected_by = package.get("selected_by", []) if package else []
            directly_selected = isinstance(selected_by, list) and "direct" in selected_by

            self.set_button("package-status", disabled=not has_instance or not has_package or not supported)
            self.set_button("package-select", disabled=not has_instance or not has_package or not supported or selected)
            self.set_button("package-unselect", disabled=not has_instance or not has_package or not directly_selected)
            self.set_button("package-install", disabled=not has_instance or not has_package or not supported)
            self.set_button("package-down-command", disabled=not has_instance or not has_package or not supported)

    EGameTui().run()
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--check", action="store_true")
    parser.add_argument("-h", "--help", action="store_true")
    args = parser.parse_args()

    if args.help:
        print(usage(), end="")
        return 0
    if args.check:
        return 0
    return run_tui()


if __name__ == "__main__":
    raise SystemExit(main())
