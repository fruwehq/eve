#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk import state_machine  # noqa: E402
from eve_sdk.dispatch import run_json  # noqa: E402
from eve_sdk.resolve import default_registry_path, load_any  # noqa: E402
from eve_sdk.state import State  # noqa: E402


def usage() -> None:
    print(
        """Usage:
  scripts/instance-view --instance <name> [--registry <path>] [--emit json] [--observe]
  scripts/instance-view --aggregate [--registry <path>]""",
        file=sys.stderr,
    )


def provider_actions(provider_id: str) -> list[dict[str, object]]:
    plugin_doc = run_json(str(ROOT / "scripts/plugin-list"), "--kind", "provider", "--json")
    plugin = next((entry for entry in plugin_doc["plugins"] if entry["id"] == provider_id), None)
    if not plugin:
        return []
    actions = plugin.get("actions")
    return actions if isinstance(actions, list) else []


def main(argv: list[str]) -> int:
    instance_name: str | None = None
    registry_path = Path(os.environ.get("EVE_INSTANCE_REGISTRY") or default_registry_path()).resolve()
    emit = "json"
    aggregate = False
    statuses_only = False
    observe = False
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--aggregate":
            aggregate = True
        elif arg == "--statuses":
            statuses_only = True
        elif arg == "--observe":
            observe = True
        elif arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = Path(args.pop(0)).resolve()
        elif arg == "--emit" and args:
            emit = args.pop(0)
        elif arg in {"-h", "--help"}:
            usage()
            return 0
        else:
            usage()
            return 2
    try:
        if aggregate or statuses_only:
            registry = load_any(registry_path)
            statuses: dict[str, dict[str, object]] = {}
            for instance in registry.get("instances", []):
                if not isinstance(instance, dict) or not instance.get("name"):
                    continue
                name = str(instance["name"])
                state = State.read(name)
                observed = state.get("observed_state", {})
                status = state_machine.status_with_observed_state(
                    {"instance": instance, "state": state, "observed_state": observed},
                    {"observed_state": observed},
                )
                inner = status.get("state")
                if isinstance(inner, dict):
                    # The list renders effective_provider_state, which is computed
                    # rather than stored; add it so this fast (no-resolve) read is a
                    # drop-in for rendering the instance table.
                    inner["effective_provider_state"] = state_machine.effective_provider_state(inner)
                statuses[name] = status
            if statuses_only:
                print(json.dumps({"statuses": statuses}, separators=(",", ":")))
            else:
                print(json.dumps({"aggregate": state_machine.aggregate_summary(statuses)}, indent=2))
            return 0
        if not instance_name:
            usage()
            return 2
        if emit != "json":
            print(f"instance-view: unsupported emit format: {emit} (only json is supported)", file=sys.stderr)
            usage()
            return 2
        if observe:
            env: dict[str, str] = {}
            if registry_path != default_registry_path():
                env["EVE_INSTANCE_REGISTRY"] = str(registry_path)
            result = subprocess.run(
                [str(ROOT / "scripts/instance-observe"), "--instance", instance_name],
                cwd=ROOT,
                env=os.environ | env,
                text=True,
                capture_output=True,
                check=False,
            )
            if result.returncode != 0:
                details = result.stderr if result.stderr else result.stdout
                raise RuntimeError(f"observe failed for {instance_name}: {details.strip()}")
        resolve_cmd = [str(ROOT / "scripts/instance-resolve"), "--instance", instance_name, "--emit", "json"]
        paths_cmd = [str(ROOT / "scripts/instance-paths"), "--instance", instance_name, "--emit", "json"]
        package_cmd = [str(ROOT / "scripts/package-list"), "--instance", instance_name, "--json"]
        if registry_path != default_registry_path():
            resolve_cmd.extend(["--registry", str(registry_path)])
            paths_cmd.extend(["--registry", str(registry_path)])
            package_cmd.extend(["--registry", str(registry_path)])
        resolved = run_json(*resolve_cmd)
        paths = run_json(*paths_cmd)
        packages = run_json(*package_cmd)["packages"]
        view = State.build_view(instance_name=instance_name, resolved=resolved, packages=packages, paths=paths)
        view["provider_actions"] = provider_actions(resolved["provider_plugin"])
        print(json.dumps(view, indent=2))
        return 0
    except Exception as error:
        print(f"instance-view: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
