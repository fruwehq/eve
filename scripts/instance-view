#!/usr/bin/env python3
"""Per-instance view: resolve + packages + paths + provider actions.

Cold entrypoint: parses catalog/plugins fresh per call, then delegates to the
shared pure assembly in ``eve_sdk.instance_view`` (the same module the warm
Engine uses), guaranteeing byte-identical output between cold and warm paths.
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.instance_view import (  # noqa: E402
    build_aggregate,
    build_instance_view,
    build_statuses,
)
from eve_sdk.plugin_manifest import PluginManifest  # noqa: E402
from eve_sdk.resolve import default_registry_path, resolve_instance  # noqa: E402


def usage() -> None:
    print(
        """Usage:
  scripts/instance-view --instance <name> [--registry <path>] [--emit json] [--observe]
  scripts/instance-view --aggregate [--registry <path>)]""",
        file=sys.stderr,
    )


def main(argv: list[str]) -> int:
    instance_name: str | None = None
    registry_path = Path(os.environ.get("EVE_INSTANCE_REGISTRY") or default_registry_path()).resolve()
    emit = "json"
    aggregate = False
    statuses_only = False
    observe = False
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--aggregate":
            aggregate = True
        elif arg == "--statuses":
            statuses_only = True
        elif arg == "--observe":
            observe = True
        elif arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = Path(args.pop(0)).resolve()
        elif arg == "--emit" and args:
            emit = args.pop(0)
        elif arg in {"-h", "--help"}:
            usage()
            return 0
        else:
            usage()
            return 2
    try:
        if aggregate or statuses_only:
            # --statuses / --aggregate never need catalog or plugins: a fast
            # persisted-state sweep over the registry.
            if statuses_only:
                print(json.dumps({"statuses": build_statuses(registry_path)}, separators=(",", ":")))
            else:
                print(json.dumps({"aggregate": build_aggregate(registry_path)}, indent=2))
            return 0
        if not instance_name:
            usage()
            return 2
        if emit != "json":
            print(f"instance-view: unsupported emit format: {emit} (only json is supported)", file=sys.stderr)
            usage()
            return 2
        if observe:
            # Live provider.status is still a subprocess boundary (it shells to
            # make + the provider plugin). Run it, then build the view in-process
            # via the shared assembly so catalog/plugins are not re-parsed here.
            env: dict[str, str] = {}
            if registry_path != default_registry_path():
                env["EVE_INSTANCE_REGISTRY"] = str(registry_path)
            result = subprocess.run(
                [str(ROOT / "scripts/instance-observe"), "--instance", instance_name],
                cwd=ROOT,
                env=os.environ | env,
                text=True,
                capture_output=True,
                check=False,
            )
            if result.returncode != 0:
                details = result.stderr if result.stderr else result.stdout
                raise RuntimeError(f"observe failed for {instance_name}: {details.strip()}")
        # Cold path: parse fresh; the shared assembly guarantees the warm Engine
        # (which passes memoized catalog/plugins) produces byte-identical output.
        resolved = resolve_instance(instance_name, registry_path)
        view = build_instance_view(
            instance_name,
            resolved=resolved,
            package_plugins=[PluginManifest.public(p) for p in PluginManifest.load_all("package")],
            provider_plugins=[PluginManifest.public(p) for p in PluginManifest.load_all("provider")],
        )
        print(json.dumps(view, indent=2))
        return 0
    except Exception as error:
        print(f"instance-view: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
