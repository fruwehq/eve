#!/usr/bin/env python3
# ruff: noqa: E501
"""Validate catalog-backed provider/platform/content choices."""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def _pkg(doc, pkg_id, **expected):
    """Check that package pkg_id has the given nested key=value pairs."""
    for p in doc["packages"]:
        if p["id"] != pkg_id:
            continue
        for key, val in expected.items():
            current = p
            for part in key.split("."):
                current = current.get(part, {}) if isinstance(current, dict) else {}
            if current != val:
                return False
        return True
    return False


def main() -> int:
    fail = 0
    result = subprocess.run(
        [sys.executable, str(ROOT / "scripts/catalog-options"), "--json"],
        cwd=str(ROOT), capture_output=True, text=True, check=False,
    )
    if result.returncode != 0:
        print(f"  [FAIL] catalog-options exited {result.returncode}", file=sys.stderr)
        return 1
    doc = json.loads(result.stdout)

    def has_plat(provider, machine=None, os_id=None):
        return any(
            p["provider"] == provider and (machine is None or p["machine"] == machine) and (os_id is None or p["os"] == os_id)
            for p in doc["platforms"]
        )

    # Bundle helper
    def bundle_includes(bundle_id):
        return next((b.get("includes", []) for b in doc["bundles"] if b["id"] == bundle_id), None)

    ds_inc = bundle_includes("desktop-streaming")
    gs_inc = bundle_includes("gaming-streaming")
    retired = {"desktop-rustdesk-vnc", "desktop-vnc", "remote-rdp", "remote-waypipe", "dev-ai-arm64"}

    check1 = (
        "vultr" in doc["providers"] and
        "truenas" in doc["providers"] and
        "gcp" in doc["providers"] and
        has_plat("aws", "aws-gpu-g4dn-spot", "ubuntu-26.04-amd64") and
        has_plat("aws", "aws-gpu-g4dn-spot", "windows-server-2025") and
        has_plat("vultr", "vultr-vcg-a40-2c", "windows-server-2025") and
        has_plat("truenas", "truenas-scale-medium", "ubuntu-26.04-amd64") and
        has_plat("gcp", "gcp-cheap-x86", "ubuntu-26.04-amd64") and
        ds_inc is not None and "gnome-desktop" not in ds_inc and
        all(x in ds_inc for x in ["sunshine", "rustdesk", "vnc", "rdp", "waypipe"]) and
        gs_inc is not None and "steam" in gs_inc and
        not any(b["id"] in retired for b in doc["bundles"]) and
        _pkg(doc, "codex-cli", **{"supports.os_families": ["ubuntu"]}) and
        _pkg(doc, "xpra", **{"supports.ubuntu_versions": ["22.04", "24.04"]}) and
        _pkg(doc, "rdp", **{"supports.os_families": ["ubuntu", "windows"], "installable_os_families": ["ubuntu"]}) and
        _pkg(doc, "thinlinc", **{"supports.os_families": ["ubuntu"], "supports.arches": ["amd64"], "installable_os_families": ["ubuntu"]}) and
        _pkg(doc, "nomachine", **{"supports.os_families": ["ubuntu", "windows"], "installable_os_families": ["ubuntu", "windows"]}) and
        _pkg(doc, "splashtop", **{"supports.os_families": ["ubuntu", "windows"], "supports.arches": ["amd64"]}) and
        _pkg(doc, "steam", **{"supports.arches": ["amd64"]})
    )
    if check1:
        print("  [OK] catalog-options emits provider/platform/content choices with package support metadata")
    else:
        print("  [FAIL] catalog-options emits provider/platform/content choices with package support metadata", file=sys.stderr)
        fail += 1

    # Check 2: hide invalid provider/OS pairs.
    no_vultr_ubuntu = all(not (p["provider"] == "vultr" and p["os"] == "ubuntu-26.04-amd64") for p in doc["platforms"])
    has_aws_windows = any(p["provider"] == "aws" and p["os"] == "windows-server-2025" for p in doc["platforms"])
    if no_vultr_ubuntu and has_aws_windows:
        print("  [OK] catalog-options hides invalid provider/OS pairs and exposes AWS Windows with image metadata")
    else:
        print("  [FAIL] catalog-options provider/OS image metadata gating regressed", file=sys.stderr)
        fail += 1

    # Check 3: init choices gated by provider.
    rpi_has_metal = any(p["provider"] == "raspberry-pi" and p["init"] == "ssh-ubuntu-metal" for p in doc["platforms"])
    rpi_only_metal = all(p["init"] == "ssh-ubuntu-metal" for p in doc["platforms"] if p["provider"] == "raspberry-pi")
    metal_only_rpi = all(p["provider"] == "raspberry-pi" for p in doc["platforms"] if p["init"] == "ssh-ubuntu-metal")
    if rpi_has_metal and rpi_only_metal and metal_only_rpi:
        print("  [OK] catalog-options gates init choices by provider")
    else:
        print("  [FAIL] catalog-options exposes invalid provider/init pairs", file=sys.stderr)
        fail += 1

    return 1 if fail else 0


if __name__ == "__main__":
    raise SystemExit(main())
