#!/usr/bin/env bash
# Validate catalog-backed provider/platform/content choices.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

FAIL=0

catalog_options_json="$(./scripts/catalog-options --json)"
if printf '%s\n' "$catalog_options_json" |
  jq -e '
    (.providers | index("vultr")) and
    (.providers | index("truenas")) and
    (.providers | index("gcp")) and
    any(.platforms[]; .provider == "vultr" and .machine == "vultr-vcg-a40-2c" and .os == "windows-server-2025") and
    any(.platforms[]; .provider == "truenas" and .machine == "truenas-scale-medium" and .os == "ubuntu-26.04-amd64") and
    any(.platforms[]; .provider == "gcp" and .machine == "gcp-cheap-x86" and .os == "ubuntu-26.04-amd64") and
    any(.bundles[]; .id == "desktop-streaming" and (.includes | index("sunshine")) and (.includes | index("rustdesk")) and (.includes | index("vnc")) and (.includes | index("rdp")) and (.includes | index("waypipe"))) and
    any(.bundles[]; .id == "gaming-streaming" and (.includes | index("steam"))) and
    all(.bundles[]; .id != "desktop-rustdesk-vnc" and .id != "desktop-vnc" and .id != "remote-rdp" and .id != "remote-waypipe" and .id != "dev-ai-arm64") and
    any(.packages[]; .id == "codex-cli" and .supports.os_families == ["ubuntu"]) and
    any(.packages[]; .id == "xpra" and .supports.ubuntu_versions == ["22.04", "24.04"]) and
    any(.packages[]; .id == "rdp" and .supports.os_families == ["ubuntu", "windows"] and .installable_os_families == ["ubuntu"]) and
    any(.packages[]; .id == "steam" and .supports.arches == ["amd64"])
  ' >/dev/null; then
  printf '  [OK] catalog-options emits provider/platform/content choices with package support metadata\n'
else
  printf '  [FAIL] catalog-options emits provider/platform/content choices with package support metadata\n' >&2
  printf '%s\n' "$catalog_options_json" >&2
  FAIL=$((FAIL + 1))
fi

if printf '%s\n' "$catalog_options_json" |
  jq -e '
    all(.platforms[]; .provider != "vultr" or .os != "ubuntu-26.04-amd64") and
    all(.platforms[]; .provider != "aws" or .os != "windows-server-2025")
  ' >/dev/null; then
  printf '  [OK] catalog-options hides provider/OS pairs without provider image metadata\n'
else
  printf '  [FAIL] catalog-options exposes provider/OS pairs without provider image metadata\n' >&2
  printf '%s\n' "$catalog_options_json" | jq '.platforms[] | select((.provider == "vultr" and .os == "ubuntu-26.04-amd64") or (.provider == "aws" and .os == "windows-server-2025"))' >&2
  FAIL=$((FAIL + 1))
fi

if printf '%s\n' "$catalog_options_json" |
  jq -e '
    any(.platforms[]; .provider == "raspberry-pi" and .init == "ssh-ubuntu-metal") and
    all(.platforms[]; .provider != "raspberry-pi" or .init == "ssh-ubuntu-metal") and
    all(.platforms[]; .provider == "raspberry-pi" or .init != "ssh-ubuntu-metal")
  ' >/dev/null; then
  printf '  [OK] catalog-options gates init choices by provider\n'
else
  printf '  [FAIL] catalog-options exposes invalid provider/init pairs\n' >&2
  printf '%s\n' "$catalog_options_json" | jq '.platforms[] | select(.init == "ssh-ubuntu-metal" or .provider == "raspberry-pi")' >&2
  FAIL=$((FAIL + 1))
fi

[ "$FAIL" -eq 0 ]
