#!/usr/bin/env bash
set -euo pipefail

# Run terraform init for a profile's stacks.
# Usage: scripts/tf-init <profile>

PROFILE="${1:?Usage: scripts/tf-init <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" != "terraform" ]; then
  echo "[tf-init] no-op for engine=$ENGINE"
  exit 0
fi

TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
echo "[tf-init] profile=$PROFILE tags=$TAGS"

run_step() {
  if [ "${EGAME_TF_PRINT:-0}" = "1" ]; then
    printf '[tf-init] would run:'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

if [ "${EGAME_TF_PRINT:-0}" != "1" ]; then
  terramate generate
fi

eval "$(./scripts/tf-env "$PROFILE")"

init_args=(terraform init -reconfigure)
tm_args=(--tags="$TAGS")

# When in v3 INSTANCE= mode, ensure a dedicated workspace exists per stack so
# subsequent plan/apply/destroy/output operations (which honor TF_WORKSPACE and
# EGAME_TF_DATA_BASE from tf-env) target isolated backend and data paths.
# PROFILE= callers skip this and keep using the default compatibility paths.
if [ -n "${EGAME_INSTANCE_NAME:-}" ]; then
  : "${EGAME_TF_STATE_BASE:?tf-env did not set EGAME_TF_STATE_BASE}"
  : "${EGAME_TF_DATA_BASE:?tf-env did not set EGAME_TF_DATA_BASE}"
  if [ "${EGAME_TF_PRINT:-0}" != "1" ]; then
    mkdir -p "$EGAME_TF_STATE_BASE" "$EGAME_TF_DATA_BASE"
  fi
  tm_args+=(--eval)
  init_args+=(
    "-backend-config=path=${EGAME_TF_STATE_BASE}/\${terramate.stack.path.relative}/default.tfstate"
    "-backend-config=workspace_dir=${EGAME_TF_STATE_BASE}/\${terramate.stack.path.relative}/workspaces"
  )
fi

run_step terramate run "${tm_args[@]}" -- "${init_args[@]}"

if [ -n "${EGAME_INSTANCE_NAME:-}" ]; then
  TF_WORKSPACE="" run_step terramate run --tags="$TAGS" -- \
    terraform workspace select -or-create "$EGAME_INSTANCE_NAME"
fi
