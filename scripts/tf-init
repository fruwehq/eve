#!/usr/bin/env bash
set -euo pipefail

# Run terraform init for a profile's stacks.
# Usage: scripts/tf-init <profile>

PROFILE="${1:?Usage: scripts/tf-init <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" != "terraform" ]; then
  echo "[tf-init] no-op for engine=$ENGINE"
  exit 0
fi

TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
echo "[tf-init] profile=$PROFILE tags=$TAGS"

run_step() {
  if [ "${EGAME_TF_PRINT:-0}" = "1" ]; then
    printf '[tf-init] would run:'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

if [ "${EGAME_TF_PRINT:-0}" != "1" ]; then
  terramate generate
fi

eval "$(./scripts/tf-env "$PROFILE")"
run_step terramate run --tags="$TAGS" -- terraform init -reconfigure

# When in v3 INSTANCE= mode, ensure a dedicated workspace exists per stack so
# subsequent plan/apply/destroy operations (which honor TF_WORKSPACE from
# tf-env) target an isolated state file. PROFILE= callers skip this and keep
# using the default workspace.
if [ -n "${EGAME_INSTANCE_NAME:-}" ]; then
  run_step terramate run --tags="$TAGS" -- \
    terraform workspace select -or-create "$EGAME_INSTANCE_NAME"
fi
