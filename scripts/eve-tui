#!/usr/bin/env python3
"""Optional Textual TUI for v3 instance management.

This file is a thin launcher. The widgets and App live in tui/widgets.py
and tui/app.py; the pure helpers live in tui/commands.py, tui/render.py,
and tui/state.py.

Textual is imported lazily inside run_tui() so --check works without
Textual installed and the runpy test in scripts/test-tui can pull the
pure helpers out of module scope without triggering the heavy import.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

# Re-export pure helpers so scripts/test-tui can reach them via
# `runpy.run_path("scripts/eve-tui")` without importing Textual.
from tui.commands import catalog_options  # noqa: F401
from tui.render import format_aggregate  # noqa: F401


def usage() -> str:
    return """Usage: scripts/eve-tui [--check]
       scripts/eve [--check]

Open Eve, the optional Textual interface for v3 concrete instances.

Options:
  --check   Validate that the script is syntactically importable without
            requiring Textual to be installed.
"""


def run_tui() -> int:
    try:
        from tui.app import run
    except ModuleNotFoundError as exc:
        if exc.name and exc.name.startswith("textual"):
            print(
                "Textual is required for the TUI.\n"
                "Install it with: poetry install\n"
                "The non-TUI v3 commands still work through make targets.",
                file=sys.stderr,
            )
            return 2
        raise
    return run()


def main() -> int:
    parser = argparse.ArgumentParser(add_help=False)
    parser.add_argument("--check", action="store_true")
    parser.add_argument("-h", "--help", action="store_true")
    args = parser.parse_args()

    if args.help:
        print(usage(), end="")
        return 0
    if args.check:
        return 0
    return run_tui()


if __name__ == "__main__":
    raise SystemExit(main())
