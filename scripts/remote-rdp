#!/usr/bin/env python3
"""Open an RDP session to an instance.

Usage: scripts/remote-rdp <instance>
"""

from __future__ import annotations

import os
import platform
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    exec_replace,
    has_command,
    has_package,
    instance_ip,
    msrdp_open_command,
    msrdp_paste_command,
    rdp_file_lines,
    repo_root,
    resolve_env,
    xfreerdp_command,
)


def _instance_password(root: Path, profile: str) -> str:
    result = subprocess.run(
        [str(root / "scripts/instance-password"), profile],
        cwd=root, text=True, capture_output=True, check=False,
    )
    sys.stderr.write(result.stderr)
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    return result.stdout.strip()


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/remote-rdp <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    resolved = resolve_env(root, profile)
    os_family = resolved.get("OS_FAMILY", "")
    ip = instance_ip(root, profile)
    host_os = platform.system()

    credssp = 1
    redirect = 0
    windows_app_ok = 1
    freerdp_extra: list[str] = []

    if os_family == "windows":
        username = "Administrator"
        pw = _instance_password(root, profile)
        admin_session = 1
    elif os_family == "ubuntu":
        # Prefer an explicit VM_USER_NAME, else the resolved human/login user
        # (HUMAN_USER_NAME/ACCESS_HUMAN_USER/SSH_USER) — e.g. a provider whose
        # bootstrap user is "ubuntu" resolves to it with no VM_USER_NAME set.
        vm_username = (
            resolved.get("VM_USER_NAME")
            or resolved.get("HUMAN_USER_NAME")
            or resolved.get("ACCESS_HUMAN_USER")
            or resolved.get("SSH_USER", "")
        )
        if has_package(resolved, "gnome-desktop") or has_package(resolved, "gnome-desktop-headless"):
            username = os.environ.get("RDP_GATE_USER", "rdpuser")
            pw = os.environ.get("RDP_GATE_PASSWORD") or os.environ.get("VM_USER_PASSWORD", "")
            credssp = 0
            redirect = 0
            freerdp_extra = []
            windows_app_ok = 1
        elif has_package(resolved, "kde-desktop") or has_package(resolved, "kde-desktop-headless"):
            username = vm_username
            pw = os.environ.get("VM_USER_PASSWORD", "")
            credssp = 1
            redirect = 1
            freerdp_extra = ["/gfx:AVC444"]
            windows_app_ok = 0
        else:
            username = vm_username
            pw = os.environ.get("VM_USER_PASSWORD", "")
            credssp = 1
            redirect = 1
            freerdp_extra = []
            windows_app_ok = 1
        if not username:
            username = os.environ.get("VM_USER_NAME", "")
        if not username:
            print("remote-rdp: VM_USER_NAME is required for Ubuntu RDP", file=sys.stderr)
            return 2
        if not pw:
            print(
                "remote-rdp: VM_USER_PASSWORD or RDP_GATE_PASSWORD is required for Ubuntu RDP login",
                file=sys.stderr,
            )
            print(
                "remote-rdp: RustDesk uses RUSTDESK_PASSWORD; "
                "Linux login/RDP uses VM_USER_PASSWORD by default.",
                file=sys.stderr,
            )
            return 2
        admin_session = 0
    else:
        print(f"remote-rdp: unsupported OS family '{os_family}'", file=sys.stderr)
        return 2

    (root / "tmp").mkdir(parents=True, exist_ok=True)
    rdp_file = root / "tmp" / "windows.rdp"
    rdp_file.write_text("\n".join(rdp_file_lines(ip, username, credssp, redirect, admin_session)) + "\n")

    if windows_app_ok == 0:
        if has_command("xfreerdp"):
            exec_replace(xfreerdp_command(ip, username, pw, freerdp_extra))
        if host_os == "Darwin":
            print(
                "remote-rdp: this KDE/krdp profile is not compatible with macOS "
                "Windows App; install xfreerdp.",
                file=sys.stderr,
            )
        elif host_os == "Linux":
            print("remote-rdp: xfreerdp is required on Linux. Install with: apt install freerdp2-x11", file=sys.stderr)
        else:
            print(f"remote-rdp: unsupported host OS: {host_os}", file=sys.stderr)
        return 2

    if host_os == "Darwin":
        if not has_command("pbcopy"):
            print("remote-rdp: pbcopy is required on macOS", file=sys.stderr)
            return 2
        subprocess.run(["pbcopy"], input=pw, text=True, check=False)
        result = subprocess.run(msrdp_open_command(str(rdp_file)), check=False)
        if result.returncode != 0:
            print("remote-rdp: Microsoft Remote Desktop is required on macOS", file=sys.stderr)
            return 2
        time.sleep(3)
        return subprocess.run(msrdp_paste_command(), check=False).returncode

    if host_os == "Linux":
        if has_command("xfreerdp"):
            exec_replace(xfreerdp_command(ip, username, pw, freerdp_extra))
        print("remote-rdp: xfreerdp is required on Linux. Install with: apt install freerdp2-x11", file=sys.stderr)
        return 2

    print(f"remote-rdp: unsupported host OS: {host_os}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
