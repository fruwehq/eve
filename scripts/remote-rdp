#!/usr/bin/env bash
# Open an RDP session to an instance.
set -euo pipefail

PROFILE="${1:?Usage: scripts/remote-rdp <instance>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
OS_FAMILY=$(printf '%s\n' "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')
BUNDLE_PACKAGES=$(printf '%s\n' "$RESOLVED_ENV" | awk -F= '/^BUNDLE_PACKAGES=/{print $2}')
IP=$(./scripts/instance-ip "$PROFILE")
is_selected() {
  case ",$BUNDLE_PACKAGES," in
    *,"$1",*) return 0 ;;
    *) return 1 ;;
  esac
}

case "$OS_FAMILY" in
  windows)
    USERNAME="Administrator"
    PW=$(./scripts/instance-password "$PROFILE")
    ADMIN_SESSION=1
    ;;
  ubuntu)
    VM_USERNAME=$(printf '%s\n' "$RESOLVED_ENV" | awk -F= '/^VM_USER_NAME=/{print $2}')
    if is_selected gnome-desktop || is_selected gnome-desktop-headless; then
      USERNAME="${RDP_GATE_USER:-rdpuser}"
      PW="${RDP_GATE_PASSWORD:-${VM_USER_PASSWORD:-}}"
      CREDSSP=0
      REDIRECT=0
      FREERDP_EXTRA=()
      WINDOWS_APP_OK=1
    elif is_selected kde-desktop || is_selected kde-desktop-headless; then
      USERNAME="$VM_USERNAME"
      PW="${VM_USER_PASSWORD:-}"
      CREDSSP=1
      REDIRECT=1
      FREERDP_EXTRA=(/gfx:AVC444)
      WINDOWS_APP_OK=0
    else
      USERNAME="$VM_USERNAME"
      PW="${VM_USER_PASSWORD:-}"
      CREDSSP=1
      REDIRECT=1
      FREERDP_EXTRA=()
      WINDOWS_APP_OK=1
    fi
    if [ -z "$USERNAME" ]; then
      USERNAME="${VM_USER_NAME:-}"
    fi
    if [ -z "$USERNAME" ]; then
      echo "remote-rdp: VM_USER_NAME is required for Ubuntu RDP" >&2
      exit 2
    fi
    if [ -z "$PW" ]; then
      echo "remote-rdp: VM_USER_PASSWORD or RDP_GATE_PASSWORD is required for Ubuntu RDP login" >&2
      echo "remote-rdp: RustDesk uses RUSTDESK_PASSWORD; Linux login/RDP uses VM_USER_PASSWORD by default." >&2
      exit 2
    fi
    ADMIN_SESSION=0
    ;;
  *)
    echo "remote-rdp: unsupported OS family '$OS_FAMILY'" >&2
    exit 2
    ;;
esac
: "${CREDSSP:=1}"
: "${REDIRECT:=0}"
: "${WINDOWS_APP_OK:=1}"
: "${FREERDP_EXTRA:=}"

mkdir -p ./tmp
printf '%s\n' \
  "full address:s:$IP" \
  "username:s:$USERNAME" \
  "prompt for credentials on client:i:1" \
  "enablecredsspsupport:i:$CREDSSP" \
  "use redirection server name:i:$REDIRECT" \
  "administrative session:i:$ADMIN_SESSION" \
  "screen mode id:i:2" \
  "session bpp:i:32" \
  "redirectclipboard:i:1" \
  "audiomode:i:0" \
  > ./tmp/windows.rdp

HOST_OS="$(uname -s)"

if [ "$WINDOWS_APP_OK" = "0" ]; then
  if command -v xfreerdp >/dev/null 2>&1; then
    exec xfreerdp /v:"$IP" /u:"$USERNAME" /p:"$PW" +clipboard /cert:ignore "${FREERDP_EXTRA[@]}"
  fi
  case "$HOST_OS" in
    Darwin)
      echo "remote-rdp: this KDE/krdp profile is not compatible with macOS Windows App; install xfreerdp." >&2
      ;;
    Linux)
      echo "remote-rdp: xfreerdp is required on Linux. Install with: apt install freerdp2-x11" >&2
      ;;
    *)
      echo "remote-rdp: unsupported host OS: $HOST_OS" >&2
      ;;
  esac
  exit 2
fi

case "$HOST_OS" in
  Darwin)
    if ! command -v pbcopy >/dev/null 2>&1; then
      echo "remote-rdp: pbcopy is required on macOS" >&2
      exit 2
    fi
    printf '%s' "$PW" | pbcopy
    if ! open -a "Microsoft Remote Desktop" ./tmp/windows.rdp; then
      echo "remote-rdp: Microsoft Remote Desktop is required on macOS" >&2
      exit 2
    fi
    sleep 3
    osascript -e 'tell application "System Events" to keystroke "v" using command down' -e 'tell application "System Events" to key code 36'
    ;;
  Linux)
    if command -v xfreerdp >/dev/null 2>&1; then
      exec xfreerdp /v:"$IP" /u:"$USERNAME" /p:"$PW" +clipboard /cert:ignore "${FREERDP_EXTRA[@]}"
    fi
    echo "remote-rdp: xfreerdp is required on Linux. Install with: apt install freerdp2-x11" >&2
    exit 2
    ;;
  *)
    echo "remote-rdp: unsupported host OS: $HOST_OS" >&2
    exit 2
    ;;
esac
