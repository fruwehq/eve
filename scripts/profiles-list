#!/usr/bin/env sh
set -eu

# List available profile names from the catalog.
# Usage: scripts/profiles-list [--with-details]

CATALOG_PATH="config/catalog.yaml"
LOCAL_CATALOG_PATH="config/catalog.local.yaml"

DETAILS=0
if [ "${1:-}" = "--with-details" ]; then
  DETAILS=1
fi

# Extract profile names from catalog using grep (works without ruby/jq deps)
extract_names() {
  grep -A 1000 '^profiles:' "$1" | grep '^\s*- name:' | sed 's/.*name: *//'
}

# Collect profile names from base catalog and local overlay (deduplicated, preserving order)
PROFILE_NAMES=""
for path in "$CATALOG_PATH" "$LOCAL_CATALOG_PATH"; do
  if [ -f "$path" ]; then
    for name in $(extract_names "$path"); do
      case " $PROFILE_NAMES " in
        *" $name "*) ;;
        *) PROFILE_NAMES="$PROFILE_NAMES $name" ;;
      esac
    done
  fi
done

# Trim leading space
PROFILE_NAMES=$(echo "$PROFILE_NAMES" | sed 's/^ //')

if [ "$DETAILS" -eq 1 ]; then
  printf "%-35s %-30s %-30s %-30s\n" "PROFILE" "MACHINE" "OS" "LOCATION"
  printf "%-35s %-30s %-30s %-30s\n" "-------" "-------" "--" "--------"
  for name in $PROFILE_NAMES; do
    machine=$(grep -A 5 "\\- name: $name" "$CATALOG_PATH" "$LOCAL_CATALOG_PATH" 2>/dev/null | grep 'machine:' | head -1 | sed 's/.*machine: *//')
    os=$(grep -A 5 "\\- name: $name" "$CATALOG_PATH" "$LOCAL_CATALOG_PATH" 2>/dev/null | grep 'os:' | head -1 | sed 's/.*os: *//')
    location=$(grep -A 5 "\\- name: $name" "$CATALOG_PATH" "$LOCAL_CATALOG_PATH" 2>/dev/null | grep 'location:' | head -1 | sed 's/.*location: *//')
    printf "%-35s %-30s %-30s %-30s\n" "$name" "${machine:--}" "${os:--}" "${location:--}"
  done
else
  for name in $PROFILE_NAMES; do
    echo "$name"
  done
fi
