#!/usr/bin/env python3
"""Persist a structured config field."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.atomic_yaml import AtomicYaml  # noqa: E402
from eve_sdk.workdir import Workdir  # noqa: E402


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(prog="config-save", usage="config-save [--unset] <section> <field> [value]")
    arg_parser.add_argument("--unset", action="store_true")
    arg_parser.add_argument("section")
    arg_parser.add_argument("field")
    arg_parser.add_argument("value", nargs="?")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    if not args.unset and args.value is None:
        args.value = ""

    config_path = Workdir.config_path()
    lock_path = Path(f"{config_path}.lock")

    try:
        with AtomicYaml.with_lock(lock_path):
            existing = AtomicYaml.load_yaml(config_path)
            section = existing.get(args.section)
            if args.unset:
                if isinstance(section, dict):
                    section.pop(args.field, None)
                    if not section:
                        existing.pop(args.section, None)
            else:
                if not isinstance(section, dict):
                    section = {}
                    existing[args.section] = section
                section[args.field] = None if str(args.value) == "" else str(args.value)
            AtomicYaml.atomic_write(config_path, existing)
        return 0
    except Exception as error:
        print(f"config-save: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
