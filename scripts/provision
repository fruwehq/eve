#!/usr/bin/env bash
# Upload the OS-appropriate provisioning tree to the profile's instance
# and run the bootstrap entry point.
#
# Usage: scripts/provision <profile>
#
# Linux:   uploads ./linux/provision/   -> $HOME/provision    runs bootstrap.sh
# Windows: uploads ./windows/provision/ -> C:\Users\<user>\provision  runs bootstrap.ps1

set -euo pipefail

PROFILE="${1:?Usage: scripts/provision <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
OS_FAMILY=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')
BUNDLE_PACKAGES=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^BUNDLE_PACKAGES=/{print $2}')
PROFILE_NAME=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROFILE_NAME=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')

echo "[provision] profile=$PROFILE os_family=$OS_FAMILY"

./scripts/ssh-wait "$PROFILE"

case "$OS_FAMILY" in
  ubuntu)
    if ! ./scripts/instance-ssh "$PROFILE" -- 'sudo -n true' >/dev/null 2>&1; then
      if [ "$PROVIDER" = "raspberry-pi" ] && [ -n "${RASPBERRY_PI_USER_PASSWORD:-}" ]; then
        echo "[provision] configuring passwordless sudo for Raspberry Pi provisioning"
        # shellcheck disable=SC2016
        printf '%s\n' "$RASPBERRY_PI_USER_PASSWORD" | ./scripts/instance-ssh "$PROFILE" -- \
          'tmp=$(mktemp); printf "%s ALL=(ALL) NOPASSWD:ALL\n" "$USER" > "$tmp"; chmod 0440 "$tmp"; sudo -S -p "" install -o root -g root -m 0440 "$tmp" /etc/sudoers.d/90-egame-provision; rm -f "$tmp"; sudo -n visudo -cf /etc/sudoers.d/90-egame-provision'
      fi
    fi

    if ! ./scripts/instance-ssh "$PROFILE" -- 'sudo -n true' >/dev/null 2>&1; then
      echo "[provision] Linux provisioning requires passwordless sudo for the SSH user." >&2
      echo "[provision] Configure RASPBERRY_PI_USER_PASSWORD or sudo NOPASSWD for VM_USER_NAME on $PROFILE, then retry." >&2
      exit 1
    fi

    STAGE=$(mktemp -d)
    trap 'rm -rf "$STAGE"' EXIT
    cp -R linux/provision/scripts "$STAGE/scripts"
    mkdir -p "$STAGE/state"
    rm -f "$STAGE/scripts/steps/"*.sh

    ordered_steps=()
    ordered_plugin_roots=()

    copy_step() {
      local step="$1"
      local plugin_root="$2"
      local source=""
      local target
      target="$STAGE/scripts/steps/$(basename "$step")"

      if [ -f "linux/provision/scripts/steps/$step" ]; then
        source="linux/provision/scripts/steps/$step"
      elif [ -f "$plugin_root/$step" ]; then
        source="$plugin_root/$step"
      else
        echo "[provision] install step not found: $step" >&2
        exit 2
      fi

      cp "$source" "$target"
    }

    add_step() {
      local step="$1"
      local plugin_root="$2"
      local existing

      for existing in "${ordered_steps[@]}"; do
        [ "$existing" = "$step" ] && return 0
      done

      ordered_steps+=("$step")
      ordered_plugin_roots+=("$plugin_root")
    }

    add_step "base.sh" ""
    add_step "human-user.sh" ""
    add_step "timezone.sh" ""

    PLUGIN_DOC=$(./scripts/plugin-list --kind package --json)
    while IFS=$'\t' read -r plugin_path step; do
      [ -n "$plugin_path" ] || continue
      case "$step" in
        base.sh|human-user.sh|timezone.sh|finish.sh) continue ;;
      esac
      add_step "$step" "$(dirname "$plugin_path")"
    done < <(
      printf '%s' "$PLUGIN_DOC" |
        jq -r --arg packages_csv "$BUNDLE_PACKAGES" '
          ($packages_csv | split(",") | map(select(length > 0))) as $selected |
          .plugins[] |
          . as $plugin |
          select($selected | index($plugin.id)) |
          (.install.ubuntu.steps // [])[] |
          [$plugin.path, .] | @tsv
        '
    )
    add_step "finish.sh" ""

    for index in "${!ordered_steps[@]}"; do
      copy_step "${ordered_steps[$index]}" "${ordered_plugin_roots[$index]}"
    done
    printf '%s\n' "${ordered_steps[@]##*/}" > "$STAGE/state/steps.list"

    # bundle_packages: one package per line for cheap grep lookup in step scripts
    printf '%s\n' "$BUNDLE_PACKAGES" | tr ',' '\n' > "$STAGE/state/bundle_packages"
    # Auto-detect host timezone if not explicitly set
    _HOST_TZ="${TIMEZONE:-}"
    if [ -z "$_HOST_TZ" ]; then
      _LINK=$(readlink /etc/localtime 2>/dev/null || true)
      _HOST_TZ=$(echo "$_LINK" | sed -n 's|.*/zoneinfo/||p')
    fi
    # env file: sourced by runner.sh so steps see PROFILE_NAME and local config.
    cat > "$STAGE/state/env" <<EOF
export OS_FAMILY="$OS_FAMILY"
export PROFILE_NAME="$PROFILE_NAME"
export VM_USER_NAME="$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^VM_USER_NAME=/{print $2}')"
export VM_USER_PASSWORD="${VM_USER_PASSWORD:-}"
export EPHEMERAL_DISPLAY_RESOLUTION="${EPHEMERAL_DISPLAY_RESOLUTION:-}"
export PROVIDER="$PROVIDER"
export EPHEMERAL_SUNSHINE_PASSWORD="${EPHEMERAL_SUNSHINE_PASSWORD:-}"
export RASPBERRY_PI_HDMI_CONNECTOR="${RASPBERRY_PI_HDMI_CONNECTOR:-}"
export RASPBERRY_PI_HDMI_MODE="${RASPBERRY_PI_HDMI_MODE:-}"
export RUSTDESK_KEY="${RUSTDESK_KEY:-}"
export RUSTDESK_PASSWORD="${RUSTDESK_PASSWORD:-}"
export RUSTDESK_SERVER="${RUSTDESK_SERVER:-}"
export SUNSHINE_MAX_BITRATE_KBPS="${SUNSHINE_MAX_BITRATE_KBPS:-}"
export SUNSHINE_VERSION="${SUNSHINE_VERSION:-}"
export TIMEZONE="$_HOST_TZ"
EOF

    echo "[provision] uploading linux/provision/ to remote"
    # Remote paths are relative to $HOME (SFTP/SCP default) to avoid shell-expansion pitfalls.
    ./scripts/instance-ssh "$PROFILE" -- 'rm -rf ~/provision/state ~/provision/scripts && mkdir -p ~/provision/state'
    ./scripts/instance-ssh "$PROFILE" --scp "$STAGE/scripts" 'provision/'
    ./scripts/instance-ssh "$PROFILE" --scp "$STAGE/state/bundle_packages" 'provision/state/'
    ./scripts/instance-ssh "$PROFILE" --scp "$STAGE/state/env" 'provision/state/'
    ./scripts/instance-ssh "$PROFILE" --scp "$STAGE/state/steps.list" 'provision/state/'
    echo "[provision] running bootstrap.sh"
    ./scripts/instance-ssh "$PROFILE" -- 'chmod +x ~/provision/scripts/bootstrap.sh ~/provision/scripts/runner.sh ~/provision/scripts/steps/*.sh ~/provision/scripts/lib/*.sh && ~/provision/scripts/bootstrap.sh'
    ;;
  windows)
    # Windows password: env var override, else terraform output (vultr only).
    WINDOWS_PASSWORD="${EPHEMERAL_WINDOWS_PASSWORD:-}"
    if [ -z "$WINDOWS_PASSWORD" ]; then
      PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
      TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
      case "$PROVIDER" in
        vultr)
          eval "$(./scripts/tf-env "$PROFILE")"
          WINDOWS_PASSWORD=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw vultr_instance_default_password)
          ;;
        *)
          echo "[provision] set EPHEMERAL_WINDOWS_PASSWORD (no terraform output available for provider=$PROVIDER)" >&2
          exit 1
          ;;
      esac
    fi
    : "${EPHEMERAL_SUNSHINE_PASSWORD:?set EPHEMERAL_SUNSHINE_PASSWORD in .env.local}"

    mkdir -p ./tmp
    jq -n \
      --arg wp "$WINDOWS_PASSWORD" \
      --arg sp "$EPHEMERAL_SUNSHINE_PASSWORD" \
      --arg dr "${EPHEMERAL_DISPLAY_RESOLUTION:-}" \
      --arg rk "${RUSTDESK_KEY:-}" \
      --arg rp "${RUSTDESK_PASSWORD:-}" \
      --arg rs "${RUSTDESK_SERVER:-}" \
      --arg sv "${SUNSHINE_VERSION:-}" \
      '{windows_password: $wp, sunshine_password: $sp, display_resolution: $dr, rustdesk_key: $rk, rustdesk_password: $rp, rustdesk_server: $rs, sunshine_version: $sv}' \
      > ./tmp/env.json

    STAGE=$(mktemp -d)
    trap 'rm -rf "$STAGE"' EXIT
    cp -R windows/provision "$STAGE/provision"

    copy_windows_step() {
      local step="$1"
      local plugin_root="$2"
      local source=""
      local target
      target="$STAGE/provision/scripts/steps/$(basename "$step")"

      if [ -f "windows/provision/scripts/steps/$step" ]; then
        source="windows/provision/scripts/steps/$step"
      elif [ -f "$plugin_root/$step" ]; then
        source="$plugin_root/$step"
      else
        echo "[provision] windows install step not found: $step" >&2
        exit 2
      fi

      cp "$source" "$target"
      if [ -n "$plugin_root" ] && [ -d "$plugin_root/provision/windows/lib" ]; then
        cp -R "$plugin_root/provision/windows/lib/." "$STAGE/provision/scripts/lib/"
      fi
      if [ -n "$plugin_root" ] && [ -d "$plugin_root/provision/windows/templates" ]; then
        mkdir -p "$STAGE/provision/scripts/templates"
        cp -R "$plugin_root/provision/windows/templates/." "$STAGE/provision/scripts/templates/"
      fi
    }

    PLUGIN_DOC=$(./scripts/plugin-list --kind package --json)
    while IFS=$'\t' read -r plugin_path step; do
      [ -n "$plugin_path" ] || continue
      [ -n "$step" ] || continue
      copy_windows_step "$step" "$(dirname "$plugin_path")"
    done < <(
      printf '%s' "$PLUGIN_DOC" |
        jq -r --arg packages_csv "$BUNDLE_PACKAGES" '
          ($packages_csv | split(",") | map(select(length > 0))) as $selected |
          .plugins[] |
          . as $plugin |
          select($selected | index($plugin.id)) |
          (.install.windows.steps // [])[] |
          [$plugin.path, .] | @tsv
        '
    )

    echo "[provision] uploading windows/provision/ to remote"
    # Clear scripts AND state — without state reset, currentStep can outrun the
    # available step files when new steps are added, silently skipping them.
    ./scripts/instance-ssh "$PROFILE" -- 'New-Item -ItemType Directory -Force C:\Users\Administrator\provision | Out-Null; if (Test-Path "C:\Users\Administrator\provision\scripts") { Remove-Item -Recurse -Force "C:\Users\Administrator\provision\scripts" }; if (Test-Path "C:\Users\Administrator\provision\state") { Remove-Item -Recurse -Force "C:\Users\Administrator\provision\state" }; New-Item -ItemType Directory -Force C:\Users\Administrator\provision\state | Out-Null'
    ./scripts/instance-ssh "$PROFILE" --scp "$STAGE/provision" '/C:/Users/Administrator/'
    ./scripts/instance-ssh "$PROFILE" --scp ./tmp/env.json '/C:/Users/Administrator/provision/state/env.json'
    echo "[provision] running bootstrap.ps1"
    # The Windows runner may trigger a reboot mid-step, which drops the SSH
    # connection (exit 255). The Scheduled Task resumes the runner after
    # reboot, so exit 255 is expected and not an error.
    exit_code=0
    ./scripts/instance-ssh "$PROFILE" -- '& "C:\Users\Administrator\provision\scripts\bootstrap.ps1"' || exit_code=$?
    if [ "$exit_code" -ne 0 ] && [ "$exit_code" -ne 255 ]; then
      exit "$exit_code"
    fi
    echo "[provision] waiting for windows provisioning to finish (polling remote log every ${EGAME_PROVISION_WAIT_POLL_INTERVAL:-5}s)"
    ./scripts/wait-for-provision "$PROFILE"
    ;;
  *)
    echo "[provision] unknown os_family: $OS_FAMILY" >&2
    exit 2
    ;;
esac
