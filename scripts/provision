#!/usr/bin/env python3
"""Upload the OS-appropriate provisioning tree to the profile's instance
and run the bootstrap entry point.

Usage: scripts/provision <instance>

Ubuntu: uploads ./oses/<catalog-os-id>/provision/ -> $HOME/provision
Windows: uploads ./oses/<catalog-os-id>/provision/ -> C:\\Users\\<user>\\provision
"""

from __future__ import annotations

import hashlib
import json
import os
import subprocess
import sys
import tempfile
from datetime import UTC, datetime
from pathlib import Path
from shutil import copy2, copytree

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import apply_tf_env  # noqa: E402


def _run(cmd: list[str], **kwargs: object) -> subprocess.CompletedProcess[str]:
    """Run a subprocess in ROOT, forwarding stderr by default."""
    return subprocess.run(cmd, cwd=ROOT, text=True, **kwargs)  # type: ignore[arg-type]


def _ssh_retry(profile: str, label: str, remote_cmd: str) -> int:
    return _run([
        str(ROOT / "scripts/ssh-retry"), label,
        str(ROOT / "scripts/instance-ssh"), profile, "--", remote_cmd,
    ], stderr=None).returncode


def _ssh_retry_scp(profile: str, label: str, source: str, dest: str) -> int:
    return _run([
        str(ROOT / "scripts/ssh-retry"), label,
        str(ROOT / "scripts/instance-ssh"), profile, "--scp", source, dest,
    ], stderr=None).returncode


def _parse_env(output: str) -> dict[str, str]:
    env: dict[str, str] = {}
    for line in output.splitlines():
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        env[key] = value
    return env


def _selected_packages(bundle_packages: str) -> list[str]:
    return [pkg for pkg in bundle_packages.split(",") if pkg]


def _plugin_ubuntu_steps(plugin_doc: dict, bundle_packages: str) -> list[tuple[str, str]]:
    """Return [(plugin_path, step_name)] in selection order from BUNDLE_PACKAGES."""
    selected = _selected_packages(bundle_packages)
    by_id = {p["id"]: p for p in plugin_doc.get("plugins") or []}
    result: list[tuple[str, str]] = []
    for package_id in selected:
        plugin = by_id.get(package_id)
        if not plugin:
            continue
        for step in (plugin.get("install") or {}).get("ubuntu", {}).get("steps") or []:
            result.append((plugin["path"], step))
    return result


def _plugin_windows_steps(plugin_doc: dict, bundle_packages: str) -> list[tuple[str, str]]:
    selected = _selected_packages(bundle_packages)
    by_id = {p["id"]: p for p in plugin_doc.get("plugins") or []}
    result: list[tuple[str, str]] = []
    for package_id in selected:
        plugin = by_id.get(package_id)
        if not plugin:
            continue
        for step in (plugin.get("install") or {}).get("windows", {}).get("steps") or []:
            result.append((plugin["path"], step))
    return result


def _sha256(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def _write_manifest(state_dir: Path, steps: list[dict], os_family: str) -> None:
    manifest = {
        "api_version": 1,
        "os_family": os_family,
        "created_at": datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ"),
        "steps": steps,
    }
    (state_dir / "provision-manifest.json").write_text(
        json.dumps(manifest, indent=2) + "\n", encoding="utf-8"
    )


def provision_ubuntu(profile: str, env: dict[str, str], root: Path) -> int:
    os_family = env.get("OS_FAMILY", "")
    os_id = env.get("OS_ID", "")
    bundle_packages = env.get("BUNDLE_PACKAGES", "")
    profile_name = env.get("PROFILE_NAME", "")
    provider = env.get("PROVIDER", "")
    os_provision_dir = root / "oses" / os_id / "provision"

    if not os_provision_dir.is_dir():
        print(f"[provision] OS provisioning directory not found: {os_provision_dir.relative_to(root)}", file=sys.stderr)
        return 2

    ssh_wait_rc = _run([str(root / "scripts/ssh-wait"), profile]).returncode
    if ssh_wait_rc != 0:
        return ssh_wait_rc

    instance_ssh = str(root / "scripts/instance-ssh")

    def check_sudo() -> bool:
        return subprocess.run(
            [instance_ssh, profile, "--", "sudo -n true"],
            cwd=root, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=False,
        ).returncode == 0

    if not check_sudo():
        rpi_password = os.environ.get("RASPBERRY_PI_USER_PASSWORD", "")
        if provider == "raspberry-pi" and rpi_password:
            print("[provision] configuring passwordless sudo for Raspberry Pi provisioning")
            remote_cmd = (
                'tmp=$(mktemp); printf "%s ALL=(ALL) NOPASSWD:ALL\\n" "$USER" > "$tmp"; '
                'chmod 0440 "$tmp"; sudo -S -p "" install -o root -g root -m 0440 "$tmp" '
                '/etc/sudoers.d/90-eve-provision; rm -f "$tmp"; '
                'sudo -n visudo -cf /etc/sudoers.d/90-eve-provision'
            )
            subprocess.run(
                [instance_ssh, profile, "--", remote_cmd],
                cwd=root, input=f"{rpi_password}\n", text=True, check=False,
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            )

    if not check_sudo():
        print(
            "[provision] Linux provisioning requires passwordless sudo"
            " for the SSH user.", file=sys.stderr,
        )
        print(
            f"[provision] Configure RASPBERRY_PI_USER_PASSWORD or sudo NOPASSWD"
            f" for VM_USER_NAME on {profile}, then retry.", file=sys.stderr,
        )
        return 1

    stage = Path(tempfile.mkdtemp())
    try:
        copytree(os_provision_dir / "scripts", stage / "scripts")
        (stage / "state").mkdir(parents=True, exist_ok=True)
        for f in (stage / "scripts" / "steps").glob("*.sh"):
            f.unlink()

        ordered_steps: list[str] = []
        ordered_roots: list[str] = []
        step_set: set[str] = set()

        def add_step(step: str, plugin_root: str) -> None:
            if step in step_set:
                return
            step_set.add(step)
            ordered_steps.append(step)
            ordered_roots.append(plugin_root)

        add_step("base.sh", "")
        add_step("human-user.sh", "")
        add_step("timezone.sh", "")

        plugin_doc = json.loads(subprocess.run(
            [str(root / "scripts/plugin-list"), "--kind", "package", "--json"],
            cwd=root, capture_output=True, text=True, check=False,
        ).stdout)
        for plugin_path, step in _plugin_ubuntu_steps(plugin_doc, bundle_packages):
            if not plugin_path:
                continue
            if step in ("base.sh", "human-user.sh", "timezone.sh", "finish.sh"):
                continue
            add_step(step, str(Path(plugin_path).parent))

        add_step("finish.sh", "")

        steps_dir = stage / "scripts" / "steps"
        for idx, step in enumerate(ordered_steps):
            plugin_root = ordered_roots[idx]
            target = steps_dir / Path(step).name
            source: Path | None = None
            os_step = os_provision_dir / "scripts" / "steps" / step
            if os_step.is_file():
                source = os_step
            elif plugin_root:
                plugin_step = Path(plugin_root) / step
                if plugin_step.is_file():
                    source = plugin_step
            if source is None:
                print(f"[provision] install step not found: {step}", file=sys.stderr)
                return 2
            copy2(source, target)

        (stage / "state" / "steps.list").write_text(
            "\n".join(Path(s).name for s in ordered_steps) + "\n", encoding="utf-8"
        )

        manifest_steps: list[dict] = []
        for idx, step in enumerate(ordered_steps):
            step_file = steps_dir / Path(step).name
            manifest_steps.append({
                "order": idx,
                "name": Path(step).name,
                "sha256": _sha256(step_file),
            })
        _write_manifest(stage / "state", manifest_steps, os_family)

        pkg_lines = "\n".join(_selected_packages(bundle_packages))
        (stage / "state" / "bundle_packages").write_text(pkg_lines + "\n", encoding="utf-8")
        (stage / "state" / "selected_packages").write_text(pkg_lines + "\n", encoding="utf-8")

        thinlinc_remote_path = os.environ.get("THINLINC_SERVER_BUNDLE_PATH", "")
        upload_thinlinc = False
        if "thinlinc" in _selected_packages(bundle_packages) and thinlinc_remote_path:
            if not Path(thinlinc_remote_path).exists():
                print(
                    f"[provision] THINLINC_SERVER_BUNDLE_PATH does not exist:"
                    f" {thinlinc_remote_path}", file=sys.stderr,
                )
                return 2
            thinlinc_basename = os.path.basename(thinlinc_remote_path)
            thinlinc_remote_path = f"$HOME/provision/downloads/thinlinc/{thinlinc_basename}"
            upload_thinlinc = True

        host_tz = os.environ.get("TIMEZONE", "")
        if not host_tz:
            tz_result = subprocess.run(
                [str(root / "scripts/host-timezone")], cwd=root,
                capture_output=True, text=True, check=False,
            )
            if tz_result.returncode == 0:
                host_tz = tz_result.stdout.strip()

        thinlinc_agent_hostname = os.environ.get("THINLINC_AGENT_HOSTNAME", "")
        if "thinlinc" in _selected_packages(bundle_packages) and not thinlinc_agent_hostname:
            ip_result = subprocess.run(
                [str(root / "scripts/instance-ip"), profile], cwd=root,
                capture_output=True, text=True, check=False,
            )
            if ip_result.returncode == 0:
                thinlinc_agent_hostname = ip_result.stdout.strip()

        env_lines = [
            f'export ACCESS_BOOTSTRAP_USER="{env.get("ACCESS_BOOTSTRAP_USER", "")}"',
            f'export ACCESS_HUMAN_USER="{env.get("ACCESS_HUMAN_USER", "")}"',
            f'export ACCESS_PROVISION_USER="{env.get("ACCESS_PROVISION_USER", "")}"',
            f'export OS_FAMILY="{os_family}"',
            f'export PROFILE_NAME="{profile_name}"',
            f'export HUMAN_USER_NAME="{env.get("HUMAN_USER_NAME", "")}"',
            f'export PROVISION_USER_NAME="{env.get("PROVISION_USER_NAME", "")}"',
            f'export VM_USER_NAME="{env.get("VM_USER_NAME", "")}"',
            f'export VM_USER_PASSWORD="{os.environ.get("VM_USER_PASSWORD", "")}"',
            f'export EPHEMERAL_DISPLAY_RESOLUTION="{os.environ.get("EPHEMERAL_DISPLAY_RESOLUTION", "")}"',
            f'export EPHEMERAL_DISPLAY_FPS="{os.environ.get("EPHEMERAL_DISPLAY_FPS", "")}"',
            f'export PROVIDER="{provider}"',
            f'export EPHEMERAL_SUNSHINE_PASSWORD="{os.environ.get("EPHEMERAL_SUNSHINE_PASSWORD", "")}"',
            f'export RDP_GATE_PASSWORD="{os.environ.get("RDP_GATE_PASSWORD", "")}"',
            f'export RDP_GATE_USER="{os.environ.get("RDP_GATE_USER", "")}"',
            f'export NOMACHINE_VERSION="{os.environ.get("NOMACHINE_VERSION", "")}"',
            f'export RASPBERRY_PI_HDMI_CONNECTOR="{os.environ.get("RASPBERRY_PI_HDMI_CONNECTOR", "")}"',
            f'export RASPBERRY_PI_HDMI_MODE="{os.environ.get("RASPBERRY_PI_HDMI_MODE", "")}"',
            f'export RUSTDESK_KEY="{os.environ.get("RUSTDESK_KEY", "")}"',
            f'export RUSTDESK_PASSWORD="{os.environ.get("RUSTDESK_PASSWORD", "")}"',
            f'export RUSTDESK_SERVER="{os.environ.get("RUSTDESK_SERVER", "")}"',
            f'export SPLASHTOP_EMAIL="{os.environ.get("SPLASHTOP_EMAIL", "")}"',
            f'export SPLASHTOP_PASSWORD="{os.environ.get("SPLASHTOP_PASSWORD", "")}"',
            f'export SPLASHTOP_STREAMER_PATH="{os.environ.get("SPLASHTOP_STREAMER_PATH", "")}"',
            f'export SPLASHTOP_STREAMER_URL="{os.environ.get("SPLASHTOP_STREAMER_URL", "")}"',
            f'export SUNSHINE_MAX_BITRATE_KBPS="{os.environ.get("SUNSHINE_MAX_BITRATE_KBPS", "")}"',
            f'export SUNSHINE_VERSION="{os.environ.get("SUNSHINE_VERSION", "")}"',
            f'export THINLINC_ACCEPT_EULA="{os.environ.get("THINLINC_ACCEPT_EULA", "")}"',
            f'export THINLINC_AGENT_HOSTNAME="{thinlinc_agent_hostname}"',
            f'export THINLINC_SERVER_BUNDLE_PATH="{thinlinc_remote_path}"',
            f'export THINLINC_SERVER_BUNDLE_URL="{os.environ.get("THINLINC_SERVER_BUNDLE_URL", "")}"',
            f'export THINLINC_WEBACCESS_PORT="{os.environ.get("THINLINC_WEBACCESS_PORT", "")}"',
            f'export TIMEZONE="{host_tz}"',
            f'export VIRTUAL_MONITOR_WIDTH="{os.environ.get("VIRTUAL_MONITOR_WIDTH", "1920")}"',
            f'export VIRTUAL_MONITOR_HEIGHT="{os.environ.get("VIRTUAL_MONITOR_HEIGHT", "1080")}"',
        ]
        (stage / "state" / "env").write_text("\n".join(env_lines) + "\n", encoding="utf-8")

        print(f"[provision] uploading {os_provision_dir.relative_to(root)}/ to remote")
        rc = _ssh_retry(profile, "prepare linux provision directory",
                        "rm -rf ~/provision/state ~/provision/scripts ~/provision/logs && mkdir -p ~/provision/state")
        if rc:
            return rc
        if upload_thinlinc:
            rc = _ssh_retry(profile, "prepare ThinLinc bundle directory",
                            "rm -rf ~/provision/downloads/thinlinc && mkdir -p ~/provision/downloads/thinlinc")
            if rc:
                return rc
            rc = _ssh_retry_scp(profile, "upload ThinLinc server bundle",
                                os.environ["THINLINC_SERVER_BUNDLE_PATH"], "provision/downloads/thinlinc")
            if rc:
                return rc
        rc = _ssh_retry_scp(profile, "upload linux scripts", str(stage / "scripts"), "provision/")
        if rc:
            return rc
        bundle_pkg_path = str(stage / "state" / "bundle_packages")
        rc = _ssh_retry_scp(profile, "upload linux bundle package list",
                            bundle_pkg_path, "provision/state/")
        if rc:
            return rc
        selected_pkg_path = str(stage / "state" / "selected_packages")
        rc = _ssh_retry_scp(profile, "upload linux selected package list",
                            selected_pkg_path, "provision/state/")
        if rc:
            return rc
        rc = _ssh_retry_scp(profile, "upload linux environment",
                            str(stage / "state" / "env"), "provision/state/")
        if rc:
            return rc
        rc = _ssh_retry_scp(profile, "upload linux step list",
                            str(stage / "state" / "steps.list"), "provision/state/")
        if rc:
            return rc
        manifest_path = str(stage / "state" / "provision-manifest.json")
        rc = _ssh_retry_scp(profile, "upload linux provision manifest",
                            manifest_path, "provision/state/")
        if rc:
            return rc
        print("[provision] running bootstrap.sh")
        rc = _ssh_retry(profile, "start linux provisioning runner",
                        "chmod +x ~/provision/scripts/bootstrap.sh ~/provision/scripts/runner.sh"
                        " ~/provision/scripts/steps/*.sh ~/provision/scripts/lib/*.sh"
                        " && ~/provision/scripts/bootstrap.sh")
        if rc:
            return rc
        poll_interval = os.environ.get("EVE_PROVISION_WAIT_POLL_INTERVAL", "5")
        print(f"[provision] waiting for linux provisioning to finish (polling remote log every {poll_interval}s)")
        rc = _run([str(root / "scripts/wait-for-provision"), profile]).returncode
        return rc
    finally:
        import shutil
        shutil.rmtree(stage, ignore_errors=True)


def provision_windows(profile: str, env: dict[str, str], root: Path) -> int:
    os_family = env.get("OS_FAMILY", "")
    os_id = env.get("OS_ID", "")
    bundle_packages = env.get("BUNDLE_PACKAGES", "")
    provider = env.get("PROVIDER", "")
    tags = env.get("STACK_TAGS", "")
    os_provision_dir = root / "oses" / os_id / "provision"

    windows_password = os.environ.get("EPHEMERAL_WINDOWS_PASSWORD", "")
    if not windows_password:
        if provider == "vultr":
            apply_tf_env(root, profile)
            windows_password = subprocess.run(
                ["terramate", "run", "--quiet",
                 "--disable-safeguards=git-untracked",
                 "--disable-safeguards=git-uncommitted",
                 "--disable-safeguards=git-out-of-sync",
                 "--disable-safeguards=outdated-code",
                 f"--tags={tags}-services", "--",
                 "terraform", "output", "-raw", "vultr_instance_default_password"],
                cwd=root, capture_output=True, text=True, check=False,
            ).stdout
        else:
            print(
                f"[provision] set EPHEMERAL_WINDOWS_PASSWORD"
                f" (no terraform output available for provider={provider})",
                file=sys.stderr,
            )
            return 1

    sunshine_password = os.environ.get("EPHEMERAL_SUNSHINE_PASSWORD", "")
    if not sunshine_password:
        print("set EPHEMERAL_SUNSHINE_PASSWORD via config-save or your shell", file=sys.stderr)
        return 1

    tmp_dir = root / "tmp"
    tmp_dir.mkdir(parents=True, exist_ok=True)
    env_json = {
        "windows_password": windows_password,
        "sunshine_password": sunshine_password,
        "display_resolution": os.environ.get("EPHEMERAL_DISPLAY_RESOLUTION", ""),
        "rustdesk_key": os.environ.get("RUSTDESK_KEY", ""),
        "rustdesk_password": os.environ.get("RUSTDESK_PASSWORD", ""),
        "rustdesk_server": os.environ.get("RUSTDESK_SERVER", ""),
        "sunshine_version": os.environ.get("SUNSHINE_VERSION", ""),
        "nomachine_version": os.environ.get("NOMACHINE_VERSION", ""),
        "splashtop_email": os.environ.get("SPLASHTOP_EMAIL", ""),
        "splashtop_password": os.environ.get("SPLASHTOP_PASSWORD", ""),
        "splashtop_streamer_url": os.environ.get("SPLASHTOP_STREAMER_URL", ""),
    }
    (tmp_dir / "env.json").write_text(json.dumps(env_json, indent=2) + "\n", encoding="utf-8")

    stage = Path(tempfile.mkdtemp())
    try:
        copytree(os_provision_dir, stage / "provision")

        plugin_doc = json.loads(subprocess.run(
            [str(root / "scripts/plugin-list"), "--kind", "package", "--json"],
            cwd=root, capture_output=True, text=True, check=False,
        ).stdout)
        for plugin_path, step in _plugin_windows_steps(plugin_doc, bundle_packages):
            if not plugin_path or not step:
                continue
            plugin_root = Path(plugin_path).parent
            source: Path | None = None
            target = stage / "provision" / "scripts" / "steps" / Path(step).name
            os_step = os_provision_dir / "scripts" / "steps" / step
            if os_step.is_file():
                source = os_step
            elif (plugin_root / step).is_file():
                source = plugin_root / step
            if source is None:
                print(f"[provision] windows install step not found: {step}", file=sys.stderr)
                return 2
            copy2(source, target)
            if (plugin_root / "provision" / "windows" / "lib").is_dir():
                copytree(plugin_root / "provision" / "windows" / "lib",
                         stage / "provision" / "scripts" / "lib", dirs_exist_ok=True)
            if (plugin_root / "provision" / "windows" / "templates").is_dir():
                (stage / "provision" / "scripts" / "templates").mkdir(parents=True, exist_ok=True)
                copytree(plugin_root / "provision" / "windows" / "templates",
                         stage / "provision" / "scripts" / "templates", dirs_exist_ok=True)

        manifest_steps: list[dict] = []
        step_files = sorted((stage / "provision" / "scripts" / "steps").glob("*.ps1"))
        for idx, step_file in enumerate(step_files):
            manifest_steps.append({
                "order": idx,
                "name": step_file.name,
                "sha256": _sha256(step_file),
            })
        (stage / "provision" / "state").mkdir(parents=True, exist_ok=True)
        _write_manifest(stage / "provision" / "state", manifest_steps, os_family)

        print(f"[provision] uploading {os_provision_dir.relative_to(root)}/ to remote")
        rc = _ssh_retry(profile, "prepare windows provision directory",
                        'New-Item -ItemType Directory -Force C:\\Users\\Administrator\\provision | Out-Null; '
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\scripts") { '
                        'Remove-Item -Recurse -Force "C:\\Users\\Administrator\\provision\\scripts" }; '
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\state") { '
                        'Remove-Item -Recurse -Force "C:\\Users\\Administrator\\provision\\state" }; '
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\logs") { '
                        'Remove-Item -Recurse -Force "C:\\Users\\Administrator\\provision\\logs" }; '
                        'New-Item -ItemType Directory -Force C:\\Users\\Administrator\\provision\\state | Out-Null')
        if rc:
            return rc
        rc = _ssh_retry_scp(profile, "upload windows provision tree",
                            str(stage / "provision"), "/C:/Users/Administrator/")
        if rc:
            return rc
        rc = _ssh_retry_scp(profile, "upload windows env.json",
                            str(tmp_dir / "env.json"), "/C:/Users/Administrator/provision/state/env.json")
        if rc:
            return rc
        print("[provision] running bootstrap.ps1")
        instance_ssh = str(root / "scripts/instance-ssh")
        result = subprocess.run(
            [instance_ssh, profile, "--", '& "C:\\Users\\Administrator\\provision\\scripts\\bootstrap.ps1"'],
            cwd=root, check=False,
        )
        if result.returncode != 0 and result.returncode != 255:
            return result.returncode
        poll_interval = os.environ.get("EVE_PROVISION_WAIT_POLL_INTERVAL", "5")
        print(f"[provision] waiting for windows provisioning to finish (polling remote log every {poll_interval}s)")
        rc = _run([str(root / "scripts/wait-for-provision"), profile]).returncode
        return rc
    finally:
        import shutil
        shutil.rmtree(stage, ignore_errors=True)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/provision <instance>", file=sys.stderr)
        return 2

    result = subprocess.run(
        [str(ROOT / "scripts/profile-resolve"), "--profile", profile, "--emit", "env"],
        cwd=ROOT, capture_output=True, text=True, check=False,
    )
    sys.stderr.write(result.stderr)
    if result.returncode != 0:
        return result.returncode
    env = _parse_env(result.stdout)

    os_family = env.get("OS_FAMILY", "")
    os_id = env.get("OS_ID", "")

    print(f"[provision] profile={profile} os={os_id} os_family={os_family}")

    if os_family == "ubuntu":
        return provision_ubuntu(profile, env, ROOT)
    if os_family == "windows":
        return provision_windows(profile, env, ROOT)
    print(f"[provision] unknown os_family: {os_family}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
