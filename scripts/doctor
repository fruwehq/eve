#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir  # noqa: E402

FORMAT = "json" if "--json" in sys.argv else "table"

def tool(group: str, name: str, check: str, darwin: str, linux: str, only: list[str] | None = None) -> dict[str, Any]:
    entry = {"group": group, "tool": name, "check": check, "install": {"darwin": darwin, "linux": linux}}
    if only:
        entry["only"] = only
    return entry


TOOL_CHECKS = [
    tool("core", "bash", "command -v bash", "brew install bash", "apt install bash"),
    tool("core", "jq", "command -v jq", "brew install jq", "apt install jq"),
    tool("core", "poetry", "command -v poetry", "brew install poetry", "pipx install poetry"),
    tool("core", "python3", "command -v python3", "brew install python", "apt install python3"),
    tool("core", "scp", "command -v scp", "xcode-select --install", "apt install openssh-client"),
    tool("core", "shellcheck", "command -v shellcheck", "brew install shellcheck", "apt install shellcheck"),
    tool("core", "ssh", "command -v ssh", "xcode-select --install", "apt install openssh-client"),
    tool("core", "yq", "command -v yq", "brew install yq", "apt install yq"),
    tool("provider", "curl", "command -v curl", "brew install curl", "apt install curl"),
    tool("provider", "docker", "docker --version", "install Docker Desktop", "apt install docker.io"),
    tool("provider", "gcloud", "command -v gcloud", "brew install --cask google-cloud-sdk", "install google-cloud-cli"),
    tool("provider", "nc", "command -v nc", "xcode-select --install", "apt install netcat-openbsd"),
    tool(
        "provider",
        "qemu-system-aarch64",
        "command -v qemu-system-aarch64",
        "brew install qemu",
        "apt install qemu-system-arm",
    ),
    tool(
        "provider",
        "qemu-system-x86_64",
        "command -v qemu-system-x86_64",
        "brew install qemu",
        "apt install qemu-system-x86",
    ),
    tool(
        "provider",
        "terraform",
        "terraform -version",
        "brew tap hashicorp/tap && brew install hashicorp/tap/terraform",
        "apt install terraform",
    ),
    tool(
        "provider",
        "terramate",
        "terramate version",
        "install Terramate release tarball",
        "install Terramate release tarball",
    ),

    tool("os", "dscacheutil", "command -v dscacheutil", "bundled with macOS", "", ["darwin"]),
    tool("os", "getent", "command -v getent", "", "apt install libc-bin", ["linux"]),
    tool("os", "pbcopy", "command -v pbcopy", "bundled with macOS", "", ["darwin"]),
    tool("os", "xfreerdp", "command -v xfreerdp", "", "apt install freerdp2-x11", ["linux"]),
]

# Provider-declared host tools (loaded from provider manifests so core has no
# provider id literals). Each provider may declare a ``host_tools`` list; doctor
# reads and checks them generically.
try:
    from eve_sdk.plugin_manifest import PluginManifest as _PM

    for _plugin in _PM.load_all("provider"):
        for _ht in _plugin.get("host_tools") or []:
            TOOL_CHECKS.append(tool(
                "provider",
                str(_ht.get("name", "")),
                str(_ht.get("check", "")),
                str(_ht.get("brew", "")),
                str(_ht.get("apt", "")),
            ))
except Exception:
    pass


def host_os() -> str:
    try:
        result = subprocess.run(["uname", "-s"], text=True, capture_output=True, check=False)
    except FileNotFoundError:
        return "unknown"
    return result.stdout.strip() if result.returncode == 0 and result.stdout.strip() else "unknown"


def os_key(os_name: str) -> str:
    return {"Darwin": "darwin", "Linux": "linux"}.get(os_name, "unsupported")


def shell_ok(command: str) -> bool:
    return (
        subprocess.run(
            ["sh", "-c", command],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            check=False,
        ).returncode
        == 0
    )


def command_output(command: str) -> dict[str, Any]:
    result = subprocess.run(["sh", "-c", command], text=True, capture_output=True, check=False)
    return {"ok": result.returncode == 0, "stdout": result.stdout, "stderr": result.stderr, "status": result.returncode}


def tool_report(os_name: str) -> list[dict[str, str]]:
    key = os_key(os_name)
    results = []
    for entry in TOOL_CHECKS:
        applies = key in entry.get("only", ["darwin", "linux"])
        install = entry["install"].get(key, f"not available on {os_name}")
        status = "ok" if applies and shell_ok(entry["check"]) else "missing" if applies else "skipped"
        results.append(
            {
                "group": entry["group"],
                "tool": entry["tool"],
                "check": entry["check"],
                "status": status,
                "install": install,
            }
        )
    return results


def runnable_check(name: str, command: str) -> dict[str, Any]:
    result = command_output(command)
    return {"name": name, "ok": result["ok"], "status": result["status"]}


def check_required_report() -> dict[str, Any]:
    result = subprocess.run(
        [str(ROOT / "scripts/check-required"), "--json"],
        cwd=ROOT,
        text=True,
        capture_output=True,
        check=False,
    )
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        return {"ok": False, "missing": [], "warnings": [], "exit_status": 1}
    data["exit_status"] = result.returncode
    return data


def docker_report(tool_results: list[dict[str, str]]) -> dict[str, Any]:
    docker = next((tool for tool in tool_results if tool["tool"] == "docker"), None)
    if not docker or docker["status"] != "ok":
        return {"checked": False, "status": "missing"}
    daemon = command_output("docker info")
    return {"checked": True, "status": "ready" if daemon["ok"] else "daemon-unreachable"}


def build_report() -> dict[str, Any]:
    os_name = host_os()
    tools = tool_report(os_name)
    state_dir = Workdir.state_base() / "instances"
    Workdir.ensure_dir(state_dir)
    return {
        "os": {"name": os_name, "key": os_key(os_name)},
        "tools": tools,
        "checks": [
            runnable_check("catalog-options", "./scripts/catalog-options --json"),
            runnable_check("plugins.validate", "./scripts/plugin-list --validate"),
        ],
        "docker": docker_report(tools),
        "providers_status_available": (ROOT / "scripts/providers-status").is_file()
        and os.access(ROOT / "scripts/providers-status", os.X_OK),
        "state": {"dir": str(state_dir)},
        "required_fields": check_required_report(),
    }


def print_section(title: str) -> None:
    print()
    print(f"== {title} ==")


def print_tool_table(tools: list[dict[str, str]]) -> None:
    groups = []
    for tool in tools:
        if tool["group"] not in groups:
            groups.append(tool["group"])
    for group in groups:
        entries = [tool for tool in tools if tool["group"] == group]
        print_section(f"{group} tools")
        print(f"  {'Tool':<24} {'Status':<8} Install")
        for tool in entries:
            if tool["status"] == "skipped":
                continue
            label = "[OK]" if tool["status"] == "ok" else "[WARN]"
            print(f"  {tool['tool']:<24} {label:<8} {tool['install']}")


def print_report(report: dict[str, Any]) -> None:
    print(f"Host OS: {report['os']['name']}")
    print_tool_table(report["tools"])
    print_section("docker")
    match report["docker"]["status"]:
        case "missing":
            print("  [INFO] Docker CLI missing")
        case "daemon-unreachable":
            print("  [INFO] Docker daemon not reachable")
        case "ready":
            print("  [OK] Docker available")
    print_section("catalog")
    for check in report["checks"]:
        print(f"  {'[OK]' if check['ok'] else '[FAIL]'} {check['name']}")
    print_section("providers")
    subprocess.run(["./scripts/providers-status"], cwd=ROOT, check=False)
    print_section("state")
    print(f"  [OK] state directory: {report['state']['dir']}")
    print("  [INFO] recover interrupted state with: make instance.recover INSTANCE=<name>")
    required = report["required_fields"]
    print_section("required fields")
    if required["ok"]:
        print("  [OK] all required fields populated")
    else:
        print("  [INFO] missing required fields:")
        for entry in required.get("missing", []):
            print(f"    {entry['provider']}.{entry['scope']}.{entry['field']} - {entry['description']}")
    warnings = required.get("warnings", [])
    if warnings:
        print_section("portability warnings")
        for warning in warnings:
            print(f"  [WARN] {warning['id']}: {warning['description']}")


def main() -> int:
    report = build_report()
    if FORMAT == "json":
        print(json.dumps(report, indent=2))
    else:
        print_report(report)
    return 1 if any(not check["ok"] for check in report["checks"]) else 0


if __name__ == "__main__":
    raise SystemExit(main())
