#!/usr/bin/env bash
set -euo pipefail

# Run vagrant destroy for a profile.
# Usage: scripts/vagrant-destroy <profile>

PROFILE="${1:?Usage: scripts/vagrant-destroy <profile>}"
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" != "vagrant" ]; then
  echo "[vagrant-destroy] not supported for engine=$ENGINE"
  exit 1
fi

echo "[vagrant-destroy] profile=$PROFILE"

WORKDIR="$(egame_instance_workdir "$PROFILE")"
if [ -f "$WORKDIR/Vagrantfile" ]; then
  cd "$WORKDIR"
  vagrant destroy -f
else
  echo "No generated Vagrantfile for instance $PROFILE. Nothing to destroy."
fi
