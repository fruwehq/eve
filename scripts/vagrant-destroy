#!/usr/bin/env python3
"""Run vagrant destroy for a profile.

Usage: scripts/vagrant-destroy <instance>
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import repo_root, resolve_env  # noqa: E402
from eve_sdk.vagrant_dispatch import instance_workdir  # noqa: E402


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/vagrant-destroy <instance>", file=sys.stderr)
        return 2
    root = repo_root()

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    if engine != "vagrant":
        print(f"[vagrant-destroy] not supported for engine={engine}")
        return 1

    print(f"[vagrant-destroy] profile={profile}")

    workdir = instance_workdir(root, profile)
    if (Path(workdir) / "Vagrantfile").is_file():
        return subprocess.run(["vagrant", "destroy", "-f"], cwd=workdir).returncode
    print(f"No generated Vagrantfile for instance {profile}. Nothing to destroy.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
