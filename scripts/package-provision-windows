#!/usr/bin/env python3
"""Upload Windows provisioning scripts and run the step subset for one package.

Usage:
  scripts/package-provision-windows --instance <name> --package <id> [--dry-run]
  scripts/package-provision-windows --profile <name> --package <id> [--dry-run]

Some Windows provisioning steps trigger reboot flags or depend on the runner
state machine restarting after a reboot (ViGEmBus, GPU driver, VDD).  Packages
whose manifest declares ``install.windows.fallback: true`` (or omits
``install.windows``) fall back to full provisioning.
"""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.package_dispatch import emit_json  # noqa: E402
from eve_sdk.tf_dispatch import repo_root, resolve_env  # noqa: E402

_USAGE = (
    "Usage:\n"
    "  scripts/package-provision-windows --instance <name> --package <id> [--dry-run]\n"
    "  scripts/package-provision-windows --profile <name> --package <id> [--dry-run]  "
    "# compatibility alias"
)

_REMOTE_STEP_DIR = r"C:\Users\Administrator\provision\scripts-package"
_REMOTE_LIB_DIR = _REMOTE_STEP_DIR + r"\lib"
_REMOTE_STEPS_DIR = _REMOTE_STEP_DIR + r"\steps"
_REMOTE_STATE_DIR = r"C:\Users\Administrator\provision\state"


def _ssh_retry(label: str, cmd: list[str]) -> int:
    return subprocess.run(
        [str(ROOT / "scripts/ssh-retry"), label, *cmd],
    ).returncode


def _instance_ssh(instance: str, *args: str) -> int:
    return subprocess.run([str(ROOT / "scripts/instance-ssh"), instance, *args]).returncode


def _plugin_list_json() -> object:
    result = subprocess.run(
        [str(ROOT / "scripts/plugin-list"), "--kind", "package", "--json"],
        capture_output=True, text=True, check=True,
    )
    return json.loads(result.stdout)


def _merge_dir(src: Path, dst: Path) -> None:
    """Merge the contents of ``src`` into ``dst`` (cp -R src/. dst/)."""
    if not src.is_dir():
        return
    shutil.copytree(src, dst, dirs_exist_ok=True)


def main(argv: list[str]) -> int:
    instance_name = ""
    package = ""
    dry_run = False

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg in {"--instance", "--profile"} and args:
            instance_name = args.pop(0)
        elif arg == "--package" and args:
            package = args.pop(0)
        elif arg == "--dry-run":
            dry_run = True
        elif arg in {"-h", "--help"}:
            print(_USAGE, file=sys.stderr)
            return 0
        else:
            print(_USAGE, file=sys.stderr)
            return 2

    if not instance_name or not package:
        print(_USAGE, file=sys.stderr)
        return 2

    root = repo_root()
    resolved = resolve_env(root, instance_name)
    os_family = resolved.get("OS_FAMILY", "")
    os_id = resolved.get("OS_ID", "")
    os_provision_dir = root / "oses" / os_id / "provision"

    if os_family != "windows":
        print(
            f"package-provision-windows: granular package install is only "
            f"implemented for windows, got {os_family}",
            file=sys.stderr,
        )
        return 2
    if not os_provision_dir.is_dir():
        print(
            f"package-provision-windows: OS provisioning directory not found: {os_provision_dir}",
            file=sys.stderr,
        )
        return 2
    os_provision_dir = os_provision_dir.resolve()

    doc = _plugin_list_json()
    plugins = doc["plugins"] if isinstance(doc, dict) else []
    entry = next((p for p in plugins if isinstance(p, dict) and p.get("id") == package), None)
    if entry is None:
        entry = {}

    # For a merged dual-OS package the record's `path` is the ubuntu half; use the
    # windows half's path (os_paths) for windows provision/command resolution.
    os_paths = entry.get("os_paths") if isinstance(entry.get("os_paths"), dict) else {}
    plugin_path = os_paths.get("windows") or entry.get("path") or ""
    plugin_root = str(Path(plugin_path).parent) if plugin_path else ""

    install = entry.get("install", {})
    install_windows = install.get("windows") if isinstance(install, dict) else None

    steps: list[str] = []
    state_files: list[str] = []
    fallback = False
    if install_windows is None:
        fallback = True
    else:
        fallback = bool(install_windows.get("fallback", False))
        steps = list(install_windows.get("steps", []))
        state_files = list(install_windows.get("state_files", []))
    if fallback:
        steps = []
        state_files = []

    if dry_run:
        emit_json({
            "kind": "package-provision-windows",
            "instance": instance_name,
            "package": package,
            "os_family": os_family,
            "steps": steps,
            "state_files": state_files,
            "fallback": fallback,
            "dry_run": True,
        })
        return 0

    if fallback:
        print(
            f"[package-provision-windows] no granular mapping for package={package}; "
            f"falling back to full provisioning"
        )
        return subprocess.run([str(ROOT / "scripts/provision"), instance_name]).returncode

    subprocess.run([str(ROOT / "scripts/ssh-wait"), instance_name]).check_returncode()

    stage = Path(tempfile.mkdtemp())
    try:
        (stage / "scripts" / "steps").mkdir(parents=True, exist_ok=True)
        _merge_dir(os_provision_dir / "scripts" / "lib", stage / "scripts" / "lib")
        if (os_provision_dir / "scripts" / "templates").is_dir():
            _merge_dir(os_provision_dir / "scripts" / "templates", stage / "scripts" / "templates")
        if plugin_root:
            _merge_dir(Path(plugin_root) / "provision" / "windows" / "lib", stage / "scripts" / "lib")
            plugin_templates = Path(plugin_root) / "provision" / "windows" / "templates"
            if plugin_templates.is_dir():
                (stage / "scripts" / "templates").mkdir(parents=True, exist_ok=True)
                _merge_dir(plugin_templates, stage / "scripts" / "templates")

        def resolve_step_path(step: str) -> Path:
            if plugin_root and (Path(plugin_root) / step).is_file():
                return Path(plugin_root) / step
            candidate = os_provision_dir / "scripts" / "steps" / step
            if candidate.is_file():
                return candidate
            print(
                f"package-provision-windows: step not found for package={package}: {step}",
                file=sys.stderr,
            )
            raise SystemExit(2)

        for step in steps:
            step_file = Path(step).name
            shutil.copy2(resolve_step_path(step), stage / "scripts" / "steps" / step_file)

        needs_env = "env.json" in state_files
        unsupported = [sf for sf in state_files if sf != "env.json"]
        if unsupported:
            print(
                f"package-provision-windows: unsupported state_files for "
                f"package={package}: {' '.join(unsupported)}",
                file=sys.stderr,
            )
            return 2

        if needs_env:
            windows_password = os.environ.get("EPHEMERAL_WINDOWS_PASSWORD", "")
            if not windows_password:
                pw_result = subprocess.run(
                    [str(ROOT / "scripts/instance-password"), instance_name],
                    capture_output=True, text=True, check=False,
                )
                windows_password = pw_result.stdout.strip() if pw_result.returncode == 0 else ""
            from eve_sdk.config import ConfigEnv

            env_payload = ConfigEnv.provision_env_payload(windows_password)
            (stage / "state").mkdir(parents=True, exist_ok=True)
            (stage / "state" / "env.json").write_text(
                json.dumps(env_payload, indent=2, ensure_ascii=False) + "\n",
                encoding="utf-8",
            )

        print(f"[package-provision-windows] uploading windows step files for package={package}")

        ssh = str(ROOT / "scripts/instance-ssh")
        reset_cmd = (
            f"if (Test-Path '{_REMOTE_STEP_DIR}') {{ Remove-Item -Recurse -Force "
            f"'{_REMOTE_STEP_DIR}' }} ; "
            f"New-Item -ItemType Directory -Force '{_REMOTE_LIB_DIR}' | Out-Null ; "
            f"New-Item -ItemType Directory -Force '{_REMOTE_STEPS_DIR}' | Out-Null"
        )
        if needs_env:
            reset_cmd += f" ; New-Item -ItemType Directory -Force '{_REMOTE_STATE_DIR}' | Out-Null"

        uploads: list[tuple[str, list[str]]] = [
            ("prepare windows package provision directory", [ssh, instance_name, "--", reset_cmd]),
            ("upload windows package lib", [ssh, instance_name, "--scp",
             str(stage / "scripts" / "lib"), "/C:/Users/Administrator/provision/scripts-package/"]),
        ]
        if (stage / "scripts" / "templates").is_dir():
            uploads.append(("upload windows package templates", [ssh, instance_name, "--scp",
                str(stage / "scripts" / "templates"),
                "/C:/Users/Administrator/provision/scripts-package/"]))
        for step in steps:
            step_file = Path(step).name
            uploads.append((f"upload windows package step {step_file}",
                [ssh, instance_name, "--scp",
                 str(stage / "scripts" / "steps" / step_file),
                 f"/C:/Users/Administrator/provision/scripts-package/steps/{step_file}"]))
        if needs_env:
            uploads.append(("upload windows package env.json", [ssh, instance_name, "--scp",
                str(stage / "state" / "env.json"),
                "/C:/Users/Administrator/provision/state/env.json"]))

        for label, cmd in uploads:
            status = _ssh_retry(label, cmd)
            if status != 0:
                return status

        for step in steps:
            step_file = Path(step).name
            print(f"[package-provision-windows] running step={step_file} package={package}")
            status = _instance_ssh(
                instance_name, "--",
                f"& 'C:\\Users\\Administrator\\provision\\scripts-package\\steps\\{step_file}'",
            )
            if status != 0:
                return status
    finally:
        shutil.rmtree(stage, ignore_errors=True)

    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
