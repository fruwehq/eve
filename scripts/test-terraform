#!/usr/bin/env python3
"""terramate generate + terraform validate across every provider services stack.

Uses dummy env vars — provider credentials are NOT required (validate is offline).
"""

from __future__ import annotations

import os
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]

TM_FLAGS = ["--disable-safeguards=git-untracked,git-uncommitted,git-out-of-sync,outdated-code"]


def main() -> int:
    os.environ.setdefault("MY_IP", "1.2.3.4")

    tmpkey = None
    if not os.environ.get("SSH_PUBLIC_KEY_FILE") or not Path(os.environ["SSH_PUBLIC_KEY_FILE"]).exists():
        tmpkey = tempfile.NamedTemporaryFile(mode="w", suffix="_key", delete=False)  # noqa: SIM115
        tmpkey.write("ssh-rsa AAAAB3NzaC1yc2EAAAA_test_only test@test\n")
        tmpkey.close()
        os.environ["SSH_PUBLIC_KEY_FILE"] = tmpkey.name

    try:
        for d in [".terraform-cache-dir/data", ".terraform-cache-dir/plugins", ".terraform-cache-dir/state"]:
            (ROOT / d).mkdir(parents=True, exist_ok=True)

        subprocess.run(["terramate", "generate"], cwd=str(ROOT), capture_output=True, check=True)

        fail = 0
        for tags in ["aws-services", "gcp-services", "vultr-services", "truenas-services"]:
            print(f"  -- {tags} --")
            init = subprocess.run(
                ["terramate", "run", *TM_FLAGS, f"--tags={tags}", "--quiet", "--",
                 "terraform", "init", "-backend=false", "-input=false", "-upgrade=false"],
                cwd=str(ROOT), capture_output=True, check=False,
            )
            if init.returncode != 0:
                print(f"  [FAIL] init: {tags}", file=sys.stderr)
                # Re-run with visible output for debugging.
                subprocess.run(
                    ["terramate", "run", *TM_FLAGS, f"--tags={tags}", "--quiet", "--",
                     "terraform", "init", "-backend=false", "-input=false"],
                    cwd=str(ROOT), check=False,
                )
                fail += 1
                continue

            validate = subprocess.run(
                ["terramate", "run", *TM_FLAGS, f"--tags={tags}", "--quiet", "--",
                 "terraform", "validate"],
                cwd=str(ROOT), capture_output=True, check=False,
            )
            if validate.returncode != 0:
                print(f"  [FAIL] validate: {tags}", file=sys.stderr)
                subprocess.run(
                    ["terramate", "run", *TM_FLAGS, f"--tags={tags}", "--quiet", "--",
                     "terraform", "validate"],
                    cwd=str(ROOT), check=False,
                )
                fail += 1
                continue

            print(f"  [OK] {tags}")

        return 1 if fail else 0
    finally:
        if tmpkey:
            Path(tmpkey.name).unlink(missing_ok=True)


if __name__ == "__main__":
    raise SystemExit(main())
