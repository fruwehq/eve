#!/usr/bin/env python3
"""Run an instance-oriented command through generated profile compatibility data.

Usage: scripts/instance-run <make-target> [instance]
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.instance_dispatch import instance_paths_env, load_runtime_env  # noqa: E402
from eve_sdk.tf_dispatch import repo_root  # noqa: E402

_PROVIDER_TARGETS = {"init", "plan", "up", "down", "start", "stop", "status", "ip", "ssh"}


def _resolve_os_family(root: Path, instance_name: str) -> str:
    """Read OS_FAMILY via instance-resolve (inherits EVE_INSTANCE_REGISTRY).

    Mirrors ``OS_FAMILY="$(./scripts/instance-resolve --instance <name> --emit
    env | awk ...)``: failure is fatal under ``set -e``/``pipefail``.
    """
    result = subprocess.run(
        [str(root / "scripts/instance-resolve"), "--instance", instance_name, "--emit", "env"],
        cwd=root, text=True, capture_output=True, check=False,
    )
    if result.returncode != 0:
        raise SystemExit(result.returncode)
    for line in result.stdout.splitlines():
        if line.startswith("OS_FAMILY="):
            return line.split("=", 1)[1]
    return ""


def main(argv: list[str]) -> int:
    root = repo_root()
    load_runtime_env(root)

    target = argv[0] if argv else ""
    if not target:
        print("Usage: scripts/instance-run <make-target> [instance]", file=sys.stderr)
        return 2
    instance_name = argv[1] if len(argv) > 1 else os.environ.get("INSTANCE", "")
    extra_args = list(argv[2:])

    if not instance_name:
        print("instance-run: INSTANCE is required", file=sys.stderr)
        print(f"Usage: ./scripts/instance-run {target} <name>", file=sys.stderr)
        return 2

    registry = os.environ.get("EVE_INSTANCE_REGISTRY", "")
    paths = instance_paths_env(root, instance_name, registry or None)
    overlay = paths.get("INSTANCE_OVERLAY_PATH", "")

    overlay_cmd = [
        str(root / "scripts/instance-profile-overlay"),
        "--instance", instance_name, "--output", overlay,
    ]
    if registry:
        overlay_cmd += ["--registry", registry]
    rc = subprocess.run(overlay_cmd, cwd=root, check=False).returncode
    if rc != 0:
        return rc

    print(
        f"[instance-run] target={target} instance={instance_name} overlay={overlay}",
        file=sys.stderr,
    )

    os.environ["EVE_CATALOG_LOCAL"] = overlay
    os.environ["EVE_INSTANCE_NAME"] = instance_name

    ssh = str(root / "scripts/instance-ssh")

    def run(cmd: list[str]) -> int:
        return subprocess.run(cmd, cwd=root, check=False).returncode

    if target in _PROVIDER_TARGETS:
        return run([
            str(root / "scripts/provider-dispatch"),
            "--instance", instance_name, "--command", target,
        ])
    if target == "provision":
        return run([str(root / "scripts/instance-provision"), "--instance", instance_name])
    if target == "env":
        return run([
            str(root / "scripts/instance-resolve"),
            "--instance", instance_name, "--emit", "env",
        ])
    if target == "info":
        return run([
            str(root / "scripts/instance-resolve"),
            "--instance", instance_name, "--emit", "json",
        ])
    if target == "validate":
        return run([
            str(root / "scripts/instance-resolve"),
            "--instance", instance_name, "--validate",
        ])
    if target == "logs":
        return run([str(root / "scripts/logs"), instance_name])
    if target == "provision.clear-state":
        os_family = _resolve_os_family(root, instance_name)
        if os_family == "ubuntu":
            return run([ssh, instance_name, "--",
                        "rm -rf ~/provision/state ~/provision/logs ~/provision/downloads"])
        if os_family == "windows":
            return run([ssh, instance_name, "--",
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\state") '
                        '{ Remove-Item -Recurse -Force '
                        '"C:\\Users\\Administrator\\provision\\state" }; '
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\logs") '
                        '{ Remove-Item -Recurse -Force '
                        '"C:\\Users\\Administrator\\provision\\logs" }; '
                        'if (Test-Path "C:\\Users\\Administrator\\provision\\downloads") '
                        '{ Remove-Item -Recurse -Force '
                        '"C:\\Users\\Administrator\\provision\\downloads" }'])
        print(f"[provision.clear-state] unknown os_family: {os_family}", file=sys.stderr)
        return 2
    if target == "provision.wait":
        return run([str(root / "scripts/wait-for-provision"), instance_name])
    if target == "update":
        return run([str(root / "scripts/update-tools"), instance_name])
    if target == "reboot":
        os_family = _resolve_os_family(root, instance_name)
        if os_family == "windows":
            return run([ssh, instance_name, "--", "shutdown /r /t 0"])
        return run([ssh, instance_name, "--", "sudo reboot"])
    if target == "show-password":
        return run([str(root / "scripts/instance-password"), instance_name])
    if target == "ssh.run":
        if sys.stdin.isatty():
            print("Usage: echo '<command>' | ./scripts/instance-run ssh.run <name>", file=sys.stderr)
            return 2
        # $(cat) strips trailing newlines; replicate for arg-level fidelity.
        command = sys.stdin.read().rstrip("\n")
        return run([ssh, instance_name, "--", command])
    if target == "ssh.wait":
        return run([str(root / "scripts/ssh-wait"), instance_name])
    if target == "upload":
        return run([str(root / "scripts/upload"), instance_name, *extra_args])

    print(f"instance-run: unsupported target: {target}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
