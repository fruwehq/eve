#!/usr/bin/env python3
"""Run terraform destroy for a profile's stacks in reverse order.

Usage: scripts/tf-destroy <instance>
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import apply_tf_env, prepare_provider_stacks, repo_root, resolve_env  # noqa: E402


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/tf-destroy <instance>", file=sys.stderr)
        return 2
    root = repo_root()

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    if engine != "terraform":
        print(f"Error: {profile} uses engine '{engine}', not terraform", file=sys.stderr)
        return 1

    tags = resolved.get("STACK_TAGS", "")
    print(f"[tf-destroy] profile={profile} tags={tags}")

    tm_run_flags = [
        "--disable-safeguards=git-untracked",
        "--disable-safeguards=git-uncommitted",
        "--disable-safeguards=git-out-of-sync",
        "--disable-safeguards=outdated-code",
    ]

    prepare_provider_stacks(root, resolved.get("PROVIDER", ""))
    rc = subprocess.run(["terramate", "generate"], cwd=root).returncode
    if rc != 0:
        return rc

    apply_tf_env(root, profile)
    return subprocess.run(
        ["terramate", "run", *tm_run_flags, f"--tags={tags}", "--reverse", "--",
         "terraform", "destroy", "-auto-approve"],
        cwd=root,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
