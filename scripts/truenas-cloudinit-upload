#!/usr/bin/env bash
set -euo pipefail

# Generate a NoCloud cloud-init seed ISO and upload it to TrueNAS.
# Usage: truenas-cloudinit-upload <vm_name> <ssh_public_key_file> <truenas_host> <iso_path>
# Env:   TRUENAS_API_KEY

VM_NAME="${1:?vm_name required}"
SSH_PUBLIC_KEY_FILE="${2:?ssh_public_key_file required}"
TRUENAS_HOST="${3:?truenas_host required}"
ISO_PATH="${4:?iso_path required}"

: "${TRUENAS_API_KEY:?TRUENAS_API_KEY must be set}"

SSH_PUBLIC_KEY=$(cat "$SSH_PUBLIC_KEY_FILE")

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

mkdir -p "$TMPDIR/cidata"

cat > "$TMPDIR/cidata/user-data" <<EOF
#cloud-config
hostname: $VM_NAME
users:
  - name: ubuntu
    ssh_authorized_keys:
      - $SSH_PUBLIC_KEY
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    groups: [adm, sudo]
EOF

cat > "$TMPDIR/cidata/meta-data" <<EOF
instance-id: $VM_NAME
local-hostname: $VM_NAME
EOF

hdiutil makehybrid \
  -o "$TMPDIR/cidata.iso" \
  -hfs -joliet -iso \
  -default-volume-name cidata \
  "$TMPDIR/cidata" \
  >/dev/null

curl -k -sf -X POST \
  -H "Authorization: Bearer $TRUENAS_API_KEY" \
  -F "data={\"path\": \"$ISO_PATH\"}" \
  -F "file=@$TMPDIR/cidata.iso" \
  "https://$TRUENAS_HOST/api/v2.0/filesystem/put"

printf '[truenas-cloudinit-upload] %s → %s\n' "$VM_NAME" "$ISO_PATH"
