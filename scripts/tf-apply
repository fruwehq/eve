#!/usr/bin/env python3
"""Run terraform apply for a profile's stacks.

Usage: scripts/tf-apply <instance>
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import apply_tf_env, prepare_provider_stacks, repo_root, resolve_env  # noqa: E402


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/tf-apply <instance>", file=sys.stderr)
        return 2
    root = repo_root()

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    if engine != "terraform":
        print(f"[tf-apply] not supported for engine={engine}")
        return 1

    tags = resolved.get("STACK_TAGS", "")
    print(f"[tf-apply] profile={profile} tags={tags}")

    prepare_provider_stacks(root, resolved.get("PROVIDER", ""))
    rc = subprocess.run(["terramate", "generate"], cwd=root).returncode
    if rc != 0:
        return rc

    apply_tf_env(root, profile)

    instance = os.environ.get("EVE_INSTANCE_NAME", "")
    if instance:
        print(f"[tf-apply] instance={instance} initializing backend before apply")
        rc = subprocess.run(
            [str(root / "scripts/tf-init"), profile], cwd=root,
        ).returncode
        if rc != 0:
            return rc

    tm_run_flags = [
        "--disable-safeguards=git-untracked",
        "--disable-safeguards=git-uncommitted",
        "--disable-safeguards=git-out-of-sync",
        "--disable-safeguards=outdated-code",
    ]
    return subprocess.run(
        ["terramate", "run", *tm_run_flags, f"--tags={tags}", "--", "terraform", "apply",
         "-auto-approve"],
        cwd=root,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
