#!/usr/bin/env bash
# Check provider configuration and connectivity.
set -euo pipefail

check_aws() {
  local configured=no reachable=no notes="missing AWS_PROFILE/AWS credentials"

  if [ -n "${AWS_PROFILE:-}" ] || [ -n "${AWS_ACCESS_KEY_ID:-}" ]; then
    configured=yes
    if ! command -v aws >/dev/null 2>&1; then
      notes="configured, but aws cli not found"
    elif aws sts get-caller-identity >/dev/null 2>&1; then
      reachable=yes
      notes="aws sts ok"
    else
      notes="configured, but aws sts failed - Please, run: make aws.login"
    fi
  fi

  printf '%-17s  %-10s  %-9s  %s\n' 'aws' "$configured" "$reachable" "$notes"
}

check_local_virtualbox() {
  local configured=no reachable=no notes="vagrant/virtualbox not found"

  if command -v vagrant >/dev/null 2>&1 || command -v VBoxManage >/dev/null 2>&1; then
    configured=yes
    if command -v VBoxManage >/dev/null 2>&1; then
      reachable=yes
      notes="VBoxManage available"
    else
      notes="vagrant present, VBoxManage missing"
    fi
  fi

  printf '%-17s  %-10s  %-9s  %s\n' 'local-virtualbox' "$configured" "$reachable" "$notes"
}

check_local_vmware() {
  local configured=no reachable=no notes="vagrant/vmrun not found"

  if command -v vagrant >/dev/null 2>&1 || command -v vmrun >/dev/null 2>&1; then
    configured=yes
    if command -v vmrun >/dev/null 2>&1; then
      reachable=yes
      notes="vmrun available"
    else
      notes="vagrant present, vmrun missing"
    fi
  fi

  printf '%-17s  %-10s  %-9s  %s\n' 'local-vmware' "$configured" "$reachable" "$notes"
}

check_truenas() {
  local host="${TRUENAS_HOST:-}"
  local port="${TRUENAS_SSH_PORT:-22}"
  local user="${TRUENAS_SSH_USER:-terraform}"
  local configured=no reachable=no notes="missing TRUENAS_HOST"

  if [ -n "$host" ]; then
    configured=yes
    notes="host=$host"
    if nc -z -w 2 "$host" "$port" >/dev/null 2>&1; then
      reachable=yes
      notes="ssh port $port reachable"
    else
      notes="ssh port $port unreachable"
    fi
    if [ -n "${TRUENAS_SSH_PRIVATE_KEY_FILE:-}" ] && [ -f "${TRUENAS_SSH_PRIVATE_KEY_FILE}" ]; then
      mkdir -p ./tmp
      if ssh -o BatchMode=yes -o ConnectTimeout=5 -o StrictHostKeyChecking=accept-new \
        -o UserKnownHostsFile=./tmp/known_hosts \
        -p "$port" -i "${TRUENAS_SSH_PRIVATE_KEY_FILE}" \
        "$user@$host" \
        'midclt call system.version >/dev/null 2>&1 && echo ok' 2>/dev/null | grep -q ok; then
        reachable=yes
        notes="ssh auth ok; midclt reachable"
      else
        notes="host reachable; ssh auth or permissions failed"
      fi
    fi
    if [ -n "${TRUENAS_API_KEY:-}" ] && curl -ksS --connect-timeout 3 --max-time 8 \
      -H "Authorization: Bearer ${TRUENAS_API_KEY}" \
      "https://$host/api/v2.0/system/version" >/dev/null 2>&1; then
      reachable=yes
      notes="api key accepted"
    fi
  fi

  printf '%-17s  %-10s  %-9s  %s\n' 'truenas' "$configured" "$reachable" "$notes"
}

check_vultr() {
  local configured=no reachable=no notes="missing VULTR_API_KEY"

  if [ -n "${VULTR_API_KEY:-}" ]; then
    configured=yes
    if curl -fsS -H "Authorization: Bearer ${VULTR_API_KEY}" \
      https://api.vultr.com/v2/account >/dev/null 2>&1; then
      reachable=yes
      notes="api ok"
    else
      notes="configured, but api call failed"
    fi
  fi

  printf '%-17s  %-10s  %-9s  %s\n' 'vultr' "$configured" "$reachable" "$notes"
}

cd "$(git rev-parse --show-toplevel)"

printf '%s\n' 'Provider           Configured  Reachable  Notes'
printf '%s\n' '-----------------  ----------  ---------  -------------------------------------------'
check_aws
check_local_virtualbox
check_local_vmware
check_truenas
check_vultr
