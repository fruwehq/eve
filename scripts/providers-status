#!/usr/bin/env python3
"""Check provider configuration and connectivity.

Usage:
  scripts/providers-status                    # show all providers (table)
  scripts/providers-status <provider>         # check one provider (table row)
  scripts/providers-status <provider> <field> # print single field (configured|reachable|notes)

The provider list is derived dynamically from PluginManifest: every provider
that declares a ``connectivity`` command appears. Each connectivity command
runs on the HOST (probes local CLIs/creds, not an instance) and prints one
JSON object: {"configured","reachable","notes"}.
"""
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import command_vector  # noqa: E402
from eve_sdk.plugin_manifest import PluginManifest  # noqa: E402

HEADER = "Provider           Configured  Reachable  Notes"
SEPARATOR = "-----------------  ----------  ---------  -------------------------------------------"


def _connectivity_providers() -> list[dict[str, Any]]:
    """Return provider plugins that declare a connectivity command, sorted by id."""
    return sorted(
        (
            PluginManifest.public(p)
            for p in PluginManifest.load_all("provider")
            if "connectivity" in (p.get("commands") or {})
        ),
        key=lambda p: p["id"],
    )


def _run_connectivity(plugin: dict[str, Any]) -> tuple[str, str, str]:
    """Run a provider's connectivity command, parse JSON → (configured, reachable, notes)."""
    spec = plugin["commands"]["connectivity"]
    cmd = command_vector(plugin, spec)
    result = subprocess.run(cmd, capture_output=True, text=True, check=False)
    if result.returncode != 0:
        return "no", "no", f"connectivity check failed (exit {result.returncode})"
    try:
        data = json.loads(result.stdout)
        return str(data.get("configured", "no")), str(data.get("reachable", "no")), str(data.get("notes", ""))
    except (json.JSONDecodeError, ValueError):
        return "no", "no", "connectivity check returned invalid JSON"


def _print_row(name: str, configured: str, reachable: str, notes: str) -> None:
    print(f"{name:<17}  {configured:<10}  {reachable:<9}  {notes}")


def main(argv: list[str]) -> int:
    provider_name = argv[0] if len(argv) > 0 else ""
    field = argv[1] if len(argv) > 1 else ""

    providers = _connectivity_providers()
    provider_ids = [p["id"] for p in providers]

    if provider_name:
        if provider_name not in provider_ids:
            print(f"Unknown provider: {provider_name} (valid: {' '.join(provider_ids)})", file=sys.stderr)
            return 1
        plugin = next(p for p in providers if p["id"] == provider_name)
        configured, reachable, notes = _run_connectivity(plugin)
        if field:
            if field == "configured":
                print(configured)
            elif field == "reachable":
                print(reachable)
            elif field == "notes":
                print(notes)
            else:
                print(
                    f"Unknown field: {field} (valid: configured, reachable, notes)",
                    file=sys.stderr,
                )
                return 1
        else:
            print(HEADER)
            print(SEPARATOR)
            _print_row(provider_name, configured, reachable, notes)
    else:
        print(HEADER)
        print(SEPARATOR)
        for plugin in providers:
            configured, reachable, notes = _run_connectivity(plugin)
            _print_row(plugin["id"], configured, reachable, notes)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
