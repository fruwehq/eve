#!/usr/bin/env python3
"""Emit a catalog overlay that exposes one concrete instance as a profile."""

from __future__ import annotations

import argparse
import copy
import json
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(prog="scripts/instance-profile-overlay")
    arg_parser.add_argument("--instance", required=True)
    arg_parser.add_argument("--registry")
    arg_parser.add_argument("--output")
    return arg_parser


def resolve_instance(instance_name: str, registry_path: str | None) -> dict[str, Any]:
    cmd = [str(ROOT / "scripts/instance-resolve"), "--instance", instance_name, "--emit", "json"]
    if registry_path:
        cmd += ["--registry", registry_path]
    result = subprocess.run(cmd, cwd=ROOT, text=True, capture_output=True, check=False)
    if result.returncode != 0:
        print(result.stdout + result.stderr, end="", file=sys.stderr)
        raise SystemExit(result.returncode)
    parsed = json.loads(result.stdout)
    if not isinstance(parsed, dict):
        raise RuntimeError("instance-resolve did not emit a JSON object")
    return parsed


def build_overlay(instance_name: str, resolved: dict[str, Any]) -> dict[str, Any]:
    composition = resolved["composition"]
    machine = resolved["machine"]
    os_doc = resolved["os"]
    init = resolved["init"]
    location = resolved["location"]
    provider = machine["provider"]
    provider_config = resolved.get("provider_config") if isinstance(resolved.get("provider_config"), dict) else {}

    machine_name = f"instance-{instance_name}-machine"
    overlay_machine = copy.deepcopy(machine)
    overlay_machine["name"] = machine_name
    source_machine = copy.deepcopy(machine)
    source_location = copy.deepcopy(location)

    overlay_profile = {
        "name": instance_name,
        "machine": machine_name,
        "os": composition["os"],
        "init": composition["init"],
        "bundles": composition.get("bundles", []),
        "location": composition["location"],
    }
    if "packages" in composition:
        overlay_profile["packages"] = composition["packages"]
    if "lifecycle" in composition:
        overlay_profile["lifecycle"] = composition["lifecycle"]

    overlay = {
        "inits": [copy.deepcopy(init)],
        "locations": [source_location],
        "machines": sorted([source_machine, overlay_machine], key=lambda entry: entry["name"]),
        "oses": [copy.deepcopy(os_doc)],
        "profiles": [overlay_profile],
    }

    if provider_config:
        overlay_location = copy.deepcopy(location)
        location_name = f"instance-{instance_name}-location"
        overlay_location["name"] = location_name
        overlay_location[provider] = {**overlay_location.get(provider, {}), **provider_config}
        if provider == "raspberry-pi" and not str(overlay_location[provider].get("host", "")):
            overlay_location[provider]["host"] = overlay_location[provider].get("ip")
        overlay_profile["location"] = location_name
        overlay["locations"] = sorted([source_location, overlay_location], key=lambda entry: entry["name"])

    return overlay


def main() -> int:
    args = parser().parse_args()
    registry_path = str(Path(args.registry).expanduser().resolve()) if args.registry else None
    output_path = Path(args.output).expanduser().resolve() if args.output else None
    resolved = resolve_instance(args.instance, registry_path)
    overlay_yaml = yaml.safe_dump(build_overlay(args.instance, resolved), sort_keys=False)
    if output_path:
        output_path.parent.mkdir(parents=True, exist_ok=True)
        if output_path.exists() and output_path.read_text(encoding="utf-8") == overlay_yaml:
            return 0
        output_path.write_text(overlay_yaml, encoding="utf-8")
    else:
        print(overlay_yaml, end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
