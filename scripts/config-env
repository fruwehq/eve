#!/usr/bin/env python3
"""Emit non-secret structured config as environment assignments."""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.config import ConfigEnv  # noqa: E402


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/config-env",
        usage="scripts/config-env [--make|--shell|--json]",
        add_help=True,
    )
    formats = arg_parser.add_mutually_exclusive_group()
    formats.add_argument("--make", action="store_const", dest="fmt", const="--make")
    formats.add_argument("--shell", action="store_const", dest="fmt", const="--shell")
    formats.add_argument("--json", action="store_const", dest="fmt", const="--json")
    formats.add_argument("--structured", action="store_const", dest="fmt", const="--structured")
    arg_parser.set_defaults(fmt="--make")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    try:
        print(ConfigEnv.emit(args.fmt), end="")
        return 0
    except Exception as error:
        print(f"config-env: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
