#!/usr/bin/env python3
"""Wait until the Sunshine API accepts authenticated requests.

Usage: scripts/remote-sunshine-wait <instance>
"""

from __future__ import annotations

import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    has_package,
    instance_ip,
    repo_root,
    resolve_env,
    sunshine_config_curl_command,
    validate_unix_user,
)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/remote-sunshine-wait <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    resolved = resolve_env(root, profile)
    ssh_user = resolved.get("SSH_USER", "")
    vm_user_name = resolved.get("VM_USER_NAME", "")
    sunshine_user = vm_user_name or ssh_user
    validate_unix_user(sunshine_user, "remote-sunshine-wait")
    if not has_package(resolved, "sunshine"):
        print("sunshine not in bundle — skipping")
        return 0

    ip = instance_ip(root, profile)
    max_attempts = 20
    print(f"Waiting for Sunshine API on {ip}:47990...")
    for attempt in range(1, max_attempts + 1):
        result = subprocess.run(
            sunshine_config_curl_command(ip), capture_output=True, text=True, check=False,
        )
        http_code = result.stdout
        if http_code.startswith("2"):
            print(f"Sunshine API is ready on {ip}:47990")
            return 0
        print(
            f"Sunshine API not ready yet (attempt {attempt}/{max_attempts}, "
            f"http={http_code}). Sleeping 2 seconds..."
        )
        time.sleep(2)

    print("Sunshine API did not become ready in time.")
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
