#!/usr/bin/env bash
# Poll the remote until provisioning has finished. Survives reboots that the
# provisioning state machine triggers between steps (SSH probes simply fail
# while the VM is rebooting and we retry on the next interval).
#
# Usage: scripts/wait-for-provision <profile> [max-wait-seconds]

set -euo pipefail

PROFILE="${1:?Usage: scripts/wait-for-provision <profile> [max-wait-seconds]}"
MAX_SECONDS=${2:-3600}
POLL_INTERVAL=${EGAME_PROVISION_WAIT_POLL_INTERVAL:-5}
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
OS_FAMILY=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^OS_FAMILY=/{print $2}')

# Each probe returns two lines:
#   line 1: DONE | RUNNING | FAILED | MISSING
#   line 2: latest "Running step ..." line from the log (or empty)
#
# DONE requires "Provisioning complete." to appear AFTER the most recent
# "Running step" line — `provision` (without clear-state) doesn't wipe the log
# file, so a stale completion marker from a prior run can otherwise short-
# circuit the wait while a new run is mid-flight.
case "$OS_FAMILY" in
  ubuntu)
    # shellcheck disable=SC2016 # $log/$HOME are expanded by the remote shell.
    PROBE='log="$HOME/provision/logs/provision.log"; if [ ! -f "$log" ]; then echo MISSING; exit 0; fi; last_step=$(awk "/Running step / {n=NR} END {print n+0}" "$log"); last_done=$(awk "/Provisioning complete\\./ {n=NR} END {print n+0}" "$log"); last_error=$(awk "/ERROR: step / {n=NR} END {print n+0}" "$log"); if [ "$last_done" -gt "$last_step" ] && [ "$last_done" -gt 0 ]; then echo DONE; elif [ "$last_error" -gt "$last_step" ] && [ "$last_error" -gt "$last_done" ]; then echo FAILED; else echo RUNNING; fi; grep -E "Running step |ERROR: step " "$log" | tail -n 1 || true'
    ;;
  windows)
    # shellcheck disable=SC2016 # $log/$lines/$lastStep/$lastDone are remote PowerShell vars.
    PROBE='$log = "C:\Users\Administrator\provision\logs\provision.log"; if (-not (Test-Path $log)) { "MISSING"; exit 0 }; $lines = Get-Content $log; $lastStep = -1; $lastDone = -1; $lastError = -1; for ($i = 0; $i -lt $lines.Count; $i++) { if ($lines[$i] -match "Running step ") { $lastStep = $i }; if ($lines[$i] -match "Provisioning complete\.") { $lastDone = $i }; if ($lines[$i] -match "ERROR: step ") { $lastError = $i } }; if ($lastDone -gt $lastStep -and $lastDone -ge 0) { "DONE" } elseif ($lastError -gt $lastStep -and $lastError -gt $lastDone) { "FAILED" } else { "RUNNING" }; $last = $lines | Select-String -Pattern "Running step|ERROR: step" | Select-Object -Last 1; if ($last) { $last.Line }'
    ;;
  *)
    echo "wait-for-provision: unknown os_family: $OS_FAMILY" >&2
    exit 2
    ;;
esac

# Strip leading timestamp ("YYYY-MM-DD HH:MM:SS ") and the redundant
# "Running step " prefix from a log line, leaving e.g. "[11/12] rustdesk.ps1".
clean_step() { sed -E -e 's/^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9:]+ //' -e 's/^Running step //'; }

SECONDS=0
last_step="(none yet)"
interactive_output=0
if [ -t 1 ]; then
  interactive_output=1
fi

print_status() {
  if [ "$interactive_output" -eq 1 ]; then
    printf "\r[%ds/%ds] %s — last step: %s                                                       " \
      "$SECONDS" "$MAX_SECONDS" "$1" "$last_step"
  else
    printf "[%ds/%ds] %s — last step: %s\n" \
      "$SECONDS" "$MAX_SECONDS" "$1" "$last_step"
  fi
}

while [ "$SECONDS" -lt "$MAX_SECONDS" ]; do
  if [ "$interactive_output" -eq 1 ]; then
    print_status "probing"
  fi
  if result=$(./scripts/instance-ssh "$PROFILE" -- "$PROBE" 2>/dev/null); then
    state=$(printf '%s\n' "$result" | sed -n '1p' | tr -d '\r')
    step_line=$(printf '%s\n' "$result" | sed -n '2p' | tr -d '\r')
    if [ -n "$step_line" ]; then
      last_step=$(printf '%s' "$step_line" | clean_step)
    fi
    if [ "$state" = "DONE" ]; then
      if [ "$interactive_output" -eq 1 ]; then
        printf "\rProvisioning complete for profile %s (%ds, last step: %s)                                       \n" "$PROFILE" "$SECONDS" "$last_step"
      else
        printf "Provisioning complete for profile %s (%ds, last step: %s)\n" "$PROFILE" "$SECONDS" "$last_step"
      fi
      exit 0
    fi
    if [ "$state" = "FAILED" ]; then
      printf "\n"
      echo "Provisioning failed for profile $PROFILE (${SECONDS}s)" >&2
      echo "Last seen step: $last_step" >&2
      exit 1
    fi
    print_status "connected"
  else
    print_status "waiting for SSH (reboot in progress?)"
  fi
  sleep "$POLL_INTERVAL"
done

printf "\n"
echo "Provisioning did not finish in time for profile $PROFILE (${MAX_SECONDS}s)" >&2
echo "Last seen step: $last_step" >&2
exit 1
