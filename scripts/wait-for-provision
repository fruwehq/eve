#!/usr/bin/env python3
"""Poll the remote until provisioning has finished. Survives reboots that the
provisioning state machine triggers between steps (SSH probes simply fail while
the VM is rebooting and we retry on the next interval).

Usage: scripts/wait-for-provision <instance> [max-wait-seconds]
"""

from __future__ import annotations

import os
import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.provision_pollers import (  # noqa: E402
    build_log_probe,
    build_status_probe,
    classify_status_json,
    clean_step,
    parse_probe_result,
)
from eve_sdk.remote_launch import repo_root, resolve_env  # noqa: E402


def _elapsed(start: float) -> int:
    """Integer wall-clock seconds since ``start`` (mirrors bash ``SECONDS``)."""
    return int(time.monotonic() - start)


def _print_status(secs: int, max_seconds: int, msg: str, last_step: str, interactive: bool) -> None:
    """Mirror the bash ``print_status``: ``\\r`` countdown (interactive) or ``\\n`` line."""
    if interactive:
        sys.stdout.write(
            f"\r[{secs}/{max_seconds}s] {msg} — last step: {last_step}" + " " * 55
        )
        sys.stdout.flush()
    else:
        sys.stdout.write(f"[{secs}/{max_seconds}s] {msg} — last step: {last_step}\n")


def _complete_status(secs: int, profile: str, progress: str, last_step: str, interactive: bool) -> None:
    if interactive:
        sys.stdout.write(
            f"\rProvisioning complete for profile {profile} ({secs}s, {progress}, last step: {last_step})"
            + " " * 39 + "\n"
        )
    else:
        sys.stdout.write(
            f"Provisioning complete for profile {profile} ({secs}s, {progress}, last step: {last_step})\n"
        )


def _complete_log(secs: int, profile: str, last_step: str, interactive: bool) -> None:
    if interactive:
        sys.stdout.write(
            f"\rProvisioning complete for profile {profile} ({secs}s, last step: {last_step})"
            + " " * 39 + "\n"
        )
    else:
        sys.stdout.write(
            f"Provisioning complete for profile {profile} ({secs}s, last step: {last_step})\n"
        )


def main(argv: list[str]) -> int:
    if not argv:
        print("Usage: scripts/wait-for-provision <instance> [max-wait-seconds]", file=sys.stderr)
        return 2
    profile = argv[0]
    max_seconds = int(argv[1]) if len(argv) > 1 else 3600
    poll_interval = int(os.environ.get("EVE_PROVISION_WAIT_POLL_INTERVAL", "5"))
    root = repo_root()
    os_family = resolve_env(root, profile).get("OS_FAMILY", "")

    if os_family not in ("ubuntu", "windows"):
        print(f"wait-for-provision: unknown os_family: {os_family}", file=sys.stderr)
        return 2

    instance_ssh = str(root / "scripts/instance-ssh")
    probe_script = os.environ.get("EVE_WAIT_FOR_PROVISION_PROBE_SCRIPT", "")
    interactive = sys.stdout.isatty()

    def run_status_probe() -> subprocess.CompletedProcess[str]:
        if probe_script:
            return subprocess.run(
                [probe_script, os_family, "status"],
                text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
            )
        return subprocess.run(
            [instance_ssh, profile, "--", build_status_probe(os_family)],
            cwd=root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
        )

    def run_log_probe(offset: int) -> subprocess.CompletedProcess[str]:
        if probe_script:
            return subprocess.run(
                [probe_script, os_family, str(offset)],
                text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
            )
        return subprocess.run(
            [instance_ssh, profile, "--", build_log_probe(os_family, offset)],
            cwd=root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=False,
        )

    start = time.monotonic()
    last_step = "(none yet)"
    log_offset = 0

    while _elapsed(start) < max_seconds:
        if interactive:
            _print_status(_elapsed(start), max_seconds, "probing", last_step, interactive)

        used_status_file = False
        status_cp = run_status_probe()
        if status_cp.returncode == 0:
            status_raw = status_cp.stdout.replace("\r", "")
            status_result = classify_status_json(status_raw)
            parts = status_result.split("\t")
            status_step = parts[1] if len(parts) > 1 else ""
            status_progress = parts[2] if len(parts) > 2 else ""

            if status_result.startswith("MALFORMED"):
                sys.stdout.write("\n")
                print(
                    "Provision status file exists but is malformed. Refusing to silently ignore.",
                    file=sys.stderr,
                )
                print(
                    "Run: scripts/instance-ssh " + profile + " -- "
                    "'cat ~/provision/state/provision-status.json' "
                    "(or C:\\Users\\Administrator\\...)",
                    file=sys.stderr,
                )
                return 1
            if status_result.startswith("NOT_PRESENT"):
                used_status_file = False
            elif status_result.startswith("DONE"):
                if status_step:
                    last_step = status_step
                _complete_status(_elapsed(start), profile, status_progress, last_step, interactive)
                return 0
            elif status_result.startswith("FAILED"):
                sys.stdout.write("\n")
                print(
                    f"Provisioning failed for profile {profile} "
                    f"({_elapsed(start)}s, {status_progress})",
                    file=sys.stderr,
                )
                if status_step:
                    print(f"Failed step: {status_step}", file=sys.stderr)
                return 1
            elif status_result.startswith("RUNNING"):
                used_status_file = True
                if status_step:
                    last_step = status_step
                _print_status(
                    _elapsed(start), max_seconds, f"connected [{status_progress}]", last_step, interactive
                )

        if not used_status_file:
            probe_cp = run_log_probe(log_offset)
            if probe_cp.returncode == 0:
                result = probe_cp.stdout.replace("\r", "")
                parsed = parse_probe_result(result)
                if parsed.step_line:
                    last_step = clean_step(parsed.step_line)
                if parsed.line_count is not None and parsed.line_count >= 0:
                    log_offset = parsed.line_count
                if parsed.new_log:
                    if interactive:
                        sys.stdout.write("\n")
                    sys.stdout.write(parsed.new_log + "\n")
                if parsed.state == "DONE":
                    _complete_log(_elapsed(start), profile, last_step, interactive)
                    return 0
                if parsed.state == "FAILED":
                    sys.stdout.write("\n")
                    print(
                        f"Provisioning failed for profile {profile} ({_elapsed(start)}s)",
                        file=sys.stderr,
                    )
                    print(f"Last seen step: {last_step}", file=sys.stderr)
                    return 1
                _print_status(_elapsed(start), max_seconds, "connected", last_step, interactive)
            else:
                _print_status(
                    _elapsed(start), max_seconds, "waiting for SSH (reboot in progress?)",
                    last_step, interactive,
                )

        time.sleep(poll_interval)

    sys.stdout.write("\n")
    print(
        f"Provisioning did not finish in time for profile {profile} ({max_seconds}s)",
        file=sys.stderr,
    )
    print(f"Last seen step: {last_step}", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
