#!/usr/bin/env python3
"""Synchronize external plugin repositories into .eve/plugins."""

from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir  # noqa: E402


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(
        prog="scripts/plugins-sync",
        description="Synchronize external plugin repositories into .eve/plugins.",
    )
    arg_parser.add_argument("--sources", default=str(Workdir.plugin_sources_path()))
    arg_parser.add_argument("--dest", default=str(Workdir.plugins_dir()))
    return arg_parser


def load_sources(path: Path) -> list[dict[str, str]]:
    if not path.exists():
        print(f"No plugin sources configured: {path}")
        raise SystemExit(0)
    doc = yaml.safe_load(path.read_text(encoding="utf-8"))
    if not isinstance(doc, dict):
        print("plugins-sync: sources file must be a map", file=sys.stderr)
        raise SystemExit(2)
    sources = doc.get("sources") or []
    if not isinstance(sources, list):
        print("plugins-sync: sources must be a list", file=sys.stderr)
        raise SystemExit(2)

    normalized = []
    for index, source in enumerate(sources, start=1):
        if not isinstance(source, dict):
            print(f"plugins-sync: source {index} must be a map", file=sys.stderr)
            raise SystemExit(2)
        normalized.append(validate_source(index, source))
    return normalized


def validate_source(index: int, source: dict[str, Any]) -> dict[str, str]:
    plugin_id = source.get("id")
    url = source.get("url")
    ref = source.get("ref") or ""
    if not all(isinstance(value, str) for value in [plugin_id, url, ref]):
        print(f"plugins-sync: source {index} id, url, and ref must be strings", file=sys.stderr)
        raise SystemExit(2)
    if not re.fullmatch(r"[a-z][a-z0-9-]*", plugin_id) or not url:
        print(
            f"plugins-sync: source {index} needs id matching [a-z][a-z0-9-]* and non-empty url",
            file=sys.stderr,
        )
        raise SystemExit(2)
    if not ref and os.environ.get("EVE_ALLOW_UNPINNED_PLUGINS") != "1":
        print(
            f"plugins-sync: source {plugin_id} is missing ref; set EVE_ALLOW_UNPINNED_PLUGINS=1 to allow this",
            file=sys.stderr,
        )
        raise SystemExit(1)
    return {"id": plugin_id, "url": url, "ref": ref}


def run_checked(*cmd: str) -> None:
    result = subprocess.run(cmd, cwd=ROOT, check=False)
    if result.returncode != 0:
        raise SystemExit(result.returncode)


def main() -> int:
    args = parser().parse_args()
    sources_path = Path(args.sources).expanduser().resolve()
    dest_root = Path(args.dest).expanduser().resolve()
    sources = load_sources(sources_path)

    for source in sources:
        dest = dest_root / source["id"]
        dest_root.mkdir(parents=True, exist_ok=True)
        if (dest / ".git").is_dir():
            run_checked("git", "-C", str(dest), "fetch", "--tags", "--prune")
        else:
            run_checked("git", "clone", source["url"], str(dest))
        if source["ref"]:
            run_checked("git", "-C", str(dest), "checkout", source["ref"])

    print(f"Plugin sources synchronized: {len(sources)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
