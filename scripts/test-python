#!/usr/bin/env python3
"""Run strict Python linting and type checks."""

from __future__ import annotations

import subprocess
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    cache_dir = tempfile.mkdtemp(prefix="eve-python-cache.")
    try:
        # Select Python scripts by shebang (same logic as the bash version).
        python_scripts = sorted(
            str(p)
            for p in (ROOT / "scripts").iterdir()
            if p.is_file() and p.read_text(encoding="utf-8", errors="replace").startswith("#!/usr/bin/env python3")
        )

        env_ruff = {"RUFF_CACHE_DIR": f"{cache_dir}/ruff", "PATH": __import__("os").environ["PATH"]}
        code = subprocess.run(
            ["poetry", "run", "ruff", "check", "eve_sdk", *python_scripts],
            cwd=str(ROOT), env={**__import__("os").environ, **env_ruff}, check=False,
        ).returncode
        if code != 0:
            return code

        env_mypy = {"MYPY_CACHE_DIR": f"{cache_dir}/mypy", "PATH": __import__("os").environ["PATH"]}
        code = subprocess.run(
            ["poetry", "run", "mypy", "scripts/eve-tui"],
            cwd=str(ROOT), env={**__import__("os").environ, **env_mypy}, check=False,
        ).returncode
        if code != 0:
            return code

        code = subprocess.run(
            ["poetry", "run", "pytest", "tests/python"],
            cwd=str(ROOT), check=False,
        ).returncode
        if code != 0:
            return code

        print("  [OK] python lint, type checks, and tests pass")
        return 0
    finally:
        import shutil
        shutil.rmtree(cache_dir, ignore_errors=True)


if __name__ == "__main__":
    raise SystemExit(main())
