#!/usr/bin/env bash
# Run strict Python linting and type checks.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

cache_dir="$(mktemp -d "${TMPDIR:-/tmp}/egame-python-cache.XXXXXX")"
trap 'rm -rf "$cache_dir"' EXIT

RUFF_CACHE_DIR="$cache_dir/ruff" poetry run ruff check scripts/egame-tui
MYPY_CACHE_DIR="$cache_dir/mypy" poetry run mypy scripts/egame-tui

printf '  [OK] python lint and type checks pass\n'
