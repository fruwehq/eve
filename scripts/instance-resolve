#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.resolve import default_registry_path, emit_env, resolve_instance  # noqa: E402


def usage() -> None:
    print(
        "Usage:\n  scripts/instance-resolve --instance <name> [--emit env|json] [--validate] [--registry <path>]",
        file=sys.stderr,
    )


def main(argv: list[str]) -> int:
    instance_name: str | None = None
    emit: str | None = None
    validate = False
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else str(default_registry_path())

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--emit" and args:
            emit = args.pop(0)
        elif arg == "--validate":
            validate = True
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg in {"-h", "--help"}:
            usage()
            return 0
        else:
            usage()
            return 2

    if not instance_name:
        usage()
        return 2

    try:
        resolved = resolve_instance(instance_name, registry_path)
        if validate:
            print(f"Instance validated: {instance_name}")
        if emit is None:
            return 0
        if emit == "json":
            print(json.dumps(resolved, separators=(",", ":")))
            return 0
        if emit == "env":
            print(emit_env(resolved), end="")
            return 0
        print(f"Unsupported --emit format: {emit}", file=sys.stderr)
        return 2
    except Exception as error:
        print(f"instance-resolve: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
