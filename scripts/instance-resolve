#!/usr/bin/env ruby
# Resolve a concrete local VM instance from the instance registry plus catalog.

require "json"
require "yaml"

ROOT = File.expand_path("..", __dir__)
CATALOG_PATH = File.join(ROOT, "config/catalog.yaml")
LOCAL_CATALOG_PATH = File.join(ROOT, "config/catalog.local.yaml")
DEFAULT_REGISTRY_PATH = File.join(ROOT, ".egame/instances.yaml")

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-resolve --instance <name> [--emit env|json] [--validate] [--registry <path>]
  USAGE
end

def load_any(path)
  return {} unless File.exist?(path)

  case File.extname(path).downcase
  when ".json"
    JSON.parse(File.read(path))
  else
    YAML.safe_load(File.read(path), permitted_classes: [], aliases: true) || {}
  end
end

def deep_merge(left, right)
  return right if left.nil?
  return left if right.nil?

  if left.is_a?(Hash) && right.is_a?(Hash)
    left.merge(right) { |_key, a, b| deep_merge(a, b) }
  else
    right
  end
end

def merge_by_key(base_arr, over_arr, key)
  out = (base_arr || []).map(&:dup)
  (over_arr || []).each do |entry|
    next unless entry.is_a?(Hash)

    idx = out.index { |candidate| candidate.is_a?(Hash) && candidate[key] == entry[key] }
    if idx
      out[idx] = deep_merge(out[idx], entry)
    else
      out << entry
    end
  end
  out
end

def load_catalog
  base = load_any(CATALOG_PATH)
  over = load_any(LOCAL_CATALOG_PATH)
  merged = deep_merge(base, over)

  %w[machines oses inits packages bundles locations profiles recipes].each do |section|
    key = case section
          when "oses", "inits", "packages", "bundles" then "id"
          else "name"
          end
    merged[section] = merge_by_key(base[section], over[section], key)
  end

  merged
end

def by_key(root, section, key, value)
  (root[section] || []).find { |entry| entry.is_a?(Hash) && entry[key] == value }
end

def env_or(name, fallback)
  value = ENV[name]
  value && !value.empty? ? value : fallback
end

def find_recipe(catalog, name)
  by_key(catalog, "recipes", "name", name) || by_key(catalog, "profiles", "name", name)
end

def resolve_bundle_packages(catalog, bundle_ids)
  bundle_ids.flat_map do |bundle_id|
    bundle = by_key(catalog, "bundles", "id", bundle_id)
    raise "Bundle not found: #{bundle_id}" unless bundle

    bundle["includes"] || []
  end.uniq.sort
end

def validate!(catalog, composition, machine, os, init, location, bundle_packages)
  raise "Machine not found: #{composition["machine"]}" unless machine
  raise "OS not found: #{composition["os"]}" unless os
  raise "Init not found: #{composition["init"]}" unless init
  raise "Location not found: #{composition["location"]}" unless location

  if init["os_family"] && init["os_family"] != os["family"]
    raise "Init/OS mismatch: init #{init["id"]} expects #{init["os_family"]}, got #{os["family"]}"
  end

  if init["provider"] && init["provider"] != machine["provider"]
    raise "Init/provider mismatch: init #{init["id"]} expects #{init["provider"]}, got #{machine["provider"]}"
  end

  package_catalog = (catalog["packages"] || []).map { |pkg| pkg["id"] }
  unknown_package = bundle_packages.find { |pkg| !package_catalog.include?(pkg) }
  raise "Bundle references unknown package id: #{unknown_package}" if unknown_package

  if bundle_packages.include?("steam") && os["ui_mode"] != "desktop"
    raise "Compatibility: steam requires desktop UI mode"
  end

  if bundle_packages.include?("sunshine") && os["ui_mode"] != "desktop"
    raise "Compatibility: sunshine requires desktop UI mode"
  end

  if bundle_packages.include?("codex-cli") && !bundle_packages.include?("dev-toolchain")
    raise "Compatibility: codex-cli requires dev-toolchain in bundles"
  end

  if bundle_packages.include?("goose") && !bundle_packages.include?("dev-toolchain")
    raise "Compatibility: goose requires dev-toolchain in bundles"
  end

  supported = %w[aws local-virtualbox local-vmware raspberry-pi truenas vultr]
  provider = machine["provider"]
  raise "Unsupported provider in machine catalog: #{provider}" unless supported.include?(provider)
  raise "Location #{location["name"]} has no mapping for provider #{provider}" unless location[provider]
end

def emit_env(resolved)
  provider = resolved.dig("machine", "provider")
  locp = resolved.dig("location", provider) || {}
  os = resolved["os"]
  machine_defaults = resolved.dig("machine", "defaults") || {}

  lines = {
    "INSTANCE_NAME" => resolved.dig("instance", "name"),
    "RECIPE_NAME" => resolved["recipe_name"] || "",
    "PROFILE_NAME" => resolved.dig("instance", "name"),
    "ENGINE" => resolved["engine"],
    "PROVIDER" => provider,
    "STACK_TAGS" => resolved["stack_tags"],
    "LOCATION_NAME" => resolved.dig("location", "name"),
    "OS_ID" => os["id"],
    "OS_FAMILY" => os["family"],
    "OS_UI_MODE" => os["ui_mode"],
    "INIT_ID" => resolved.dig("init", "id"),
    "BUNDLE_PACKAGES" => resolved["bundle_packages"].join(","),
    "VM_MEMORY_MB" => (machine_defaults["memory_mb"] || 0).to_s,
    "VM_CPU_CORES" => (machine_defaults["cpu_cores"] || machine_defaults["cpus"] || 0).to_s,
    "VM_CPU_MODE" => (machine_defaults["cpu_mode"] || ""),
    "VM_VCPUS" => (machine_defaults["vcpus"] || 1).to_s,
    "VM_AUTOSTART" => (machine_defaults.fetch("autostart", true)).to_s,
    "VM_STATE" => (machine_defaults["state"] || "STOPPED"),
    "VM_NIC_ATTACH" => (machine_defaults["network"] || locp["bridge"] || "br0"),
    "VM_DISK_GB" => (machine_defaults["disk_gb"] || 30).to_s,
    "VM_POOL" => (machine_defaults["pool"] || locp["pool"] || "main"),
    "VM_PLAN" => (machine_defaults["plan"] || ""),
    "VM_INSTANCE_TYPE" => (machine_defaults["instance_type"] || ""),
    "VM_ROOT_VOLUME_TYPE" => (machine_defaults["root_volume_type"] || ""),
    "VULTR_OS_ID" => (os["vultr_os_id"] || 0).to_s,
    "LOCATION_REGION" => (locp["region"] || ""),
    "LOCATION_AVAILABILITY_ZONE" => (locp["availability_zone"] || ""),
    "SSH_USER" => if os["family"] == "windows"
                    "Administrator"
                  elsif provider == "raspberry-pi"
                    env_or("VM_USER_NAME", "")
                  else
                    "ubuntu"
                  end,
    "CLOUD_IMAGE_URL" => (os["cloud_image_url"] || ""),
    "RASPBERRY_PI_HOST" => env_or("RASPBERRY_PI_HOST", locp["host"] || ""),
    "TRUENAS_HOST" => env_or("TRUENAS_HOST", locp["host"] || ""),
    "TRUENAS_SSH_PORT" => env_or("TRUENAS_SSH_PORT", (locp["ssh_port"] || 22).to_s),
    "TRUENAS_SSH_USER" => env_or("TRUENAS_SSH_USER", locp["ssh_user"] || ""),
    "VM_USER_NAME" => env_or("VM_USER_NAME", "")
  }

  lines.each { |key, value| puts "#{key}=#{value}" }
end

instance_name = nil
emit = nil
validate = false
registry_path = DEFAULT_REGISTRY_PATH

args = ARGV.dup
until args.empty?
  case args.shift
  when "--instance"
    instance_name = args.shift
  when "--emit"
    emit = args.shift
  when "--validate"
    validate = true
  when "--registry"
    registry_path = File.expand_path(args.shift, Dir.pwd)
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless instance_name
  usage
  exit 2
end

begin
  catalog = load_catalog
  registry = load_any(registry_path)
  instance = (registry["instances"] || []).find { |entry| entry["name"] == instance_name }
  raise "Instance not found: #{instance_name} (registry: #{registry_path})" unless instance

  recipe_name = instance["recipe"]
  recipe = recipe_name ? find_recipe(catalog, recipe_name) : {}
  raise "Recipe not found: #{recipe_name}" if recipe_name && !recipe

  instance_overrides = instance.reject do |key, _value|
    %w[name recipe overrides created_at updated_at state].include?(key)
  end
  composition = deep_merge(recipe || {}, instance_overrides)
  composition["name"] = instance["name"]

  machine = by_key(catalog, "machines", "name", composition["machine"])
  os = by_key(catalog, "oses", "id", composition["os"])
  init = by_key(catalog, "inits", "id", composition["init"])
  location = by_key(catalog, "locations", "name", composition["location"])

  machine = deep_merge(machine, {
    "defaults" => deep_merge(machine&.fetch("defaults", nil) || {}, instance["overrides"] || {})
  })

  bundle_packages = (resolve_bundle_packages(catalog, composition["bundles"] || []) + (composition["packages"] || [])).uniq.sort
  validate!(catalog, composition, machine, os, init, location, bundle_packages)

  provider = machine["provider"]
  engine = if machine["kind"] == "metal"
             "metal"
           elsif provider.start_with?("local-")
             "vagrant"
           else
             "terraform"
           end
  resolved = {
    "instance" => instance,
    "recipe_name" => recipe_name,
    "recipe" => recipe,
    "composition" => composition,
    "machine" => machine,
    "os" => os,
    "init" => init,
    "location" => location,
    "bundle_packages" => bundle_packages,
    "provider_plugin" => provider,
    "package_plugins" => bundle_packages.map { |package_id| { "id" => package_id, "plugin" => package_id } },
    "engine" => engine,
    "stack_tags" => "instance-#{instance["name"]}"
  }

  puts "Instance validated: #{instance_name}" if validate

  case emit
  when nil
    exit 0
  when "json"
    puts JSON.generate(resolved)
  when "env"
    emit_env(resolved)
  else
    warn "Unsupported --emit format: #{emit}"
    exit 2
  end
rescue StandardError => e
  warn "instance-resolve: #{e.message}"
  exit 1
end
