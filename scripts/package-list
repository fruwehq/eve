#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import run_json, support_allowed  # noqa: E402
from eve_sdk.workdir import Workdir  # noqa: E402


def usage() -> None:
    print("Usage:\n  scripts/package-list --instance <name> [--registry <path>] [--json]", file=sys.stderr)


def compatibility_target(os_family: str, package_ids: list[str]) -> dict[str, str]:
    if os_family == "windows":
        return {"platform": "windows", "desktop": "Windows", "session": "Native"}
    if os_family == "ubuntu" and "gnome-desktop-headless" in package_ids:
        return {"platform": "ubuntu", "desktop": "GNOME Headless", "session": "Wayland"}
    if os_family == "ubuntu" and "gnome-desktop" in package_ids:
        return {"platform": "ubuntu", "desktop": "GNOME", "session": "Wayland"}
    if os_family == "ubuntu" and "kde-desktop-headless" in package_ids:
        return {"platform": "ubuntu", "desktop": "KDE Plasma Headless", "session": "Wayland"}
    if os_family == "ubuntu" and "kde-desktop" in package_ids:
        return {"platform": "ubuntu", "desktop": "KDE Plasma", "session": "Wayland"}
    if os_family == "ubuntu" and "xfce-desktop-headless" in package_ids:
        return {"platform": "ubuntu", "desktop": "XFCE Headless", "session": "X11"}
    if os_family == "ubuntu":
        return {"platform": "ubuntu", "desktop": "XFCE", "session": "X11"}
    return {"platform": os_family, "desktop": "", "session": ""}


def compatibility_match(plugin: dict[str, Any], target: dict[str, str]) -> bool:
    entries = plugin.get("compatibility") if isinstance(plugin.get("compatibility"), list) else []
    if plugin.get("compatibility_enforced") is not True:
        return True
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        if entry.get("status") != "supported":
            continue
        if entry.get("platform") != target["platform"]:
            continue
        if str(entry.get("desktop") or "") and entry.get("desktop") != target["desktop"]:
            continue
        if str(entry.get("session") or "") and entry.get("session") != target["session"]:
            continue
        return True
    return False


def parse_args(argv: list[str]) -> tuple[str, str | None, bool]:
    instance_name: str | None = None
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else None
    emit_json = False
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg == "--json":
            emit_json = True
        elif arg in {"-h", "--help"}:
            usage()
            raise SystemExit(0)
        else:
            usage()
            raise SystemExit(2)
    if not instance_name:
        usage()
        raise SystemExit(2)
    return instance_name, registry_path, emit_json


def build_packages(instance_name: str, registry_path: str | None) -> tuple[str, list[dict[str, Any]]]:
    resolve_cmd = [str(Workdir.repo_root() / "scripts/instance-resolve"), "--instance", instance_name, "--emit", "json"]
    if registry_path:
        resolve_cmd.extend(["--registry", registry_path])
    resolved = run_json(*resolve_cmd)
    plugin_doc = run_json(str(Workdir.repo_root() / "scripts/plugin-list"), "--kind", "package", "--json")
    plugins = plugin_doc["plugins"]
    plugin_by_id = {plugin["id"]: plugin for plugin in plugins}
    selected_ids = resolved["bundle_packages"]
    package_sources = resolved.get("package_sources", {})
    os_doc = resolved["os"]
    os_family = os_doc["family"]
    os_arch = os_doc.get("arch", "")
    os_version = os_doc.get("version", "")
    target = compatibility_target(os_family, selected_ids)

    packages: list[dict[str, Any]] = []
    for plugin in sorted(plugins, key=lambda entry: entry["id"]):
        supports = plugin.get("supports") or {}
        supported = (
            support_allowed(supports, "os_families", os_family)
            and support_allowed(supports, "arches", os_arch)
            and support_allowed(supports, "os_ids", os_doc["id"])
            and support_allowed(supports, "os_versions", os_version)
            and support_allowed(supports, f"{os_family}_versions", os_version)
        )
        install = plugin.get("install") if isinstance(plugin.get("install"), dict) else {}
        installable = isinstance(install.get(os_family), dict)
        actions = plugin.get("actions", [])
        conflicts = plugin.get("conflicts_with") if isinstance(plugin.get("conflicts_with"), list) else []
        conflict = next((package for package in conflicts if package in selected_ids), None)
        if conflict or not compatibility_match(plugin, target):
            supported = False
            installable = False
            actions = []
        packages.append(
            {
                "id": plugin["id"],
                "display_name": plugin["display_name"],
                "plugin": plugin["id"],
                "selected": plugin["id"] in selected_ids,
                "selected_by": package_sources.get(plugin["id"], []),
                "supported": supported,
                "installable": installable,
                "source": plugin["source"],
                "path": plugin["path"],
                "actions": actions,
            }
        )

    for package_id in selected_ids:
        if package_id in plugin_by_id:
            continue
        packages.append(
            {
                "id": package_id,
                "display_name": package_id,
                "plugin": None,
                "selected": True,
                "selected_by": package_sources.get(package_id, []),
                "supported": False,
                "source": "missing",
                "path": None,
                "actions": [],
            }
        )
    return os_family, packages


def main(argv: list[str]) -> int:
    instance_name, registry_path, emit_json = parse_args(argv)
    try:
        os_family, packages = build_packages(instance_name, registry_path)
    except Exception as error:
        print(f"package-list: {error}", file=sys.stderr)
        return 1
    if emit_json:
        print(json.dumps({"instance": instance_name, "os_family": os_family, "packages": packages}, indent=2))
        return 0
    print(f"{'PACKAGE':<24} {'SELECTED':<8} {'SELECTED_BY':<22} {'SUPPORTED':<9} {'SOURCE':<10} DISPLAY")
    print(f"{'-------':<24} {'--------':<8} {'-----------':<22} {'---------':<9} {'------':<10} -------")
    for package in packages:
        print(
            f"{package['id']:<24} "
            f"{'yes' if package['selected'] else 'no':<8} "
            f"{','.join(package['selected_by']):<22} "
            f"{'yes' if package['supported'] else 'no':<9} "
            f"{package['source']:<10} "
            f"{package['display_name']}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
