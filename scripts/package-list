#!/usr/bin/env python3
"""List package plugins available to an instance.

Cold entrypoint: parses fresh, then delegates the row assembly to the shared
``eve_sdk.instance_view.build_package_rows`` (the same function the warm Engine
uses), guaranteeing byte-identical output between cold and warm paths.
"""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.instance_view import build_package_rows  # noqa: E402
from eve_sdk.plugin_manifest import PluginManifest  # noqa: E402
from eve_sdk.resolve import resolve_instance  # noqa: E402


def usage() -> None:
    print("Usage:\n  scripts/package-list --instance <name> [--registry <path>] [--json]", file=sys.stderr)


def parse_args(argv: list[str]) -> tuple[str, str | None, bool]:
    instance_name: str | None = None
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else None
    emit_json = False
    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg == "--json":
            emit_json = True
        elif arg in {"-h", "--help"}:
            usage()
            raise SystemExit(0)
        else:
            usage()
            raise SystemExit(2)
    if not instance_name:
        usage()
        raise SystemExit(2)
    return instance_name, registry_path, emit_json


def build_packages(
    instance_name: str, registry_path: str | None
) -> tuple[str, list[dict[str, Any]]]:
    # Cold path: parse fresh for parity with the warm Engine (which passes its
    # memoized resolved + plugin set to the same build_package_rows()).
    registry = str(Path(registry_path).resolve()) if registry_path else None
    resolved = resolve_instance(instance_name, registry)
    packages = [PluginManifest.public(p) for p in PluginManifest.load_all("package")]
    return build_package_rows(resolved, packages)


def main(argv: list[str]) -> int:
    instance_name, registry_path, emit_json = parse_args(argv)
    try:
        os_family, packages = build_packages(instance_name, registry_path)
    except Exception as error:
        print(f"package-list: {error}", file=sys.stderr)
        return 1
    if emit_json:
        print(json.dumps({"instance": instance_name, "os_family": os_family, "packages": packages}, indent=2))
        return 0
    print(f"{'PACKAGE':<24} {'SELECTED':<8} {'SELECTED_BY':<22} {'SUPPORTED':<9} {'SOURCE':<10} DISPLAY")
    print(f"{'-------':<24} {'--------':<8} {'-----------':<22} {'---------':<9} {'------':<10} -------")
    for package in packages:
        print(
            f"{package['id']:<24} "
            f"{'yes' if package['selected'] else 'no':<8} "
            f"{','.join(package['selected_by']):<22} "
            f"{'yes' if package['supported'] else 'no':<9} "
            f"{package['source']:<10} "
            f"{package['display_name']}"
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
