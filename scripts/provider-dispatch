#!/usr/bin/env python3
"""Provider command dispatcher (instance-scoped + provider-level).

Thin cold wrapper around ``eve_sdk.provider_command.dispatch_instance_command``
and ``dispatch_provider_command`` — the same in-process orchestration the warm
Engine uses. This script parses fresh per invocation; the Engine passes its
memoized catalog/plugins so a multi-op session parses them exactly once.
"""

from __future__ import annotations

import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import desired_state_for, provider_state_for, record_provider_state  # noqa: E402
from eve_sdk.provider_command import (  # noqa: E402
    dispatch_instance_command,
    dispatch_provider_command,
)


def usage() -> None:
    print(
        """Usage:
  scripts/provider-dispatch --instance <name>   --command <command> [--registry <path>] [--dry-run] [-- <args...>]
  scripts/provider-dispatch --provider <id>     --command <command> [--dry-run] [-- <args...>]

Provider-level mode (--provider) skips instance resolution and dispatches
the named command directly to the provider plugin. Use it for bootstrap
actions like `login` that must run before any instance can be created.""",
        file=sys.stderr,
    )


def parse_args(argv: list[str]) -> tuple[str | None, str | None, str | None, str | None, bool, list[str]]:
    instance_name: str | None = None
    provider_name: str | None = None
    command: str | None = None
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else None
    dry_run = os.environ.get("EVE_PROVIDER_DRY_RUN") == "1"
    extra_args: list[str] = []

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--provider" and args:
            provider_name = args.pop(0)
        elif arg == "--command" and args:
            command = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg == "--dry-run":
            dry_run = True
        elif arg == "--":
            extra_args = args
            break
        elif arg in {"-h", "--help"}:
            usage()
            raise SystemExit(0)
        else:
            usage()
            raise SystemExit(2)

    if instance_name and provider_name:
        print("provider-dispatch: --instance and --provider are mutually exclusive", file=sys.stderr)
        raise SystemExit(2)
    if not (instance_name or provider_name) or not command:
        usage()
        raise SystemExit(2)
    return instance_name, provider_name, command, registry_path, dry_run, extra_args


def main(argv: list[str]) -> int:
    instance_name, provider_name, command, registry_path, dry_run, extra_args = parse_args(argv)
    try:
        if provider_name:
            dispatch_provider_command(
                provider_name, command or "", dry_run=dry_run, extra_args=extra_args
            )
            return 0
        return dispatch_instance_command(
            instance_name or "",
            command or "",
            registry_path=registry_path,
            dry_run=dry_run,
            extra_args=extra_args,
        )
    except Exception as error:
        if instance_name and not dry_run:
            try:
                record_provider_state(
                    instance_name,
                    command or "unknown",
                    "failed",
                    error=str(error),
                    desired_state=desired_state_for(command),
                    provider_state=provider_state_for(command, "failed"),
                )
            except Exception as state_error:
                print(f"provider-dispatch: failed to record failure state: {state_error}", file=sys.stderr)
        print(f"provider-dispatch: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
