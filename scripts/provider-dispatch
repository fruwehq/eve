#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import (  # noqa: E402
    DispatchError,
    command_vector,
    desired_state_for,
    exec_cmd,
    interactive_provider_command,
    load_plugin,
    prepare_overlay,
    provider_state_for,
    record_provider_state,
    resolve_instance,
    stream_command,
    validate_provider_output,
)
from eve_sdk.schema import validate_output  # noqa: E402


def usage() -> None:
    print(
        """Usage:
  scripts/provider-dispatch --instance <name>   --command <command> [--registry <path>] [--dry-run] [-- <args...>]
  scripts/provider-dispatch --provider <id>     --command <command> [--dry-run] [-- <args...>]

Provider-level mode (--provider) skips instance resolution and dispatches
the named command directly to the provider plugin. Use it for bootstrap
actions like `login` that must run before any instance can be created.""",
        file=sys.stderr,
    )


def parse_args(argv: list[str]) -> tuple[str | None, str | None, str | None, str | None, bool, list[str]]:
    instance_name: str | None = None
    provider_name: str | None = None
    command: str | None = None
    registry_path = os.environ.get("EVE_INSTANCE_REGISTRY")
    registry_path = str(Path(registry_path).resolve()) if registry_path else None
    dry_run = os.environ.get("EVE_PROVIDER_DRY_RUN") == "1"
    extra_args: list[str] = []

    args = list(argv)
    while args:
        arg = args.pop(0)
        if arg == "--instance" and args:
            instance_name = args.pop(0)
        elif arg == "--provider" and args:
            provider_name = args.pop(0)
        elif arg == "--command" and args:
            command = args.pop(0)
        elif arg == "--registry" and args:
            registry_path = str(Path(args.pop(0)).resolve())
        elif arg == "--dry-run":
            dry_run = True
        elif arg == "--":
            extra_args = args
            break
        elif arg in {"-h", "--help"}:
            usage()
            raise SystemExit(0)
        else:
            usage()
            raise SystemExit(2)

    if instance_name and provider_name:
        print("provider-dispatch: --instance and --provider are mutually exclusive", file=sys.stderr)
        raise SystemExit(2)
    if not (instance_name or provider_name) or not command:
        usage()
        raise SystemExit(2)
    return instance_name, provider_name, command, registry_path, dry_run, extra_args


def provider_level(provider_name: str, command: str, dry_run: bool, extra_args: list[str]) -> None:
    plugin = load_plugin("provider", provider_name)
    spec = plugin.get("commands", {}).get(command)
    if not isinstance(spec, dict):
        raise DispatchError(f"provider plugin {provider_name} has no command: {command}")
    cmd = command_vector(plugin, spec) + extra_args
    env = os.environ | {"EVE_PROVIDER_PLUGIN": provider_name}
    if dry_run:
        env["EVE_PLUGIN_DRY_RUN"] = "1"
        print(json.dumps({"kind": "provider", "provider": provider_name, "command": command, "dry_run": True}))
        return
    exec_cmd(cmd, env)


def instance_level(
    instance_name: str,
    command: str,
    registry_path: str | None,
    dry_run: bool,
    extra_args: list[str],
) -> int:
    resolved = resolve_instance(instance_name, registry_path)
    provider = resolved["machine"]["provider"]
    plugin = load_plugin("provider", provider)
    spec = plugin.get("commands", {}).get(command)
    if not isinstance(spec, dict):
        raise DispatchError(f"provider plugin {provider} has no command: {command}")
    cmd = command_vector(plugin, spec) + extra_args

    if dry_run:
        payload = {
            "kind": "provider",
            "provider": provider,
            "command": command,
            "instance": instance_name,
            "profile": instance_name,
            "engine": resolved["engine"],
            "dry_run": True,
        }
        validate_output(payload, "provider_command_output")
        print(json.dumps(payload, separators=(",", ":")))
        return 0

    overlay = prepare_overlay(instance_name, registry_path)
    env = os.environ | {
        "EVE_CATALOG_LOCAL": overlay,
        "EVE_INSTANCE_NAME": instance_name,
        "EVE_PROVIDER_PLUGIN": provider,
        "EVE_RESOLVED_JSON": json.dumps(resolved, separators=(",", ":")),
    }
    if registry_path:
        env["EVE_INSTANCE_REGISTRY"] = registry_path

    if interactive_provider_command(plugin, command):
        exec_cmd(cmd, env)

    desired_state = desired_state_for(command)
    record_provider_state(
        instance_name,
        command,
        "running",
        desired_state=desired_state,
        provider_state=provider_state_for(command, "running"),
    )

    exit_status, output = stream_command(cmd, env=env, stdin_text=json.dumps(resolved, separators=(",", ":")))
    if exit_status == 0:
        try:
            validate_provider_output(output)
        except Exception as error:
            record_provider_state(
                instance_name,
                command,
                "failed",
                error=f"invalid provider output: {error}",
                desired_state=desired_state,
                provider_state=provider_state_for(command, "failed"),
            )
            print(f"provider-dispatch: {error}", file=sys.stderr)
            return 1
        record_provider_state(
            instance_name,
            command,
            "succeeded",
            desired_state=desired_state,
            provider_state=provider_state_for(command, "succeeded"),
        )
    else:
        try:
            record_provider_state(
                instance_name,
                command,
                "failed",
                error=f"exit {exit_status}",
                desired_state=desired_state,
                provider_state=provider_state_for(command, "failed"),
            )
        except Exception as error:
            print(f"provider-dispatch: failed to record failure state: {error}", file=sys.stderr)
    return exit_status


def main(argv: list[str]) -> int:
    instance_name, provider_name, command, registry_path, dry_run, extra_args = parse_args(argv)
    try:
        if provider_name:
            provider_level(provider_name, command or "", dry_run, extra_args)
            return 0
        return instance_level(instance_name or "", command or "", registry_path, dry_run, extra_args)
    except Exception as error:
        if instance_name and not dry_run:
            try:
                record_provider_state(
                    instance_name,
                    command or "unknown",
                    "failed",
                    error=str(error),
                    desired_state=desired_state_for(command),
                    provider_state=provider_state_for(command, "failed"),
                )
            except Exception as state_error:
                print(f"provider-dispatch: failed to record failure state: {state_error}", file=sys.stderr)
        print(f"provider-dispatch: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
