#!/usr/bin/env python3
"""Validate JSON Schemas and their fixtures."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any

import yaml
from jsonschema import Draft202012Validator
from jsonschema.exceptions import SchemaError

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.workdir import Workdir  # noqa: E402

SCHEMA_DIR = ROOT / "core/schema"
FIXTURE_REGISTRY = ROOT / "tests/fixtures/instances.yaml"
OBSERVED_DIR = ROOT / "tests/fixtures/observed-state"
failures = 0


def pass_check(message: str) -> None:
    print(f"[OK]   {message}")


def fail_check(message: str) -> None:
    global failures
    print(f"[FAIL] {message}")
    failures += 1


def load_json(path: Path) -> Any:
    return json.loads(path.read_text(encoding="utf-8"))


def load_yaml(path: Path) -> Any:
    return yaml.safe_load(path.read_text(encoding="utf-8"))


def validator(schema_name: str) -> Draft202012Validator:
    schema = load_json(SCHEMA_DIR / schema_name)
    Draft202012Validator.check_schema(schema)
    return Draft202012Validator(schema)


def print_errors(errors: list[Any]) -> None:
    for error in errors:
        pointer = "/" + "/".join(str(part) for part in error.absolute_path)
        print(f"    {pointer if pointer != '/' else '/'}: {error.message}", file=sys.stderr)


def validate_data(schema_validator: Draft202012Validator, data: Any) -> bool:
    errors = sorted(schema_validator.iter_errors(data), key=lambda error: list(error.path))
    print_errors(errors)
    return not errors


def validate_negative(schema_validator: Draft202012Validator, data: Any) -> bool:
    return bool(list(schema_validator.iter_errors(data)))


print("\n== schemas: meta-validation ==")
for path in sorted(SCHEMA_DIR.glob("*.schema.json")):
    try:
        Draft202012Validator.check_schema(load_json(path))
    except SchemaError as error:
        fail_check(f"{path.name} meta-valid")
        print(f"    {error.message}", file=sys.stderr)
    else:
        pass_check(f"{path.name} meta-valid")

print("\n== schemas: resolved-instance ==")
resolved_validator = validator("resolved-instance.schema.json")
registry = load_yaml(FIXTURE_REGISTRY) or {}
for inst in registry.get("instances", []):
    name = inst["name"]
    label = f"resolved-instance: {name}"
    result = subprocess.run(
        [str(ROOT / "scripts/instance-resolve"), "--instance", name, "--emit", "json"],
        env=os.environ | {"EVE_INSTANCE_REGISTRY": str(FIXTURE_REGISTRY)},
        cwd=ROOT,
        text=True,
        capture_output=True,
        check=False,
    )
    if result.returncode != 0:
        fail_check(f"{label} (resolve failed)")
        continue
    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError as error:
        fail_check(f"{label} (JSON parse: {error})")
        continue
    pass_check(label) if validate_data(resolved_validator, data) else fail_check(label)

print("\n== schemas: plugin-manifest (shipped) ==")
manifest_validator = validator("plugin-manifest.schema.json")
shipped = 0
for path in sorted(ROOT.glob("plugins/*/*/eve-plugin.yaml")):
    rel = path.relative_to(ROOT / "plugins")
    shipped += 1
    if validate_data(manifest_validator, load_yaml(path)):
        pass_check(f"shipped: {rel}")
    else:
        fail_check(f"shipped: {rel}")
print(f"  ({shipped} shipped manifests checked)")

print("\n== schemas: plugin-manifest (fixture positive) ==")
for path in sorted(ROOT.glob("tests/fixtures/plugins/*/*/eve-plugin.yaml")):
    if path.parent.name.startswith("bad"):
        continue
    rel = path.relative_to(ROOT / "tests/fixtures/plugins")
    label = f"fixture+: {rel}"
    pass_check(label) if validate_data(manifest_validator, load_yaml(path)) else fail_check(label)

print("\n== schemas: plugin-manifest (negative) ==")
negative_paths = sorted(
    {
        *ROOT.glob("tests/fixtures/plugins/*/bad*/eve-plugin.yaml"),
        *ROOT.glob("tests/fixtures/plugins/*/*/bad*/eve-plugin.yaml"),
    }
)
for path in negative_paths:
    rel = path.relative_to(ROOT / "tests/fixtures/plugins")
    if validate_negative(manifest_validator, load_yaml(path)):
        pass_check(f"negative: {rel} (correctly rejected)")
    else:
        fail_check(f"negative: {rel} (should have failed validation)")

print("\n== schemas: observed-state (fixtures) ==")
observed_validator = validator("observed-state.schema.json")
if OBSERVED_DIR.is_dir():
    for path in sorted(OBSERVED_DIR.glob("*.json")):
        data = load_json(path)
        if path.name.startswith("bad"):
            label = f"negative observed-state: {path.name}"
            pass_check(f"{label} (correctly rejected)") if validate_negative(observed_validator, data) else fail_check(
                f"{label} (should have failed validation)"
            )
        else:
            label = f"observed-state: {path.name}"
            pass_check(label) if validate_data(observed_validator, data) else fail_check(label)
else:
    print("  (no observed-state fixtures found)")

print("\n== schemas: observed-state (live) ==")
state_dir = Workdir.state_base() / "instances"
if state_dir.is_dir():
    found = 0
    for path in sorted(state_dir.glob("*.json")):
        found += 1
        label = f"live-state: {path.name}"
        pass_check(label) if validate_data(observed_validator, load_json(path)) else fail_check(label)
    if not found:
        print("  (no live state files)")
else:
    print("  (no live state directory)")

print("\n== schemas: config (defaults) ==")
config_validator = validator("config.schema.json")
defaults_path = ROOT / "config/defaults.yaml"
if defaults_path.exists():
    label = "config/defaults.yaml validates against config.schema.json"
    pass_check(label) if validate_data(config_validator, load_yaml(defaults_path)) else fail_check(label)
else:
    print("  (config/defaults.yaml not found)")

print("\n== schemas: plugin-manifest config_schema (shipped) ==")
shipped_config = 0
for path in sorted(ROOT.glob("plugins/*/*/eve-plugin.yaml")):
    data = load_yaml(path)
    if not isinstance(data, dict) or "config_schema" not in data:
        continue
    shipped_config += 1
    rel = path.relative_to(ROOT / "plugins")
    errors = [
        error
        for error in manifest_validator.iter_errors(data)
        if "config_schema" in "/" + "/".join(str(part) for part in error.absolute_path)
    ]
    if not errors:
        pass_check(f"config_schema: {rel}")
    else:
        fail_check(f"config_schema: {rel}")
        print_errors(errors)
if shipped_config:
    print(f"  ({shipped_config} shipped config_schema blocks checked)")

print("\n== schemas: provider config_schema presence ==")
for path in sorted(ROOT.glob("plugins/providers/*/eve-plugin.yaml")):
    data = load_yaml(path)
    if not isinstance(data, dict) or data.get("kind") != "provider":
        continue
    rel = path.relative_to(ROOT / "plugins/providers")
    if isinstance(data.get("config_schema"), dict):
        pass_check(f"presence: {rel}")
    else:
        fail_check(f"presence: {rel} (missing config_schema)")

def fixture_schema_section(
    title: str,
    schema_name: str,
    fixture_dir: Path,
    positive_label: str,
    negative_label: str,
) -> None:
    print(f"\n== schemas: {title} ==")
    schema_validator = validator(schema_name)
    if not fixture_dir.is_dir():
        print(f"  (no {title} fixtures found)")
        return
    for path in sorted(fixture_dir.glob("*.json")):
        data = load_json(path)
        if path.name.startswith("bad"):
            label = f"negative {negative_label}: {path.name}"
            pass_check(f"{label} (correctly rejected)") if validate_negative(schema_validator, data) else fail_check(
                f"{label} (should have failed validation)"
            )
        else:
            label = f"{positive_label}: {path.name}"
            pass_check(label) if validate_data(schema_validator, data) else fail_check(label)


fixture_schema_section(
    "provision-manifest (fixtures)",
    "provision-manifest.schema.json",
    ROOT / "tests/fixtures/provision-manifest",
    "provision-manifest",
    "provision-manifest",
)
fixture_schema_section(
    "provision-status (fixtures)",
    "provision-status.schema.json",
    ROOT / "tests/fixtures/provision-status",
    "provision-status",
    "provision-status",
)

print()
if failures:
    print(f"{failures} check(s) failed.", file=sys.stderr)
    raise SystemExit(1)
print("All schema checks passed.")
