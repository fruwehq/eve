#!/usr/bin/env python3
"""Emit catalog-backed choices for direct instance creation."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.catalog import load_catalog
from eve_sdk.plugin_manifest import PluginManifest


def provider_os_support() -> dict[str, set[str]]:
    """Build provider → set of supported OS ids from contributed catalog.oses."""
    support: dict[str, set[str]] = {}
    for plugin in PluginManifest.load_all("provider"):
        catalog = plugin.get("catalog")
        if not isinstance(catalog, dict):
            continue
        oses = catalog.get("oses")
        if not isinstance(oses, list):
            continue
        support[plugin["id"]] = {
            entry["id"]
            for entry in oses
            if isinstance(entry, dict) and entry.get("id")
        }
    return support


def os_available_for_provider(
    os_entry: dict[str, Any], provider: str, support: dict[str, set[str]]
) -> bool:
    """Check if an OS is available for a provider via contributed catalog.oses."""
    return os_entry.get("id") in support.get(provider, set())


def init_available_for_provider(init: dict[str, Any], provider: str) -> bool:
    providers = init.get("providers") if isinstance(init.get("providers"), list) else []
    if providers:
        return provider in providers
    return init.get("provider") is None or init.get("provider") == provider


def build_doc() -> dict[str, Any]:
    catalog = load_catalog()
    os_support = provider_os_support()
    package_plugins = PluginManifest.load_all("package")
    package_plugin_by_id = {plugin["id"]: plugin for plugin in package_plugins}
    providers = sorted({machine.get("provider") for machine in catalog["machines"] if machine.get("provider")})
    platforms: list[dict[str, Any]] = []

    for machine in catalog["machines"]:
        provider = machine.get("provider")
        if not provider:
            continue
        for os_entry in catalog["oses"]:
            supports = machine.get("supports") if isinstance(machine.get("supports"), dict) else {}
            arches = supports.get("arches") if isinstance(supports.get("arches"), list) else []
            os_ids = supports.get("os_ids") if isinstance(supports.get("os_ids"), list) else []
            if arches and os_entry.get("arch") not in arches:
                continue
            if os_ids and os_entry.get("id") not in os_ids:
                continue
            if not os_available_for_provider(os_entry, provider, os_support):
                continue
            for init in catalog["inits"]:
                if init.get("os_family") and init.get("os_family") != os_entry.get("family"):
                    continue
                if not init_available_for_provider(init, provider):
                    continue
                for location in catalog["locations"]:
                    if not location.get(provider):
                        continue
                    defaults = machine.get("defaults") if isinstance(machine.get("defaults"), dict) else {}
                    platforms.append(
                        {
                            "id": ":".join(
                                [
                                    str(provider),
                                    str(machine.get("name")),
                                    str(os_entry.get("id")),
                                    str(init.get("id")),
                                    str(location.get("name")),
                                ]
                            ),
                            "provider": provider,
                            "machine": machine.get("name"),
                            "os": os_entry.get("id"),
                            "os_family": os_entry.get("family"),
                            "os_version": os_entry.get("version"),
                            "arch": os_entry.get("arch"),
                            "init": init.get("id"),
                            "location": location.get("name"),
                            "defaults": defaults,
                        }
                    )

    bundles = [
        {"id": bundle.get("id"), "includes": bundle.get("includes") if isinstance(bundle.get("includes"), list) else []}
        for bundle in catalog["bundles"]
    ]

    packages = []
    for package in catalog["packages"]:
        plugin = package_plugin_by_id.get(package.get("id"), {})
        supports = plugin.get("supports") if isinstance(plugin.get("supports"), dict) else {}
        actions = plugin.get("actions") if isinstance(plugin.get("actions"), list) else []
        compatibility = plugin.get("compatibility") if isinstance(plugin.get("compatibility"), list) else []
        install = plugin.get("install") if isinstance(plugin.get("install"), dict) else None
        packages.append(
            {
                "id": package.get("id"),
                "display_name": plugin.get("display_name") or package.get("id"),
                "supports": supports,
                "conflicts_with": plugin.get("conflicts_with") if isinstance(plugin.get("conflicts_with"), list) else [],
                "installable": install is not None,
                "installable_os_families": list(install.keys()) if install else [],
                "actions": actions,
                "compatibility_enforced": plugin.get("compatibility_enforced") is True,
                "compatibility": compatibility,
            }
        )

    return {
        "providers": providers,
        "platforms": sorted(
            platforms,
            key=lambda platform: (
                str(platform["provider"]),
                str(platform["machine"]),
                str(platform["os"]),
                str(platform["location"]),
                str(platform["init"]),
            ),
        ),
        "bundles": sorted(bundles, key=lambda bundle: str(bundle.get("id"))),
        "packages": sorted(packages, key=lambda package: str(package.get("id"))),
    }


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(prog="scripts/catalog-options", usage="scripts/catalog-options [--json]")
    arg_parser.add_argument("--json", action="store_true")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    try:
        doc = build_doc()
    except Exception as error:
        print(f"catalog-options: {error}", file=sys.stderr)
        return 1

    if args.json:
        print(json.dumps(doc, indent=2))
    else:
        print("PROVIDERS")
        for provider in doc["providers"]:
            print(f"  {provider}")
        print()
        print("PLATFORMS")
        for platform in doc["platforms"]:
            print(f"  {platform['provider']} {platform['machine']} {platform['os']} {platform['location']} {platform['init']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
