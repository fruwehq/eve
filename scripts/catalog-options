#!/usr/bin/env python3
"""Emit catalog-backed choices for direct instance creation."""

from __future__ import annotations

import argparse
import json
import sys
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.catalog import load_catalog  # noqa: E402
from eve_sdk.catalog_view import build_catalog_options  # noqa: E402
from eve_sdk.plugin_manifest import PluginManifest  # noqa: E402


def build_doc() -> dict[str, Any]:
    # Cold path: parse fresh, then delegate to the shared assembly the warm Engine
    # also uses (eve_sdk.catalog_view.build_catalog_options) for byte-identical output.
    return build_catalog_options(
        load_catalog(),
        PluginManifest.load_all("provider"),
        PluginManifest.load_all("package"),
    )


def parser() -> argparse.ArgumentParser:
    arg_parser = argparse.ArgumentParser(prog="scripts/catalog-options", usage="scripts/catalog-options [--json]")
    arg_parser.add_argument("--json", action="store_true")
    return arg_parser


def main() -> int:
    args = parser().parse_args()
    try:
        doc = build_doc()
    except Exception as error:
        print(f"catalog-options: {error}", file=sys.stderr)
        return 1

    if args.json:
        print(json.dumps(doc, indent=2))
    else:
        print("PROVIDERS")
        for provider in doc["providers"]:
            print(f"  {provider}")
        print()
        print("PLATFORMS")
        for platform in doc["platforms"]:
            print(
                f"  {platform['provider']} {platform['machine']} {platform['os']} "
                f"{platform['location']} {platform['init']}"
            )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
