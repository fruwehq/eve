#!/usr/bin/env bash
# Validate the optional Textual TUI entrypoint without requiring Textual.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

cache_dir="$(mktemp -d "${TMPDIR:-/tmp}/egame-tui-pycache.XXXXXX")"
trap 'rm -rf "$cache_dir"' EXIT

PYTHONPYCACHEPREFIX="$cache_dir" poetry run python -m py_compile scripts/egame-tui
poetry run python ./scripts/egame-tui --check

printf '  [OK] egame-tui compiles without importing optional Textual dependency\n'
