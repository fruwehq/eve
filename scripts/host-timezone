#!/usr/bin/env python3
"""Print the host timezone when /etc/localtime points into zoneinfo."""

from __future__ import annotations

from pathlib import Path

try:
    real_path = str(Path("/etc/localtime").resolve(strict=True))
except OSError:
    raise SystemExit(1) from None

marker = "/zoneinfo/"
if marker not in real_path:
    raise SystemExit(1)

timezone = real_path.split(marker, 1)[1]
if not timezone:
    raise SystemExit(1)

print(timezone)
