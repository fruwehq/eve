#!/usr/bin/env python3
"""Pair Moonlight with Sunshine via a fixed PIN.

Usage: scripts/remote-moonlight-pair <instance>
"""

from __future__ import annotations

import subprocess
import sys
import time
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.remote_launch import (  # noqa: E402
    has_package,
    instance_ip,
    moonlight_pair_command,
    repo_root,
    resolve_env,
    sunshine_pair_curl_command,
)


def main(argv: list[str]) -> int:
    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/remote-moonlight-pair <instance>", file=sys.stderr)
        return 2
    root = repo_root()
    resolved = resolve_env(root, profile)
    if not has_package(resolved, "sunshine"):
        print("sunshine not in bundle — skipping")
        return 0
    ip = instance_ip(root, profile)
    pin = "1234"
    pair_response_file = str(root / "tmp" / "moonlight-pair-response.json")

    (root / "tmp").mkdir(parents=True, exist_ok=True)
    Path(pair_response_file).unlink(missing_ok=True)

    print(f"Starting Moonlight pairing against {ip} with PIN {pin}...")
    moonlight = subprocess.Popen(moonlight_pair_command(ip, pin))
    time.sleep(2)

    print("Submitting pairing PIN to Sunshine...")
    curl = subprocess.run(
        sunshine_pair_curl_command(ip, pin, pair_response_file),
        capture_output=True, text=True, check=False,
    )
    http_code = curl.stdout
    if curl.returncode != 0:
        moonlight.terminate()
        moonlight.wait()
        print("Sunshine pairing API call failed.")
        return 1

    if not http_code.startswith("2"):
        moonlight.terminate()
        moonlight.wait()
        print(f"Sunshine pairing API returned HTTP {http_code}.")
        if Path(pair_response_file).is_file():
            print(Path(pair_response_file).read_text(), end="")
        return 1

    print("Sunshine pairing API accepted the PIN. Waiting for Moonlight to finish...")
    return moonlight.wait()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
