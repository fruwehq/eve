  EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
    --instance dev-a \
    --operation package.down \
    --status succeeded \
    --desired-state running \
    --provider-state running \
    --package docker \
    --package-state removed
)"
if printf '%s\n' "$state_json" | jq -e '.last_operation.name == "package.down" and .last_operation.type == "package" and .last_operation.id == 1 and .desired_state == "running" and .provider_state == "running" and .package_state.docker.status == "removed" and (.operation_history | length == 1)' >/dev/null; then
  printf '  [OK] instance state records package operation\n'
else
  printf '  [FAIL] instance state records package operation\n' >&2
  printf '%s\n' "$state_json" >&2
  FAIL=$((FAIL + 1))
fi

running_state="$(
  EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
    --instance recover-a \
    --operation provider.up \
    --status running \
    --provider-state changing
)"
recovered_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance recover-a --recover-running)"
if printf '%s\n' "$running_state" "$recovered_state" |
  jq -s -e '.[0].last_operation.status == "running" and .[1].last_operation.status == "failed" and .[1].provider_state == "error" and (.[1].last_error | test("Recovered interrupted operation provider.up"))' >/dev/null; then
  printf '  [OK] instance state recovers interrupted running operation\n'
else
  printf '  [FAIL] instance state recover-running mismatch\n' >&2
  printf '%s\n' "$recovered_state" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
  --instance recover-read-a \
  --operation provider.up \
  --status succeeded \
  --desired-state running \
  --provider-state running >/dev/null
EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
  --instance recover-read-a \
  --operation provider.ip \
  --status running >/dev/null
recovered_read_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance recover-read-a --recover-running)"
if printf '%s\n' "$recovered_read_state" |
  jq -e '.last_operation.name == "provider.ip" and .last_operation.status == "failed" and .provider_state == "running" and (.last_error | test("Recovered interrupted operation provider.ip"))' >/dev/null; then
  printf '  [OK] instance state recover preserves read-only provider state\n'
else
  printf '  [FAIL] instance state read-only recover mismatch\n' >&2
  printf '%s\n' "$recovered_read_state" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
  --instance dev-a \
  --operation provider.status \
  --status succeeded \
  --provider-state nonsense >/dev/null 2>"$tmp_err"; then
  printf '  [FAIL] instance state accepted invalid provider_state\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'provider_state must be one of:' "$tmp_err"; then
  printf '  [OK] instance state rejects invalid provider_state\n'
else
  printf '  [FAIL] instance state invalid provider_state error mismatch\n' >&2
  cat "$tmp_err" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
  --instance dev-a \
  --operation package.status \
  --status succeeded \
  --package docker \
  --package-state bogus >/dev/null 2>"$tmp_err"; then
  printf '  [FAIL] instance state accepted invalid package_state\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'package_state must be one of:' "$tmp_err"; then
  printf '  [OK] instance state rejects invalid package_state\n'
else
  printf '  [FAIL] instance state invalid package_state error mismatch\n' >&2
  cat "$tmp_err" >&2
  FAIL=$((FAIL + 1))
fi

if EGAME_STATE_DIR="$state_dir" ./scripts/instance-state \
  --instance dev-a \
  --operation package.status \
  --status succeeded \
  --package docker >/dev/null 2>"$tmp_err"; then
  printf '  [FAIL] instance state accepted package without package_state\n' >&2
  FAIL=$((FAIL + 1))
elif grep -q 'package and package_state must be provided together' "$tmp_err"; then
  printf '  [OK] instance state rejects incomplete package update\n'
else
  printf '  [FAIL] instance state incomplete package update error mismatch\n' >&2
  cat "$tmp_err" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_STATE_DIR="$state_dir" \
  EGAME_PACKAGE_STATUS_SSH="$fake_ssh" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-package-dispatch-test" \
  ./scripts/package-dispatch --registry "$FIXTURE" --instance dev-a --package docker --command status >/dev/null
recorded_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$recorded_state" | jq -e '.last_operation.name == "package.status" and .last_operation.status == "succeeded" and .package_state.docker.status == "installed" and ([.operation_history[-2].status, .operation_history[-1].status] == ["running", "succeeded"])' >/dev/null; then
  printf '  [OK] package dispatch records state\n'
else
  printf '  [FAIL] package dispatch records state\n' >&2
  printf '%s\n' "$recorded_state" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_PLUGIN_ROOTS="$PLUGIN_FIXTURE" \
  EGAME_STATE_DIR="$state_dir" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-package-dispatch-test" \
  ./scripts/package-dispatch --registry "$FIXTURE" --instance dev-a --package dummy --command status >/dev/null
hook_status_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$hook_status_state" | jq -e '.package_state.dummy.status == "installed"' >/dev/null; then
  printf '  [OK] package dispatch records hook status contract\n'
else
  printf '  [FAIL] package dispatch hook status mismatch\n' >&2
  printf '%s\n' "$hook_status_state" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_STATE_DIR="$state_dir" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-package-dispatch-test" \
  ./scripts/package-dispatch --registry "$FIXTURE" --instance dev-a --package missing-package --command status >/dev/null 2>&1 || true
failed_package_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$failed_package_state" | jq -e '.last_operation.name == "package.status" and .last_operation.status == "failed" and .last_error and .package_state["missing-package"].status == "failed"' >/dev/null; then
  printf '  [OK] package dispatch records failed package state\n'
else
  printf '  [FAIL] package dispatch failed state mismatch\n' >&2
  printf '%s\n' "$failed_package_state" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_STATE_DIR="$state_dir" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-provider-dispatch-test" \
  ./scripts/instance-state \
    --instance dev-a \
    --operation provider.up \
    --status succeeded \
    --desired-state running \
    --provider-state running >/dev/null
EGAME_STATE_DIR="$state_dir" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-provider-dispatch-test" \
  ./scripts/provider-dispatch --registry "$FIXTURE" --instance dev-a --command ip >/dev/null 2>&1 || true
failed_ip_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$failed_ip_state" | jq -e '.last_operation.name == "provider.ip" and .last_operation.status == "failed" and .provider_state == "running" and .last_error' >/dev/null; then
  printf '  [OK] provider dispatch read failures preserve lifecycle state\n'
else
  printf '  [FAIL] provider dispatch read failure state mismatch\n' >&2
  printf '%s\n' "$failed_ip_state" >&2
  FAIL=$((FAIL + 1))
fi

EGAME_STATE_DIR="$state_dir" \
  EGAME_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/egame-provider-dispatch-test" \
  ./scripts/provider-dispatch --registry "$FIXTURE" --instance dev-a --command bogus >/dev/null 2>&1 || true
failed_provider_state="$(EGAME_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$failed_provider_state" | jq -e '.last_operation.name == "provider.bogus" and .last_operation.status == "failed" and .provider_state == "error" and .last_error' >/dev/null; then
  printf '  [OK] provider dispatch records failed provider state\n'
else
  printf '  [FAIL] provider dispatch failed state mismatch\n' >&2
  printf '%s\n' "$failed_provider_state" >&2
  FAIL=$((FAIL + 1))
fi

[ "$FAIL" -eq 0 ]
