  printf '%s\n' "$valid_provider_output_err" >&2
  FAIL=$((FAIL + 1))
fi

provider_status_catalog="$profile_catalog_dir/provider-status-catalog.local.yaml"
provider_status_registry="$profile_catalog_dir/provider-status-instances.yaml"
cat >"$provider_status_catalog" <<'YAML'
machines:
  - name: acme-small
    provider: acme
    kind: vm
    defaults:
      disk_gb: 30
      memory_mb: 4096
locations:
  - name: tokyo
    acme:
      region: test-region
inits:
  - id: ssh-ubuntu-cloud-init
    providers: [acme]
YAML
cat >"$provider_status_registry" <<'YAML'
version: 1
instances:
  - name: acme-a
    machine: acme-small
    os: ubuntu-26.04-amd64
    init: ssh-ubuntu-cloud-init
    packages: [docker]
    location: tokyo
YAML
provider_dispatch_output_err="$(
  EVE_PLUGIN_ROOTS="$BAD_PROVIDER_STATUS_FIXTURE" \
    EVE_CATALOG_LOCAL="$provider_status_catalog" \
    EVE_INSTANCE_WORKDIR="$profile_catalog_dir/provider-dispatch-workdir" \
    EVE_DISABLE_STATE=1 \
    ./scripts/provider-dispatch --registry "$provider_status_registry" --instance acme-a --command status 2>&1 >/dev/null || true
)"
if printf '%s\n' "$provider_dispatch_output_err" | grep -q "failed schema validation"; then
  printf '  [OK] provider dispatch rejects invalid status from provider command output\n'
else
  printf '  [FAIL] provider dispatch should reject invalid status from provider command output\n' >&2
  printf '%s\n' "$provider_dispatch_output_err" >&2
  FAIL=$((FAIL + 1))
fi

# shellcheck disable=SC2016
prov_status_jq='
  .api_version == 1
  and (.os_family | IN("ubuntu","windows"))
  and has("started_at")
  and ((.started_at | type) == "string" or (.started_at | type) == "null")
  and (.status as $s | $s | IN("running","done","failed"))
  and (.steps | type) == "array"
  and ([.steps[] | (
    (.step | type) == "string" and (.step | length) > 0
    and (.phase as $p | $p | IN("pending","running","succeeded","failed","skipped"))
    and has("started_at")
    and has("ended_at")
    and has("exit_code")
    and ((.started_at | type) == "string" or (.started_at | type) == "null")
    and ((.ended_at | type) == "string" or (.ended_at | type) == "null")
    and ((.exit_code | type) == "number" or (.exit_code | type) == "null")
    and (if .exit_code != null then (.exit_code | . == floor) else true end)
  )] | all)
'

missing_os_family='{"api_version":1,"started_at":null,"status":"running","steps":[]}'
if printf '%s' "$missing_os_family" | jq -e "$prov_status_jq" >/dev/null 2>&1; then
  printf '  [FAIL] provision-status jq accepts missing os_family\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] provision-status jq rejects missing os_family\n'
fi

missing_started_at='{"api_version":1,"os_family":"ubuntu","status":"running","steps":[]}'
if printf '%s' "$missing_started_at" | jq -e "$prov_status_jq" >/dev/null 2>&1; then
  printf '  [FAIL] provision-status jq accepts missing started_at\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] provision-status jq rejects missing started_at\n'
fi

step_missing_timing='{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"running","exit_code":null}]}'
if printf '%s' "$step_missing_timing" | jq -e "$prov_status_jq" >/dev/null 2>&1; then
  printf '  [FAIL] provision-status jq accepts step missing started_at/ended_at\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] provision-status jq rejects step missing started_at/ended_at\n'
fi

step_bad_timing_type='{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"running","started_at":123,"ended_at":null,"exit_code":null}]}'
if printf '%s' "$step_bad_timing_type" | jq -e "$prov_status_jq" >/dev/null 2>&1; then
  printf '  [FAIL] provision-status jq accepts non-string step started_at\n' >&2
  FAIL=$((FAIL + 1))
else
  printf '  [OK] provision-status jq rejects non-string step started_at\n'
fi

valid_running='{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"succeeded","started_at":"2025-01-15T10:30:00Z","ended_at":"2025-01-15T10:31:00Z","exit_code":0},{"step":"human-user.sh","phase":"running","started_at":"2025-01-15T10:31:01Z","ended_at":null,"exit_code":null}]}'
if printf '%s' "$valid_running" | jq -e "$prov_status_jq" >/dev/null 2>&1; then
  printf '  [OK] provision-status jq accepts valid running status\n'
else
  printf '  [FAIL] provision-status jq rejects valid running status\n' >&2
  FAIL=$((FAIL + 1))
fi

[ "$FAIL" -eq 0 ]
