# shellcheck disable=SC2016
valid_provider_output_err="$(printf '{"status":"running"}' | ruby -rjson -e '
  $LOAD_PATH.unshift(File.join(ENV["PWD"] || ".", "core"))
  require "sdk"
  begin
    Eve::SDK::Contract.validate_output!(JSON.parse(STDIN.read), def_name: "provider_command_output")
    exit 0
  rescue Eve::SDK::ContractError => e
