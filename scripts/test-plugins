  ./scripts/provider-dispatch --registry "$FIXTURE" --instance dev-a --command ip >/dev/null 2>&1 || true
failed_ip_state="$(EVE_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$failed_ip_state" | jq -e '.last_operation.name == "provider.ip" and .last_operation.status == "failed" and .provider_state == "running" and .last_error' >/dev/null; then
  printf '  [OK] provider dispatch read failures preserve lifecycle state\n'
else
  printf '  [FAIL] provider dispatch read failure state mismatch\n' >&2
  printf '%s\n' "$failed_ip_state" >&2
  FAIL=$((FAIL + 1))
fi

EVE_STATE_DIR="$state_dir" \
  EVE_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/eve-provider-dispatch-test" \
  ./scripts/provider-dispatch --registry "$FIXTURE" --instance dev-a --command bogus >/dev/null 2>&1 || true
failed_provider_state="$(EVE_STATE_DIR="$state_dir" ./scripts/instance-state --instance dev-a --get)"
if printf '%s\n' "$failed_provider_state" | jq -e '.last_operation.name == "provider.bogus" and .last_operation.status == "failed" and .provider_state == "error" and .last_error' >/dev/null; then
  printf '  [OK] provider dispatch records failed provider state\n'
else
  printf '  [FAIL] provider dispatch failed state mismatch\n' >&2
  printf '%s\n' "$failed_provider_state" >&2
  FAIL=$((FAIL + 1))
fi

contract_grep="$(rg 'Contract\.validate' core/sdk/provider.rb scripts/package-dispatch scripts/provider-dispatch || true)"
if [ -n "$contract_grep" ]; then
  printf '  [OK] Contract.validate has real callers in provider and package dispatch\n'
else
  printf '  [FAIL] Contract.validate has no callers outside contract.rb\n' >&2
  FAIL=$((FAIL + 1))
fi

# shellcheck disable=SC2016
invalid_status_err="$(printf '{"status":"not-a-valid-status"}' | ruby -rjson -e '
  $LOAD_PATH.unshift(File.join(ENV["PWD"] || ".", "core"))
  require "sdk"
  begin
    Eve::SDK::Contract.validate_output!(JSON.parse(STDIN.read), def_name: "package_command_output")
    exit 0
  rescue Eve::SDK::ContractError => e
    warn e.message
    exit 1
  end
' 2>&1 || true)"
if printf '%s\n' "$invalid_status_err" | grep -q "failed schema validation"; then
  printf '  [OK] Contract rejects invalid package command output\n'
else
  printf '  [FAIL] Contract should reject invalid package command output\n' >&2
  printf '%s\n' "$invalid_status_err" >&2
  FAIL=$((FAIL + 1))
fi

bad_status_dispatch_err="$(
  EVE_PLUGIN_ROOTS="$BAD_STATUS_FIXTURE" \
    EVE_INSTANCE_WORKDIR="${TMPDIR:-/tmp}/eve-package-dispatch-test" \
    EVE_DISABLE_STATE=1 \
    ./scripts/package-dispatch --registry "$FIXTURE" --instance dev-a --package invalid-status-output --command status 2>&1 >/dev/null || true
)"
if printf '%s\n' "$bad_status_dispatch_err" | grep -q "failed schema validation"; then
  printf '  [OK] package dispatch rejects invalid status from plugin command output\n'
else
  printf '  [FAIL] package dispatch should reject invalid status from plugin command output\n' >&2
  printf '%s\n' "$bad_status_dispatch_err" >&2
  FAIL=$((FAIL + 1))
fi

