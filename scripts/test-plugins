#!/usr/bin/env python3
# ruff: noqa: E501,E701,E702,E722,F841,I001,RUF100,SIM105,S101,S603,S607
"""Validate plugin manifests and dry-run dispatch contracts (hermetic)."""

from __future__ import annotations

import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
os.environ["EVE_PLUGIN_ROOTS"] = str(ROOT / "tests/fixtures/hermetic")
os.environ["EVE_PLUGIN_ROOTS_EXCLUSIVE"] = "1"
os.environ.setdefault("EVE_HOME", tempfile.mkdtemp(prefix="eve-plugins."))
sys.path.insert(0, str(ROOT))

FIXTURE = str(ROOT / "tests/fixtures/hermetic/instances.yaml")
DUMMY = str(ROOT / "tests/fixtures/plugins/packages/dummy")
LOCAL_EXEC = str(ROOT / "tests/fixtures/plugins/packages/local-exec")
OVERRIDE = str(ROOT / "tests/fixtures/plugins/packages/docker-override")
BAD = str(ROOT / "tests/fixtures/plugins/packages/bad")
BAD_UBUNTU = str(ROOT / "tests/fixtures/plugins/packages/bad-install-ubuntu")
BAD_WIN_STATE = str(ROOT / "tests/fixtures/plugins/packages/bad-install-windows-state")
BAD_NON_STR = str(ROOT / "tests/fixtures/plugins/packages/bad-install-non-string")
BAD_STATUS = str(ROOT / "tests/fixtures/plugins/packages/invalid-status-output")
BAD_PKG_SUPP = str(ROOT / "tests/fixtures/plugins/packages/bad-supports")
BAD_PROV_SUPP = str(ROOT / "tests/fixtures/plugins/providers/bad-supports")
BAD_PROV_STATUS = str(ROOT / "tests/fixtures/plugins/providers/acme-invalid-status-output")

FAIL = 0


def _run(*args, env=None, timeout=120, input_data=None):
    e = {**os.environ, **(env or {})}
    cmd = list(args)
    if cmd and not cmd[0].startswith(("/", "python", "rg")):
        cmd[0] = str(ROOT / cmd[0])
    return subprocess.run(cmd, cwd=str(ROOT), env=e, capture_output=True, text=True, check=False, timeout=timeout, input=input_data)


def _run_json(*args, env=None):
    r = _run(*args, env=env)
    if r.returncode != 0 or not r.stdout.strip(): return None
    try: return json.loads(r.stdout)
    except json.JSONDecodeError: return None


def _ok(label): print(f"  [OK] {label}")
def _fail(label, detail=""):
    global FAIL
    print(f"  [FAIL] {label}", file=sys.stderr)
    if detail: print(detail, file=sys.stderr)
    FAIL += 1
def _check(label, cond, detail=""):
    if cond: _ok(label)
    else: _fail(label, detail)


def _make_exec(path, content):
    path.write_text(content, encoding="utf-8")
    path.chmod(0o755)


def main():
    global FAIL
    WRK = f"{tempfile.gettempdir()}/eve-pkg-dispatch"
    WRK_PROV = f"{tempfile.gettempdir()}/eve-prov-dispatch"
    state_dir = tempfile.mkdtemp(prefix="eve-state-test.")

    try:
        # --- plugin listing ---
        _check("built-in plugins validate", _run("scripts/plugin-list", "--validate").returncode == 0)

        _check("mock-cloud provider plugin listed",
              any(p["id"] == "mock-cloud" and p["kind"] == "provider" for p in
                  (_run_json("scripts/plugin-list", "--kind", "provider", "--json") or {}).get("plugins", [])))

        _check("mock-app package plugin listed",
              any(p["id"] == "mock-app" and p["kind"] == "package" for p in
                  (_run_json("scripts/plugin-list", "--kind", "package", "--json") or {}).get("plugins", [])))

        # --- instance resolver maps plugins ---
        dj = _run_json("scripts/instance-resolve", "--registry", FIXTURE, "--instance", "mock-dev-a", "--emit", "json")
        _check("instance resolver maps provider and package plugins",
              dj is not None and dj.get("provider_plugin") == "mock-cloud" and
              any(p["id"] == "mock-app" for p in dj.get("package_plugins", [])))

        # --- external fixtures (EVE_PLUGIN_ROOTS append) ---
        # These need the EXCLUSIVE flag off so the hermetic root + extra root both work.
        _check("external dummy plugin listed",
              _run_json("scripts/plugin-list", "--kind", "package", "--json",
                        env={"EVE_PLUGIN_ROOTS": f"{os.environ['EVE_PLUGIN_ROOTS']}:{DUMMY}"}).get("plugins") is not None
              if _run_json("scripts/plugin-list", "--kind", "package", "--json",
                          env={"EVE_PLUGIN_ROOTS": f"{os.environ['EVE_PLUGIN_ROOTS']}:{DUMMY}"}) else False)

        # --- bad plugin rejection ---
        _check("invalid external plugin rejected",
              _run("scripts/plugin-list", "--json", env={"EVE_PLUGIN_ROOTS": f"{os.environ['EVE_PLUGIN_ROOTS']}:{BAD}"}).returncode != 0)

        for fixture, needle, label in [
            (BAD_UBUNTU, "install.ubuntu.steps must be a non-empty list", "empty install.ubuntu.steps rejected"),
            (BAD_WIN_STATE, "install.windows.state_files contains unsupported entries", "unsupported install.windows.state_files rejected"),
            (BAD_NON_STR, "install.ubuntu.steps must be a list of strings", "non-string install.ubuntu.steps rejected"),
            (BAD_PROV_SUPP, "supports.engines must be a list", "malformed supports.engines rejected"),
            (BAD_PKG_SUPP, "supports.os_families must be a list", "malformed supports.os_families rejected"),
        ]:
            r = _run("scripts/plugin-list", "--validate", env={"EVE_PLUGIN_ROOTS": f"{os.environ['EVE_PLUGIN_ROOTS']}:{fixture}"})
            _check(label, needle in (r.stderr + r.stdout))

        # --- provider dispatch dry-run matrix ---
        matrix_fail = 0
        for inst, prov_id, _engine in [("mock-dev-a", "mock-cloud", "terraform"), ("mock-gpu-a", "mock-cloud", "terraform"), ("mock-win-a", "mock-cloud", "terraform")]:
            for cmd_name in ["resolve", "init", "plan", "up", "down", "start", "stop", "status", "ip", "ssh"]:
                d = _run_json("scripts/provider-dispatch", "--registry", FIXTURE, "--instance", inst, "--command", cmd_name, "--dry-run",
                              env={"EVE_INSTANCE_WORKDIR": WRK_PROV})
                if not (d and d.get("kind") == "provider" and d.get("provider") == prov_id and d.get("command") == cmd_name and d.get("dry_run") is True):
                    matrix_fail += 1
        _check("provider dispatch dry-run matrix", matrix_fail == 0)

        # --- provider manifest boundary ---
        boundary_fail = 0
        for mf in sorted((ROOT / "tests/fixtures/hermetic/providers").glob("*/eve-plugin.yaml")):
            pdir = mf.parent
            pc = pdir / "commands" / "provider-command"
            if not (pc.is_file() and os.access(pc, os.X_OK)):
                boundary_fail += 1
        _check("provider manifests route lifecycle commands through plugin-owned implementations", boundary_fail == 0)

        # --- instance-view provider actions ---
        iv = _run_json("scripts/instance-view", "--registry", FIXTURE, "--instance", "mock-dev-a",
                       env={"EVE_INSTANCE_WORKDIR": f"{tempfile.gettempdir()}/eve-iv", "EVE_STATE_DIR": f"{tempfile.gettempdir()}/eve-iv-state"})
        _check("instance-view exposes provider action metadata",
              iv is not None and any(a.get("id") == "status-details" for a in iv.get("provider_actions", [])))

        # --- package status dry-run ---
        d = _run_json("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "mock-dev-a", "--package", "mock-app", "--command", "status", "--dry-run", env={"EVE_INSTANCE_WORKDIR": WRK})
        _check("package status dry-run", d is not None and d.get("package") == "mock-app")

        # --- package dispatch rejects unsupported ---
        # mock-win-app doesn't support ubuntu
        _check("package dispatch rejects unsupported os family",
              "does not support os family ubuntu" in _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "mock-dev-a",
                  "--package", "mock-win-app", "--command", "status", "--dry-run", env={"EVE_PLUGIN_ROOTS_EXCLUSIVE": "0", "EVE_PLUGIN_ROOTS": f"{os.environ['EVE_PLUGIN_ROOTS']}", "EVE_INSTANCE_WORKDIR": WRK}).stderr)

        # --- package hook presence ---
        _check("mock-app has ubuntu down/status hooks",
              (ROOT / "tests/fixtures/hermetic/packages/mock-app/commands/ubuntu/down").is_file() and
              (ROOT / "tests/fixtures/hermetic/packages/mock-app/commands/ubuntu/status").is_file())
        _check("mock-win-app has windows down/status hooks",
              (ROOT / "tests/fixtures/hermetic/packages/mock-win-app/commands/windows/down").is_file() and
              (ROOT / "tests/fixtures/hermetic/packages/mock-win-app/commands/windows/status").is_file())

        # --- package reinstall = down then install ---
        d = _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "mock-dev-a", "--package", "mock-app", "--command", "reinstall", "--dry-run", env={"EVE_INSTANCE_WORKDIR": WRK})
        try:
            cmds = [json.loads(line) for line in d.stdout.strip().split("\n") if line.strip()]
            _check("package reinstall defaults to down then install", [c.get("command") for c in cmds] == ["down", "install"])
        except Exception:
            _fail("package reinstall defaults to down then install")

        # --- package dispatch records state ---
        SE = {"EVE_STATE_DIR": state_dir}
        _run("scripts/instance-state", "--instance", "mock-dev-a", "--operation", "provider.up", "--status", "succeeded",
             "--desired-state", "running", "--provider-state", "running", env=SE)

        # --- instance state tests ---
        empty = _run_json("scripts/instance-state", "--instance", "fresh-a", "--get", env=SE)
        _check("instance state get returns default state shape",
              empty is not None and empty.get("desired_state") == "unknown" and empty.get("package_state") == {})

        sj = _run_json("scripts/instance-state", "--instance", "mock-dev-a", "--operation", "package.down",
                       "--status", "succeeded", "--desired-state", "running", "--provider-state", "running",
                       "--package", "mock-app", "--package-state", "removed", env=SE)
        _check("instance state records package operation",
              sj is not None and sj["last_operation"]["name"] == "package.down")

        # recover
        _run("scripts/instance-state", "--instance", "recover-a", "--operation", "provider.up", "--status", "running", "--provider-state", "changing", env=SE)
        rec = _run_json("scripts/instance-state", "--instance", "recover-a", "--recover-running", env=SE)
        _check("instance state recovers interrupted running operation",
              rec is not None and rec["last_operation"]["status"] == "failed" and rec.get("provider_state") == "error")

        # invalid values
        _check("instance state rejects invalid provider_state",
              _run("scripts/instance-state", "--instance", "d", "--operation", "provider.status", "--status", "succeeded",
                   "--provider-state", "nonsense", env=SE).returncode != 0)
        _check("instance state rejects invalid package_state",
              _run("scripts/instance-state", "--instance", "d", "--operation", "package.status", "--status", "succeeded",
                   "--package", "mock-app", "--package-state", "bogus", env=SE).returncode != 0)
        _check("instance state rejects incomplete package update",
              _run("scripts/instance-state", "--instance", "d", "--operation", "package.status", "--status", "succeeded",
                   "--package", "mock-app", env=SE).returncode != 0)

        # --- schema validation callers ---
        import subprocess as _sp
        cg = _sp.run(["rg", "validate_(def|output)", "eve_sdk", "scripts/package-dispatch", "scripts/provider-dispatch"],
                     cwd=str(ROOT), capture_output=True, text=True, check=False)
        _check("schema validation has real callers in provider and package dispatch", bool(cg.stdout.strip()))

        # --- schema validation rejects invalid ---
        for json_str, label in [
            ('{"status":"not-a-valid-status"}', "schema validation rejects invalid package command output"),
            ('{"status":"not-a-valid-status"}', "schema validation rejects invalid provider command output status"),
            ('{"ip":""}', "schema validation rejects empty provider command output ip"),
        ]:
            r = _run("python3", "-c",
                     "import json,sys; from eve_sdk.schema import SchemaValidationError, validate_def; "
                     "validate_def('command-io.schema.json','provider_command_output',json.load(sys.stdin),'Command output')",
                     env={"PYTHONPATH": str(ROOT)}, input_data=json_str)
            _check(label, "failed schema validation" in r.stderr)

        r = _run("python3", "-c",
                 "import json,sys; from eve_sdk.schema import SchemaValidationError, validate_def; "
                 "validate_def('command-io.schema.json','provider_command_output',json.load(sys.stdin),'Command output')",
                 env={"PYTHONPATH": str(ROOT)}, input_data='{"status":"running"}')
        _check("schema validation accepts valid provider command output", not r.stderr)

        # --- provision-status jq tests (pure JSON validation, no plugins needed) ---
        def _prov_status_valid(d):
            if d.get("api_version") != 1: return False
            if d.get("os_family") not in ("ubuntu", "windows"): return False
            if "started_at" not in d: return False
            if not (d["started_at"] is None or isinstance(d["started_at"], str)): return False
            if d.get("status") not in ("running", "done", "failed"): return False
            if not isinstance(d.get("steps"), list): return False
            for s in d["steps"]:
                if not (isinstance(s.get("step"), str) and len(s["step"]) > 0): return False
                if s.get("phase") not in ("pending", "running", "succeeded", "failed", "skipped"): return False
                for k in ("started_at", "ended_at", "exit_code"):
                    if k not in s: return False
                if not (s["started_at"] is None or isinstance(s["started_at"], str)): return False
                if not (s["ended_at"] is None or isinstance(s["ended_at"], str)): return False
                if not (s["exit_code"] is None or isinstance(s["exit_code"], int)): return False
            return True

        for json_str, expected_valid, label in [
            ('{"api_version":1,"started_at":null,"status":"running","steps":[]}', False, "provision-status rejects missing os_family"),
            ('{"api_version":1,"os_family":"ubuntu","status":"running","steps":[]}', False, "provision-status rejects missing started_at"),
            ('{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"running","exit_code":null}]}', False, "provision-status rejects step missing started_at/ended_at"),
            ('{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"succeeded","started_at":"2025-01-15T10:30:00Z","ended_at":"2025-01-15T10:31:00Z","exit_code":0}]}', True, "provision-status accepts valid running status"),
        ]:
            try:
                d = json.loads(json_str); result = _prov_status_valid(d)
            except Exception:
                result = False
            _check(label, result == expected_valid)

    finally:
        shutil.rmtree(state_dir, ignore_errors=True)

    return 1 if FAIL else 0


if __name__ == "__main__":
    raise SystemExit(main())
