#!/usr/bin/env python3
# ruff: noqa: E501,E701
# ruff: noqa: E501,E701
"""Validate plugin manifests and dry-run dispatch contracts.

Faithful 1:1 port of the legacy bash test-plugins: same checks, [OK]/[FAIL]
strings, and exit codes.
"""
from __future__ import annotations

import json
import os
import re
import shutil
import stat
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

FIXTURE = "tests/fixtures/instances.yaml"
PLUGIN_FIXTURE = "tests/fixtures/plugins/packages/dummy"
LOCAL_EXEC_FIXTURE = "tests/fixtures/plugins/packages/local-exec"
OVERRIDE_FIXTURE = "tests/fixtures/plugins/packages/docker-override"
EXAMPLE_PKG = "examples/plugins/packages/hello-package"
EXAMPLE_PROV = "examples/plugins/providers/echo-provider"
BAD_PLUGIN = "tests/fixtures/plugins/packages/bad"
BAD_INSTALL_UBUNTU = "tests/fixtures/plugins/packages/bad-install-ubuntu"
BAD_INSTALL_WIN_STATE = "tests/fixtures/plugins/packages/bad-install-windows-state"
BAD_INSTALL_NON_STR = "tests/fixtures/plugins/packages/bad-install-non-string"
BAD_STATUS = "tests/fixtures/plugins/packages/invalid-status-output"
BAD_PKG_SUPPORTS = "tests/fixtures/plugins/packages/bad-supports"
BAD_PROV_STATUS = "tests/fixtures/plugins/providers/acme-invalid-status-output"
BAD_PROV_SUPPORTS = "tests/fixtures/plugins/providers/bad-supports"
WIN_ONLY = "tests/fixtures/plugins/packages/win-only"

FAIL = 0


def _run(*args: str, env: dict[str, str] | None = None, input_data: str | None = None) -> subprocess.CompletedProcess[str]:
    e = {**os.environ, **(env or {})}
    cmd = list(args)
    # Only resolve the FIRST arg (the script path); leave flags/args as-is.
    if cmd and not cmd[0].startswith("/") and not cmd[0].startswith(("make", "python", "rg")):
        cmd[0] = str(ROOT / cmd[0])
    return subprocess.run(
        cmd, cwd=str(ROOT), env=e, capture_output=True, text=True, check=False,
        input=input_data, timeout=120,
    )


def _run_json(*args: str, env: dict[str, str] | None = None) -> Any:
    r = _run(*args, env=env)
    if r.returncode != 0 or not r.stdout.strip():
        return None
    try:
        return json.loads(r.stdout)
    except json.JSONDecodeError:
        return None


def _ok(label: str) -> None:
    print(f"  [OK] {label}")


def _fail(label: str, detail: str = "") -> None:
    global FAIL
    print(f"  [FAIL] {label}", file=sys.stderr)
    if detail:
        print(detail, file=sys.stderr)
    FAIL += 1


def _check(label: str, cond: bool, detail: str = "") -> None:
    if cond:
        _ok(label)
    else:
        _fail(label, detail)


def _jq(label: str, args: list[str], predicate, env: dict[str, str] | None = None) -> None:
    doc = _run_json(*args, env=env)
    _check(label, doc is not None and predicate(doc), json.dumps(doc, indent=2) if doc else "no output")


def _grep_err(label: str, args: list[str], needle: str, env: dict[str, str] | None = None) -> None:
    r = _run(*args, env=env)
    _check(label, needle in (r.stderr + r.stdout), (r.stderr + r.stdout)[:500])


def _make_exec(path: Path, content: str) -> None:
    path.write_text(content, encoding="utf-8")
    path.chmod(path.stat().st_mode | stat.S_IEXEC)


def main() -> int:
    global FAIL

    # --- setup ---
    profile_dir = tempfile.mkdtemp(prefix="eve-plugin-profiles.")
    profile_catalog = Path(profile_dir) / "catalog.local.yaml"
    profile_catalog.write_text(
        "profiles:\n"
        "  - name: local-qemu-ubuntu-dev-gui\n"
        "    machine: local-qemu-medium\n    os: ubuntu-26.04-arm64\n"
        "    init: ssh-ubuntu-cloud-init\n    bundles: [dev-ai]\n    location: tokyo\n\n"
        "  - name: vultr-windows-gaming\n"
        "    machine: vultr-vcg-a40-2c\n    os: windows-server-2025\n"
        "    init: ssh-windows-powershell7\n    bundles: [gaming-streaming]\n    location: tokyo\n",
        encoding="utf-8",
    )
    os.environ["EVE_CATALOG_LOCAL"] = str(profile_catalog)

    WRK = f"{tempfile.gettempdir()}/eve-package-dispatch-test"
    WRK_PROV = f"{tempfile.gettempdir()}/eve-provider-dispatch-test"
    state_dir = tempfile.mkdtemp(prefix="eve-state-test.")

    try:
        # --- simple checks ---
        _check("built-in plugins validate", _run("scripts/plugin-list", "--validate").returncode == 0)

        _jq("aws provider plugin listed",
            ["scripts/plugin-list", "--kind", "provider", "--json"],
            lambda d: any(p["id"] == "aws" and p["kind"] == "provider" for p in d["plugins"]))

        _jq("docker package plugin listed",
            ["scripts/plugin-list", "--kind", "package", "--json"],
            lambda d: any(p["id"] == "docker" and p["kind"] == "package" for p in d["plugins"]))

        _jq("instance resolver maps provider and package plugins",
            ["scripts/instance-resolve", "--registry", FIXTURE, "--instance", "dev-a", "--emit", "json"],
            lambda d: d.get("provider_plugin") == "local-qemu" and any(p["id"] == "docker" and p["plugin"] == "docker" for p in d.get("package_plugins", [])))

        _jq("external dummy plugin listed",
            ["scripts/plugin-list", "--kind", "package", "--json"],
            lambda d: any(p["id"] == "dummy" for p in d["plugins"]),
            env={"EVE_PLUGIN_ROOTS": PLUGIN_FIXTURE})

        _jq("external plugin-local exec listed",
            ["scripts/plugin-list", "--kind", "package", "--json"],
            lambda d: any(p["id"] == "local-exec" for p in d["plugins"]),
            env={"EVE_PLUGIN_ROOTS": LOCAL_EXEC_FIXTURE})

        _jq("external plugin override replaces built-in",
            ["scripts/plugin-list", "--kind", "package", "--json"],
            lambda d: len([p for p in d["plugins"] if p["id"] == "docker"]) == 1 and next(p for p in d["plugins"] if p["id"] == "docker")["display_name"] == "Docker Override Test Package",
            env={"EVE_PLUGIN_ALLOW_OVERRIDE": "1", "EVE_PLUGIN_ROOTS": OVERRIDE_FIXTURE})

        # example plugins validate
        _check("documented example plugins validate",
              _run("scripts/plugin-list", "--validate", env={"EVE_PLUGIN_ROOTS": f"{EXAMPLE_PKG}:{EXAMPLE_PROV}"}).returncode == 0)

        # bad plugin rejected
        _check("invalid external plugin rejected",
              _run("scripts/plugin-list", "--json", env={"EVE_PLUGIN_ROOTS": BAD_PLUGIN}).returncode != 0)

        # metadata checks via plugin-list JSON
        plugins = _run_json("scripts/plugin-list", "--kind", "package", "--json")
        pkg_list = _run_json("scripts/package-list", "--registry", FIXTURE, "--instance", "dev-a", "--json")

        def _pkg(pid):
            return next((p for p in plugins["plugins"] if p["id"] == pid), {})

        _check("built-in package install metadata validates",
              bool(_pkg("steam").get("install", {}).get("ubuntu", {}).get("steps")) and bool(_pkg("steam").get("install", {}).get("windows", {}).get("steps")))

        _check("package remote action metadata validates",
              [a["id"] for a in _pkg("sunshine").get("actions", [])] == ["sunshine", "pair-moonlight", "moonlight"])

        _check("ThinLinc package metadata validates",
              "THINLINC_SERVER_BUNDLE_URL" in _pkg("thinlinc").get("env", []) and
              any(a.get("id") == "web" and a.get("target") == "thinlinc.web" for a in _pkg("thinlinc").get("actions", [])))

        _check("NoMachine package metadata validates",
              _pkg("nomachine").get("supports", {}).get("os_families") == ["ubuntu", "windows"] and
              _pkg("nomachine").get("compatibility_enforced") is True and
              any(a.get("id") == "nomachine" and a.get("target") == "nomachine.connect" for a in _pkg("nomachine").get("actions", [])))

        _check("Splashtop package metadata validates",
              _pkg("splashtop").get("supports", {}).get("arches") == ["amd64"] and
              "SPLASHTOP_EMAIL" in _pkg("splashtop").get("env", []) and
              any(a.get("id") == "splashtop-info" and a.get("target") == "splashtop.info" for a in _pkg("splashtop").get("actions", [])))

        # package-list exposes actions
        def _pkgl(pid):
            return next((p for p in pkg_list["packages"] if p["id"] == pid), {})

        _check("package-list exposes package actions to callers",
              any(a.get("id") == "rustdesk" and a.get("target") == "rustdesk.connect" for a in _pkgl("rustdesk").get("actions", [])))

        # GNOME remote desktop compatibility
        gnome_reg = tempfile.mktemp()
        shutil.copy(FIXTURE, gnome_reg)
        _run("make", "--no-print-directory", "bundle.select", "INSTANCE=dev-a", "BUNDLE=desktop-gnome",
             env={"EVE_INSTANCE_REGISTRY": gnome_reg})
        gnome_pkgs = _run_json("scripts/package-list", "--registry", gnome_reg, "--instance", "dev-a", "--json", env={"EVE_INSTANCE_REGISTRY": gnome_reg})
        if gnome_pkgs:
            incompatible = ["rustdesk", "sunshine", "thinlinc", "vnc", "waypipe"]
            _check("package-list keeps only GNOME Remote Desktop RDP for GNOME desktop selections",
                  all(_pkgl_gnome(p)["supported"] is False and _pkgl_gnome(p)["installable"] is False and _pkgl_gnome(p)["actions"] == []
                      for p in incompatible for _pkgl_gnome in [lambda pid: next((x for x in gnome_pkgs["packages"] if x["id"] == pid), {})]) and
                  next((x for x in gnome_pkgs["packages"] if x["id"] == "rdp"), {}).get("supported") is True and
                  next((x for x in gnome_pkgs["packages"] if x["id"] == "rdp"), {}).get("installable") is True)
        else:
            _fail("package-list keeps only GNOME Remote Desktop RDP for GNOME desktop selections")
        os.unlink(gnome_reg)

        # vnc prompt metadata
        vnc_pkg = _pkgl("vnc")
        _check("package-list exposes UI prompt metadata for package actions",
              any(a.get("id") == "vnc" and a.get("prompt", {}).get("env") == "VNC_VIEWER" and
                  [c["value"] for c in a.get("prompt", {}).get("choices", [])] == ["auto", "system", "tigervnc"]
                  for a in vnc_pkg.get("actions", [])))

        # rdp native action
        _check("package-list exposes RDP as native-capable package action",
              any(a.get("id") == "rdp" and a.get("target") == "rdp.open" and a.get("native") is True for a in _pkgl("rdp").get("actions", [])))

        # package-action dry-runs
        for pkg, action, target in [("rustdesk", "rustdesk-info", "rustdesk.info"), ("thinlinc", "web", "thinlinc.web"), ("nomachine", "nomachine-info", "nomachine.info")]:
            d = _run_json("scripts/package-action", "--instance", "dev-a", "--package", pkg, "--action", action, "--dry-run",
                          env={"EVE_INSTANCE_REGISTRY": FIXTURE})
            _check(f"{pkg} package action dry-run resolves manifest target",
                  d is not None and d.get("kind") == "package-action" and d.get("package") == pkg and d.get("action") == action and d.get("target") == target and d.get("dry_run") is True)

        # package-provision dry-runs
        d = _run_json("scripts/package-provision", "--instance", "dev-a", "--package", "rustdesk", "--dry-run", env={"EVE_INSTANCE_REGISTRY": FIXTURE})
        _check("package-provision dry-run honors EVE_INSTANCE_REGISTRY",
              d is not None and d.get("kind") == "package-provision" and d.get("instance") == "dev-a" and d.get("package") == "rustdesk" and d.get("dry_run") is True)

        d = _run_json("scripts/package-provision", "--profile", "local-qemu-ubuntu-dev-gui", "--package", "thinlinc", "--dry-run")
        _check("ThinLinc package-provision dry-run resolves install steps",
              d is not None and d.get("package") == "thinlinc" and "provision/ubuntu/thinlinc.sh" in d.get("steps", []) and "thinlinc" in d.get("package_markers", []))

        # remote-sunshine-wait
        rsw = (ROOT / "scripts/remote-sunshine-wait").read_text(encoding="utf-8", errors="replace")
        _check("remote-sunshine-wait only waits and does not start Sunshine",
              not re.search(r"Sunshine not responding|starting via SSH|Start-Process.*Sunshine|systemctl --user start sunshine", rsw))

        # remote-waypipe XQuartz rejection
        waypipe_bin = tempfile.mkdtemp(prefix="eve-waypipe-bin.")
        _make_exec(Path(waypipe_bin) / "waypipe", "#!/usr/bin/env sh\nexit 99\n")
        wp_env = {"PATH": f"{waypipe_bin}:{os.environ['PATH']}", "WAYLAND_DISPLAY": "", "DISPLAY": "/tmp/org.xquartz:0"}
        wp_r = _run("scripts/remote-waypipe", "dev-a", env=wp_env)
        _check("remote-waypipe rejects XQuartz without local Wayland", "X11/XQuartz display, not a Wayland socket" in wp_r.stderr)
        shutil.rmtree(waypipe_bin, ignore_errors=True)

        # bad plugin validation
        for fixture, needle, label in [
            (BAD_INSTALL_UBUNTU, "install.ubuntu.steps must be a non-empty list", "plugin with empty install.ubuntu.steps rejected"),
            (BAD_INSTALL_WIN_STATE, "install.windows.state_files contains unsupported entries", "plugin with unsupported install.windows.state_files rejected"),
            (BAD_INSTALL_NON_STR, "install.ubuntu.steps must be a list of strings", "plugin with non-string install.ubuntu.steps entry rejected"),
            (BAD_PROV_SUPPORTS, "supports.engines must be a list", "provider plugin with malformed supports.engines rejected"),
            (BAD_PKG_SUPPORTS, "supports.os_families must be a list", "package plugin with malformed supports.os_families rejected"),
        ]:
            r = _run("scripts/plugin-list", "--validate", env={"EVE_PLUGIN_ROOTS": fixture})
            _check(label, needle in (r.stderr + r.stdout))

        # provider dispatch dry-run matrix
        matrix_fail = 0
        for inst, prov_id, engine in [("dev-a", "local-qemu", "qemu"), ("qemu-a", "local-qemu", "qemu"), ("aws-gpu-a", "aws", "terraform"), ("truenas-all-a", "truenas", "terraform"), ("rpi-all-a", "raspberry-pi", "metal")]:
            for cmd_name in ["resolve", "init", "plan", "up", "down", "start", "stop", "status", "ip", "ssh"]:
                d = _run_json("scripts/provider-dispatch", "--registry", FIXTURE, "--instance", inst, "--command", cmd_name, "--dry-run",
                              env={"EVE_INSTANCE_WORKDIR": WRK_PROV})
                if not (d and d.get("kind") == "provider" and d.get("provider") == prov_id and d.get("command") == cmd_name and d.get("engine") == engine and d.get("dry_run") is True):
                    matrix_fail += 1
        _check("provider dispatch dry-run matrix", matrix_fail == 0)

        # provider manifest boundary
        boundary_fail = 0
        for mf in sorted(Path(".eve/plugins/eve-providers").glob("*/eve-plugin.yaml")):
            pdir = mf.parent
            pc = pdir / "commands" / "provider-command"
            if not (pc.is_file() and os.access(pc, os.X_OK)):
                boundary_fail += 1
            txt = mf.read_text(encoding="utf-8")
            if "scripts/provider-plugin" in txt:
                boundary_fail += 1
            if re.search(r'^  (init|plan|up|down|start|stop|status|ip|ssh): \{exec: commands/provider-command', txt, re.M):
                boundary_fail += 1
        _check("provider manifests route lifecycle commands through plugin-owned implementations", boundary_fail == 0)

        # provider lifecycle exec paths are executable
        import yaml
        exec_fail = False
        for mf in sorted(Path(".eve/plugins/eve-providers").glob("*/eve-plugin.yaml")):
            pdir = mf.parent
            commands = yaml.safe_load(mf.read_text(encoding="utf-8"))["commands"]
            for cmd_name in ["init", "plan", "up", "down", "start", "stop", "status", "ip", "ssh"]:
                spec = commands.get(cmd_name)
                if not spec:
                    exec_fail = True
                    break
                ep = Path(spec["exec"])
                exe = ep if ep.is_absolute() else pdir / ep
                if not (exe.is_file() and exe.stat().st_mode & 0o111):
                    exec_fail = True
                    break
        _check("provider lifecycle command exec paths are executable", not exec_fail)

        # provider action targets executable commands
        action_fail = False
        for mf in sorted(Path(".eve/plugins/eve-providers").glob("*/eve-plugin.yaml")):
            pdir = mf.parent
            plugin = yaml.safe_load(mf.read_text(encoding="utf-8"))
            actions = plugin.get("actions") or []
            if not actions:
                action_fail = True
                break
            for action in actions:
                target = action.get("target", "")
                if not target.startswith("provider."):
                    continue
                cmd_name = target.split(".", 1)[1]
                spec = plugin["commands"].get(cmd_name)
                if not spec:
                    action_fail = True
                    break
                ep = Path(spec["exec"])
                exe = ep if ep.is_absolute() else pdir / ep
                if not (exe.is_file() and exe.stat().st_mode & 0o111):
                    action_fail = True
                    break
        _check("provider action metadata targets executable provider commands", not action_fail)

        # instance-view provider actions
        iv = _run_json("scripts/instance-view", "--registry", FIXTURE, "--instance", "aws-gpu-a",
                       env={"EVE_INSTANCE_WORKDIR": f"{tempfile.gettempdir()}/eve-provider-action-view", "EVE_STATE_DIR": f"{tempfile.gettempdir()}/eve-provider-action-state"})
        _check("instance-view exposes provider action metadata",
              iv is not None and any(a.get("id") == "login" and a.get("target") == "provider.login" for a in iv.get("provider_actions", [])) and
              any(a.get("id") == "status-details" and a.get("target") == "provider.status" for a in iv.get("provider_actions", [])))

        # package status dry-run
        d = _run_json("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "docker", "--command", "status", "--dry-run", env={"EVE_INSTANCE_WORKDIR": WRK})
        _check("package status dry-run", d is not None and d.get("package") == "docker" and d.get("command") == "status" and d.get("selected") is True and d.get("status") == "unknown")

        # unsupported os family / version
        _grep_err("package dispatch rejects unsupported os family",
                  ["scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "win-only", "--command", "status", "--dry-run"],
                  "does not support os family ubuntu", env={"EVE_PLUGIN_ROOTS": WIN_ONLY, "EVE_INSTANCE_WORKDIR": WRK})
        _grep_err("package dispatch rejects unsupported os version",
                  ["scripts/package-dispatch", "--registry", FIXTURE, "--instance", "truenas-all-a", "--package", "xpra", "--command", "status", "--dry-run"],
                  "does not support ubuntu version 26.04", env={"EVE_INSTANCE_WORKDIR": WRK})

        # ubuntu/windows provision step mapping
        d = _run_json("scripts/package-provision", "--profile", "local-qemu-ubuntu-dev-gui", "--package", "docker", "--dry-run")
        _check("ubuntu package install maps to granular provision steps", d is not None and d.get("steps") == ["base.sh", "timezone.sh", "provision/ubuntu/docker.sh"])

        d = _run_json("scripts/package-provision", "--profile", "local-qemu-ubuntu-dev-gui", "--package", "codex-cli", "--dry-run")
        _check("package install includes dependency package markers", d is not None and d.get("steps") == ["base.sh", "timezone.sh", "provision/ubuntu/dev-toolchain.sh", "provision/ubuntu/codex-cli.sh"] and d.get("package_markers") == ["dev-toolchain", "codex-cli"])

        # windows provision checks
        for pkg, steps, state_files, fallback in [
            ("steam", ["provision/windows/steam.ps1"], [], False),
            ("rustdesk", ["provision/windows/rustdesk.ps1"], ["env.json"], False),
            ("xpra", ["provision/windows/xpra.ps1"], [], False),
            ("sunshine", [], [], True),
            ("docker", [], [], True),
        ]:
            d = _run_json("scripts/package-provision-windows", "--profile", "vultr-windows-gaming", "--package", pkg, "--dry-run")
            _check(f"windows {pkg} provision mapping", d is not None and d.get("package") == pkg and d.get("steps") == steps and d.get("state_files") == state_files and d.get("fallback") == fallback)

        _check("windows rustdesk install uploads env.json so rendezvous/key/password are configured",
              "env.json" in (_run_json("scripts/package-provision-windows", "--profile", "vultr-windows-gaming", "--package", "rustdesk", "--dry-run") or {}).get("state_files", []))

        # manifest step assertions
        _check("steam plugin manifest declares ubuntu install steps",
              ",".join(_pkg("steam").get("install", {}).get("ubuntu", {}).get("steps", [])) == "base.sh,timezone.sh,provision/ubuntu/steam.sh")

        sunshine_win_steps = ",".join(_pkg("sunshine").get("install", {}).get("windows", {}).get("steps", []))
        expected_win = "provision/windows/10_sunshine.ps1,provision/windows/11_vigembus.ps1,provision/windows/20_vdd.ps1,provision/windows/21_vdd_config.ps1,provision/windows/22_vdd_only_display.ps1,provision/windows/23_sunshine_target_vdd.ps1,provision/windows/31_virtual_audio.ps1"
        _check("sunshine plugin manifest owns reboot-coupled Windows steps", sunshine_win_steps == expected_win)

        # hardcoded reference checks
        for script in ["scripts/package-provision", "scripts/package-provision-windows"]:
            txt = Path(ROOT / script).read_text(encoding="utf-8", errors="replace")
            _check(f'no hardcoded case "$PACKAGE" mapping in {script}', not re.search(r'case\s+"?\$PACKAGE"?', txt))

        # package list via make
        pl_env = {"EVE_INSTANCE_REGISTRY": FIXTURE}
        pl_r = _run("make", "--no-print-directory", "package.list", "INSTANCE=dev-a", "EMIT=json", env=pl_env)
        try:
            pl = json.loads(pl_r.stdout)
            _check("package list shows selected and available packages",
                  pl.get("instance") == "dev-a" and
                  any(p["id"] == "docker" and p["selected"] and p["supported"] and "bundle:dev-ai" in p.get("selected_by", []) for p in pl["packages"]) and
                  any(p["id"] == "steam" and not p["selected"] and p.get("selected_by") == [] for p in pl["packages"]))
        except Exception:
            _fail("package list shows selected and available packages")

        # destructive down requires confirmation
        _check("destructive package down requires confirmation",
              _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "docker", "--command", "down", "--dry-run", env={"EVE_INSTANCE_WORKDIR": WRK}).returncode != 0)

        # dummy reinstall = down then install
        d = _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "dummy", "--command", "reinstall", "--dry-run",
                 env={"EVE_PLUGIN_ROOTS": PLUGIN_FIXTURE, "EVE_INSTANCE_WORKDIR": WRK})
        try:
            cmds = [json.loads(line) for line in d.stdout.strip().split("\n") if line.strip()]
            _check("package reinstall defaults to down then install", [c["command"] for c in cmds] == ["down", "install"])
        except Exception:
            _fail("package reinstall defaults to down then install")

        # dummy/local-exec/override hook dispatch
        for label, pkg, roots_env, kind in [
            ("package plugin command folder hook runs", "dummy", {"EVE_PLUGIN_ROOTS": PLUGIN_FIXTURE}, "package-hook"),
            ("external plugin-local exec dispatch runs", "local-exec", {"EVE_PLUGIN_ROOTS": LOCAL_EXEC_FIXTURE}, "package-local-exec"),
            ("external plugin override dispatch runs", "docker", {"EVE_PLUGIN_ALLOW_OVERRIDE": "1", "EVE_PLUGIN_ROOTS": OVERRIDE_FIXTURE}, "package-override"),
        ]:
            d = _run_json("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", pkg, "--command", "status",
                          env={**roots_env, "EVE_INSTANCE_WORKDIR": WRK, "EVE_DISABLE_STATE": "1"})
            _check(label, d is not None and d.get("kind") == kind and d.get("package") == pkg and d.get("instance") == "dev-a")

        # built-in hook presence
        for pkg_set, repo, hook in [
            (["claude", "codex-cli", "dev-toolchain", "docker", "gnome-desktop", "goose", "hermes", "macos-desktop-theme", "opencode", "rdp", "rustdesk", "steam", "sunshine", "vnc", "vscode", "waypipe", "xpra"], "eve-packages-linux", "ubuntu"),
            (["rustdesk", "steam", "sunshine", "xpra"], "eve-packages-windows", "windows"),
        ]:
            for action in ["down", "status"]:
                missing = [p for p in pkg_set if not (ROOT / f".eve/plugins/{repo}/{p}/commands/{hook}/{action}").exists()]
                _check(f"built-in {hook} packages have {action} hooks", not missing, f"missing: {missing}")

        # built-in docker down dry-run
        d = _run_json("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "docker", "--command", "down", "--dry-run", "--yes", env={"EVE_INSTANCE_WORKDIR": WRK})
        _check("built-in package down dry-run exposes removal command",
              d is not None and d.get("kind") == "package-down" and d.get("package") == "docker" and d.get("instance") == "dev-a" and d.get("os_family") == "ubuntu" and d.get("dry_run") is True and "docker-ce" in d.get("command", ""))

        # hardcoded down mappings
        pp_txt = (ROOT / "scripts/package-plugin").read_text(encoding="utf-8", errors="replace")
        _check("package down implementations live in plugin hooks",
              not re.search(r'"(claude|codex-cli|dev-toolchain|docker|gnome-desktop|goose|hermes|macos-desktop-theme|opencode|rdp|rustdesk|steam|sunshine|vscode|vnc|waypipe|xpra)"\s*=>', pp_txt))

        # --- state tests with fake SSH ---
        fake_ssh = Path(state_dir) / "fake-instance-ssh"
        _make_exec(fake_ssh, "#!/usr/bin/env sh\nset -eu\nprintf 'installed\\n'\n")
        fake_down_ssh = Path(state_dir) / "fake-instance-down-ssh"
        _make_exec(fake_down_ssh, "#!/usr/bin/env sh\nset -eu\nexit 0\n")
        fake_capture_ssh = Path(state_dir) / "fake-capture-instance-ssh"
        _make_exec(fake_capture_ssh, '#!/usr/bin/env sh\nset -eu\nprintf \'%s\\n\' "$*" >"${EVE_FAKE_SSH_ARGS:?}"\nprintf \'#< CLIXML\\n\'\nprintf \'installed\\n\'\n')
        fake_running_ssh = Path(state_dir) / "fake-running-ssh"
        _make_exec(fake_running_ssh, "#!/usr/bin/env sh\nset -eu\nprintf 'running\\n'\n")
        fake_args_file = Path(state_dir) / "fake-ssh-args.txt"

        # package status helper
        d = _run_json("scripts/package-status-command", "docker", "ignored",
                      env={"EVE_PACKAGE_STATUS_SSH": str(fake_ssh), "EVE_INSTANCE_NAME": "dev-a"})
        _check("package status helper emits status contract",
              d is not None and d.get("kind") == "package-status" and d.get("package") == "docker" and d.get("instance") == "dev-a" and d.get("os_family") == "ubuntu" and d.get("status") == "installed")

        # windows status helper
        d = _run_json("scripts/package-status-windows", "steam", "C:\\Program Files (x86)\\Steam\\steam.exe",
                      env={"EVE_PACKAGE_STATUS_SSH": str(fake_capture_ssh), "EVE_FAKE_SSH_ARGS": str(fake_args_file), "EVE_INSTANCE_NAME": "win-a"})
        _check("windows package status helper emits status contract",
              d is not None and d.get("kind") == "package-status" and d.get("package") == "steam" and d.get("instance") == "win-a" and d.get("os_family") == "windows" and d.get("status") == "installed" and d.get("details") == "installed")

        # windows running status
        d = _run_json("scripts/package-status-windows", "rustdesk", "C:\\Program Files\\RustDesk\\rustdesk.exe",
                      env={"EVE_PACKAGE_STATUS_SSH": str(fake_running_ssh), "EVE_INSTANCE_NAME": "win-a", "EVE_PACKAGE_STATUS_PROCESS": "rustdesk", "EVE_PACKAGE_STATUS_SERVICE_PATTERN": "rustdesk"})
        _check("windows package status helper keeps running packages installed",
              d is not None and d.get("status") == "installed" and d.get("details") == "running")

        # encoded powershell command check
        args_content = fake_args_file.read_text(encoding="utf-8") if fake_args_file.exists() else ""
        _check("windows package status helper protects powershell variables from ssh shell expansion",
              "-EncodedCommand" in args_content and "$paths" not in args_content)

        # package down helper
        d = _run_json("scripts/package-down-command", "docker", "sudo apt-get remove -y docker-ce || true",
                      env={"EVE_PACKAGE_DOWN_SSH": str(fake_down_ssh), "EVE_INSTANCE_NAME": "dev-a"})
        _check("package down helper emits removal contract",
              d is not None and d.get("kind") == "package-down" and d.get("package") == "docker" and d.get("instance") == "dev-a" and d.get("os_family") == "ubuntu" and d.get("status") == "removed")

        # windows down helper
        d = _run_json("scripts/package-down-windows", "steam", "winget uninstall --id Valve.Steam --silent; exit 0",
                      env={"EVE_PACKAGE_DOWN_SSH": str(fake_down_ssh), "EVE_INSTANCE_NAME": "win-a"})
        _check("windows package down helper emits removal contract",
              d is not None and d.get("kind") == "package-down" and d.get("package") == "steam" and d.get("instance") == "win-a" and d.get("os_family") == "windows" and d.get("status") == "removed")

        # instance state tests
        SE = {"EVE_STATE_DIR": state_dir}
        empty = _run_json("scripts/instance-state", "--instance", "fresh-a", "--get", env=SE)
        _check("instance state get returns default state shape",
              empty is not None and empty.get("instance") == "fresh-a" and empty.get("desired_state") == "unknown" and empty.get("provider_state") == "unknown" and empty.get("provision_state") == "unknown" and empty.get("package_state") == {} and empty.get("operation_history") == [])

        sj = _run_json("scripts/instance-state", "--instance", "dev-a", "--operation", "package.down", "--status", "succeeded", "--desired-state", "running", "--provider-state", "running", "--package", "docker", "--package-state", "removed", env=SE)
        _check("instance state records package operation",
              sj is not None and sj.get("last_operation", {}).get("name") == "package.down" and sj["last_operation"]["type"] == "package" and sj["last_operation"]["id"] == 1 and sj.get("desired_state") == "running" and sj.get("provider_state") == "running" and sj.get("package_state", {}).get("docker", {}).get("status") == "removed" and len(sj.get("operation_history", [])) == 1)

        # recover running
        _run("scripts/instance-state", "--instance", "recover-a", "--operation", "provider.up", "--status", "running", "--provider-state", "changing", env=SE)
        rec = _run_json("scripts/instance-state", "--instance", "recover-a", "--recover-running", env=SE)
        _check("instance state recovers interrupted running operation",
              rec is not None and rec.get("last_operation", {}).get("status") == "failed" and rec.get("provider_state") == "error" and rec.get("last_error") is not None and "Recovered interrupted operation provider.up" in rec["last_error"])

        # recover read-only
        _run("scripts/instance-state", "--instance", "recover-read-a", "--operation", "provider.up", "--status", "succeeded", "--desired-state", "running", "--provider-state", "running", env=SE)
        _run("scripts/instance-state", "--instance", "recover-read-a", "--operation", "provider.ip", "--status", "running", env=SE)
        rec2 = _run_json("scripts/instance-state", "--instance", "recover-read-a", "--recover-running", env=SE)
        _check("instance state recover preserves read-only provider state",
              rec2 is not None and rec2.get("last_operation", {}).get("name") == "provider.ip" and rec2["last_operation"]["status"] == "failed" and rec2.get("provider_state") == "running" and rec2.get("last_error") is not None and "Recovered interrupted operation provider.ip" in rec2["last_error"])

        # invalid state values
        for args, needle, label in [
            (["--operation", "provider.status", "--status", "succeeded", "--provider-state", "nonsense"], "provider_state must be one of:", "instance state rejects invalid provider_state"),
            (["--operation", "package.status", "--status", "succeeded", "--package", "docker", "--package-state", "bogus"], "package_state must be one of:", "instance state rejects invalid package_state"),
            (["--operation", "package.status", "--status", "succeeded", "--package", "docker"], "package and package_state must be provided together", "instance state rejects incomplete package update"),
        ]:
            r = _run("scripts/instance-state", "--instance", "dev-a", *args, env=SE)
            _check(label, r.returncode != 0 and needle in r.stderr)

        # package dispatch records state
        _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "docker", "--command", "status",
             env={**SE, "EVE_PACKAGE_STATUS_SSH": str(fake_ssh), "EVE_INSTANCE_WORKDIR": WRK})
        rs = _run_json("scripts/instance-state", "--instance", "dev-a", "--get", env=SE)
        _check("package dispatch records state",
              rs is not None and rs.get("last_operation", {}).get("name") == "package.status" and rs["last_operation"]["status"] == "succeeded" and rs.get("package_state", {}).get("docker", {}).get("status") == "installed" and [rs["operation_history"][-2]["status"], rs["operation_history"][-1]["status"]] == ["running", "succeeded"])

        # hook status
        _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "dummy", "--command", "status",
             env={**SE, "EVE_PLUGIN_ROOTS": PLUGIN_FIXTURE, "EVE_INSTANCE_WORKDIR": WRK})
        hs = _run_json("scripts/instance-state", "--instance", "dev-a", "--get", env=SE)
        _check("package dispatch records hook status contract",
              hs is not None and hs.get("package_state", {}).get("dummy", {}).get("status") == "installed")

        # failed package state
        _run("scripts/package-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--package", "missing-package", "--command", "status",
             env={**SE, "EVE_INSTANCE_WORKDIR": WRK})
        fs = _run_json("scripts/instance-state", "--instance", "dev-a", "--get", env=SE)
        _check("package dispatch records failed package state",
              fs is not None and fs.get("last_operation", {}).get("name") == "package.status" and fs["last_operation"]["status"] == "failed" and fs.get("last_error") is not None and fs.get("package_state", {}).get("missing-package", {}).get("status") == "failed")

        # provider dispatch state
        _run("scripts/instance-state", "--instance", "dev-a", "--operation", "provider.up", "--status", "succeeded", "--desired-state", "running", "--provider-state", "running", env=SE)
        _run("scripts/provider-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--command", "ip", env={**SE, "EVE_INSTANCE_WORKDIR": WRK_PROV})
        fips = _run_json("scripts/instance-state", "--instance", "dev-a", "--get", env=SE)
        _check("provider dispatch read failures preserve lifecycle state",
              fips is not None and fips.get("last_operation", {}).get("name") == "provider.ip" and fips["last_operation"]["status"] == "failed" and fips.get("provider_state") == "running" and fips.get("last_error") is not None)

        _run("scripts/provider-dispatch", "--registry", FIXTURE, "--instance", "dev-a", "--command", "bogus", env={**SE, "EVE_INSTANCE_WORKDIR": WRK_PROV})
        fps = _run_json("scripts/instance-state", "--instance", "dev-a", "--get", env=SE)
        _check("provider dispatch records failed provider state",
              fps is not None and fps.get("last_operation", {}).get("name") == "provider.bogus" and fps["last_operation"]["status"] == "failed" and fps.get("provider_state") == "error" and fps.get("last_error") is not None)

        # schema validation callers
        import subprocess as _sp
        contract_grep = _sp.run(["rg", "validate_(def|output)", "eve_sdk", "scripts/package-dispatch", "scripts/provider-dispatch"],
                                cwd=str(ROOT), capture_output=True, text=True, check=False)
        _check("schema validation has real callers in provider and package dispatch", bool(contract_grep.stdout.strip()))

        # schema validation tests
        for json_str, label in [
            ('{"status":"not-a-valid-status"}', "schema validation rejects invalid package command output"),
            ('{"status":"not-a-valid-status"}', "schema validation rejects invalid provider command output status"),
            ('{"ip":""}', "schema validation rejects empty provider command output ip"),
        ]:
            r = _run("python3", "-c",
                     "import json,sys; from eve_sdk.schema import SchemaValidationError, validate_def; "
                     "validate_def('command-io.schema.json','provider_command_output',json.load(sys.stdin),'Command output')",
                     input_data=json_str)
            _check(label, "failed schema validation" in r.stderr)

        # valid provider output
        r = _run("python3", "-c",
                 "import json,sys; from eve_sdk.schema import SchemaValidationError, validate_def; "
                 "validate_def('command-io.schema.json','provider_command_output',json.load(sys.stdin),'Command output')",
                 input_data='{"status":"running"}')
        _check("schema validation accepts valid provider command output", not r.stderr)

        # provider dispatch rejects invalid status
        psc = Path(profile_dir) / "provider-status-catalog.local.yaml"
        psc.write_text("machines:\n  - name: acme-small\n    provider: acme\n    kind: vm\n    defaults:\n      disk_gb: 30\n      memory_mb: 4096\nlocations:\n  - name: tokyo\n    acme:\n      region: test-region\ninits:\n  - id: ssh-ubuntu-cloud-init\n    providers: [acme]\n", encoding="utf-8")
        psr = Path(profile_dir) / "provider-status-instances.yaml"
        psr.write_text("version: 1\ninstances:\n  - name: acme-a\n    machine: acme-small\n    os: ubuntu-26.04-amd64\n    init: ssh-ubuntu-cloud-init\n    packages: [docker]\n    location: tokyo\n", encoding="utf-8")
        r = _run("scripts/provider-dispatch", "--registry", str(psr), "--instance", "acme-a", "--command", "status",
                 env={"EVE_PLUGIN_ROOTS": BAD_PROV_STATUS, "EVE_CATALOG_LOCAL": str(psc), "EVE_INSTANCE_WORKDIR": f"{profile_dir}/pd-workdir", "EVE_DISABLE_STATE": "1"})
        _check("provider dispatch rejects invalid status from provider command output", "failed schema validation" in r.stderr)

        # provision-status jq tests (translated from jq to Python)
        def _prov_status_valid(d):
            if d.get("api_version") != 1: return False
            if d.get("os_family") not in ("ubuntu", "windows"): return False
            if "started_at" not in d: return False
            if not (d["started_at"] is None or isinstance(d["started_at"], str)): return False
            if d.get("status") not in ("running", "done", "failed"): return False
            if not isinstance(d.get("steps"), list): return False
            for s in d["steps"]:
                if not (isinstance(s.get("step"), str) and len(s["step"]) > 0): return False
                if s.get("phase") not in ("pending", "running", "succeeded", "failed", "skipped"): return False
                for k in ("started_at", "ended_at", "exit_code"):
                    if k not in s: return False
                if not (s["started_at"] is None or isinstance(s["started_at"], str)): return False
                if not (s["ended_at"] is None or isinstance(s["ended_at"], str)): return False
                if not (s["exit_code"] is None or isinstance(s["exit_code"], int)): return False
            return True

        for json_str, expected_valid, label in [
            ('{"api_version":1,"started_at":null,"status":"running","steps":[]}', False, "provision-status jq rejects missing os_family"),
            ('{"api_version":1,"os_family":"ubuntu","status":"running","steps":[]}', False, "provision-status jq rejects missing started_at"),
            ('{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"running","exit_code":null}]}', False, "provision-status jq rejects step missing started_at/ended_at"),
            ('{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"running","started_at":123,"ended_at":null,"exit_code":null}]}', False, "provision-status jq rejects non-string step started_at"),
            ('{"api_version":1,"os_family":"ubuntu","started_at":"2025-01-15T10:30:00Z","status":"running","steps":[{"step":"base.sh","phase":"succeeded","started_at":"2025-01-15T10:30:00Z","ended_at":"2025-01-15T10:31:00Z","exit_code":0},{"step":"human-user.sh","phase":"running","started_at":"2025-01-15T10:31:01Z","ended_at":null,"exit_code":null}]}', True, "provision-status jq accepts valid running status"),
        ]:
            try:
                d = json.loads(json_str)
                result = _prov_status_valid(d)
            except Exception:
                result = False
            _check(label, result == expected_valid)

    finally:
        shutil.rmtree(profile_dir, ignore_errors=True)
        shutil.rmtree(state_dir, ignore_errors=True)

    return 1 if FAIL else 0


if __name__ == "__main__":
    raise SystemExit(main())
