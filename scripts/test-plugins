  printf '  [OK] built-in package down dry-run exposes removal command\n'
else
  printf '  [FAIL] built-in package down dry-run contract mismatch\n' >&2
  printf '%s\n' "$builtin_docker_down_dry_run" >&2
  FAIL=$((FAIL + 1))
