#!/usr/bin/env sh
# Run or describe a Linux package removal command for a package plugin.

set -eu

package="${1:?Usage: package-down-command <package> <remote-command>}"
remote_command="${2:?Usage: package-down-command <package> <remote-command>}"
profile="${EGAME_INSTANCE_NAME:?EGAME_INSTANCE_NAME is required}"
ssh_cmd="${EGAME_PACKAGE_DOWN_SSH:-./scripts/instance-ssh}"

if resolved_env=$(./scripts/profile-resolve --profile "$profile" --emit env 2>/dev/null); then
  ssh_user=$(printf "%s\n" "$resolved_env" | awk -F= '/^SSH_USER=/{print $2}')
  vm_user_name=$(printf "%s\n" "$resolved_env" | awk -F= '/^VM_USER_NAME=/{print $2}')
else
  ssh_user=""
  vm_user_name=""
fi
human_user="${vm_user_name:-$ssh_user}"
human_user="${human_user:-$(id -un)}"
case "$human_user" in
  *[!a-zA-Z0-9._-]*)
    echo "package-down-command: unsupported VM user name: $human_user" >&2
    exit 2
    ;;
esac

remote_command_with_context=$(cat <<EOF
set -eu
EGAME_HUMAN_USER="$human_user"
EGAME_HUMAN_HOME=\$(getent passwd "\$EGAME_HUMAN_USER" | cut -d: -f6)
EGAME_HUMAN_UID=\$(id -u "\$EGAME_HUMAN_USER")
export EGAME_HUMAN_USER EGAME_HUMAN_HOME EGAME_HUMAN_UID
export HOME="\$EGAME_HUMAN_HOME"
export PATH="\$EGAME_HUMAN_HOME/.local/bin:\$PATH"
egame_human_run() {
  sudo -H -u "\$EGAME_HUMAN_USER" env \
    HOME="\$EGAME_HUMAN_HOME" \
    USER="\$EGAME_HUMAN_USER" \
    LOGNAME="\$EGAME_HUMAN_USER" \
    XDG_RUNTIME_DIR="/run/user/\$EGAME_HUMAN_UID" \
    "\$@"
}
$remote_command
EOF
)

if [ "${EGAME_PLUGIN_DRY_RUN:-0}" = "1" ]; then
  jq -n \
    --arg package "$package" \
    --arg instance "$profile" \
    --arg command "$remote_command" \
    '{kind: "package-down", package: $package, instance: $instance, os_family: "ubuntu", command: $command, dry_run: true}'
  exit 0
fi

"$ssh_cmd" "$profile" -- "$remote_command_with_context"
jq -n \
  --arg package "$package" \
  --arg instance "$profile" \
  '{kind: "package-down", package: $package, instance: $instance, os_family: "ubuntu", status: "removed"}'
