#!/usr/bin/env bash
# Run non-Python lint and syntax checks.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

FAIL=0

printf '  -- yaml syntax --\n'
YAML_FILES=()
while IFS= read -r file; do
  YAML_FILES+=("$file")
done < <(find .github config plugins tests -type f \( -name '*.yaml' -o -name '*.yml' \) | sort)
if ! python3 - "${YAML_FILES[@]}" <<'PY'; then
import sys

import yaml

for path in sys.argv[1:]:
    try:
        with open(path, encoding="utf-8") as handle:
            yaml.safe_load(handle)
    except Exception as error:
        print(f"{path}: {error.__class__.__name__}: {error}", file=sys.stderr)
        raise SystemExit(1) from error
PY
  FAIL=$((FAIL + 1))
fi

printf '  -- terraform fmt --\n'
TF_FMT_DIRS=()
for dir in modules stacks plugins/providers; do
  [ -d "$dir" ] && TF_FMT_DIRS+=("$dir")
done
if [ "${#TF_FMT_DIRS[@]}" -gt 0 ] && ! terraform fmt -check -recursive -no-color "${TF_FMT_DIRS[@]}" >/dev/null; then
  terraform fmt -check -recursive -no-color "${TF_FMT_DIRS[@]}" >&2 || true
  FAIL=$((FAIL + 1))
fi

printf '  -- terramate fmt --\n'
tmp_dir="$(mktemp -d "${TMPDIR:-/tmp}/eve-terramate-fmt.XXXXXX")"
trap 'rm -rf "$tmp_dir"' EXIT
while IFS= read -r file; do
  tmp_file="$tmp_dir/${file//\//__}"
  cp "$file" "$tmp_file"
  terramate fmt --quiet "$tmp_file"
  if ! cmp -s "$file" "$tmp_file"; then
    printf '  [FAIL] terramate fmt: %s\n' "$file" >&2
    diff -u "$file" "$tmp_file" >&2 || true
    FAIL=$((FAIL + 1))
  fi
done < <(find . -type f -name '*.tm.hcl' -not -path './.terraform-cache-dir/*' | sort)

if [ "$FAIL" -ne 0 ]; then
  exit 1
fi

printf '  [OK] non-Python lint and syntax checks pass\n'
