#!/usr/bin/env python3
"""Run non-Python lint and syntax checks."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def main() -> int:
    fail = 0

    # -- yaml syntax --
    print("  -- yaml syntax --")
    yaml_files = sorted(
        str(p)
        for pattern in [".github", "config", "plugins", "tests"]
        for p in (ROOT / pattern).rglob("*")
        if p.is_file() and p.suffix in (".yaml", ".yml")
    )
    try:
        import yaml
        for path in yaml_files:
            try:
                with open(path, encoding="utf-8") as handle:
                    yaml.safe_load(handle)
            except Exception as error:
                print(f"{path}: {error.__class__.__name__}: {error}", file=sys.stderr)
                raise
    except Exception:
        fail += 1

    # -- terraform fmt --
    print("  -- terraform fmt --")
    tf_dirs = [str(ROOT / d) for d in ("modules", "stacks", "plugins/providers") if (ROOT / d).is_dir()]
    if tf_dirs:
        result = subprocess.run(
            ["terraform", "fmt", "-check", "-recursive", "-no-color", *tf_dirs],
            cwd=str(ROOT), capture_output=True, check=False,
        )
        if result.returncode != 0:
            print(result.stderr.decode(errors="replace"), file=sys.stderr)
            fail += 1

    # -- terramate fmt --
    print("  -- terramate fmt --")
    tmp_dir = tempfile.mkdtemp(prefix="eve-terramate-fmt.")
    try:
        tm_files = sorted(
            p for p in ROOT.rglob("*.tm.hcl")
            if ".terraform-cache-dir" not in str(p)
        )
        for f in tm_files:
            tmp_file = Path(tmp_dir) / str(f.relative_to(ROOT)).replace("/", "__")
            shutil.copy2(f, tmp_file)
            subprocess.run(["terramate", "fmt", "--quiet", str(tmp_file)], check=False)
            if Path(f).read_bytes() != tmp_file.read_bytes():
                print(f"  [FAIL] terramate fmt: {f.relative_to(ROOT)}", file=sys.stderr)
                fail += 1
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)

    if fail:
        return 1
    print("  [OK] non-Python lint and syntax checks pass")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
