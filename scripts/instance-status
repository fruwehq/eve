#!/usr/bin/env ruby
# Emit a combined local status view for a concrete v3 instance.
# State reads go through core/sdk/state.rb (sole state owner).
# The JSON output is the shared view object consumed by the TUI.

require "json"
require "open3"

ROOT = File.expand_path("..", __dir__)
$LOAD_PATH.unshift(File.join(ROOT, "core"))
require "sdk"

def usage
  warn <<~USAGE
    Usage:
      scripts/instance-status --instance <name> [--registry <path>] [--json]
  USAGE
end

def run_json(*cmd)
  out, status = Open3.capture2e(*cmd)
  raise out unless status.success?

  JSON.parse(out)
end

instance_name = nil
registry_path = ENV["EVE_INSTANCE_REGISTRY"] ? File.expand_path(ENV["EVE_INSTANCE_REGISTRY"], Dir.pwd) : nil
json = false

args = ARGV.dup
until args.empty?
  case args.shift
  when "--instance"
    instance_name = args.shift
  when "--registry"
    registry_path = File.expand_path(args.shift, Dir.pwd)
  when "--json"
    json = true
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

unless instance_name
  usage
  exit 2
end

begin
  resolve_cmd = [File.join(ROOT, "scripts/instance-resolve"), "--instance", instance_name, "--emit", "json"]
  paths_cmd = [File.join(ROOT, "scripts/instance-paths"), "--instance", instance_name, "--emit", "json"]
  package_cmd = [File.join(ROOT, "scripts/package-list"), "--instance", instance_name, "--json"]
  if registry_path
    resolve_cmd += ["--registry", registry_path]
    paths_cmd += ["--registry", registry_path]
    package_cmd += ["--registry", registry_path]
  end

  resolved = run_json(*resolve_cmd)
  paths = run_json(*paths_cmd)
  packages = run_json(*package_cmd).fetch("packages")

  status = Eve::SDK::State.build_view(
    instance_name: instance_name,
    resolved: resolved,
    packages: packages,
    paths: paths
  )

  state = status["state"]

  if json
    puts JSON.pretty_generate(status)
  else
    instance = status.fetch("instance")
    printf "Instance: %s\n", instance.fetch("name")
    printf "Provider: %s (%s, %s)\n", instance.fetch("provider"), instance.fetch("provider_plugin"), instance.fetch("engine")
    printf "OS: %s (%s)\n", instance.fetch("os"), instance.fetch("os_family")
    printf "State: desired=%s provider=%s provision=%s\n",
           state.fetch("desired_state"),
           state.fetch("provider_state"),
           state.fetch("provision_state")
    observed = state.fetch("observed_state", {})
    unless observed.empty?
      printf "Observed: provider=%s ip=%s at=%s\n",
             observed.fetch("provider_status", "unknown"),
             observed.fetch("ip", "-"),
             observed.fetch("observed_at", "unknown")
      printf "Refresh error: %s\n", observed["refresh_error"] if observed["refresh_error"]
    end
    printf "Last operation: %s\n", state["last_operation"] ? "#{state.dig("last_operation", "name")} #{state.dig("last_operation", "status")}" : "none"
    printf "Last error: %s\n", state["last_error"] || "none"
    package_summary = status.fetch("packages", {}).fetch("summary", {})
    selected_packages = status.fetch("packages", {}).fetch("selected", [])
    printf "Selected package states: installed=%d missing=%d unknown=%d failed=%d\n",
           package_summary.fetch("installed"),
           package_summary.fetch("missing"),
           package_summary.fetch("unknown"),
           package_summary.fetch("failed")
    if selected_packages.empty?
      printf "Selected packages: none\n"
    else
      printf "\n%-24s %-11s %-9s %s\n", "PACKAGE", "STATE", "SUPPORTED", "SELECTED_BY"
      printf "%-24s %-11s %-9s %s\n", "-------", "-----", "---------", "-----------"
      selected_packages.each do |package|
        printf "%-24s %-11s %-9s %s\n",
               package.fetch("id"),
               package.dig("state", "status") || "unknown",
               package["supported"] ? "yes" : "no",
               package.fetch("selected_by", []).join(",")
      end
    end
  end
rescue StandardError => e
  warn "instance-status: #{e.message}"
  exit 1
end
