#!/usr/bin/env python3
"""Validate GitHub Actions pipeline assumptions that local unit tests do not cover."""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path
from typing import Any

try:
    import yaml
except ModuleNotFoundError:
    print("PyYAML is required for scripts/test-ci-pipeline; run `poetry install`.", file=sys.stderr)
    raise SystemExit(2) from None


class Checks:
    def __init__(self) -> None:
        self.failures = 0

    def ok(self, message: str) -> None:
        print(f"  [OK] {message}")

    def fail(self, message: str) -> None:
        self.failures += 1
        print(f"  [FAIL] {message}", file=sys.stderr)

    def assert_check(self, message: str, condition: bool) -> None:
        if condition:
            self.ok(message)
        else:
            self.fail(message)


def repo_root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        check=True,
        stdout=subprocess.PIPE,
        text=True,
    )
    return Path(result.stdout.strip())


def load_workflow(path: Path) -> dict[str, Any]:
    with path.open() as handle:
        loaded = yaml.safe_load(handle)
    if not isinstance(loaded, dict):
        raise SystemExit(f"{path} did not parse to a YAML mapping")
    return loaded


def step_names(steps: list[Any]) -> list[str]:
    return [step["name"] for step in steps if isinstance(step, dict) and isinstance(step.get("name"), str)]


def find_step(steps: list[Any], name: str) -> dict[str, Any] | None:
    for step in steps:
        if isinstance(step, dict) and step.get("name") == name:
            return step
    return None


def run_text(step: dict[str, Any] | None) -> str:
    if step is None:
        return ""
    run = step.get("run", "")
    return run if isinstance(run, str) else ""


def http_head_ok(url: str, redirects: int = 5) -> tuple[bool, str]:
    if redirects < 0:
        return False, "too many redirects"

    request = urllib.request.Request(url, method="HEAD")
    try:
        with urllib.request.urlopen(request, timeout=10) as response:
            status = response.status
            if 200 <= status < 300:
                return True, str(status)
            if 300 <= status < 400:
                location = response.headers.get("location")
                if location is None:
                    return False, f"{status} redirect without location"
                redirected = urllib.parse.urljoin(url, location)
                return http_head_ok(redirected, redirects=redirects - 1)
            return False, f"{status} {response.reason}"
    except urllib.error.HTTPError as error:
        return False, f"{error.code} {error.reason}"
    except urllib.error.URLError as error:
        return False, str(error.reason)


def count_docker_builds(workflow: dict[str, Any]) -> int:
    jobs = workflow.get("jobs", {})
    if not isinstance(jobs, dict):
        return 0

    count = 0
    for job in jobs.values():
        if not isinstance(job, dict):
            continue
        steps = job.get("steps", [])
        if not isinstance(steps, list):
            continue
        for step in steps:
            if isinstance(step, dict) and "docker build -f docker/Dockerfile --target runtime-slim" in run_text(step):
                count += 1
    return count


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--offline", action="store_true", help="Skip remote release-asset checks")
    args = parser.parse_args()

    root = repo_root()
    os.chdir(root)
    workflow_path = root / ".github/workflows/test.yml"
    workflow = load_workflow(workflow_path)
    checks = Checks()

    print("\n== ci-pipeline workflow contract ==")

    triggers = workflow.get("on", workflow.get(True))
    checks.assert_check(
        "workflow runs on pull_request",
        isinstance(triggers, dict) and "pull_request" in triggers,
    )

    jobs = workflow.get("jobs", {})
    if not isinstance(jobs, dict):
        raise SystemExit("workflow jobs must be a mapping")

    test_job = jobs.get("test", {})
    matrix_os = test_job.get("strategy", {}).get("matrix", {}).get("os") if isinstance(test_job, dict) else None
    checks.assert_check(
        "test matrix includes macos-latest and ubuntu-24.04",
        isinstance(matrix_os, list) and sorted(matrix_os) == ["macos-latest", "ubuntu-24.04"],
    )

    test_steps = test_job.get("steps", []) if isinstance(test_job, dict) else []
    if not isinstance(test_steps, list):
        test_steps = []
    test_step_names = step_names(test_steps)
    checks.assert_check("test job installs Terramate", "Install Terramate" in test_step_names)
    checks.assert_check("test job runs make test", "Run make test" in test_step_names)
    checks.assert_check("test job publishes timing summary", "Timing summary" in test_step_names)
    checks.assert_check(
        "test job writes timing summary to GITHUB_STEP_SUMMARY",
        "$GITHUB_STEP_SUMMARY" in run_text(find_step(test_steps, "Timing summary")),
    )

    terramate_step = find_step(test_steps, "Install Terramate")
    terramate_version = terramate_step.get("env", {}).get("TERRAMATE_VERSION") if terramate_step else None
    terramate_run = run_text(terramate_step)
    checks.assert_check(
        "Terramate version is declared in workflow",
        isinstance(terramate_version, str) and bool(terramate_version),
    )
    checks.assert_check(
        "Terramate x86_64 tarball mapping matches release asset names",
        "x86_64|amd64) tool_arch=x86_64 ;;" in terramate_run,
    )
    checks.assert_check(
        "Terramate arm64 tarball mapping matches release asset names",
        "arm64|aarch64) tool_arch=arm64 ;;" in terramate_run,
    )

    docker_slim_job = jobs.get("docker-runtime-slim", {})
    docker_slim_steps = docker_slim_job.get("steps", []) if isinstance(docker_slim_job, dict) else []
    if not isinstance(docker_slim_steps, list):
        docker_slim_steps = []
    docker_slim_step_names = step_names(docker_slim_steps)
    checks.assert_check(
        "docker-runtime-slim runs on ubuntu-24.04",
        isinstance(docker_slim_job, dict) and docker_slim_job.get("runs-on") == "ubuntu-24.04",
    )
    checks.assert_check(
        "docker-runtime-slim builds and smokes image",
        "Build slim runtime image" in docker_slim_step_names
        and "Smoke slim runtime image" in docker_slim_step_names,
    )
    checks.assert_check("docker-runtime-slim reports inspectable image size", "Report slim image size" in docker_slim_step_names)
    checks.assert_check("docker-runtime-slim publishes timing summary", "Timing summary" in docker_slim_step_names)
    checks.assert_check(
        "docker-runtime-slim writes timing summary to GITHUB_STEP_SUMMARY",
        "$GITHUB_STEP_SUMMARY" in run_text(find_step(docker_slim_steps, "Timing summary")),
    )
    checks.assert_check("only one dedicated slim Docker build exists", count_docker_builds(workflow) == 1)

    size_run = run_text(find_step(docker_slim_steps, "Report slim image size"))
    checks.assert_check(
        "docker-runtime-slim reports compressed image size",
        "slim image: uncompressed=${inspect_size} compressed=${compressed_size}" in size_run,
    )
    checks.assert_check(
        "docker-runtime-slim enforces uncompressed size under 1600 MB",
        '"${inspect_size}" -ge 1600000000' in size_run,
    )
    checks.assert_check(
        "docker-runtime-slim enforces compressed size under 500 MB",
        '"${compressed_size}" -ge 500000000' in size_run,
    )

    docker_full_job = jobs.get("docker-runtime-full", {})
    docker_full_steps = docker_full_job.get("steps", []) if isinstance(docker_full_job, dict) else []
    if not isinstance(docker_full_steps, list):
        docker_full_steps = []
    checks.assert_check(
        "docker-runtime-full is schedule-only",
        isinstance(docker_full_job, dict) and "github.event_name == 'schedule'" in str(docker_full_job.get("if", "")),
    )
    checks.assert_check("docker-runtime-full publishes timing summary", "Timing summary" in step_names(docker_full_steps))

    print("\n== ci-pipeline Terramate asset checks ==")

    if args.offline:
        print("  [SKIP] remote Terramate release-asset checks (--offline)")
    elif not isinstance(terramate_version, str) or not terramate_version:
        checks.fail("Terramate release asset checks require TERRAMATE_VERSION")
    else:
        for os_name in ("darwin", "linux"):
            for arch in ("arm64", "x86_64"):
                asset = f"terramate_{terramate_version}_{os_name}_{arch}.tar.gz"
                url = f"https://github.com/terramate-io/terramate/releases/download/v{terramate_version}/{asset}"
                ok, detail = http_head_ok(url)
                checks.assert_check(f"{asset} exists upstream", ok)
                if not ok:
                    print(f"    {url}: {detail}", file=sys.stderr)

    print("\n== ci-pipeline Docker installer contract ==")

    for path in ("docker/Dockerfile", "docker/Dockerfile.toolchain"):
        content = (root / path).read_text()
        checks.assert_check(
            f"{path} maps Terraform amd64 separately from Terramate x86_64",
            "terraform_arch=amd64" in content and "terramate_arch=x86_64" in content,
        )

    if checks.failures:
        print(f"\n{checks.failures} ci-pipeline check(s) failed.", file=sys.stderr)
        return 1

    print("\nAll ci-pipeline checks passed.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
