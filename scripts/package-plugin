#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.dispatch import exec_cmd, read_resolved_from_env_or_stdin, stream_command  # noqa: E402
from eve_sdk.workdir import Workdir  # noqa: E402


def command_hook(plugin_root: str | None, os_family: str, command: str) -> str | None:
    if not plugin_root:
        return None
    root = Path(plugin_root)
    candidates = [
        root / "commands" / os_family / command,
        root / "commands" / "common" / command,
    ]
    for path in candidates:
        if path.is_file():
            return str(path)
    return None


def run_hook(path: str, resolved: dict[str, object]) -> None:
    if not os.access(path, os.X_OK):
        print(f"package-plugin: command hook is not executable: {path}", file=sys.stderr)
        raise SystemExit(126)
    status, _ = stream_command(
        [path],
        env=os.environ.copy(),
        stdin_text=json.dumps(resolved, separators=(",", ":")),
        capture_stdout=False,
    )
    raise SystemExit(status)


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print("Usage: scripts/package-plugin <package> <install|status|down>", file=sys.stderr)
        return 2
    package_id = argv[0]
    command = argv[1]
    try:
        resolved = read_resolved_from_env_or_stdin()
        instance_name = resolved["instance"]["name"]  # type: ignore[index]
        selected = package_id in resolved["bundle_packages"]  # type: ignore[operator]
        os_family = resolved["os"]["family"]  # type: ignore[index]
        hook = command_hook(os.environ.get("EVE_PACKAGE_PLUGIN_ROOT"), str(os_family), command)

        if os.environ.get("EVE_PLUGIN_DRY_RUN") == "1" and hook and command == "down":
            run_hook(hook, resolved)

        if os.environ.get("EVE_PLUGIN_DRY_RUN") == "1":
            payload = {
                "kind": "package",
                "package": package_id,
                "command": command,
                "instance": instance_name,
                "profile": instance_name,
                "selected": selected,
                "os_family": os_family,
                "status": "unknown" if command == "status" else None,
                "dry_run": True,
            }
            print(json.dumps({key: value for key, value in payload.items() if value is not None}))
            return 0

        if hook:
            run_hook(hook, resolved)

        if command == "status":
            print(
                json.dumps(
                    {
                        "kind": "package",
                        "package": package_id,
                        "instance": instance_name,
                        "profile": instance_name,
                        "selected": selected,
                        "os_family": os_family,
                        "status": "unknown",
                    }
                )
            )
            return 0
        if command == "install":
            if os_family == "ubuntu":
                exec_cmd(
                    [
                        str(Workdir.repo_root() / "scripts/package-provision"),
                        "--instance",
                        str(instance_name),
                        "--package",
                        package_id,
                    ]
                )
            if os_family == "windows":
                exec_cmd(
                    [
                        str(Workdir.repo_root() / "scripts/package-provision-windows"),
                        "--instance",
                        str(instance_name),
                        "--package",
                        package_id,
                    ]
                )
            print(f"[package-plugin] install currently delegates to full provisioning for {os_family}", file=sys.stderr)
            exec_cmd([str(Workdir.repo_root() / "scripts/provision"), str(instance_name)])
        if command == "down":
            print(f"package-plugin: no {os_family} down hook for package: {package_id}", file=sys.stderr)
            return 2
        print(f"package-plugin: unsupported command: {command}", file=sys.stderr)
        return 2
    except SystemExit as error:
        raise error
    except Exception as error:
        print(f"package-plugin: {error}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
