#!/usr/bin/env ruby
# Built-in package plugin compatibility wrapper.

require "json"
require "open3"

ROOT = File.expand_path("..", __dir__)
package_id = ARGV.shift
command = ARGV.shift

unless package_id && command
  warn "Usage: scripts/package-plugin <package> <install|status|down>"
  exit 2
end

resolved = JSON.parse($stdin.read)
profile = resolved.fetch("instance").fetch("name")
selected = resolved.fetch("bundle_packages").include?(package_id)
os_family = resolved.fetch("os").fetch("family")

def command_hook(plugin_root, os_family, command)
  return nil unless plugin_root && !plugin_root.empty?

  candidates = [
    File.join(plugin_root, "commands", os_family, command),
    File.join(plugin_root, "commands", "common", command)
  ]
  candidates.find { |path| File.file?(path) }
end

def run_hook(path, resolved)
  env = ENV.to_h
  exit_status = 0
  Open3.popen3(env, path, chdir: ROOT) do |stdin, stdout, stderr, wait_thr|
    stdin.write(JSON.generate(resolved))
    stdin.close
    out = stdout.read
    err = stderr.read
    warn err unless err.empty?
    print out
    exit_status = wait_thr.value.exitstatus || 1
  end
  exit exit_status
rescue Errno::EACCES
  warn "package-plugin: command hook is not executable: #{path}"
  exit 126
end

if ENV["EGAME_PLUGIN_DRY_RUN"] == "1"
  puts JSON.generate({
    "kind" => "package",
    "package" => package_id,
    "command" => command,
    "profile" => profile,
    "selected" => selected,
    "os_family" => os_family,
    "dry_run" => true
  })
  exit 0
end

hook = command_hook(ENV["EGAME_PACKAGE_PLUGIN_ROOT"], os_family, command)
run_hook(hook, resolved) if hook

case command
when "status"
  puts JSON.generate({
    "kind" => "package",
    "package" => package_id,
    "profile" => profile,
    "selected" => selected,
    "status" => selected ? "selected" : "not-selected"
  })
when "install"
  if os_family == "ubuntu"
    exec File.join(ROOT, "scripts/package-provision"), "--profile", profile, "--package", package_id
  end

  if os_family == "windows"
    # package-provision-windows handles its own fallback to `make provision`
    # for packages without a granular step mapping, and logs the fallback.
    exec File.join(ROOT, "scripts/package-provision-windows"), "--profile", profile, "--package", package_id
  end

  warn "[package-plugin] install currently delegates to full provisioning for #{os_family}"
  exec "make", "provision", "PROFILE=#{profile}", "INSTANCE="
when "down"
  warn "package-plugin: no #{os_family} down hook for package: #{package_id}"
  exit 2
else
  warn "package-plugin: unsupported command: #{command}"
  exit 2
end
