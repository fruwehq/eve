#!/usr/bin/env python3
"""Run vagrant up for a profile.

Usage: scripts/vagrant-up [--plan] <instance>
  --plan: generate Vagrantfile only, do not start the VM.
"""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.tf_dispatch import repo_root, resolve_env  # noqa: E402
from eve_sdk.vagrant_dispatch import instance_workdir  # noqa: E402


def main(argv: list[str]) -> int:
    plan = False
    if argv and argv[0] == "--plan":
        plan = True
        argv = argv[1:]

    profile = argv[0] if argv else ""
    if not profile:
        print("Usage: scripts/vagrant-up [--plan] <instance>", file=sys.stderr)
        return 2
    root = repo_root()

    resolved = resolve_env(root, profile)
    engine = resolved.get("ENGINE", "")
    if engine != "vagrant":
        print(f"[vagrant-up] not supported for engine={engine}")
        return 1

    provider = resolved.get("PROVIDER", "")
    engine = resolved.get("ENGINE", "")
    # The qemu engine uses the qemu Vagrant provider;
    # other local engines (e.g. vagrant) are not wired here.
    if engine == "qemu":
        vagrant_provider = "qemu"
    else:
        print(f"[vagrant-up] unsupported engine={engine}", file=sys.stderr)
        return 2
    print(f"[vagrant-up] profile={profile} provider={vagrant_provider}")

    workdir = instance_workdir(root, profile)
    Path(workdir).mkdir(parents=True, exist_ok=True)
    rc = subprocess.run(
        [str(root / "scripts/profile-resolve"), "--profile", profile,
         "--emit", "vagrant", "--output", f"{workdir}/Vagrantfile"],
        cwd=root,
    ).returncode
    if rc != 0:
        return rc

    if plan:
        print(f"[vagrant-up] Vagrantfile generated at {workdir}/Vagrantfile (dry run)")
        return 0

    return subprocess.run(
        ["vagrant", "up", f"--provider={vagrant_provider}"], cwd=workdir,
    ).returncode


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
