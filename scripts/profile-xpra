#!/usr/bin/env bash
# Start, stop, or run apps on a remote Xpra session over SSH.
#
# Usage:
#   scripts/profile-xpra <profile> start [app [args...]]
#   scripts/profile-xpra <profile> stop
#   scripts/profile-xpra <profile> run <app> [args...]
#   scripts/profile-xpra <profile> attach
#
# Modes:
#   start [app]  - start the xpra server (and optionally launch an app)
#   stop         - stop the xpra server
#   run <app>    - launch an app on the running session
#   attach       - attach the local xpra client (foreground)
#
# The typical workflow:
#   1. make remote.xpra.start PROFILE=... APP=xeyes   (start server + first app)
#   2. make remote.xpra.run PROFILE=... APP=firefox    (add more apps)
#   3. Ctrl-C in the attach terminal, or: make remote.xpra.stop PROFILE=...

set -euo pipefail

PROFILE="${1:?Usage: scripts/profile-xpra <profile> <start|stop|run|attach> [args...]}"
ACTION="${2:?Usage: scripts/profile-xpra <profile> <start|stop|run|attach> [args...]}"
shift 2
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" = "vagrant" ]; then
  SSH_USER=vagrant
  IP=$(./scripts/profile-ip "$PROFILE")
  SSH_PORT=$(cd ".generated/$PROFILE" && vagrant ssh-config | awk '/Port/ {print $2; exit}')
  PRIV_KEY=$(cd ".generated/$PROFILE" && vagrant ssh-config | awk '/IdentityFile/ {print $2; exit}')
else
  SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^SSH_USER=/{print $2}')
  IP=$(./scripts/profile-ip "$PROFILE")
  SSH_PORT=22
  KEY_FILE="${SSH_PUBLIC_KEY_FILE:-}"
  if [ -n "$KEY_FILE" ] && [ "${KEY_FILE%.pub}" != "$KEY_FILE" ]; then
    PRIV_KEY="${KEY_FILE%.pub}"
  else
    PRIV_KEY="${SSH_PRIVATE_KEY_FILE:-}"
  fi
fi

[ -n "$IP" ] || { echo "profile-xpra: could not resolve IP for $PROFILE" >&2; exit 1; }

SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ServerAliveInterval=10)
[ -n "$PRIV_KEY" ] && SSH_OPTS+=(-i "$PRIV_KEY")
[ "$SSH_PORT" != "22" ] && SSH_OPTS+=(-p "$SSH_PORT")

DISPLAY_NUM="${XPRA_DISPLAY:-100}"
XPRA_URI="ssh://$SSH_USER@$IP/$DISPLAY_NUM"
SSH_CMD="ssh ${SSH_OPTS[*]}"

# shellcheck disable=SC2317
remote_ssh() {
  ssh "${SSH_OPTS[@]}" -l "$SSH_USER" "$IP" "$@"
}

case "$ACTION" in
  start)
    if ! command -v xpra >/dev/null 2>&1; then
      echo "profile-xpra: xpra not installed locally." >&2
      echo "  macOS:  install the signed .pkg from https://xpra.org/install/ (also needs XQuartz)." >&2
      exit 1
    fi

    echo "[profile-xpra] starting server on display :$DISPLAY_NUM"
    remote_ssh "xpra start :$DISPLAY_NUM" || {
      echo "profile-xpra: remote 'xpra start :$DISPLAY_NUM' failed" >&2
      echo "  Is xpra installed? Run: make provision PROFILE=$PROFILE" >&2
      exit 1
    }

    echo "[profile-xpra] server running. Attach with: make remote.xpra.attach PROFILE=$PROFILE"
    ;;

  stop)
    echo "[profile-xpra] stopping session on display :$DISPLAY_NUM"
    remote_ssh "xpra stop :$DISPLAY_NUM" 2>/dev/null || true
    xpra stop "$XPRA_URI" 2>/dev/null || true
    echo "[profile-xpra] stopped"
    ;;

  status)
    remote_ssh "xpra info :$DISPLAY_NUM 2>/dev/null" | grep -E '^(state|sessions|clients)' || {
      echo "[profile-xpra] no session on display :$DISPLAY_NUM"
      exit 1
    }
    ;;

  run)
    if [ "$#" -lt 1 ]; then
      echo "Usage: scripts/profile-xpra <profile> run <app> [args...]" >&2
      exit 1
    fi
    START_CMD="$*"
    echo "[profile-xpra] launching '$START_CMD' on display :$DISPLAY_NUM"
    remote_ssh "DISPLAY=:$DISPLAY_NUM nohup $START_CMD </dev/null >/dev/null 2>&1 &"
    ;;

  attach)
    if ! command -v xpra >/dev/null 2>&1; then
      echo "profile-xpra: xpra not installed locally." >&2
      echo "  macOS:  install the signed .pkg from https://xpra.org/install/ (also needs XQuartz)." >&2
      exit 1
    fi

    # shellcheck disable=SC2329
    cleanup() {
      echo "[profile-xpra] detaching"
      kill "$XPRA_PID" 2>/dev/null || true
      pkill -P "$XPRA_PID" 2>/dev/null || true
    }
    trap cleanup EXIT INT TERM

    echo "[profile-xpra] attaching to display :$DISPLAY_NUM (press Ctrl-C to detach)"
    xpra attach "$XPRA_URI" --ssh="$SSH_CMD" &

    XPRA_PID=$!
    wait $XPRA_PID 2>/dev/null
    trap - EXIT INT TERM
    kill "$XPRA_PID" 2>/dev/null || true
    pkill -P "$XPRA_PID" 2>/dev/null || true
    ;;

  apps)
    # shellcheck disable=SC2016
    remote_ssh 'for f in /usr/share/applications/*.desktop ~/.local/share/applications/*.desktop; do
      name=$(grep "^Name=" "$f" 2>/dev/null | head -1 | cut -d= -f2-)
      exec=$(grep "^Exec=" "$f" 2>/dev/null | head -1 | cut -d= -f2- | cut -d" " -f1)
      [ -n "$name" ] && [ -n "$exec" ] && printf "%-40s %s\n" "$name" "$exec"
    done 2>/dev/null | sort -u'
    ;;

  *)
    echo "Unknown action: $ACTION (use start, stop, run, attach, status, or apps)" >&2
    exit 1
    ;;
esac
