#!/usr/bin/env bash
# Launch a remote Linux GUI app via Xpra over SSH, rendered as a native-looking
# window on the local macOS/Linux host (no full remote desktop required).
#
# Usage:
#   scripts/profile-xpra <profile> <app> [app-args...]
#
# Example:
#   scripts/profile-xpra aws-ubuntu-dev-headless xeyes
#   scripts/profile-xpra aws-ubuntu-dev-headless firefox https://example.com

set -euo pipefail

PROFILE="${1:?Usage: scripts/profile-xpra <profile> <app> [args...]}"
APP="${2:?Usage: scripts/profile-xpra <profile> <app> [args...]}"
shift 2
cd "$(git rev-parse --show-toplevel)"

if ! command -v xpra >/dev/null 2>&1; then
  echo "profile-xpra: xpra not installed locally." >&2
  echo "  macOS:  install the signed .pkg from https://xpra.org/install/ (also needs XQuartz)." >&2
  echo "  Linux:  apt-get install xpra  (or your distro equivalent)." >&2
  exit 1
fi

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')

if [ "$ENGINE" = "vagrant" ]; then
  SSH_USER=vagrant
  IP=$(./scripts/profile-ip "$PROFILE")
  SSH_PORT=$(cd ".generated/$PROFILE" && vagrant ssh-config | awk '/Port/ {print $2; exit}')
  PRIV_KEY=$(cd ".generated/$PROFILE" && vagrant ssh-config | awk '/IdentityFile/ {print $2; exit}')
else
  SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^SSH_USER=/{print $2}')
  IP=$(./scripts/profile-ip "$PROFILE")
  SSH_PORT=22
  KEY_FILE="${SSH_PUBLIC_KEY_FILE:-}"
  if [ -n "$KEY_FILE" ] && [ "${KEY_FILE%.pub}" != "$KEY_FILE" ]; then
    PRIV_KEY="${KEY_FILE%.pub}"
  else
    PRIV_KEY="${SSH_PRIVATE_KEY_FILE:-}"
  fi
fi

[ -n "$IP" ] || { echo "profile-xpra: could not resolve IP for $PROFILE" >&2; exit 1; }

SSH_OPTS=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ServerAliveInterval=10)
[ -n "$PRIV_KEY" ] && SSH_OPTS+=(-i "$PRIV_KEY")
[ "$SSH_PORT" != "22" ] && SSH_OPTS+=(-p "$SSH_PORT")

DISPLAY_NUM="${XPRA_DISPLAY:-100}"
START_CMD="$APP"
if [ "$#" -gt 0 ]; then
  START_CMD="$APP $*"
fi

echo "[profile-xpra] launching '$START_CMD' on $SSH_USER@$IP:$SSH_PORT (display :$DISPLAY_NUM)"
exec xpra start "ssh://$SSH_USER@$IP/$DISPLAY_NUM" \
  --ssh="ssh ${SSH_OPTS[*]}" \
  --start-child="$START_CMD" \
  --exit-with-children
