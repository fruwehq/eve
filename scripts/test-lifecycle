#!/usr/bin/env python3
"""Fake-provider lifecycle regression test."""

from __future__ import annotations

import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any

import yaml

ROOT = Path(__file__).resolve().parents[1]
FAKE_PLUGIN_PATH = ROOT / "tests/fixtures/plugins/providers/fake"
failures = 0


def pass_check(message: str) -> None:
    print(f"  [OK] {message}")


def fail_check(message: str) -> None:
    global failures
    print(f"  [FAIL] {message}")
    failures += 1


def run_capture(*cmd: str, env: dict[str, str]) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=ROOT, env=os.environ | env, text=True, capture_output=True, check=False)


def read_state(state_dir: Path) -> dict[str, Any]:
    return json.loads((state_dir / "instances/fake-lifecycle-a.json").read_text(encoding="utf-8"))


def last_json_with(output: str, key: str) -> dict[str, Any] | None:
    for line in reversed(output.splitlines()):
        line = line.strip()
        if not line:
            continue
        try:
            parsed = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(parsed, dict) and key in parsed:
            return parsed
    return None


print("\n== lifecycle: fake provider ==")
with tempfile.TemporaryDirectory(prefix="eve-lifecycle-test-") as tmp:
    tmpdir = Path(tmp)
    workdir = tmpdir / "work"
    state_dir = tmpdir / "state"
    registry_dir = tmpdir / "registry"
    catalog_dir = tmpdir / "catalog"
    for path in [workdir, state_dir, registry_dir, catalog_dir]:
        path.mkdir(parents=True, exist_ok=True)

    registry_path = registry_dir / "instances.yaml"
    (workdir / "fake-lifecycle-a").mkdir(parents=True, exist_ok=True)
    catalog_path = catalog_dir / "catalog.local.yaml"
    catalog_path.write_text(
        yaml.safe_dump(
            {
                "machines": [
                    {
                        "name": "fake-vm",
                        "provider": "fake",
                        "kind": "vm",
                        "defaults": {"cpu_cores": 2, "memory_mb": 4096, "disk_gb": 30},
                    }
                ],
                "oses": [
                    {
                        "id": "fake-os",
                        "family": "ubuntu",
                        "arch": "amd64",
                        "version": "26.04",
                        "vagrant_box": "test/fake",
                    }
                ],
                "inits": [{"id": "fake-init", "os_family": "ubuntu", "providers": ["fake"]}],
                "locations": [{"name": "fake-location", "fake": {"region": "test"}}],
                "packages": [],
                "bundles": [],
            },
            sort_keys=False,
        ),
        encoding="utf-8",
    )
    registry_path.write_text(
        yaml.safe_dump(
            {
                "instances": [
                    {
                        "name": "fake-lifecycle-a",
                        "machine": "fake-vm",
                        "os": "fake-os",
                        "init": "fake-init",
                        "location": "fake-location",
                        "bundles": [],
                        "packages": [],
                    }
                ]
            },
            sort_keys=False,
        ),
        encoding="utf-8",
    )

    base_env = {
        "EVE_INSTANCE_REGISTRY": str(registry_path),
        "EVE_CATALOG_LOCAL": str(catalog_path),
        "EVE_INSTANCE_WORKDIR": str(workdir),
        "EVE_STATE_DIR": str(state_dir),
        "EVE_PLUGIN_ROOTS": str(FAKE_PLUGIN_PATH),
    }
    provision_stub = tmpdir / "fake-provision"
    provision_stub.write_text("#!/usr/bin/env sh\nexit 0\n", encoding="utf-8")
    provision_stub.chmod(0o755)

    resolved = run_capture(
        str(ROOT / "scripts/instance-resolve"),
        "--instance",
        "fake-lifecycle-a",
        "--emit",
        "json",
        env=base_env,
    )
    if resolved.returncode == 0 and json.loads(resolved.stdout)["machine"]["provider"] == "fake":
        pass_check("instance resolves with fake provider")
    else:
        fail_check(f"instance resolve failed: {resolved.stderr}")

    expectations = {
        "up": {"provider_state": "running", "desired_state": "running"},
        "status": {"state_includes": "running"},
        "ip": {"ip": "127.0.0.1"},
        "stop": {"provider_state": "stopped", "desired_state": "stopped"},
        "down": {"provider_state": "absent", "desired_state": "absent"},
    }
    for command in ["up", "status", "ip", "stop", "down"]:
        result = run_capture(
            str(ROOT / "scripts/provider-dispatch"),
            "--instance",
            "fake-lifecycle-a",
            "--command",
            command,
            env=base_env,
        )
        expected = expectations[command]
        if result.returncode != 0:
            fail_check(f"provider-dispatch {command} failed: {result.stderr}")
            continue
        pass_check(f"provider-dispatch {command} succeeded")
        state = read_state(state_dir)
        if "provider_state" in expected:
            if state["provider_state"] == expected["provider_state"]:
                pass_check(f"{command} sets provider_state={state['provider_state']}")
            else:
                fail_check(
                    f"{command} provider_state: "
                    f"expected={expected['provider_state']} actual={state['provider_state']}"
                )
        if "desired_state" in expected:
            if state["desired_state"] == expected["desired_state"]:
                pass_check(f"{command} sets desired_state={state['desired_state']}")
            else:
                fail_check(
                    f"{command} desired_state: "
                    f"expected={expected['desired_state']} actual={state['desired_state']}"
                )
        if "state_includes" in expected and state.get("provider_state"):
            pass_check(f"{command} state file exists")
        if command == "ip":
            ip_json = last_json_with(result.stdout, "ip")
            if ip_json and ip_json["ip"] == expected["ip"]:
                pass_check(f"ip command returns {expected['ip']}")
            else:
                fail_check(f"ip output mismatch: {result.stdout}")

    start = run_capture(
        str(ROOT / "scripts/provider-dispatch"),
        "--instance",
        "fake-lifecycle-a",
        "--command",
        "start",
        env=base_env,
    )
    if start.returncode == 0 and read_state(state_dir)["provider_state"] == "running":
        pass_check("start transitions provider_state back to running")
    else:
        fail_check(f"provider-dispatch start failed: {start.stderr}")

    ssh = run_capture(
        str(ROOT / "scripts/provider-dispatch"),
        "--instance",
        "fake-lifecycle-a",
        "--command",
        "ssh",
        "--",
        "exit",
        "0",
        env=base_env,
    )
    if ssh.returncode == 0:
        pass_check("provider-dispatch ssh probe succeeds")
    else:
        fail_check(f"provider-dispatch ssh probe failed: {ssh.stderr}")

    provision = run_capture(
        str(ROOT / "scripts/instance-provision"),
        "--instance",
        "fake-lifecycle-a",
        env=base_env | {"EVE_PROVISION_SCRIPT": str(provision_stub)},
    )
    if provision.returncode == 0 and read_state(state_dir)["provision_state"] == "provisioned":
        pass_check("instance-provision records provision_state=provisioned")
    else:
        fail_check(f"instance-provision failed: {provision.stderr}")

    status = run_capture(
        str(ROOT / "scripts/instance-status"),
        "--instance",
        "fake-lifecycle-a",
        "--json",
        env=base_env,
    )
    status_json = json.loads(status.stdout) if status.returncode == 0 else {}
    if (
        status_json.get("state", {}).get("desired_state") == "running"
        and status_json.get("state", {}).get("provider_state") == "running"
        and status_json.get("state", {}).get("provision_state") == "provisioned"
    ):
        pass_check("instance-status renders lifecycle state")
    else:
        fail_check(f"instance-status output mismatch: {status.stdout}{status.stderr}")

    for command in ["stop", "down"]:
        result = run_capture(
            str(ROOT / "scripts/provider-dispatch"),
            "--instance",
            "fake-lifecycle-a",
            "--command",
            command,
            env=base_env,
        )
        if result.returncode == 0:
            pass_check(f"post-provision provider-dispatch {command} succeeds")
        else:
            fail_check(f"post-provision provider-dispatch {command} failed: {result.stderr}")

    state = read_state(state_dir)
    recorded = [entry["name"] for entry in state.get("operation_history", [])]
    for command in ["up", "status", "ip", "stop", "down", "start"]:
        op_name = f"provider.{command}"
        if op_name in recorded:
            pass_check(f"history records provider.{command}")
        else:
            fail_check(f"history missing provider.{command}: recorded={recorded!r}")

    dry = run_capture(
        str(ROOT / "scripts/provider-dispatch"),
        "--instance",
        "fake-lifecycle-a",
        "--command",
        "up",
        "--dry-run",
        env=base_env,
    )
    dry_json = last_json_with(dry.stdout, "dry_run") if dry.returncode == 0 else None
    if dry_json and dry_json["dry_run"] is True:
        pass_check("dry-run mode emits dry_run=true")
    else:
        fail_check(f"dry-run output: {dry.stdout}{dry.stderr}")

if failures:
    print(f"\n{failures} check(s) failed.", file=sys.stderr)
    raise SystemExit(1)
print("\nAll lifecycle checks passed.")
