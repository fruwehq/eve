#!/usr/bin/env bash
# Resolve the public/reachable IP of a profile's instance.
# Usage: scripts/instance-ip <profile>
#
# Dispatches by engine/provider:
#   - terraform + aws         -> output "public_ip"
#   - terraform + gcp         -> output "public_ip"
#   - terraform + vultr       -> output "vultr_instance_main_ip"
#   - terraform + truenas     -> output VM MAC, then resolve it from NAS ARP
#   - metal + raspberry-pi    -> use RASPBERRY_PI_IP or resolve RASPBERRY_PI_HOST
#   - vagrant                 -> `vagrant ssh-config` hostname

set -euo pipefail

PROFILE="${1:?Usage: scripts/instance-ip <profile>}"
cd "$(git rev-parse --show-toplevel)"
# shellcheck source=lib/instance-workdir.sh
. ./scripts/lib/instance-workdir.sh

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')
RESOLVED_SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^SSH_USER=/{print $2}')
RESOLVED_RASPBERRY_PI_HOST=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^RASPBERRY_PI_HOST=/{print substr($0, index($0, "=") + 1)}')
RESOLVED_RASPBERRY_PI_IP=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^RASPBERRY_PI_IP=/{print substr($0, index($0, "=") + 1)}')

if [ "$ENGINE" = "terraform" ]; then
  eval "$(./scripts/tf-env "$PROFILE")"
fi

TM_OUTPUT_FLAGS=(
  --disable-safeguards=git-untracked
  --disable-safeguards=git-uncommitted
  --disable-safeguards=git-out-of-sync
  --disable-safeguards=outdated-code
)

resolve_host_ip() {
  local host="$1"
  local ip
  case "$host" in
    ''|*[!0-9.]*)
      ;;
    *.*)
      printf '%s\n' "$host"
      return 0
      ;;
  esac

  if command -v getent >/dev/null 2>&1; then
    ip=$(getent ahostsv4 "$host" 2>/dev/null | awk '{print $1; exit}')
    [ -n "$ip" ] && { printf '%s\n' "$ip"; return 0; }
  fi

  if command -v dscacheutil >/dev/null 2>&1; then
    ip=$(dscacheutil -q host -a name "$host" 2>/dev/null | awk '/ip_address:/ {print $2; exit}')
    [ -n "$ip" ] && { printf '%s\n' "$ip"; return 0; }
  fi

  if command -v dig >/dev/null 2>&1; then
    ip=$(dig +short "$host" A 2>/dev/null | awk '/^[0-9.]+$/ {print; exit}')
    [ -n "$ip" ] && { printf '%s\n' "$ip"; return 0; }
  fi

  if command -v host >/dev/null 2>&1; then
    ip=$(host "$host" 2>/dev/null | awk '/has address/ {print $4; exit}')
    [ -n "$ip" ] && { printf '%s\n' "$ip"; return 0; }
  fi

  return 1
}

ssh_host_ip() {
  local host="$1"
  local user="$2"
  local key_file="${SSH_PUBLIC_KEY_FILE:-}"
  local priv_key=""
  local ip

  if [ -n "$key_file" ] && [ "${key_file%.pub}" != "$key_file" ]; then
    priv_key="${key_file%.pub}"
  else
    priv_key="${SSH_PRIVATE_KEY_FILE:-}"
  fi

  local ssh_opts=(-o StrictHostKeyChecking=no -o ServerAliveInterval=10 -o BatchMode=yes -o ConnectTimeout=5 -o WarnWeakCrypto=no-pq-kex)
  [ -n "$priv_key" ] && ssh_opts+=(-i "$priv_key" -o IdentitiesOnly=yes)

  ip=$(ssh "${ssh_opts[@]}" "$user@$host" "hostname -I | awk '{print \$1}'" 2>/dev/null || true)
  [ -n "$ip" ] && printf '%s\n' "$ip"
}

discover_ssh_ip() {
  local user="$1"
  local key_file="${SSH_PUBLIC_KEY_FILE:-}"
  local priv_key=""
  local candidates=""
  local candidate
  local found

  if [ -n "$key_file" ] && [ "${key_file%.pub}" != "$key_file" ]; then
    priv_key="${key_file%.pub}"
  else
    priv_key="${SSH_PRIVATE_KEY_FILE:-}"
  fi

  if command -v arp >/dev/null 2>&1; then
    candidates=$(arp -an 2>/dev/null | awk '
      /\([0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\)/ && $0 !~ /incomplete/ {
        gsub(/[()]/, "", $2)
        print $2
      }' | sort -u)
  fi

  local ssh_opts=(-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o BatchMode=yes -o ConnectTimeout=2 -o ConnectionAttempts=1 -o WarnWeakCrypto=no-pq-kex)
  [ -n "$priv_key" ] && ssh_opts+=(-i "$priv_key" -o IdentitiesOnly=yes)

  for candidate in $candidates; do
    found=$(ssh "${ssh_opts[@]}" "$user@$candidate" "hostname -I | awk '{print \$1}'" 2>/dev/null || true)
    if [ -n "$found" ]; then
      printf '%s\n' "$found"
      return 0
    fi
  done

  return 1
}

case "$ENGINE:$PROVIDER" in
  metal:raspberry-pi)
    ./scripts/env-require VM_USER_NAME
    PI_HOST="${RESOLVED_RASPBERRY_PI_HOST:-${RASPBERRY_PI_HOST:-}}"
    IP="${RESOLVED_RASPBERRY_PI_IP:-${RASPBERRY_PI_IP:-}}"
    if [ -z "$IP" ]; then
      [ -n "$PI_HOST" ] || ./scripts/env-require RASPBERRY_PI_HOST
      PI_HOST="${PI_HOST:-$RASPBERRY_PI_HOST}"
      IP=$(resolve_host_ip "$PI_HOST" || true)
    fi
    if [ -z "$IP" ]; then
      SSH_USER="${RESOLVED_SSH_USER:-$VM_USER_NAME}"
      IP=$(ssh_host_ip "$PI_HOST" "$SSH_USER" || true)
    fi
    if [ -z "$IP" ]; then
      IP=$(discover_ssh_ip "$SSH_USER" || true)
    fi
    if [ -z "$IP" ]; then
      echo "instance-ip: could not resolve Raspberry Pi host '${PI_HOST:-}' to an IP address" >&2
      exit 1
    fi
    printf '%s\n' "$IP"
    ;;
  terraform:aws)
    terramate run "${TM_OUTPUT_FLAGS[@]}" --quiet --tags="$TAGS-services" -- terraform output -raw public_ip
    ;;
  terraform:gcp)
    terramate run "${TM_OUTPUT_FLAGS[@]}" --quiet --tags="$TAGS-services" -- terraform output -raw public_ip
    ;;
  terraform:vultr)
    terramate run "${TM_OUTPUT_FLAGS[@]}" --quiet --tags="$TAGS-services" -- terraform output -raw vultr_instance_main_ip
    ;;
  terraform:truenas)
    ./scripts/env-require TRUENAS_SSH_USER
    RESOLVED_TRUENAS_HOST=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_HOST=/{print $2}')
    RESOLVED_TRUENAS_SSH_PORT=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_SSH_PORT=/{print $2}')
    RESOLVED_TRUENAS_SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_SSH_USER=/{print $2}')

    VM_NAME=$(terramate run "${TM_OUTPUT_FLAGS[@]}" --quiet --tags="$TAGS-services" -- terraform output -raw truenas_vm_name)
    SSH_USER="${TRUENAS_SSH_USER:-$RESOLVED_TRUENAS_SSH_USER}"
    SSH_HOST="${TRUENAS_HOST:-$RESOLVED_TRUENAS_HOST}"
    if [ -z "$SSH_HOST" ]; then
      echo "instance-ip: missing TrueNAS host for profile '$PROFILE'" >&2
      exit 2
    fi
    SSH_KEY="${TRUENAS_SSH_PRIVATE_KEY_FILE:-}"
    # shellcheck disable=SC2088,SC2016
    case "$SSH_KEY" in
      '$(HOME)'|'$(HOME)/'*) SSH_KEY="${HOME}${SSH_KEY#\$\(HOME\)}" ;;
      '$HOME'|'$HOME/'*) SSH_KEY="${HOME}${SSH_KEY#\$HOME}" ;;
      '~'|'~/'*) SSH_KEY="${HOME}${SSH_KEY#\~}" ;;
    esac
    NAS_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
    [ -n "$SSH_KEY" ] && NAS_OPTS+=(-i "$SSH_KEY")
    SSH_PORT="${TRUENAS_SSH_PORT:-$RESOLVED_TRUENAS_SSH_PORT}"
    [ -n "$SSH_PORT" ] && [ "$SSH_PORT" != "22" ] && NAS_OPTS+=(-p "$SSH_PORT")

    # TrueNAS auto-generates NIC MACs but does not expose them in Terraform or
    # vm.device.query. Match the VM by its cloud-init hostname instead.
    CANDIDATES=$(ssh "${NAS_OPTS[@]}" "${SSH_USER}@${SSH_HOST}" \
      "awk '/br0/ && /00:a0:98/ {print \$1}' /proc/net/arp")
    if [ -z "$CANDIDATES" ]; then
      echo "instance-ip: no TrueNAS VM ARP candidates found" >&2
      exit 2
    fi

    VM_SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=1)
    SSH_PUBLIC_KEY_FILE="${SSH_PUBLIC_KEY_FILE:-}"
    # shellcheck disable=SC2088,SC2016
    case "$SSH_PUBLIC_KEY_FILE" in
      '$(HOME)'|'$(HOME)/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\$\(HOME\)}" ;;
      '$HOME'|'$HOME/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\$HOME}" ;;
      '~'|'~/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\~}" ;;
    esac
    [ -n "$SSH_PUBLIC_KEY_FILE" ] && VM_SSH_KEY="${SSH_PUBLIC_KEY_FILE%.pub}" && VM_SSH_OPTS+=(-i "$VM_SSH_KEY")

    FOUND=""
    for IP in $CANDIDATES; do
      [ -n "$RESOLVED_SSH_USER" ] || continue
      HOSTNAME=$(ssh "${VM_SSH_OPTS[@]}" "${RESOLVED_SSH_USER}@${IP}" hostname 2>/dev/null) || continue
      if [ "$HOSTNAME" = "$VM_NAME" ]; then
        FOUND="$IP"
        break
      fi
      [ -n "$FOUND" ] && break
    done
    if [ -z "$FOUND" ]; then
      echo "instance-ip: no TrueNAS ARP candidate matched hostname '$VM_NAME'" >&2
      exit 2
    fi
    printf '%s\n' "$FOUND"
    ;;
  vagrant:*)
    cd "$(egame_instance_workdir "$PROFILE")"
    vagrant ssh-config | awk '/HostName/ {print $2; exit}'
    ;;
  *)
    echo "instance-ip: unsupported engine/provider: $ENGINE/$PROVIDER" >&2
    exit 2
    ;;
esac
