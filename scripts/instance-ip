#!/usr/bin/env bash
# Resolve the public/reachable IP of a profile's instance.
# Usage: scripts/instance-ip <profile>
#
# Dispatches by engine/provider:
#   - terraform + aws         -> output "public_ip"
#   - terraform + vultr       -> output "vultr_instance_main_ip"
#   - terraform + truenas     -> output VM MAC, then resolve it from NAS ARP
#   - vagrant                 -> `vagrant ssh-config` hostname

set -euo pipefail

PROFILE="${1:?Usage: scripts/instance-ip <profile>}"
cd "$(git rev-parse --show-toplevel)"

RESOLVED_ENV=$(./scripts/profile-resolve --profile "$PROFILE" --emit env)
ENGINE=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^ENGINE=/{print $2}')
PROVIDER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^PROVIDER=/{print $2}')
TAGS=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^STACK_TAGS=/{print $2}')

case "$ENGINE:$PROVIDER" in
  terraform:aws)
    terramate run --quiet --tags="$TAGS-services" -- terraform output -raw public_ip
    ;;
  terraform:vultr)
    terramate run --quiet --tags="$TAGS-services" -- terraform output -raw vultr_instance_main_ip
    ;;
  terraform:truenas)
    RESOLVED_TRUENAS_HOST=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_HOST=/{print $2}')
    RESOLVED_TRUENAS_SSH_PORT=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_SSH_PORT=/{print $2}')
    RESOLVED_TRUENAS_SSH_USER=$(printf "%s\n" "$RESOLVED_ENV" | awk -F= '/^TRUENAS_SSH_USER=/{print $2}')

    VM_NAME=$(terramate run --quiet --tags="$TAGS-services" -- terraform output -raw truenas_vm_name)
    SSH_USER="${TRUENAS_SSH_USER:-$RESOLVED_TRUENAS_SSH_USER}"
    SSH_HOST="${TRUENAS_HOST:-$RESOLVED_TRUENAS_HOST}"
    if [ -z "$SSH_HOST" ]; then
      echo "instance-ip: missing TrueNAS host for profile '$PROFILE'" >&2
      exit 2
    fi
    SSH_KEY="${TRUENAS_SSH_PRIVATE_KEY_FILE:-}"
    # shellcheck disable=SC2088,SC2016
    case "$SSH_KEY" in
      '$(HOME)'|'$(HOME)/'*) SSH_KEY="${HOME}${SSH_KEY#\$\(HOME\)}" ;;
      '$HOME'|'$HOME/'*) SSH_KEY="${HOME}${SSH_KEY#\$HOME}" ;;
      '~'|'~/'*) SSH_KEY="${HOME}${SSH_KEY#\~}" ;;
    esac
    NAS_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes)
    [ -n "$SSH_KEY" ] && NAS_OPTS+=(-i "$SSH_KEY")
    SSH_PORT="${TRUENAS_SSH_PORT:-$RESOLVED_TRUENAS_SSH_PORT}"
    [ -n "$SSH_PORT" ] && [ "$SSH_PORT" != "22" ] && NAS_OPTS+=(-p "$SSH_PORT")

    # TrueNAS auto-generates NIC MACs but does not expose them in Terraform or
    # vm.device.query. Match the VM by its cloud-init hostname instead.
    CANDIDATES=$(ssh "${NAS_OPTS[@]}" "${SSH_USER}@${SSH_HOST}" \
      "awk '/br0/ && /00:a0:98/ {print \$1}' /proc/net/arp")
    if [ -z "$CANDIDATES" ]; then
      echo "instance-ip: no TrueNAS VM ARP candidates found" >&2
      exit 2
    fi

    VM_SSH_OPTS=(-o StrictHostKeyChecking=no -o IdentitiesOnly=yes -o BatchMode=yes -o ConnectTimeout=1)
    SSH_PUBLIC_KEY_FILE="${SSH_PUBLIC_KEY_FILE:-}"
    # shellcheck disable=SC2088,SC2016
    case "$SSH_PUBLIC_KEY_FILE" in
      '$(HOME)'|'$(HOME)/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\$\(HOME\)}" ;;
      '$HOME'|'$HOME/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\$HOME}" ;;
      '~'|'~/'*) SSH_PUBLIC_KEY_FILE="${HOME}${SSH_PUBLIC_KEY_FILE#\~}" ;;
    esac
    [ -n "$SSH_PUBLIC_KEY_FILE" ] && VM_SSH_KEY="${SSH_PUBLIC_KEY_FILE%.pub}" && VM_SSH_OPTS+=(-i "$VM_SSH_KEY")

    FOUND=""
    for IP in $CANDIDATES; do
      HOSTNAME=$(ssh "${VM_SSH_OPTS[@]}" "ubuntu@${IP}" hostname 2>/dev/null) || continue
      if [ "$HOSTNAME" = "$VM_NAME" ]; then
        FOUND="$IP"
        break
      fi
    done
    if [ -z "$FOUND" ]; then
      echo "instance-ip: no TrueNAS ARP candidate matched hostname '$VM_NAME'" >&2
      exit 2
    fi
    printf '%s\n' "$FOUND"
    ;;
  vagrant:*)
    cd ".generated/$PROFILE"
    vagrant ssh-config | awk '/HostName/ {print $2; exit}'
    ;;
  *)
    echo "instance-ip: unsupported engine/provider: $ENGINE/$PROVIDER" >&2
    exit 2
    ;;
esac
