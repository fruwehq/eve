#!/usr/bin/env bash
# Boundary lint: checks on central scripts/ AND the provider-agnostic
# shared dispatchers under plugins/providers/_common and _terraform-common.
#
#   1. provider/OS ID references outside the allowlist
#   2. bash/sh shebangs in central scripts/ outside the allowlist
#      (language policy: no new bash in scripts/)
#
# The _common and _terraform-common directories must be provider-agnostic
# by construction. Any provider/OS ID in them is a violation by definition
# and either belongs in a per-provider plugin or in the allowlist (with
# a Part 2 follow-up marker).
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

ALLOWLIST="scripts/test-core-boundary.allowlist"

# --- Self-test: shebang detection logic ---
if [ "${1:-}" = "--self-test" ]; then
  PASS_SHEBANGS=(
    '#!/usr/bin/env bash'
    '#!/usr/bin/env sh'
    '#!/bin/bash'
    '#!/bin/sh'
  )
  NEG_SHEBANGS=(
    '#!/usr/bin/env ruby'
    '#!/usr/bin/env python'
    '#!/usr/bin/env python3'
    '#!/usr/bin/env zsh'
    '#!/usr/bin/ruby'
    '#!/usr/bin/python'
  )
  ST_FAIL=0
  for s in "${PASS_SHEBANGS[@]}"; do
    case "$s" in
      '#!/usr/bin/env bash'|'#!/usr/bin/env sh'|'#!/bin/bash'|'#!/bin/sh') ;;
      *) printf 'SELF-TEST FAIL: %s not detected as bash/sh\n' "$s"; ST_FAIL=1 ;;
    esac
  done
  for s in "${NEG_SHEBANGS[@]}"; do
    case "$s" in
      '#!/usr/bin/env bash'|'#!/usr/bin/env sh'|'#!/bin/bash'|'#!/bin/sh')
        printf 'SELF-TEST FAIL: %s false positive\n' "$s"; ST_FAIL=1 ;;
    esac
  done
  if [ "$ST_FAIL" -eq 0 ]; then
    printf '[OK] core-boundary self-test: shebang detection passes\n'
  fi
  exit "$ST_FAIL"
fi

fail=0

# --- Check 1: provider/OS ID references ---
PROVIDER_IDS="aws gcp local-qemu raspberry-pi truenas vultr"
OS_IDS="$(awk '/^oses:/{a=1;next} /^[^ ]/{a=0} a&&/^  - id:/{print $3}' config/catalog.yaml)"
ALL_IDS="$PROVIDER_IDS $OS_IDS"

# Files scanned for provider/OS references:
#   - scripts/* (central scripts; old surface)
#   - plugins/providers/_common/commands/* (must be provider-agnostic)
#   - plugins/providers/_common/lib/* if present
#   - plugins/providers/_terraform-common/commands/* (must be provider-agnostic)
#   - plugins/providers/_terraform-common/lib/* if present
SCAN_FILES=()
for f in scripts/*; do
  [[ -d "$f" ]] && continue
  base="$(basename "$f")"
  [[ "$base" == test-* || "$base" == test ]] && continue
  SCAN_FILES+=("$f")
done
for dir in plugins/providers/_common plugins/providers/_terraform-common; do
  [[ -d "$dir" ]] || continue
  while IFS= read -r f; do
    SCAN_FILES+=("$f")
  done < <(find "$dir" -type f -not -path '*/\.*')
done

for f in "${SCAN_FILES[@]}"; do
  for id in $ALL_IDS; do
    if grep -qF "$id" "$f"; then
      if ! grep -q "^${f}:provider/OS reference -" "$ALLOWLIST" 2>/dev/null; then
        printf 'FAIL: %s (references %s) not in allowlist\n' "$f" "$id" >&2
        fail=1
      fi
      break
    fi
  done
done

# --- Check 2: bash/sh shebangs (language policy) ---
for f in scripts/*; do
  [[ -d "$f" ]] && continue
  base="$(basename "$f")"
  [[ "$base" == *".allowlist" ]] && continue
  shebang="$(head -1 "$f")"
  case "$shebang" in
    '#!/usr/bin/env bash'|'#!/usr/bin/env sh'|'#!/bin/bash'|'#!/bin/sh')
      if ! grep -q "^${f}:bash shebang -" "$ALLOWLIST" 2>/dev/null; then
        printf 'FAIL: %s has bash/sh shebang but no bash allowlist entry\n' "$f" >&2
        fail=1
      fi
      ;;
  esac
done

if [[ "$fail" -ne 0 ]]; then
  printf '\nAdd to %s or move the logic into a provider plugin / port to Ruby.\n' "$ALLOWLIST" >&2
  exit 1
fi

printf '[OK] core-boundary: no unallowed provider/OS references or bash scripts in central scripts\n'
