#!/usr/bin/env python3
"""Core-boundary lint.

Checks:
  1. No provider/OS id literals in core files outside the allowlist.
  2. No bash/sh shebangs in scripts/ outside the allowlist (language policy).

Provider/OS id sets are derived dynamically — no hardcoded lists:
  - provider ids from ``PluginManifest.load_all("provider")``
  - OS ids from the aggregated catalog (``eve_sdk.catalog``) ``oses`` section

Scanned for provider/OS references (Check 1):
  - ``scripts/*`` (non-``test*`` files)
  - ``eve_sdk/**/*.py``
  - ``plugins/providers/_common/**``
  - ``plugins/providers/_terraform-common/**``

The ``_common`` and ``_terraform-common`` directories must be provider-agnostic
by construction; any provider/OS id in them is a violation. Known pre-existing
core coupling (Phase 3 extraction debt) is tracked in the allowlist with an
explicit "Phase 3" marker.
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(ROOT))

from eve_sdk.catalog import load_catalog  # noqa: E402
from eve_sdk.plugin_manifest import PluginManifest  # noqa: E402

REPO = ROOT
ALLOWLIST = REPO / "scripts/test-core-boundary.allowlist"

BASH_SHEBANGS = (
    "#!/usr/bin/env bash",
    "#!/usr/bin/env sh",
    "#!/bin/bash",
    "#!/bin/sh",
)


# --- id derivation (dynamic) -----------------------------------------------

def provider_ids() -> list[str]:
    """Provider ids from loaded provider plugin manifests."""
    return sorted(plugin["id"] for plugin in PluginManifest.load_all("provider"))


def os_ids() -> list[str]:
    """OS ids from the aggregated catalog ``oses`` section."""
    catalog = load_catalog()
    return sorted(
        entry["id"]
        for entry in catalog.get("oses", [])
        if isinstance(entry, dict) and entry.get("id")
    )


def all_ids() -> list[str]:
    return [*provider_ids(), *os_ids()]


# --- scan scope ------------------------------------------------------------

def scan_paths() -> list[Path]:
    """Core files scanned for provider/OS id references (Check 1)."""
    files: list[Path] = []
    for entry in sorted((REPO / "scripts").iterdir()):
        if entry.is_dir():
            continue
        if entry.name.startswith("test-") or entry.name == "test":
            continue
        files.append(entry)
    files.extend(sorted(REPO.glob("eve_sdk/**/*.py")))
    for sub in ("plugins/providers/_common", "plugins/providers/_terraform-common"):
        base = REPO / sub
        if base.is_dir():
            files.extend(sorted(p for p in base.rglob("*") if p.is_file()))
    seen: set[Path] = set()
    unique: list[Path] = []
    for path in files:
        if path not in seen:
            seen.add(path)
            unique.append(path)
    return unique


def script_paths() -> list[Path]:
    """All files in scripts/ (for the bash-shebang language policy check)."""
    return sorted(
        p for p in (REPO / "scripts").iterdir()
        if p.is_file() and not p.name.endswith(".allowlist")
    )


# --- allowlist parsing -----------------------------------------------------

def parse_allowlist(path: Path) -> tuple[set[str], set[str]]:
    """Return ``(provider_os_allowed, bash_allowed)`` rel-path sets."""
    provider_os: set[str] = set()
    bash: set[str] = set()
    if not path.exists():
        return provider_os, bash
    for line in path.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or ":" not in stripped:
            continue
        rel, _sep, reason = stripped.partition(":")
        rel = rel.strip()
        reason = reason.strip()
        if reason.startswith("provider/OS reference"):
            provider_os.add(rel)
        elif reason.startswith("bash shebang"):
            bash.add(rel)
    return provider_os, bash


# --- checks ----------------------------------------------------------------

def is_bash_shebang(line: str) -> bool:
    return line in BASH_SHEBANGS


def find_provider_os_violations(
    files: list[tuple[str, str]],
    ids: list[str],
    allowed: set[str],
) -> list[str]:
    """Return violation messages for unallowed provider/OS id references.

    ``files`` is a list of ``(rel_path, content)`` pairs. A file violates if any
    id appears as a substring (parity with the legacy ``grep -F`` semantics) and
    the rel_path is not in ``allowed``.
    """
    violations: list[str] = []
    for rel_path, content in files:
        hit = next((identifier for identifier in ids if identifier in content), None)
        if hit is not None and rel_path not in allowed:
            violations.append(
                f"FAIL: {rel_path} (references {hit}) not in allowlist"
            )
    return violations


def find_bash_violations(
    files: list[tuple[str, str]],
    allowed: set[str],
) -> list[str]:
    """Return violation messages for unallowed bash/sh shebangs in scripts/."""
    violations: list[str] = []
    for rel_path, content in files:
        first_line = content.split("\n", 1)[0] if content else ""
        if is_bash_shebang(first_line) and rel_path not in allowed:
            violations.append(
                f"FAIL: {rel_path} has bash/sh shebang but no bash allowlist entry"
            )
    return violations


def _read_rel(path: Path) -> tuple[str, str]:
    rel = str(path.relative_to(REPO))
    try:
        content = path.read_text(encoding="utf-8", errors="replace")
    except OSError:
        content = ""
    return rel, content


def run() -> int:
    allowed_po, allowed_bash = parse_allowlist(ALLOWLIST)
    ids = all_ids()

    po_violations = find_provider_os_violations(
        [_read_rel(p) for p in scan_paths()], ids, allowed_po
    )
    sh_violations = find_bash_violations(
        [_read_rel(p) for p in script_paths()], allowed_bash
    )

    violations = po_violations + sh_violations
    for violation in violations:
        print(violation, file=sys.stderr)

    if violations:
        print(
            f"\nAdd to {ALLOWLIST.relative_to(REPO)} or move the logic into a "
            "provider/plugin-specific command.",
            file=sys.stderr,
        )
        return 1

    print(
        "[OK] core-boundary: no unallowed provider/OS references or bash "
        "scripts in central scripts"
    )
    return 0


# --- self-test -------------------------------------------------------------

def self_test() -> int:
    """Shebang detection logic parity with the legacy bash --self-test."""
    neg_shebangs = (
        "#!/usr/bin/env python",
        "#!/usr/bin/env python3",
        "#!/usr/bin/env zsh",
        "#!/usr/bin/python",
    )
    fail = 0
    for shebang in BASH_SHEBANGS:
        if not is_bash_shebang(shebang):
            print(f"SELF-TEST FAIL: {shebang} not detected as bash/sh")
            fail = 1
    for shebang in neg_shebangs:
        if is_bash_shebang(shebang):
            print(f"SELF-TEST FAIL: {shebang} false positive")
            fail = 1
    if fail == 0:
        print("[OK] core-boundary self-test: shebang detection passes")
    return fail


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description="Core-boundary lint")
    parser.add_argument("--self-test", action="store_true")
    args = parser.parse_args(argv)
    if args.self_test:
        return self_test()
    return run()


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
