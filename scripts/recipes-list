#!/usr/bin/env ruby
# List reusable VM recipes from the catalog.

require "json"
require "yaml"

ROOT = File.expand_path("..", __dir__)
CATALOG_PATHS = [
  File.join(ROOT, "config/catalog.yaml"),
  File.join(ROOT, "config/catalog.local.yaml")
].freeze

def usage
  warn "Usage: scripts/recipes-list [--json] [--with-details]"
end

def load_any(path)
  return {} unless File.exist?(path)

  YAML.safe_load(File.read(path), permitted_classes: [], aliases: true) || {}
end

json = false
details = false

args = ARGV.dup
until args.empty?
  case args.shift
  when "--json"
    json = true
  when "--with-details"
    details = true
  when "-h", "--help"
    usage
    exit 0
  else
    usage
    exit 2
  end
end

recipes_by_name = {}

CATALOG_PATHS.each do |path|
  catalog = load_any(path)
  entries = []
  entries.concat(catalog["recipes"]) if catalog["recipes"].is_a?(Array)
  # Lower-level compatibility overlays may still use the old key.
  entries.concat(catalog["profiles"]) if catalog["profiles"].is_a?(Array)

  entries.each do |entry|
    next unless entry.is_a?(Hash)

    name = entry["name"]
    next if name.nil? || name.to_s.empty?

    recipes_by_name[name.to_s] = {
      "name" => name.to_s,
      "machine" => entry["machine"],
      "os" => entry["os"],
      "location" => entry["location"]
    }.compact
  end
end

recipes = recipes_by_name.values

if json
  puts JSON.pretty_generate({ "recipes" => recipes })
  exit 0
end

if details
  printf "%-35s %-30s %-30s %-30s\n", "RECIPE", "MACHINE", "OS", "LOCATION"
  printf "%-35s %-30s %-30s %-30s\n", "------", "-------", "--", "--------"
  recipes.each do |recipe|
    printf "%-35s %-30s %-30s %-30s\n",
           recipe["name"],
           recipe["machine"] || "-",
           recipe["os"] || "-",
           recipe["location"] || "-"
  end
  exit 0
end

recipes.each { |recipe| puts recipe["name"] }
