#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import sys

command = sys.argv[1] if len(sys.argv) > 1 else None
if not command:
    print("Usage: provider-command <command>", file=sys.stderr)
    raise SystemExit(2)

raw = os.environ.get("EVE_RESOLVED_JSON") or sys.stdin.read()
resolved = json.loads(raw)
payload = {
    "kind": "provider",
    "provider": resolved.get("machine", {}).get("provider") or "acme",
    "command": command,
    "instance": resolved.get("instance", {}).get("name") or "unknown",
    "profile": resolved.get("instance", {}).get("name") or "unknown",
    "engine": resolved.get("engine") or "terraform",
    "dry_run": os.environ.get("EVE_PLUGIN_DRY_RUN") == "1",
}
print(json.dumps(payload, separators=(",", ":")))
