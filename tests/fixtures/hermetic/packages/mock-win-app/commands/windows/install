#!/usr/bin/env sh
set -eu
pkg="${1:?package id}"
if [ -n "${EVE_PLUGIN_DRY_RUN:-}" ] || [ "${2:-}" = "--dry-run" ]; then
  printf '{"kind":"package-install","package":"%s","command":"install","instance":"%s","os_family":"windows","status":"unknown","selected":true,"dry_run":true}\n' "$pkg" "${EVE_INSTANCE_NAME:-unknown}"
  exit 0
fi
printf '{"kind":"package-install","package":"%s","command":"install","instance":"%s","os_family":"windows","status":"installed","details":"installed"}\n' "$pkg" "${EVE_INSTANCE_NAME:-unknown}"
